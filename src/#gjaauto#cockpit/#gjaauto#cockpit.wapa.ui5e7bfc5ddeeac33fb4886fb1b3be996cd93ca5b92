sap.ui.define([                                                                                                                                                                                                                                                
    "sap/ui/layout/form/SimpleForm",                                                                                                                                                                                                                           
    "sap/m/Label",                                                                                                                                                                                                                                             
    "sap/m/Input"                                                                                                                                                                                                                                              
], function (SimpleForm, Label, Input) {                                                                                                                                                                                                                       
    "use strict";                                                                                                                                                                                                                                              
                                                                                                                                                                                                                                                               
    return {                                                                                                                                                                                                                                                   
        key: "operacao",                                                                                                                                                                                                                                       
        title: "Criar operaÃ§Ã£o",                                                                                                                                                                                                                             
        entityType: "cds_xgjaautoxsd_cockpit.OperacoesType",                                                                                                                                                                                                   
        fields: ["auto", "opera", "descr", "snro", "snronr"],                                                                                                                                                                                                  
        buildForm: function () {                                                                                                                                                                                                                               
            return new SimpleForm({                                                                                                                                                                                                                            
                layout: "ResponsiveGridLayout",                                                                                                                                                                                                                
                editable: true,                                                                                                                                                                                                                                
                visible: "{= ${create>/selectedType} === 'operacao' }",                                                                                                                                                                                        
                content: [                                                                                                                                                                                                                                     
                    new Label({ text: "{create>/labels/operacao/auto}" }),                                                                                                                                                                                     
                    new Input({                                                                                                                                                                                                                                
                        value: "{create>/operacao/auto}",                                                                                                                                                                                                      
                        maxLength: "{create>/maxLength/operacao/auto}",                                                                                                                                                                                        
                        required: "{create>/required/operacao/auto}",                                                                                                                                                                                          
                        editable: "{create>/editable/operacao/auto}"                                                                                                                                                                                           
                    }),                                                                                                                                                                                                                                        
                    new Label({ text: "{create>/labels/operacao/opera}" }),                                                                                                                                                                                    
                    new Input({                                                                                                                                                                                                                                
                        value: "{create>/operacao/opera}",                                                                                                                                                                                                     
                        maxLength: "{create>/maxLength/operacao/opera}",                                                                                                                                                                                       
                        required: "{create>/required/operacao/opera}",                                                                                                                                                                                         
                        editable: "{create>/editable/operacao/opera}"                                                                                                                                                                                          
                    }),                                                                                                                                                                                                                                        
                    new Label({ text: "{create>/labels/operacao/descr}" }),                                                                                                                                                                                    
                    new Input({                                                                                                                                                                                                                                
                        value: "{create>/operacao/descr}",                                                                                                                                                                                                     
                        maxLength: "{create>/maxLength/operacao/descr}",                                                                                                                                                                                       
                        required: "{create>/required/operacao/descr}",                                                                                                                                                                                         
                        editable: "{create>/editable/operacao/descr}"                                                                                                                                                                                          
                    }),                                                                                                                                                                                                                                        
                    new Label({ text: "{create>/labels/operacao/snro}" }),                                                                                                                                                                                     
                    new Input({                                                                                                                                                                                                                                
                        value: "{create>/operacao/snro}",                                                                                                                                                                                                      
                        maxLength: "{create>/maxLength/operacao/snro}",                                                                                                                                                                                        
                        required: "{create>/required/operacao/snro}",                                                                                                                                                                                          
                        editable: "{create>/editable/operacao/snro}"                                                                                                                                                                                           
                    }),                                                                                                                                                                                                                                        
                    new Label({ text: "{create>/labels/operacao/snronr}" }),                                                                                                                                                                                   
                    new Input({                                                                                                                                                                                                                                
                        value: "{create>/operacao/snronr}",                                                                                                                                                                                                    
                        maxLength: "{create>/maxLength/operacao/snronr}",                                                                                                                                                                                      
                        required: "{create>/required/operacao/snronr}",                                                                                                                                                                                        
                        editable: "{create>/editable/operacao/snronr}"                                                                                                                                                                                         
                    })                                                                                                                                                                                                                                         
                ]                                                                                                                                                                                                                                              
            });                                                                                                                                                                                                                                                
        },                                                                                                                                                                                                                                                     
        applyPrefill: function (oModel, oPrefill) {                                                                                                                                                                                                            
            if (oPrefill.auto) {                                                                                                                                                                                                                               
                oModel.setProperty("/operacao/auto", oPrefill.auto);                                                                                                                                                                                           
            }                                                                                                                                                                                                                                                  
        },                                                                                                                                                                                                                                                     
        getCreatePath: function (oMainModel, oPayload) {                                                                                                                                                                                                       
            if (!oPayload.auto) {                                                                                                                                                                                                                              
                return null;                                                                                                                                                                                                                                   
            }                                                                                                                                                                                                                                                  
            var sAutoKey = oMainModel.createKey("Automacoes", { auto: oPayload.auto });                                                                                                                                                                        
            return "/" + sAutoKey + "/to_Operacoes";                                                                                                                                                                                                           
        },                                                                                                                                                                                                                                                     
        getUpdatePath: function (oMainModel, oData) {                                                                                                                                                                                                          
            return "/" + oMainModel.createKey("Operacoes", {                                                                                                                                                                                                   
                auto: oData.auto,                                                                                                                                                                                                                              
                opera: oData.opera                                                                                                                                                                                                                             
            });                                                                                                                                                                                                                                                
        }                                                                                                                                                                                                                                                      
    };                                                                                                                                                                                                                                                         
});                                                                                                                                                                                                                                                            
                                                                                                                                                                                                                                                               