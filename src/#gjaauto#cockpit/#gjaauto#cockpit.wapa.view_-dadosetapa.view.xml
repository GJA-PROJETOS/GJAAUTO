<mvc:View                                                                                                                                                                                                                                                      
    controllerName="br.com.gja.zui5.gjaauto.cockpit.controller.DadosEtapa"                                                                                                                                                                                     
    xmlns="sap.m"                                                                                                                                                                                                                                              
    xmlns:mvc="sap.ui.core.mvc"                                                                                                                                                                                                                                
    displayBlock="true"                                                                                                                                                                                                                                        
    height="100%"                                                                                                                                                                                                                                              
>                                                                                                                                                                                                                                                              
    <Page                                                                                                                                                                                                                                                      
        id="dadosEtapaPage"                                                                                                                                                                                                                                    
        showHeader="true"                                                                                                                                                                                                                                      
        title="Dados da Etapa"                                                                                                                                                                                                                                 
        showNavButton="false"                                                                                                                                                                                                                                  
    >                                                                                                                                                                                                                                                          
        <content>                                                                                                                                                                                                                                              
            <VBox                                                                                                                                                                                                                                              
                id="dadosEtapaContent"                                                                                                                                                                                                                         
                class="sapUiSmallMargin"                                                                                                                                                                                                                       
            >                                                                                                                                                                                                                                                  
                <Panel                                                                                                                                                                                                                                         
                    id="dadosListPanel"                                                                                                                                                                                                                        
                    headerText="Lista de Dados"                                                                                                                                                                                                                
                    class="sapUiResponsiveMargin"                                                                                                                                                                                                              
                    width="auto"                                                                                                                                                                                                                               
                >                                                                                                                                                                                                                                              
                    <content>                                                                                                                                                                                                                                  
                        <Table                                                                                                                                                                                                                                 
                            id="dadosTable"                                                                                                                                                                                                                    
                            items="{dados>/items}"                                                                                                                                                                                                             
                            growing="true"                                                                                                                                                                                                                     
                            growingThreshold="20"                                                                                                                                                                                                              
                            busy="{dados>/busy}"                                                                                                                                                                                                               
                        >                                                                                                                                                                                                                                      
                            <headerToolbar>                                                                                                                                                                                                                    
                                <OverflowToolbar id="dadosTableToolbar">                                                                                                                                                                                       
                                    <Title                                                                                                                                                                                                                     
                                        id="dadosTableTitle"                                                                                                                                                                                                   
                                        text="Dados ({= ${dados>/items}.length })"                                                                                                                                                                             
                                    />                                                                                                                                                                                                                         
                                    <ToolbarSpacer id="dadosToolbarSpacer" />                                                                                                                                                                                  
                                    <SearchField                                                                                                                                                                                                               
                                        id="dadosSearchField"                                                                                                                                                                                                  
                                        width="20%"                                                                                                                                                                                                            
                                        search=".onSearchDados"                                                                                                                                                                                                
                                        placeholder="Pesquisar..."                                                                                                                                                                                             
                                    />                                                                                                                                                                                                                         
                                </OverflowToolbar>                                                                                                                                                                                                             
                            </headerToolbar>                                                                                                                                                                                                                   
                            <columns>                                                                                                                                                                                                                          
                                <Column id="nameColumn">                                                                                                                                                                                                       
                                    <Text id="nameHeader" text="Nome" />                                                                                                                                                                                       
                                </Column>                                                                                                                                                                                                                      
                                <Column id="reftypnameColumn">                                                                                                                                                                                                 
                                    <Text id="reftypnameHeader" text="Tipo Referência" />                                                                                                                                                                      
                                </Column>                                                                                                                                                                                                                      
                                <Column id="reftypeColumn" width="8rem">                                                                                                                                                                                       
                                    <Text id="reftypeHeader" text="Ref Type" />                                                                                                                                                                                
                                </Column>                                                                                                                                                                                                                      
                                <Column id="etapaBornColumn" width="8rem">                                                                                                                                                                                     
                                    <Text id="etapaBornHeader" text="Etapa Origem" />                                                                                                                                                                          
                                </Column>                                                                                                                                                                                                                      
                                <Column id="datanatuColumn" width="8rem">                                                                                                                                                                                      
                                    <Text id="datanatuHeader" text="Natureza" />                                                                                                                                                                               
                                </Column>                                                                                                                                                                                                                      
                            </columns>                                                                                                                                                                                                                         
                            <items>                                                                                                                                                                                                                            
                                <ColumnListItem id="dadosItem" type="Active" press=".onDadoPress">                                                                                                                                                             
                                    <cells>                                                                                                                                                                                                                    
                                        <Text                                                                                                                                                                                                                  
                                            id="nameText"                                                                                                                                                                                                      
                                            text="{dados>Name}"                                                                                                                                                                                                
                                        />                                                                                                                                                                                                                     
                                        <Text                                                                                                                                                                                                                  
                                            id="reftypnameText"                                                                                                                                                                                                
                                            text="{dados>Reftypname}"                                                                                                                                                                                          
                                        />                                                                                                                                                                                                                     
                                        <Text                                                                                                                                                                                                                  
                                            id="reftypeText"                                                                                                                                                                                                   
                                            text="{dados>Reftype}"                                                                                                                                                                                             
                                        />                                                                                                                                                                                                                     
                                        <Text                                                                                                                                                                                                                  
                                            id="etapaBornText"                                                                                                                                                                                                 
                                            text="{dados>EtapaBorn}"                                                                                                                                                                                           
                                        />                                                                                                                                                                                                                     
                                        <Text                                                                                                                                                                                                                  
                                            id="datanatuText"                                                                                                                                                                                                  
                                            text="{dados>Datanatu}"                                                                                                                                                                                            
                                        />                                                                                                                                                                                                                     
                                    </cells>                                                                                                                                                                                                                   
                                </ColumnListItem>                                                                                                                                                                                                              
                            </items>                                                                                                                                                                                                                           
                        </Table>                                                                                                                                                                                                                               
                    </content>                                                                                                                                                                                                                                 
                </Panel>                                                                                                                                                                                                                                       
            </VBox>                                                                                                                                                                                                                                            
        </content>                                                                                                                                                                                                                                             
    </Page>                                                                                                                                                                                                                                                    
</mvc:View>                                                                                                                                                                                                                                                    
                                                                                                                                                                                                                                                               