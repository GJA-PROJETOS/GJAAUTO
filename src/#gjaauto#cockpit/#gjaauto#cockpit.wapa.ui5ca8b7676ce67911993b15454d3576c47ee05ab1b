sap.ui.define([                                                                                                                                                                                                                                                
    "sap/ui/core/mvc/Controller",                                                                                                                                                                                                                              
    "sap/ui/model/json/JSONModel",                                                                                                                                                                                                                             
    "sap/m/MessageToast"                                                                                                                                                                                                                                       
], function (Controller, JSONModel, MessageToast) {                                                                                                                                                                                                            
    "use strict";                                                                                                                                                                                                                                              
                                                                                                                                                                                                                                                               
    return Controller.extend("br.com.gja.zui5.gjaauto.cockpit.controller.FieldMaster", {                                                                                                                                                                       
        /**                                                                                                                                                                                                                                                    
         * Inicializa o controlador.                                                                                                                                                                                                                           
         * @public                                                                                                                                                                                                                                             
         */                                                                                                                                                                                                                                                    
        onInit: function () {                                                                                                                                                                                                                                  
            var oRouter = this.getOwnerComponent().getRouter();                                                                                                                                                                                                
&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;                                                                                                                                                                                       
            // Escuta as rotas que usam o FieldMaster                                                                                                                                                                                                          
            oRouter.getRoute("RouteEtapaImportWorkarea").attachPatternMatched(this._onRouteMatched, this);                                                                                                                                                     
            oRouter.getRoute("RouteEtapaExportWorkarea").attachPatternMatched(this._onRouteMatched, this);                                                                                                                                                     
            oRouter.getRoute("RouteEtapaTables").attachPatternMatched(this._onRouteMatched, this);                                                                                                                                                             
            oRouter.getRoute("RouteEtapaImportWorkareaField").attachPatternMatched(this._onFieldRouteMatched, this);                                                                                                                                           
            oRouter.getRoute("RouteEtapaExportWorkareaField").attachPatternMatched(this._onFieldRouteMatched, this);                                                                                                                                           
            oRouter.getRoute("RouteEtapaTablesField").attachPatternMatched(this._onFieldRouteMatched, this);                                                                                                                                                   
                                                                                                                                                                                                                                                               
            // Inscreve no EventBus para quando um campo for selecionado na HomeField                                                                                                                                                                          
            var oEventBus = sap.ui.getCore().getEventBus();                                                                                                                                                                                                    
            oEventBus.subscribe("HomeField", "FieldSelected", this._onHomeFieldSelected, this);                                                                                                                                                                
        },                                                                                                                                                                                                                                                     
                                                                                                                                                                                                                                                               
        /**                                                                                                                                                                                                                                                    
         * Chamado quando o controller é destruído.                                                                                                                                                                                                            
         * @public                                                                                                                                                                                                                                             
         */                                                                                                                                                                                                                                                    
        onExit: function () {                                                                                                                                                                                                                                  
            // Remove a inscrição do EventBus                                                                                                                                                                                                                  
            var oEventBus = sap.ui.getCore().getEventBus();                                                                                                                                                                                                    
            oEventBus.unsubscribe("HomeField", "FieldSelected", this._onHomeFieldSelected, this);                                                                                                                                                              
        },                                                                                                                                                                                                                                                     
                                                                                                                                                                                                                                                               
        /**                                                                                                                                                                                                                                                    
         * Chamado quando um campo é selecionado na HomeField.                                                                                                                                                                                                 
         * @param {string} sChannelId ID do canal                                                                                                                                                                                                              
         * @param {string} sEventId ID do evento                                                                                                                                                                                                               
         * @param {object} oData Dados do evento                                                                                                                                                                                                               
         * @private                                                                                                                                                                                                                                            
         */                                                                                                                                                                                                                                                    
        _onHomeFieldSelected: function (sChannelId, sEventId, oData) {                                                                                                                                                                                         
            var iIndex = oData.index;                                                                                                                                                                                                                          
            // Remove seleção do item "Visão Geral"                                                                                                                                                                                                            
            var oHomeList = this.byId("fieldMasterList");                                                                                                                                                                                                      
            if (oHomeList) {                                                                                                                                                                                                                                   
                oHomeList.removeSelections(true);                                                                                                                                                                                                              
            }                                                                                                                                                                                                                                                  
            // Seleciona na lista de campos                                                                                                                                                                                                                    
            var oList = this.byId("fieldItemsList");                                                                                                                                                                                                           
            if (oList) {                                                                                                                                                                                                                                       
                var aItems = oList.getItems();                                                                                                                                                                                                                 
                if (aItems[iIndex]) {                                                                                                                                                                                                                          
                    oList.setSelectedItem(aItems[iIndex]);                                                                                                                                                                                                     
                    // Navega para o campo selecionado                                                                                                                                                                                                         
                    this._navigateToField(aItems[iIndex]);                                                                                                                                                                                                     
                }                                                                                                                                                                                                                                              
            }                                                                                                                                                                                                                                                  
        },                                                                                                                                                                                                                                                     
                                                                                                                                                                                                                                                               
        /**                                                                                                                                                                                                                                                    
         * Chamado quando a rota da workarea é correspondida.                                                                                                                                                                                                  
         * Mostra a HomeField sem selecionar nenhum item.                                                                                                                                                                                                      
         * @param {sap.ui.base.Event} oEvent Evento de correspondência da rota                                                                                                                                                                                 
         * @private                                                                                                                                                                                                                                            
         */                                                                                                                                                                                                                                                    
        _onRouteMatched: function (oEvent) {                                                                                                                                                                                                                   
            // Remove seleção da lista de campos                                                                                                                                                                                                               
            var oFieldsList = this.byId("fieldItemsList");                                                                                                                                                                                                     
            if (oFieldsList) {                                                                                                                                                                                                                                 
                oFieldsList.removeSelections(true);                                                                                                                                                                                                            
            }                                                                                                                                                                                                                                                  
            // Seleciona o item "Visão Geral"                                                                                                                                                                                                                  
            var oHomeList = this.byId("fieldMasterList");                                                                                                                                                                                                      
            if (oHomeList) {                                                                                                                                                                                                                                   
                var oHomeItem = this.byId("homeFieldItem");                                                                                                                                                                                                    
                if (oHomeItem) {                                                                                                                                                                                                                               
                    oHomeList.setSelectedItem(oHomeItem);                                                                                                                                                                                                      
                }                                                                                                                                                                                                                                              
            }                                                                                                                                                                                                                                                  
        },                                                                                                                                                                                                                                                     
                                                                                                                                                                                                                                                               
        /**                                                                                                                                                                                                                                                    
         * Chamado quando a rota do field é correspondida.                                                                                                                                                                                                     
         * Seleciona o item correspondente.                                                                                                                                                                                                                    
         * @param {sap.ui.base.Event} oEvent Evento de correspondência da rota                                                                                                                                                                                 
         * @private                                                                                                                                                                                                                                            
         */                                                                                                                                                                                                                                                    
        _onFieldRouteMatched: function (oEvent) {                                                                                                                                                                                                              
            var oArgs = oEvent.getParameter("arguments");                                                                                                                                                                                                      
            var sKeyField = oArgs.keyField;                                                                                                                                                                                                                    
            var that = this;                                                                                                                                                                                                                                   
&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;                                                                                                                                                                                       
            // Aguarda o modelo estar carregado                                                                                                                                                                                                                
            setTimeout(function() {                                                                                                                                                                                                                            
                that._selectItemByKey(sKeyField);                                                                                                                                                                                                              
            }, 500);                                                                                                                                                                                                                                           
        },                                                                                                                                                                                                                                                     
                                                                                                                                                                                                                                                               
        /**                                                                                                                                                                                                                                                    
         * Seleciona um item da lista pela key (FieldName).                                                                                                                                                                                                    
         * @param {string} sKey Nome do campo                                                                                                                                                                                                                  
         * @private                                                                                                                                                                                                                                            
         */                                                                                                                                                                                                                                                    
        _selectItemByKey: function (sKey) {                                                                                                                                                                                                                    
            // Remove seleção do item "Visão Geral"                                                                                                                                                                                                            
            var oHomeList = this.byId("fieldMasterList");                                                                                                                                                                                                      
            if (oHomeList) {                                                                                                                                                                                                                                   
                oHomeList.removeSelections(true);                                                                                                                                                                                                              
            }                                                                                                                                                                                                                                                  
            // Seleciona o campo na lista                                                                                                                                                                                                                      
            var oList = this.byId("fieldItemsList");                                                                                                                                                                                                           
            if (oList) {                                                                                                                                                                                                                                       
                var aItems = oList.getItems();                                                                                                                                                                                                                 
                for (var i = 0; i < aItems.length; i++) {                                                                                                                                                                                                      
                    var oContext = aItems[i].getBindingContext("etapa");                                                                                                                                                                                       
                    if (oContext) {                                                                                                                                                                                                                            
                        var sFieldName = oContext.getProperty("FieldName");                                                                                                                                                                                    
                        if (sFieldName === sKey) {                                                                                                                                                                                                             
                            oList.setSelectedItem(aItems[i]);                                                                                                                                                                                                  
                            break;                                                                                                                                                                                                                             
                        }                                                                                                                                                                                                                                      
                    }                                                                                                                                                                                                                                          
                }                                                                                                                                                                                                                                              
            }                                                                                                                                                                                                                                                  
        },                                                                                                                                                                                                                                                     
                                                                                                                                                                                                                                                               
        /**                                                                                                                                                                                                                                                    
         * Manipula seleção de um campo na lista.                                                                                                                                                                                                              
         * @param {sap.ui.base.Event} oEvent Evento de seleção                                                                                                                                                                                                 
         * @public                                                                                                                                                                                                                                             
         */                                                                                                                                                                                                                                                    
        onFieldSelected: function (oEvent) {                                                                                                                                                                                                                   
            var oItem = oEvent.getParameter("listItem");                                                                                                                                                                                                       
            // Remove seleção do item "Visão Geral"                                                                                                                                                                                                            
            var oHomeList = this.byId("fieldMasterList");                                                                                                                                                                                                      
            if (oHomeList) {                                                                                                                                                                                                                                   
                oHomeList.removeSelections(true);                                                                                                                                                                                                              
            }                                                                                                                                                                                                                                                  
            this._navigateToField(oItem);                                                                                                                                                                                                                      
        },                                                                                                                                                                                                                                                     
                                                                                                                                                                                                                                                               
        /**                                                                                                                                                                                                                                                    
         * Navega para a HomeField (Visão Geral) via selectionChange.                                                                                                                                                                                          
         * @param {sap.ui.base.Event} oEvent Evento de seleção                                                                                                                                                                                                 
         * @public                                                                                                                                                                                                                                             
         */                                                                                                                                                                                                                                                    
        onHomeFieldSelected: function (oEvent) {                                                                                                                                                                                                               
            // Remove seleção da lista de campos                                                                                                                                                                                                               
            var oFieldsList = this.byId("fieldItemsList");                                                                                                                                                                                                     
            if (oFieldsList) {                                                                                                                                                                                                                                 
                oFieldsList.removeSelections(true);                                                                                                                                                                                                            
            }                                                                                                                                                                                                                                                  
&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;                                                                                                                                                                                       
            this._navigateToHomeField();                                                                                                                                                                                                                       
        },                                                                                                                                                                                                                                                     
                                                                                                                                                                                                                                                               
        /**                                                                                                                                                                                                                                                    
         * Navega para a HomeField (Visão Geral).                                                                                                                                                                                                              
         * @private                                                                                                                                                                                                                                            
         */                                                                                                                                                                                                                                                    
        _navigateToHomeField: function () {                                                                                                                                                                                                                    
            var oEtapaModel = this.getOwnerComponent().getModel("etapa");                                                                                                                                                                                      
            if (!oEtapaModel) {                                                                                                                                                                                                                                
                oEtapaModel = this.getView().getModel("etapa");                                                                                                                                                                                                
            }                                                                                                                                                                                                                                                  
&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;                                                                                                                                                                                       
            var sCodigoAuto = oEtapaModel.getProperty("/codigoAuto");                                                                                                                                                                                          
            var sCodigoOpera = oEtapaModel.getProperty("/codigoOpera");                                                                                                                                                                                        
            var sCodigoEtapa = oEtapaModel.getProperty("/codigoEtapa");                                                                                                                                                                                        
            var sParamNatu = oEtapaModel.getProperty("/currentParamNatu");                                                                                                                                                                                     
            var sKeyWorkarea = oEtapaModel.getProperty("/parameterDoku/Param");                                                                                                                                                                                
&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;                                                                                                                                                                                       
            var oRouter = this.getOwnerComponent().getRouter();                                                                                                                                                                                                
&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;                                                                                                                                                                                       
            switch (sParamNatu) {                                                                                                                                                                                                                              
                case "import":                                                                                                                                                                                                                                 
                    oRouter.navTo("RouteEtapaImportWorkarea", {                                                                                                                                                                                                
                        codigoAuto: sCodigoAuto,                                                                                                                                                                                                               
                        codigoOpera: sCodigoOpera,                                                                                                                                                                                                             
                        codigoEtapa: sCodigoEtapa,                                                                                                                                                                                                             
                        keyWorkarea: sKeyWorkarea                                                                                                                                                                                                              
                    });                                                                                                                                                                                                                                        
                    break;                                                                                                                                                                                                                                     
                case "export":                                                                                                                                                                                                                                 
                    oRouter.navTo("RouteEtapaExportWorkarea", {                                                                                                                                                                                                
                        codigoAuto: sCodigoAuto,                                                                                                                                                                                                               
                        codigoOpera: sCodigoOpera,                                                                                                                                                                                                             
                        codigoEtapa: sCodigoEtapa,                                                                                                                                                                                                             
                        keyWorkarea: sKeyWorkarea                                                                                                                                                                                                              
                    });                                                                                                                                                                                                                                        
                    break;                                                                                                                                                                                                                                     
                case "tables":                                                                                                                                                                                                                                 
                    oRouter.navTo("RouteEtapaTables", {                                                                                                                                                                                                        
                        codigoAuto: sCodigoAuto,                                                                                                                                                                                                               
                        codigoOpera: sCodigoOpera,                                                                                                                                                                                                             
                        codigoEtapa: sCodigoEtapa,                                                                                                                                                                                                             
                        keyTable: sKeyWorkarea                                                                                                                                                                                                                 
                    });                                                                                                                                                                                                                                        
                    break;                                                                                                                                                                                                                                     
            }                                                                                                                                                                                                                                                  
        },                                                                                                                                                                                                                                                     
                                                                                                                                                                                                                                                               
        /**                                                                                                                                                                                                                                                    
         * Navega para a view do field selecionado.                                                                                                                                                                                                            
         * @param {sap.m.StandardListItem} oItem Item selecionado                                                                                                                                                                                              
         * @private                                                                                                                                                                                                                                            
         */                                                                                                                                                                                                                                                    
        _navigateToField: function (oItem) {                                                                                                                                                                                                                   
            var oContext = oItem.getBindingContext("etapa");                                                                                                                                                                                                   
            if (!oContext) {                                                                                                                                                                                                                                   
                return;                                                                                                                                                                                                                                        
            }                                                                                                                                                                                                                                                  
&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;                                                                                                                                                                                       
            var sFieldName = oContext.getProperty("FieldName");                                                                                                                                                                                                
            var oEtapaModel = this.getOwnerComponent().getModel("etapa");                                                                                                                                                                                      
&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;                                                                                                                                                                                       
            if (!oEtapaModel) {                                                                                                                                                                                                                                
                // Tenta obter do view pai                                                                                                                                                                                                                     
                oEtapaModel = this.getView().getModel("etapa");                                                                                                                                                                                                
            }                                                                                                                                                                                                                                                  
&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;                                                                                                                                                                                       
            var sCodigoAuto = oEtapaModel.getProperty("/codigoAuto");                                                                                                                                                                                          
            var sCodigoOpera = oEtapaModel.getProperty("/codigoOpera");                                                                                                                                                                                        
            var sCodigoEtapa = oEtapaModel.getProperty("/codigoEtapa");                                                                                                                                                                                        
            var sParamNatu = oEtapaModel.getProperty("/currentParamNatu");                                                                                                                                                                                     
            var sKeyWorkarea = oEtapaModel.getProperty("/parameterDoku/Param");                                                                                                                                                                                
&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;                                                                                                                                                                                       
            var oRouter = this.getOwnerComponent().getRouter();                                                                                                                                                                                                
&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;                                                                                                                                                                                       
            switch (sParamNatu) {                                                                                                                                                                                                                              
                case "import":                                                                                                                                                                                                                                 
                    oRouter.navTo("RouteEtapaImportWorkareaField", {                                                                                                                                                                                           
                        codigoAuto: sCodigoAuto,                                                                                                                                                                                                               
                        codigoOpera: sCodigoOpera,                                                                                                                                                                                                             
                        codigoEtapa: sCodigoEtapa,                                                                                                                                                                                                             
                        keyWorkarea: sKeyWorkarea,                                                                                                                                                                                                             
                        keyField: sFieldName                                                                                                                                                                                                                   
                    });                                                                                                                                                                                                                                        
                    break;                                                                                                                                                                                                                                     
                case "export":                                                                                                                                                                                                                                 
                    oRouter.navTo("RouteEtapaExportWorkareaField", {                                                                                                                                                                                           
                        codigoAuto: sCodigoAuto,                                                                                                                                                                                                               
                        codigoOpera: sCodigoOpera,                                                                                                                                                                                                             
                        codigoEtapa: sCodigoEtapa,                                                                                                                                                                                                             
                        keyWorkarea: sKeyWorkarea,                                                                                                                                                                                                             
                        keyField: sFieldName                                                                                                                                                                                                                   
                    });                                                                                                                                                                                                                                        
                    break;                                                                                                                                                                                                                                     
                case "tables":                                                                                                                                                                                                                                 
                    oRouter.navTo("RouteEtapaTablesField", {                                                                                                                                                                                                   
                        codigoAuto: sCodigoAuto,                                                                                                                                                                                                               
                        codigoOpera: sCodigoOpera,                                                                                                                                                                                                             
                        codigoEtapa: sCodigoEtapa,                                                                                                                                                                                                             
                        keyTable: sKeyWorkarea,                                                                                                                                                                                                                
                        keyField: sFieldName                                                                                                                                                                                                                   
                    });                                                                                                                                                                                                                                        
                    break;                                                                                                                                                                                                                                     
            }                                                                                                                                                                                                                                                  
&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;                                                                                                                                                                                       
            // Atualiza o campo selecionado no modelo                                                                                                                                                                                                          
            oEtapaModel.setProperty("/selectedField", oContext.getObject());                                                                                                                                                                                   
        },                                                                                                                                                                                                                                                     
                                                                                                                                                                                                                                                               
        /**                                                                                                                                                                                                                                                    
         * Navega de volta para a tela da Etapa.                                                                                                                                                                                                               
         * @public                                                                                                                                                                                                                                             
         */                                                                                                                                                                                                                                                    
        onNavBack: function () {                                                                                                                                                                                                                               
            var oEtapaModel = this.getView().getModel("etapa");                                                                                                                                                                                                
&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;                                                                                                                                                                                       
            if (!oEtapaModel) {                                                                                                                                                                                                                                
                oEtapaModel = this.getOwnerComponent().getModel("etapa");                                                                                                                                                                                      
            }                                                                                                                                                                                                                                                  
&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;                                                                                                                                                                                       
            var sCodigoAuto = oEtapaModel.getProperty("/codigoAuto");                                                                                                                                                                                          
            var sCodigoOpera = oEtapaModel.getProperty("/codigoOpera");                                                                                                                                                                                        
            var sCodigoEtapa = oEtapaModel.getProperty("/codigoEtapa");                                                                                                                                                                                        
&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;                                                                                                                                                                                       
            var oRouter = this.getOwnerComponent().getRouter();                                                                                                                                                                                                
            oRouter.navTo("RouteEtapa", {                                                                                                                                                                                                                      
                codigoAuto: sCodigoAuto,                                                                                                                                                                                                                       
                codigoOpera: sCodigoOpera,                                                                                                                                                                                                                     
                codigoEtapa: sCodigoEtapa                                                                                                                                                                                                                      
            });                                                                                                                                                                                                                                                
        }                                                                                                                                                                                                                                                      
    });                                                                                                                                                                                                                                                        
});                                                                                                                                                                                                                                                            
                                                                                                                                                                                                                                                               