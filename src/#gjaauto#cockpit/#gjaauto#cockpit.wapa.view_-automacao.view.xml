<mvc:View                                                                                                                                                                                                                                                      
    controllerName="br.com.gja.zui5.gjaauto.cockpit.controller.Automacao"                                                                                                                                                                                      
    xmlns="sap.m"                                                                                                                                                                                                                                              
    xmlns:mvc="sap.ui.core.mvc"                                                                                                                                                                                                                                
    displayBlock="true"                                                                                                                                                                                                                                        
    height="100%"                                                                                                                                                                                                                                              
>                                                                                                                                                                                                                                                              
    <Page                                                                                                                                                                                                                                                      
        id="automacaoPage"                                                                                                                                                                                                                                     
        showHeader="true"                                                                                                                                                                                                                                      
        title="{automacao>/auto} - {automacao>/descr}"                                                                                                                                                                                                         
        showNavButton="false"                                                                                                                                                                                                                                  
    >                                                                                                                                                                                                                                                          
        <content>                                                                                                                                                                                                                                              
            <VBox                                                                                                                                                                                                                                              
                id="automacaoContent"                                                                                                                                                                                                                          
                class="sapUiSmallMargin"                                                                                                                                                                                                                       
            >                                                                                                                                                                                                                                                  
                <ObjectHeader                                                                                                                                                                                                                                  
                    id="automacaoHeader"                                                                                                                                                                                                                       
                    title="{automacao>/descr}"                                                                                                                                                                                                                 
                    number="{automacao>/auto}"                                                                                                                                                                                                                 
                    icon="{automacao>/icon_fiori}"                                                                                                                                                                                                             
                />                                                                                                                                                                                                                                             
                                                                                                                                                                                                                                                               
                <Panel                                                                                                                                                                                                                                         
                    id="automacaoDetailsPanel"                                                                                                                                                                                                                 
                    headerText="Detalhes da Automação"                                                                                                                                                                                                         
                    class="sapUiResponsiveMargin"                                                                                                                                                                                                              
                    width="auto"                                                                                                                                                                                                                               
                >                                                                                                                                                                                                                                              
                    <headerToolbar>                                                                                                                                                                                                                            
                        <OverflowToolbar id="otbSubheader">                                                                                                                                                                                                    
                            <Title                                                                                                                                                                                                                             
                                id="dadosTableTitle"                                                                                                                                                                                                           
                                text="Detalhes da Automação"                                                                                                                                                                                                   
                            />                                                                                                                                                                                                                                 
                            <ToolbarSpacer />                                                                                                                                                                                                                  
                            <OverflowToolbarButton                                                                                                                                                                                                             
                                tooltip="Editar"                                                                                                                                                                                                               
                                type="Emphasized"                                                                                                                                                                                                              
                                text="Editar"                                                                                                                                                                                                                  
                                icon="sap-icon://edit"                                                                                                                                                                                                         
                                press="onEditAutomacao"                                                                                                                                                                                                        
                            />                                                                                                                                                                                                                                 
                        </OverflowToolbar>                                                                                                                                                                                                                     
                    </headerToolbar>                                                                                                                                                                                                                           
                    <content>                                                                                                                                                                                                                                  
                        <VBox id="detailsBox">                                                                                                                                                                                                                 
                            <Label                                                                                                                                                                                                                             
                                id="codigoLabel"                                                                                                                                                                                                               
                                text="Código"                                                                                                                                                                                                                  
                                class="sapUiTinyMarginTop"                                                                                                                                                                                                     
                            />                                                                                                                                                                                                                                 
                            <Text                                                                                                                                                                                                                              
                                id="codigoText"                                                                                                                                                                                                                
                                text="{automacao>/auto}"                                                                                                                                                                                                       
                                class="sapUiTinyMarginBottom"                                                                                                                                                                                                  
                            />                                                                                                                                                                                                                                 
                                                                                                                                                                                                                                                               
                            <Label                                                                                                                                                                                                                             
                                id="descricaoLabel"                                                                                                                                                                                                            
                                text="Descrição"                                                                                                                                                                                                               
                                class="sapUiTinyMarginTop"                                                                                                                                                                                                     
                            />                                                                                                                                                                                                                                 
                            <Text                                                                                                                                                                                                                              
                                id="descricaoText"                                                                                                                                                                                                             
                                text="{automacao>/descr}"                                                                                                                                                                                                      
                                class="sapUiTinyMarginBottom"                                                                                                                                                                                                  
                            />                                                                                                                                                                                                                                 
                        </VBox>                                                                                                                                                                                                                                
                    </content>                                                                                                                                                                                                                                 
                </Panel>                                                                                                                                                                                                                                       
                                                                                                                                                                                                                                                               
                <Panel                                                                                                                                                                                                                                         
                    id="operacoesPanel"                                                                                                                                                                                                                        
                    headerText="Operações Disponíveis"                                                                                                                                                                                                         
                    class="sapUiResponsiveMargin"                                                                                                                                                                                                              
                    width="auto"                                                                                                                                                                                                                               
                >                                                                                                                                                                                                                                              
                    <content>                                                                                                                                                                                                                                  
                        <List                                                                                                                                                                                                                                  
                            id="operacoesList"                                                                                                                                                                                                                 
                            items="{automacao>/to_Operacoes/results}"                                                                                                                                                                                          
                            mode="SingleSelectMaster"                                                                                                                                                                                                          
                            itemPress=".onOperacaoPress"                                                                                                                                                                                                       
                        >                                                                                                                                                                                                                                      
                            <StandardListItem                                                                                                                                                                                                                  
                                id="operacaoItem"                                                                                                                                                                                                              
                                title="{automacao>descr}"                                                                                                                                                                                                      
                                description="{automacao>opera}"                                                                                                                                                                                                
                                icon="sap-icon://activity-items"                                                                                                                                                                                               
                                type="Navigation"                                                                                                                                                                                                              
                            />                                                                                                                                                                                                                                 
                        </List>                                                                                                                                                                                                                                
                    </content>                                                                                                                                                                                                                                 
                </Panel>                                                                                                                                                                                                                                       
            </VBox>                                                                                                                                                                                                                                            
        </content>                                                                                                                                                                                                                                             
    </Page>                                                                                                                                                                                                                                                    
</mvc:View>                                                                                                                                                                                                                                                    
                                                                                                                                                                                                                                                               