<mvc:View                                                                                                                                                                                                                                                      
    controllerName="br.com.gja.zui5.gjaauto.cockpit.controller.Etapa"                                                                                                                                                                                          
    xmlns="sap.m"                                                                                                                                                                                                                                              
    xmlns:mvc="sap.ui.core.mvc"                                                                                                                                                                                                                                
    xmlns:core="sap.ui.core"                                                                                                                                                                                                                                   
    xmlns:tnt="sap.tnt"                                                                                                                                                                                                                                        
    displayBlock="true"                                                                                                                                                                                                                                        
    height="100%"                                                                                                                                                                                                                                              
>                                                                                                                                                                                                                                                              
    <tnt:ToolPage                                                                                                                                                                                                                                              
        id="etapaToolPage"                                                                                                                                                                                                                                     
        busy="{etapa>/busy}"                                                                                                                                                                                                                                   
        busyIndicatorDelay="0"                                                                                                                                                                                                                                 
    >                                                                                                                                                                                                                                                          
        <tnt:header>                                                                                                                                                                                                                                           
            <tnt:ToolHeader id="etapaToolHeader">                                                                                                                                                                                                              
                <Button                                                                                                                                                                                                                                        
                    id="etapaSideNavigationToggleButton"                                                                                                                                                                                                       
                    icon="sap-icon://menu2"                                                                                                                                                                                                                    
                    type="Transparent"                                                                                                                                                                                                                         
                    press=".onSideNavButtonPress"                                                                                                                                                                                                              
                    tooltip="Menu"                                                                                                                                                                                                                             
                >                                                                                                                                                                                                                                              
                    <layoutData>                                                                                                                                                                                                                               
                        <OverflowToolbarLayoutData                                                                                                                                                                                                             
                            id="etapaOverflowToolbarLayoutData"                                                                                                                                                                                                
                            priority="NeverOverflow"                                                                                                                                                                                                           
                        />                                                                                                                                                                                                                                     
                    </layoutData>                                                                                                                                                                                                                              
                </Button>                                                                                                                                                                                                                                      
                <Button                                                                                                                                                                                                                                        
                    id="etapaBackButton"                                                                                                                                                                                                                       
                    icon="sap-icon://nav-back"                                                                                                                                                                                                                 
                    type="Transparent"                                                                                                                                                                                                                         
                    press=".onNavBack"                                                                                                                                                                                                                         
                    tooltip="Voltar"                                                                                                                                                                                                                           
                />                                                                                                                                                                                                                                             
                <ToolbarSpacer id="etapaToolbarSpacer1" />                                                                                                                                                                                                     
                <Title                                                                                                                                                                                                                                         
                    id="etapaTitle"                                                                                                                                                                                                                            
                    text="{etapa>/etapaData/descr}"                                                                                                                                                                                                            
                    level="H2"                                                                                                                                                                                                                                 
                />                                                                                                                                                                                                                                             
                <ToolbarSpacer id="etapaToolbarSpacer2" />                                                                                                                                                                                                     
                <Button                                                                                                                                                                                                                                        
                    id="etapaRefreshButton"                                                                                                                                                                                                                    
                    icon="sap-icon://refresh"                                                                                                                                                                                                                  
                    type="Transparent"                                                                                                                                                                                                                         
                    press=".onRefresh"                                                                                                                                                                                                                         
                    tooltip="Atualizar"                                                                                                                                                                                                                        
                />                                                                                                                                                                                                                                             
            </tnt:ToolHeader>                                                                                                                                                                                                                                  
        </tnt:header>                                                                                                                                                                                                                                          
                                                                                                                                                                                                                                                               
        <tnt:sideContent>                                                                                                                                                                                                                                      
            <tnt:SideNavigation                                                                                                                                                                                                                                
                id="etapaSideNavigation"                                                                                                                                                                                                                       
                selectedKey="{etapa>/selectedMenuKey}"                                                                                                                                                                                                         
                itemSelect=".onSideMenuItemSelect"                                                                                                                                                                                                             
                visible="{etapa>/showSideNavigation}"                                                                                                                                                                                                          
            >                                                                                                                                                                                                                                                  
                <tnt:NavigationList id="etapaNavigationList">                                                                                                                                                                                                  
                    <!-- Etapa Home -->                                                                                                                                                                                                                        
                    <tnt:NavigationListItem                                                                                                                                                                                                                    
                        id="menuEtapa"                                                                                                                                                                                                                         
                        text="Etapa"                                                                                                                                                                                                                           
                        key="etapa"                                                                                                                                                                                                                            
                        icon="sap-icon://home"                                                                                                                                                                                                                 
                    />                                                                                                                                                                                                                                         
                    <!-- Dados -->                                                                                                                                                                                                                             
                    <tnt:NavigationListItem                                                                                                                                                                                                                    
                        id="menuDados"                                                                                                                                                                                                                         
                        text="Dados"                                                                                                                                                                                                                           
                        key="dados"                                                                                                                                                                                                                            
                        icon="sap-icon://database"                                                                                                                                                                                                             
                    />                                                                                                                                                                                                                                         
                    <!-- Import -->                                                                                                                                                                                                                            
                    <tnt:NavigationListItem                                                                                                                                                                                                                    
                        id="menuImport"                                                                                                                                                                                                                        
                        text="Import"                                                                                                                                                                                                                          
                        key="import"                                                                                                                                                                                                                           
                        icon="sap-icon://download"                                                                                                                                                                                                             
                        expanded="true"                                                                                                                                                                                                                        
                        items="{                                                                                                                                                                                                                               
                            path: 'etapa>/functionImport/import',                                                                                                                                                                                              
                            templateShareable: false                                                                                                                                                                                                           
                        }"                                                                                                                                                                                                                                     
                    >                                                                                                                                                                                                                                          
                        <tnt:NavigationListItem                                                                                                                                                                                                                
                            id="menuImportItem"                                                                                                                                                                                                                
                            text="{= ${etapa>isMapped} ? '🔹 ' + ${etapa>Parameter} : ${etapa>Parameter}}"                                                                                                                                                     
                            key="import-{etapa>Parameter}"                                                                                                                                                                                                     
                        >                                                                                                                                                                                                                                      
                        </tnt:NavigationListItem>                                                                                                                                                                                                              
                    </tnt:NavigationListItem>                                                                                                                                                                                                                  
                    <!-- Export -->                                                                                                                                                                                                                            
                    <tnt:NavigationListItem                                                                                                                                                                                                                    
                        id="menuExport"                                                                                                                                                                                                                        
                        text="Export"                                                                                                                                                                                                                          
                        key="export"                                                                                                                                                                                                                           
                        icon="sap-icon://upload"                                                                                                                                                                                                               
                        expanded="true"                                                                                                                                                                                                                        
                        items="{                                                                                                                                                                                                                               
                            path: 'etapa>/functionImport/export',                                                                                                                                                                                              
                            templateShareable: false                                                                                                                                                                                                           
                        }"                                                                                                                                                                                                                                     
                    >                                                                                                                                                                                                                                          
                        <tnt:NavigationListItem                                                                                                                                                                                                                
                            id="menuExportItem"                                                                                                                                                                                                                
                            text="{= ${etapa>isMapped} ? '🔹 ' + ${etapa>Parameter} : ${etapa>Parameter}}"                                                                                                                                                     
                            key="export-{etapa>Parameter}"                                                                                                                                                                                                     
                        >                                                                                                                                                                                                                                      
                        </tnt:NavigationListItem>                                                                                                                                                                                                              
                    </tnt:NavigationListItem>                                                                                                                                                                                                                  
                    <!-- Tables -->                                                                                                                                                                                                                            
                    <tnt:NavigationListItem                                                                                                                                                                                                                    
                        id="menuTables"                                                                                                                                                                                                                        
                        text="Tables"                                                                                                                                                                                                                          
                        key="tables"                                                                                                                                                                                                                           
                        icon="sap-icon://table-view"                                                                                                                                                                                                           
                        expanded="true"                                                                                                                                                                                                                        
                        items="{                                                                                                                                                                                                                               
                            path: 'etapa>/functionImport/tables',                                                                                                                                                                                              
                            templateShareable: false                                                                                                                                                                                                           
                        }"                                                                                                                                                                                                                                     
                    >                                                                                                                                                                                                                                          
                        <tnt:NavigationListItem                                                                                                                                                                                                                
                            id="menuTableItem"                                                                                                                                                                                                                 
                            text="{= ${etapa>isMapped} ? '🔹 ' + ${etapa>Parameter} : ${etapa>Parameter}}"                                                                                                                                                     
                            key="tables-{etapa>Parameter}"                                                                                                                                                                                                     
                        >                                                                                                                                                                                                                                      
                        </tnt:NavigationListItem>                                                                                                                                                                                                              
                    </tnt:NavigationListItem>                                                                                                                                                                                                                  
                </tnt:NavigationList>                                                                                                                                                                                                                          
            </tnt:SideNavigation>                                                                                                                                                                                                                              
        </tnt:sideContent>                                                                                                                                                                                                                                     
&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;                                                                                                                                                                                                               
        <tnt:mainContents>                                                                                                                                                                                                                                     
            <NavContainer id="etapaMainContents" />                                                                                                                                                                                                            
        </tnt:mainContents>                                                                                                                                                                                                                                    
    </tnt:ToolPage>                                                                                                                                                                                                                                            
</mvc:View>                                                                                                                                                                                                                                                    
                                                                                                                                                                                                                                                               