sap.ui.define([                                                                                                                                                                                                                                                
    "sap/ui/core/mvc/Controller",                                                                                                                                                                                                                              
    "sap/ui/model/json/JSONModel",                                                                                                                                                                                                                             
    "sap/ui/model/Filter",                                                                                                                                                                                                                                     
    "sap/ui/model/FilterOperator",                                                                                                                                                                                                                             
    "sap/m/MessageToast",                                                                                                                                                                                                                                      
    "sap/m/MessageBox"                                                                                                                                                                                                                                         
], function (Controller, JSONModel, Filter, FilterOperator, MessageToast, MessageBox) {                                                                                                                                                                        
    "use strict";                                                                                                                                                                                                                                              
                                                                                                                                                                                                                                                               
    return Controller.extend("br.com.gja.zui5.gjaauto.cockpit.controller.Cockpit", {                                                                                                                                                                           
        /* =========================================================== */                                                                                                                                                                                      
        /* Eventos do Ciclo de Vida                                   */                                                                                                                                                                                       
        /* =========================================================== */                                                                                                                                                                                      
                                                                                                                                                                                                                                                               
        /**                                                                                                                                                                                                                                                    
         * Inicializa o controlador.                                                                                                                                                                                                                           
         * Configura o modelo de visualização, carrega o menu de automações                                                                                                                                                                                    
         * e busca as execuções iniciais.                                                                                                                                                                                                                      
         * @public                                                                                                                                                                                                                                             
         */                                                                                                                                                                                                                                                    
        onInit: function () {                                                                                                                                                                                                                                  
            var oViewModel = this._createViewModel();                                                                                                                                                                                                          
                                                                                                                                                                                                                                                               
            this.getView().setModel(oViewModel, "cockpit");                                                                                                                                                                                                    
                                                                                                                                                                                                                                                               
            this._loadData();                                                                                                                                                                                                                                  
&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;                                                                                                                                                                                       
            // Configura o roteador para gerenciar as navegações                                                                                                                                                                                               
            var oRouter = this.getOwnerComponent().getRouter();                                                                                                                                                                                                
            oRouter.getRoute("RouteCockpit").attachPatternMatched(this._onPatternMatched, this);                                                                                                                                                               
        },                                                                                                                                                                                                                                                     
                                                                                                                                                                                                                                                               
        /**                                                                                                                                                                                                                                                    
         * Chamado quando a rota Cockpit é correspondida.                                                                                                                                                                                                      
         * @param {sap.ui.base.Event} oEvent Evento de correspondência da rota                                                                                                                                                                                 
         * @private                                                                                                                                                                                                                                            
         */                                                                                                                                                                                                                                                    
        _onPatternMatched: function (oEvent) {                                                                                                                                                                                                                 
            // Navega para a tela home ao abrir o cockpit                                                                                                                                                                                                      
            var oRouter = this.getOwnerComponent().getRouter();                                                                                                                                                                                                
            oRouter.getTargets().display("TargetHome");                                                                                                                                                                                                        
        },                                                                                                                                                                                                                                                     
                                                                                                                                                                                                                                                               
        /* =========================================================== */                                                                                                                                                                                      
        /* Métodos Privados - Inicialização                           */                                                                                                                                                                                       
        /* =========================================================== */                                                                                                                                                                                      
                                                                                                                                                                                                                                                               
        /**                                                                                                                                                                                                                                                    
         * Cria e retorna o modelo de visualização com valores iniciais.                                                                                                                                                                                       
         * @returns {JSONModel} Modelo de visualização configurado                                                                                                                                                                                             
         * @private                                                                                                                                                                                                                                            
         */                                                                                                                                                                                                                                                    
        _createViewModel: function () {                                                                                                                                                                                                                        
            return new JSONModel({                                                                                                                                                                                                                             
                // Dados de automações e operações                                                                                                                                                                                                             
                automacoes: [],                                                                                                                                                                                                                                
&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;                                                                                                                                                               
                // Estado da UI                                                                                                                                                                                                                                
                busy: false,                                                                                                                                                                                                                                   
                                                                                                                                                                                                                                                               
                // Seleção atual                                                                                                                                                                                                                               
                selectedAutomation: "",                                                                                                                                                                                                                        
                selectedOperation: "",                                                                                                                                                                                                                         
                operacaoSelecionada: ""                                                                                                                                                                                                                        
            });                                                                                                                                                                                                                                                
        },                                                                                                                                                                                                                                                     
                                                                                                                                                                                                                                                               
        /* =========================================================== */                                                                                                                                                                                      
        /* Métodos Privados - Carregamento de Dados                   */                                                                                                                                                                                       
        /* =========================================================== */                                                                                                                                                                                      
                                                                                                                                                                                                                                                               
        /**                                                                                                                                                                                                                                                    
         * Carrega todos os dados necessários para a tela de Cockpit,                                                                                                                                                                                          
         * @private                                                                                                                                                                                                                                            
         */                                                                                                                                                                                                                                                    
        _loadData: function () {                                                                                                                                                                                                                               
            var oMainModel = this.getOwnerComponent().getModel();                                                                                                                                                                                              
            var oViewModel = this.getView().getModel("cockpit");                                                                                                                                                                                               
            var that = this;                                                                                                                                                                                                                                   
                                                                                                                                                                                                                                                               
            if (!oMainModel) {                                                                                                                                                                                                                                 
                MessageBox.error("Modelo OData não está disponível. Verifique a configuração do manifest.json");                                                                                                                                               
                return;                                                                                                                                                                                                                                        
            }                                                                                                                                                                                                                                                  
                                                                                                                                                                                                                                                               
            oViewModel.setProperty("/busy", true);                                                                                                                                                                                                             
                                                                                                                                                                                                                                                               
            oMainModel.read("/Automacoes", {                                                                                                                                                                                                                   
                urlParameters: {                                                                                                                                                                                                                               
                    "$expand": "to_Operacoes"                                                                                                                                                                                                                  
                },                                                                                                                                                                                                                                             
                success: function (oData) {                                                                                                                                                                                                                    
                    var aAutomations = oData.results;                                                                                                                                                                                                          
                    oViewModel.setProperty("/automacoes", aAutomations);                                                                                                                                                                                       
                    oViewModel.setProperty("/busy", false);                                                                                                                                                                                                    
                    MessageToast.show("Dados carregados com sucesso!");                                                                                                                                                                                        
                },                                                                                                                                                                                                                                             
                error: function (oError) {                                                                                                                                                                                                                     
                    oViewModel.setProperty("/busy", false);                                                                                                                                                                                                    
                    that._handleODataError(oError, "Automacoes");                                                                                                                                                                                              
                }                                                                                                                                                                                                                                              
            });                                                                                                                                                                                                                                                
        },                                                                                                                                                                                                                                                     
                                                                                                                                                                                                                                                               
        /* =========================================================== */                                                                                                                                                                                      
        /* Métodos Privados - Tratamento de Erros                    */                                                                                                                                                                                        
        /* =========================================================== */                                                                                                                                                                                      
                                                                                                                                                                                                                                                               
        /**                                                                                                                                                                                                                                                    
         * Trata erros de chamadas OData.                                                                                                                                                                                                                      
         * @param {object} oError - Objeto de erro                                                                                                                                                                                                             
         * @param {string} sEntity - Nome da entidade ou operação                                                                                                                                                                                              
         * @private                                                                                                                                                                                                                                            
         */                                                                                                                                                                                                                                                    
        _handleODataError: function (oError, sEntity) {                                                                                                                                                                                                        
            var sMessage = "Erro ao carregar " + sEntity;                                                                                                                                                                                                      
                                                                                                                                                                                                                                                               
            if (oError && oError.responseText) {                                                                                                                                                                                                               
                try {                                                                                                                                                                                                                                          
                    var oErrorResponse = JSON.parse(oError.responseText);                                                                                                                                                                                      
                    sMessage = oErrorResponse.error.message.value || sMessage;                                                                                                                                                                                 
                } catch (e) {                                                                                                                                                                                                                                  
                    // Usar mensagem padrão                                                                                                                                                                                                                    
                }                                                                                                                                                                                                                                              
            }                                                                                                                                                                                                                                                  
                                                                                                                                                                                                                                                               
            MessageBox.error(sMessage);                                                                                                                                                                                                                        
        },                                                                                                                                                                                                                                                     
                                                                                                                                                                                                                                                               
        /* =========================================================== */                                                                                                                                                                                      
        /* Event Handlers - Navegação                                 */                                                                                                                                                                                       
        /* =========================================================== */                                                                                                                                                                                      
                                                                                                                                                                                                                                                               
        /**                                                                                                                                                                                                                                                    
         * Navega para tela de detalhes da etapa selecionada.                                                                                                                                                                                                  
         * @param {sap.ui.base.Event} oEvent - Evento de seleção                                                                                                                                                                                               
         * @public                                                                                                                                                                                                                                             
         */                                                                                                                                                                                                                                                    
        onAutomationSelect: function (oEvent) {                                                                                                                                                                                                                
            var oSelectedItem = oEvent.getParameter("listItem") || oEvent.getSource();                                                                                                                                                                         
            var sKey = oSelectedItem.getBindingContext("cockpit").getProperty("Chave");                                                                                                                                                                        
            var oRouter = this.getOwnerComponent().getRouter();                                                                                                                                                                                                
                                                                                                                                                                                                                                                               
            oRouter.navTo("Automacao", {                                                                                                                                                                                                                       
                chave: sKey                                                                                                                                                                                                                                    
            });                                                                                                                                                                                                                                                
        },                                                                                                                                                                                                                                                     
                                                                                                                                                                                                                                                               
        /**                                                                                                                                                                                                                                                    
         * Manipula seleção de item no menu de navegação.                                                                                                                                                                                                      
         * Recarrega execuções com base na seleção.                                                                                                                                                                                                            
         * @param {sap.ui.base.Event} oEvent - Evento de seleção                                                                                                                                                                                               
         * @public                                                                                                                                                                                                                                             
         */                                                                                                                                                                                                                                                    
        onSideMenuItemSelect: function (oEvent) {                                                                                                                                                                                                              
            this._collapseSideNavigation();                                                                                                                                                                                                                    
                                                                                                                                                                                                                                                               
            var oItem = oEvent.getParameter("item");                                                                                                                                                                                                           
            var sKey = oItem.getKey();                                                                                                                                                                                                                         
&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;                                                                                                                                                                                       
            if (!sKey) {                                                                                                                                                                                                                                       
                return;                                                                                                                                                                                                                                        
            }                                                                                                                                                                                                                                                  
                                                                                                                                                                                                                                                               
            var oRouter = this.getOwnerComponent().getRouter();                                                                                                                                                                                                
&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;                                                                                                                                                                                       
            // Verifica se é uma automação ou operação                                                                                                                                                                                                         
            if (sKey.indexOf("-") > -1) {                                                                                                                                                                                                                      
                // É uma operação (formato: "AUTO-OPERA")                                                                                                                                                                                                      
                var aParts = sKey.split("-");                                                                                                                                                                                                                  
                oRouter.navTo("RouteOperacao", {                                                                                                                                                                                                               
                    codigoAuto: aParts[0],                                                                                                                                                                                                                     
                    codigoOpera: aParts[1]                                                                                                                                                                                                                     
                });                                                                                                                                                                                                                                            
            } else {                                                                                                                                                                                                                                           
                // É uma automação                                                                                                                                                                                                                             
                oRouter.navTo("RouteAutomacao", {                                                                                                                                                                                                              
                    codigoAuto: sKey                                                                                                                                                                                                                           
                });                                                                                                                                                                                                                                            
            }                                                                                                                                                                                                                                                  
        },                                                                                                                                                                                                                                                     
                                                                                                                                                                                                                                                               
        /**                                                                                                                                                                                                                                                    
         * Recolhe a barra lateral de navegação se estiver expandida.                                                                                                                                                                                          
         * @private                                                                                                                                                                                                                                            
         */                                                                                                                                                                                                                                                    
        _collapseSideNavigation: function () {                                                                                                                                                                                                                 
            var oToolPage = this.byId("toolPage");                                                                                                                                                                                                             
            if (oToolPage && oToolPage.getSideExpanded()) {                                                                                                                                                                                                    
                oToolPage.setSideExpanded(false);                                                                                                                                                                                                              
            }                                                                                                                                                                                                                                                  
        },                                                                                                                                                                                                                                                     
                                                                                                                                                                                                                                                               
        /**                                                                                                                                                                                                                                                    
         * Obtém os itens selecionados (automação e operação).                                                                                                                                                                                                 
         * @param {sap.ui.base.Event} [oEvent] - Evento de seleção                                                                                                                                                                                             
         * @param {JSONModel} oViewModel - Modelo de visualização                                                                                                                                                                                              
         * @returns {object} Objeto com automation e operation                                                                                                                                                                                                 
         * @private                                                                                                                                                                                                                                            
         */                                                                                                                                                                                                                                                    
        _getSelectedItems: function (oEvent, oViewModel) {                                                                                                                                                                                                     
            var sAutomation = "";                                                                                                                                                                                                                              
            var sOperation = "";                                                                                                                                                                                                                               
                                                                                                                                                                                                                                                               
            if (oEvent) {                                                                                                                                                                                                                                      
                var oSelectedItem = oEvent.getParameter("item");                                                                                                                                                                                               
                var aKeys = oSelectedItem.getKey().split("-");                                                                                                                                                                                                 
                sAutomation = aKeys[0];                                                                                                                                                                                                                        
                sOperation = aKeys[1];                                                                                                                                                                                                                         
                                                                                                                                                                                                                                                               
                oViewModel.setProperty("/selectedAutomation", sAutomation);                                                                                                                                                                                    
                oViewModel.setProperty("/selectedOperation", sOperation);                                                                                                                                                                                      
            } else {                                                                                                                                                                                                                                           
                sAutomation = oViewModel.getProperty("/selectedAutomation") || "";                                                                                                                                                                             
                sOperation = oViewModel.getProperty("/selectedOperation") || "";                                                                                                                                                                               
            }                                                                                                                                                                                                                                                  
                                                                                                                                                                                                                                                               
            return {                                                                                                                                                                                                                                           
                automation: sAutomation,                                                                                                                                                                                                                       
                operation: sOperation                                                                                                                                                                                                                          
            };                                                                                                                                                                                                                                                 
        },                                                                                                                                                                                                                                                     
                                                                                                                                                                                                                                                               
        /**                                                                                                                                                                                                                                                    
         * Constrói a descrição da operação selecionada.                                                                                                                                                                                                       
         * @param {string} sAutomation - ID da automação                                                                                                                                                                                                       
         * @param {string} sOperation - ID da operação                                                                                                                                                                                                         
         * @param {JSONModel} oViewModel - Modelo                                                                                                                                                                                                              
         * @returns {string} Descrição formatada                                                                                                                                                                                                               
         * @private                                                                                                                                                                                                                                            
         */                                                                                                                                                                                                                                                    
        _buildOperationDescription: function (sAutomation, sOperation, oViewModel) {                                                                                                                                                                           
            if (!sAutomation) {                                                                                                                                                                                                                                
                return "Todas as Automações";                                                                                                                                                                                                                  
            }                                                                                                                                                                                                                                                  
                                                                                                                                                                                                                                                               
            var aAutomations = oViewModel.getProperty("/automacoes") || [];                                                                                                                                                                                    
            var oAutomation = aAutomations.find(function (item) {                                                                                                                                                                                              
                return item.auto === sAutomation;                                                                                                                                                                                                              
            });                                                                                                                                                                                                                                                
                                                                                                                                                                                                                                                               
            if (!oAutomation) {                                                                                                                                                                                                                                
                return;                                                                                                                                                                                                                                        
            }                                                                                                                                                                                                                                                  
                                                                                                                                                                                                                                                               
            if (sOperation) {                                                                                                                                                                                                                                  
                var oOperation = oAutomation.to_Operacoes.results.find(function (item) {                                                                                                                                                                       
                    return item.opera === sOperation;                                                                                                                                                                                                          
                });                                                                                                                                                                                                                                            
            }                                                                                                                                                                                                                                                  
                                                                                                                                                                                                                                                               
            if (!oOperation) {                                                                                                                                                                                                                                 
                return;                                                                                                                                                                                                                                        
            }                                                                                                                                                                                                                                                  
                                                                                                                                                                                                                                                               
            oViewModel.setProperty("/operationTitle", sOperation + " - " + oOperation.descr);                                                                                                                                                                  
            oViewModel.setProperty("/operationSubtitle", sAutomation + " - " + oAutomation.descr);                                                                                                                                                             
        },                                                                                                                                                                                                                                                     
                                                                                                                                                                                                                                                               
        /* =========================================================== */                                                                                                                                                                                      
        /* Event Handlers - Criação                                   */                                                                                                                                                                                       
        /* =========================================================== */                                                                                                                                                                                      
                                                                                                                                                                                                                                                               
        /**                                                                                                                                                                                                                                                    
         * Abre o popup de criação.                                                                                                                                                                                                                            
         * @public                                                                                                                                                                                                                                             
         */                                                                                                                                                                                                                                                    
        onNewButtonPress: function () {                                                                                                                                                                                                                        
            var oViewModel = this.getView().getModel("cockpit");                                                                                                                                                                                               
            var sKey = oViewModel.getProperty("/operacaoSelecionada") || "";                                                                                                                                                                                   
            var sAuto = "";                                                                                                                                                                                                                                    
            var sOpera = "";                                                                                                                                                                                                                                   
                                                                                                                                                                                                                                                               
            if (sKey) {                                                                                                                                                                                                                                        
                if (sKey.indexOf("-") > -1) {                                                                                                                                                                                                                  
                    var aParts = sKey.split("-");                                                                                                                                                                                                              
                    sAuto = aParts[0];                                                                                                                                                                                                                         
                    sOpera = aParts[1];                                                                                                                                                                                                                        
                } else {                                                                                                                                                                                                                                       
                    sAuto = sKey;                                                                                                                                                                                                                              
                }                                                                                                                                                                                                                                              
            }                                                                                                                                                                                                                                                  
                                                                                                                                                                                                                                                               
            var oPrefill = {};                                                                                                                                                                                                                                 
            if (sAuto) {                                                                                                                                                                                                                                       
                oPrefill.auto = sAuto;                                                                                                                                                                                                                         
            }                                                                                                                                                                                                                                                  
            if (sOpera) {                                                                                                                                                                                                                                      
                oPrefill.opera = sOpera;                                                                                                                                                                                                                       
            }                                                                                                                                                                                                                                                  
                                                                                                                                                                                                                                                               
            this.getOwnerComponent().getCreateEditDialog().openCreate(null, oPrefill, function () {                                                                                                                                                            
                this._loadData();                                                                                                                                                                                                                              
            }.bind(this));                                                                                                                                                                                                                                     
        },                                                                                                                                                                                                                                                     
                                                                                                                                                                                                                                                               
        /**                                                                                                                                                                                                                                                    
         * Handler para alternar visibilidade da navegação lateral.                                                                                                                                                                                            
         * @public                                                                                                                                                                                                                                             
         */                                                                                                                                                                                                                                                    
        onSideNavButtonPress: function () {                                                                                                                                                                                                                    
            var oToolPage = this.byId("toolPage");                                                                                                                                                                                                             
            oToolPage.setSideExpanded(!oToolPage.getSideExpanded());                                                                                                                                                                                           
        },                                                                                                                                                                                                                                                     
                                                                                                                                                                                                                                                               
        /**                                                                                                                                                                                                                                                    
         * Handler para atualizar os dados.                                                                                                                                                                                                                    
         * @public                                                                                                                                                                                                                                             
         */                                                                                                                                                                                                                                                    
        onRefresh: function () {                                                                                                                                                                                                                               
            this._loadData();                                                                                                                                                                                                                                  
        }                                                                                                                                                                                                                                                      
    });                                                                                                                                                                                                                                                        
});                                                                                                                                                                                                                                                            
                                                                                                                                                                                                                                                               