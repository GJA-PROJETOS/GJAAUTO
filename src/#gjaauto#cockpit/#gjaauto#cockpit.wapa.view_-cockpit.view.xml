<mvc:View                                                                                                                                                                                                                                                      
    controllerName="br.com.gja.zui5.gjaauto.cockpit.controller.Cockpit"                                                                                                                                                                                        
    xmlns="sap.m"                                                                                                                                                                                                                                              
    xmlns:mvc="sap.ui.core.mvc"                                                                                                                                                                                                                                
    xmlns:core="sap.ui.core"                                                                                                                                                                                                                                   
    xmlns:tnt="sap.tnt"                                                                                                                                                                                                                                        
    xmlns:uxap="sap.uxap"                                                                                                                                                                                                                                      
    xmlns:table="sap.ui.table"                                                                                                                                                                                                                                 
    xmlns:f="sap.ui.layout.form"                                                                                                                                                                                                                               
    displayBlock="true"                                                                                                                                                                                                                                        
    height="100%"                                                                                                                                                                                                                                              
>                                                                                                                                                                                                                                                              
    <Shell id="_IDCockpitShell">                                                                                                                                                                                                                               
        <Page                                                                                                                                                                                                                                                  
            id="page"                                                                                                                                                                                                                                          
            showHeader="false"                                                                                                                                                                                                                                 
        >                                                                                                                                                                                                                                                      
            <content>                                                                                                                                                                                                                                          
                <tnt:ToolPage                                                                                                                                                                                                                                  
                    id="toolPage"                                                                                                                                                                                                                              
                    busy="{cockpit>/busy}"                                                                                                                                                                                                                     
                    busyIndicatorDelay="0"                                                                                                                                                                                                                     
                >                                                                                                                                                                                                                                              
                    <tnt:header>                                                                                                                                                                                                                               
                        <tnt:ToolHeader id="_IDGenToolHeader">                                                                                                                                                                                                 
                            <Button                                                                                                                                                                                                                            
                                id="sideNavigationToggleButton"                                                                                                                                                                                                
                                icon="sap-icon://menu2"                                                                                                                                                                                                        
                                type="Transparent"                                                                                                                                                                                                             
                                press=".onSideNavButtonPress"                                                                                                                                                                                                  
                                tooltip="{i18n>collpaseMenuButtonText}"                                                                                                                                                                                        
                            >                                                                                                                                                                                                                                  
                                <layoutData>                                                                                                                                                                                                                   
                                    <OverflowToolbarLayoutData                                                                                                                                                                                                 
                                        id="_IDGenOverflowToolbarLayoutData"                                                                                                                                                                                   
                                        priority="NeverOverflow"                                                                                                                                                                                               
                                    />                                                                                                                                                                                                                         
                                </layoutData>                                                                                                                                                                                                                  
                            </Button>                                                                                                                                                                                                                          
                            <ToolbarSpacer id="_IDGenToolbarSpacer" />                                                                                                                                                                                         
                            <Title                                                                                                                                                                                                                             
                                id="_IDGenTitle"                                                                                                                                                                                                               
                                text="{i18n>cockpitTitle}"                                                                                                                                                                                                     
                                level="H2"                                                                                                                                                                                                                     
                            />                                                                                                                                                                                                                                 
                            <ToolbarSpacer id="_IDGenToolbarSpacer1" />                                                                                                                                                                                        
                            <Button                                                                                                                                                                                                                            
                                id="newButton"                                                                                                                                                                                                                 
                                icon="sap-icon://add"                                                                                                                                                                                                          
                                type="Transparent"                                                                                                                                                                                                             
                                press=".onNewButtonPress"                                                                                                                                                                                                      
                                tooltip="{i18n>newButtonTooltip}"                                                                                                                                                                                              
                            />                                                                                                                                                                                                                                 
                        </tnt:ToolHeader>                                                                                                                                                                                                                      
                    </tnt:header>                                                                                                                                                                                                                              
                                                                                                                                                                                                                                                               
                    <tnt:sideContent>                                                                                                                                                                                                                          
                        <tnt:SideNavigation                                                                                                                                                                                                                    
                            id="sideNavigation"                                                                                                                                                                                                                
                            selectedKey="{cockpit>/operacaoSelecionada}"                                                                                                                                                                                       
                            itemSelect=".onSideMenuItemSelect"                                                                                                                                                                                                 
                        >                                                                                                                                                                                                                                      
                            <tnt:NavigationList                                                                                                                                                                                                                
                                id="navigationListAutomacoes"                                                                                                                                                                                                  
                                items="{                                                                                                                                                                                                                       
                                    path: 'cockpit>/automacoes',                                                                                                                                                                                               
                                    templateShareable: false                                                                                                                                                                                                   
                                }"                                                                                                                                                                                                                             
                            >                                                                                                                                                                                                                                  
                                <tnt:NavigationListItem                                                                                                                                                                                                        
                                    id="_IDGenNavigationListItem"                                                                                                                                                                                              
                                    text="{cockpit>auto} - {cockpit>descr}"                                                                                                                                                                                    
                                    key="{cockpit>auto}"                                                                                                                                                                                                       
                                    icon="{cockpit>icon_fiori}"                                                                                                                                                                                                
                                    expanded="true"                                                                                                                                                                                                            
                                    items="{                                                                                                                                                                                                                   
                                        path: 'cockpit>to_Operacoes/results',                                                                                                                                                                                  
                                        templateShareable: false                                                                                                                                                                                               
                                    }"                                                                                                                                                                                                                         
                                >                                                                                                                                                                                                                              
                                    <tnt:NavigationListItem                                                                                                                                                                                                    
                                        id="_IDGenNavigationListItem1"                                                                                                                                                                                         
                                        text="{cockpit>opera} - {cockpit>descr}"                                                                                                                                                                               
                                        key="{cockpit>auto}-{cockpit>opera}"                                                                                                                                                                                   
                                        icon="sap-icon://activity-items"                                                                                                                                                                                       
                                    />                                                                                                                                                                                                                         
                                </tnt:NavigationListItem>                                                                                                                                                                                                      
                            </tnt:NavigationList>                                                                                                                                                                                                              
                        </tnt:SideNavigation>                                                                                                                                                                                                                  
                    </tnt:sideContent>                                                                                                                                                                                                                         
                    <tnt:mainContents>                                                                                                                                                                                                                         
                        <NavContainer id="mainContents" />                                                                                                                                                                                                     
                    </tnt:mainContents>                                                                                                                                                                                                                        
                </tnt:ToolPage>                                                                                                                                                                                                                                
            </content>                                                                                                                                                                                                                                         
        </Page>                                                                                                                                                                                                                                                
    </Shell>                                                                                                                                                                                                                                                   
</mvc:View>                                                                                                                                                                                                                                                    
                                                                                                                                                                                                                                                               