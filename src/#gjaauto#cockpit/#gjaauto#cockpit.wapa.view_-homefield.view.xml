<mvc:View                                                                                                                                                                                                                                                      
    controllerName="br.com.gja.zui5.gjaauto.cockpit.controller.HomeField"                                                                                                                                                                                      
    xmlns="sap.m"                                                                                                                                                                                                                                              
    xmlns:mvc="sap.ui.core.mvc"                                                                                                                                                                                                                                
    xmlns:f="sap.ui.layout.form"                                                                                                                                                                                                                               
    xmlns:core="sap.ui.core"                                                                                                                                                                                                                                   
    displayBlock="true"                                                                                                                                                                                                                                        
    height="100%"                                                                                                                                                                                                                                              
>                                                                                                                                                                                                                                                              
    <Page                                                                                                                                                                                                                                                      
        id="homeFieldPage"                                                                                                                                                                                                                                     
        showHeader="true"                                                                                                                                                                                                                                      
        title="{etapa>/parameterDoku/Param}"                                                                                                                                                                                                                   
        showNavButton="false"                                                                                                                                                                                                                                  
    >                                                                                                                                                                                                                                                          
        <content>                                                                                                                                                                                                                                              
            <VBox                                                                                                                                                                                                                                              
                id="homeFieldContent"                                                                                                                                                                                                                          
                class="sapUiSmallMargin"                                                                                                                                                                                                                       
            >                                                                                                                                                                                                                                                  
                <!-- Informações do Parâmetro -->                                                                                                                                                                                                              
                <f:SimpleForm                                                                                                                                                                                                                                  
                    id="paramInfoForm"                                                                                                                                                                                                                         
                    editable="false"                                                                                                                                                                                                                           
                    layout="ResponsiveGridLayout"                                                                                                                                                                                                              
                    labelSpanXL="3"                                                                                                                                                                                                                            
                    labelSpanL="3"                                                                                                                                                                                                                             
                    labelSpanM="4"                                                                                                                                                                                                                             
                    labelSpanS="12"                                                                                                                                                                                                                            
                    columnsXL="2"                                                                                                                                                                                                                              
                    columnsL="2"                                                                                                                                                                                                                               
                    columnsM="1"                                                                                                                                                                                                                               
                    class="sapUiSmallMarginBottom"                                                                                                                                                                                                             
                >                                                                                                                                                                                                                                              
                    <f:content>                                                                                                                                                                                                                                
                        <core:Title id="paramTitle" text="Informações do Parâmetro"/>                                                                                                                                                                          
&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;                                                                                                               
                        <Label id="paramNameLabel" text="Parâmetro"/>                                                                                                                                                                                          
                        <Text id="paramNameText" text="{etapa>/parameterDoku/Param}"/>                                                                                                                                                                         
&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;                                                                                                               
                        <Label id="paramDataTypeLabel" text="Tipo de Dado"/>                                                                                                                                                                                   
                        <Text id="paramDataTypeText" text="{etapa>/parameterDoku/DataType}"/>                                                                                                                                                                  
&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;                                                                                                               
                        <Label id="paramTypeLabel" text="Tipo"/>                                                                                                                                                                                               
                        <Text id="paramTypeText" text="{= ${etapa>/parameterDoku/ParamTyp} === 'T' ? 'Estrutura' : 'Campo Simples'}"/>                                                                                                                         
&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;                                                                                                               
                        <Label id="paramFieldCountLabel" text="Quantidade de Campos"/>                                                                                                                                                                         
                        <Text id="paramFieldCountText" text="{= ${etapa>/parameterDoku/items/results}.length }"/>                                                                                                                                              
                    </f:content>                                                                                                                                                                                                                               
                </f:SimpleForm>                                                                                                                                                                                                                                
                                                                                                                                                                                                                                                               
                <!-- Informações de atribuição -->                                                                                                                                                                                                             
                <f:SimpleForm                                                                                                                                                                                                                                  
                    id="paramInfoAtributionForm"                                                                                                                                                                                                               
                    editable="true"                                                                                                                                                                                                                            
                    layout="ResponsiveGridLayout"                                                                                                                                                                                                              
                    labelSpanXL="3"                                                                                                                                                                                                                            
                    labelSpanL="3"                                                                                                                                                                                                                             
                    labelSpanM="4"                                                                                                                                                                                                                             
                    labelSpanS="12"                                                                                                                                                                                                                            
                    columnsXL="2"                                                                                                                                                                                                                              
                    columnsL="2"                                                                                                                                                                                                                               
                    columnsM="1"                                                                                                                                                                                                                               
                    class="sapUiSmallMarginBottom"                                                                                                                                                                                                             
                >                                                                                                                                                                                                                                              
                    <f:content>                                                                                                                                                                                                                                
                        <core:Title id="paramTitle2" text="Informações de Atribuição"/>                                                                                                                                                                        
&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;                                                                                                               
                        <Label id="paramNameLabel2" text="Tabela Origem"/>                                                                                                                                                                                     
                        <Select                                                                                                                                                                                                                                
                            id="selectParamFrom"                                                                                                                                                                                                               
                            selectedKey="{etapa>/paramAtribuicao/ParamFrom}"                                                                                                                                                                                   
                            items="{etapa>/dadosOrigem}"                                                                                                                                                                                                       
                            forceSelection="false"                                                                                                                                                                                                             
                        >                                                                                                                                                                                                                                      
                            <core:Item id="itemParamFrom" key="{etapa>Name}" text="{etapa>Name}"/>                                                                                                                                                             
                        </Select>                                                                                                                                                                                                                              
                    </f:content>                                                                                                                                                                                                                               
                    <f:toolbar>                                                                                                                                                                                                                                
                        <OverflowToolbar id="atribuicaoToolbar">                                                                                                                                                                                               
                            <ToolbarSpacer id="atribuicaoToolbarSpacer"/>                                                                                                                                                                                      
                            <Button                                                                                                                                                                                                                            
                                id="btnDeleteAtribuicao"                                                                                                                                                                                                       
                                text="Deletar"                                                                                                                                                                                                                 
                                type="Reject"                                                                                                                                                                                                                  
                                icon="sap-icon://delete"                                                                                                                                                                                                       
                                press=".onDeleteAtribuicao"                                                                                                                                                                                                    
                                visible="{= !!${etapa>/paramAtribuicao/ParamFrom} }"                                                                                                                                                                           
                            />                                                                                                                                                                                                                                 
                            <Button                                                                                                                                                                                                                            
                                id="btnSaveAtribuicao"                                                                                                                                                                                                         
                                text="Salvar"                                                                                                                                                                                                                  
                                type="Emphasized"                                                                                                                                                                                                              
                                icon="sap-icon://save"                                                                                                                                                                                                         
                                press=".onSaveAtribuicao"                                                                                                                                                                                                      
                            />                                                                                                                                                                                                                                 
                        </OverflowToolbar>                                                                                                                                                                                                                     
                    </f:toolbar>                                                                                                                                                                                                                               
                </f:SimpleForm>                                                                                                                                                                                                                                
                                                                                                                                                                                                                                                               
                <!-- Tabela de Campos -->                                                                                                                                                                                                                      
                <Panel                                                                                                                                                                                                                                         
                    id="fieldsPanel"                                                                                                                                                                                                                           
                    headerText="Campos da Estrutura"                                                                                                                                                                                                           
                    expandable="false"                                                                                                                                                                                                                         
                    expanded="true"                                                                                                                                                                                                                            
                >                                                                                                                                                                                                                                              
                    <Table                                                                                                                                                                                                                                     
                        id="fieldsTable"                                                                                                                                                                                                                       
                        items="{etapa>/parameterDoku/items/results}"                                                                                                                                                                                           
                        growing="true"                                                                                                                                                                                                                         
                        growingThreshold="20"                                                                                                                                                                                                                  
                        mode="SingleSelectMaster"                                                                                                                                                                                                              
                        selectionChange=".onFieldSelect"                                                                                                                                                                                                       
                    >                                                                                                                                                                                                                                          
                        <headerToolbar>                                                                                                                                                                                                                        
                            <OverflowToolbar id="fieldsTableToolbar">                                                                                                                                                                                          
                                <Title id="fieldsTableTitle" text="Campos"/>                                                                                                                                                                                   
                                <ToolbarSpacer id="fieldsTableSpacer"/>                                                                                                                                                                                        
                                <SearchField                                                                                                                                                                                                                   
                                    id="fieldsSearchField"                                                                                                                                                                                                     
                                    width="300px"                                                                                                                                                                                                              
                                    placeholder="Buscar campo..."                                                                                                                                                                                              
                                    search=".onSearchField"                                                                                                                                                                                                    
                                />                                                                                                                                                                                                                             
                            </OverflowToolbar>                                                                                                                                                                                                                 
                        </headerToolbar>                                                                                                                                                                                                                       
                        <columns>                                                                                                                                                                                                                              
                            <Column id="colFieldName" width="20%">                                                                                                                                                                                             
                                <Text id="colFieldNameText" text="Campo"/>                                                                                                                                                                                     
                            </Column>                                                                                                                                                                                                                          
                            <Column id="colFieldDesc">                                                                                                                                                                                                         
                                <Text id="colFieldDescText" text="Descrição"/>                                                                                                                                                                                 
                            </Column>                                                                                                                                                                                                                          
                            <Column id="colFieldDataType" width="10%">                                                                                                                                                                                         
                                <Text id="colFieldDataTypeText" text="Tipo"/>                                                                                                                                                                                  
                            </Column>                                                                                                                                                                                                                          
                            <Column id="colFieldLength" width="10%">                                                                                                                                                                                           
                                <Text id="colFieldLengthText" text="Comprimento"/>                                                                                                                                                                             
                            </Column>                                                                                                                                                                                                                          
                            <Column id="colFieldFixValue" width="10%">                                                                                                                                                                                         
                                <Text id="colFieldFixValueText" text="Valor Fixo"/>                                                                                                                                                                            
                            </Column>                                                                                                                                                                                                                          
                        </columns>                                                                                                                                                                                                                             
                        <items>                                                                                                                                                                                                                                
                            <ColumnListItem                                                                                                                                                                                                                    
                                id="fieldListItem"                                                                                                                                                                                                             
                                type="Navigation"                                                                                                                                                                                                              
                                press=".onFieldPress"                                                                                                                                                                                                          
                            >                                                                                                                                                                                                                                  
                                <cells>                                                                                                                                                                                                                        
                                    <Text id="cellFieldName" text="{etapa>FieldName}"/>                                                                                                                                                                        
                                    <Text id="cellFieldDesc" text="{etapa>Desc}"/>                                                                                                                                                                             
                                    <Text id="cellFieldDataType" text="{etapa>DataType}"/>                                                                                                                                                                     
                                    <Text id="cellFieldLength" text="{etapa>Leng}"/>                                                                                                                                                                           
                                    <Text id="cellFieldFixValue" text="{= ${etapa>FixValue} === 'X' ? 'Sim' : 'Não'}"/>                                                                                                                                        
                                </cells>                                                                                                                                                                                                                       
                            </ColumnListItem>                                                                                                                                                                                                                  
                        </items>                                                                                                                                                                                                                               
                    </Table>                                                                                                                                                                                                                                   
                </Panel>                                                                                                                                                                                                                                       
            </VBox>                                                                                                                                                                                                                                            
        </content>                                                                                                                                                                                                                                             
    </Page>                                                                                                                                                                                                                                                    
</mvc:View>                                                                                                                                                                                                                                                    
                                                                                                                                                                                                                                                               