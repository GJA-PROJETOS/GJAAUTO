sap.ui.define([                                                                                                                                                                                                                                                
    "sap/ui/layout/form/SimpleForm",                                                                                                                                                                                                                           
    "sap/m/Label",                                                                                                                                                                                                                                             
    "sap/m/Input"                                                                                                                                                                                                                                              
], function (SimpleForm, Label, Input) {                                                                                                                                                                                                                       
    "use strict";                                                                                                                                                                                                                                              
                                                                                                                                                                                                                                                               
    return {                                                                                                                                                                                                                                                   
        key: "etapa",                                                                                                                                                                                                                                          
        title: "Criar etapa",                                                                                                                                                                                                                                  
        entityType: "cds_xgjaautoxsd_cockpit.EtapasType",                                                                                                                                                                                                      
        fields: ["auto", "opera", "etapa", "descr", "tpeta", "rotin","after","commit_after", "mapea", "keyfieldname"],                                                                                                                                         
        buildForm: function () {                                                                                                                                                                                                                               
            return new SimpleForm({                                                                                                                                                                                                                            
                layout: "ResponsiveGridLayout",                                                                                                                                                                                                                
                editable: true,                                                                                                                                                                                                                                
                visible: "{= ${create>/selectedType} === 'etapa' }",                                                                                                                                                                                           
                content: [                                                                                                                                                                                                                                     
                    new Label({ text: "{create>/labels/etapa/auto}" }),                                                                                                                                                                                        
                    new Input({                                                                                                                                                                                                                                
                        value: "{create>/etapa/auto}",                                                                                                                                                                                                         
                        maxLength: "{create>/maxLength/etapa/auto}",                                                                                                                                                                                           
                        required: "{create>/required/etapa/auto}",                                                                                                                                                                                             
                        editable: "{create>/editable/etapa/auto}"                                                                                                                                                                                              
                    }),                                                                                                                                                                                                                                        
                    new Label({ text: "{create>/labels/etapa/opera}" }),                                                                                                                                                                                       
                    new Input({                                                                                                                                                                                                                                
                        value: "{create>/etapa/opera}",                                                                                                                                                                                                        
                        maxLength: "{create>/maxLength/etapa/opera}",                                                                                                                                                                                          
                        required: "{create>/required/etapa/opera}",                                                                                                                                                                                            
                        editable: "{create>/editable/etapa/opera}"                                                                                                                                                                                             
                    }),                                                                                                                                                                                                                                        
                    new Label({ text: "{create>/labels/etapa/etapa}" }),                                                                                                                                                                                       
                    new Input({                                                                                                                                                                                                                                
                        value: "{create>/etapa/etapa}",                                                                                                                                                                                                        
                        maxLength: "{create>/maxLength/etapa/etapa}",                                                                                                                                                                                          
                        required: "{create>/required/etapa/etapa}",                                                                                                                                                                                            
                        editable: "{create>/editable/etapa/etapa}"                                                                                                                                                                                             
                    }),                                                                                                                                                                                                                                        
                    new Label({ text: "{create>/labels/etapa/descr}" }),                                                                                                                                                                                       
                    new Input({                                                                                                                                                                                                                                
                        value: "{create>/etapa/descr}",                                                                                                                                                                                                        
                        maxLength: "{create>/maxLength/etapa/descr}",                                                                                                                                                                                          
                        required: "{create>/required/etapa/descr}",                                                                                                                                                                                            
                        editable: "{create>/editable/etapa/descr}"                                                                                                                                                                                             
                    }),                                                                                                                                                                                                                                        
                    new Label({ text: "{create>/labels/etapa/tpeta}" }),                                                                                                                                                                                       
                    new Input({                                                                                                                                                                                                                                
                        value: "{create>/etapa/tpeta}",                                                                                                                                                                                                        
                        maxLength: "{create>/maxLength/etapa/tpeta}",                                                                                                                                                                                          
                        required: "{create>/required/etapa/tpeta}",                                                                                                                                                                                            
                        editable: "{create>/editable/etapa/tpeta}"                                                                                                                                                                                             
                    }),                                                                                                                                                                                                                                        
                    new Label({ text: "{create>/labels/etapa/rotin}" }),                                                                                                                                                                                       
                    new Input({                                                                                                                                                                                                                                
                        value: "{create>/etapa/rotin}",                                                                                                                                                                                                        
                        maxLength: "{create>/maxLength/etapa/rotin}",                                                                                                                                                                                          
                        required: "{create>/required/etapa/rotin}",                                                                                                                                                                                            
                        editable: "{create>/editable/etapa/rotin}"                                                                                                                                                                                             
                    }),                                                                                                                                                                                                                                        
                    new Label({ text: "{create>/labels/etapa/after}" }),                                                                                                                                                                                       
                    new Input({                                                                                                                                                                                                                                
                        value: "{create>/etapa/after}",                                                                                                                                                                                                        
                        maxLength: "{create>/maxLength/etapa/after}",                                                                                                                                                                                          
                        required: "{create>/required/etapa/after}",                                                                                                                                                                                            
                        editable: "{create>/editable/etapa/after}"                                                                                                                                                                                             
                    }),                                                                                                                                                                                                                                        
                    new Label({ text: "{create>/labels/etapa/commit_after}" }),                                                                                                                                                                                
                    new Input({                                                                                                                                                                                                                                
                        value: "{create>/etapa/commit_after}",                                                                                                                                                                                                 
                        maxLength: "{create>/maxLength/etapa/commit_after}",                                                                                                                                                                                   
                        required: "{create>/required/etapa/commit_after}",                                                                                                                                                                                     
                        editable: "{create>/editable/etapa/commit_after}"                                                                                                                                                                                      
                    }),                                                                                                                                                                                                                                        
                    new Label({ text: "{create>/labels/etapa/mapea}" }),                                                                                                                                                                                       
                    new Input({                                                                                                                                                                                                                                
                        value: "{create>/etapa/mapea}",                                                                                                                                                                                                        
                        maxLength: "{create>/maxLength/etapa/mapea}",                                                                                                                                                                                          
                        required: "{create>/required/etapa/mapea}",                                                                                                                                                                                            
                        editable: "{create>/editable/etapa/mapea}"                                                                                                                                                                                             
                    }),                                                                                                                                                                                                                                        
                    new Label({ text: "{create>/labels/etapa/keyfieldname}" }),                                                                                                                                                                                
                    new Input({                                                                                                                                                                                                                                
                        value: "{create>/etapa/keyfieldname}",                                                                                                                                                                                                 
                        maxLength: "{create>/maxLength/etapa/keyfieldname}",                                                                                                                                                                                   
                        required: "{create>/required/etapa/keyfieldname}",                                                                                                                                                                                     
                        editable: "{create>/editable/etapa/keyfieldname}"                                                                                                                                                                                      
                    })                                                                                                                                                                                                                                         
                ]                                                                                                                                                                                                                                              
            });                                                                                                                                                                                                                                                
        },                                                                                                                                                                                                                                                     
        applyPrefill: function (oModel, oPrefill) {                                                                                                                                                                                                            
            if (oPrefill.auto) {                                                                                                                                                                                                                               
                oModel.setProperty("/etapa/auto", oPrefill.auto);                                                                                                                                                                                              
            }                                                                                                                                                                                                                                                  
            if (oPrefill.opera) {                                                                                                                                                                                                                              
                oModel.setProperty("/etapa/opera", oPrefill.opera);                                                                                                                                                                                            
            }                                                                                                                                                                                                                                                  
        },                                                                                                                                                                                                                                                     
        getCreatePath: function (oMainModel, oPayload) {                                                                                                                                                                                                       
            if (!oPayload.auto || !oPayload.opera) {                                                                                                                                                                                                           
                return null;                                                                                                                                                                                                                                   
            }                                                                                                                                                                                                                                                  
            var sOperaKey = oMainModel.createKey("Operacoes", {                                                                                                                                                                                                
                auto: oPayload.auto,                                                                                                                                                                                                                           
                opera: oPayload.opera                                                                                                                                                                                                                          
            });                                                                                                                                                                                                                                                
            return "/" + sOperaKey + "/to_Etapas";                                                                                                                                                                                                             
        },                                                                                                                                                                                                                                                     
        getUpdatePath: function (oMainModel, oData) {                                                                                                                                                                                                          
            return "/" + oMainModel.createKey("Etapas", {                                                                                                                                                                                                      
                auto: oData.auto,                                                                                                                                                                                                                              
                opera: oData.opera,                                                                                                                                                                                                                            
                etapa: oData.etapa                                                                                                                                                                                                                             
            });                                                                                                                                                                                                                                                
        }                                                                                                                                                                                                                                                      
    };                                                                                                                                                                                                                                                         
});                                                                                                                                                                                                                                                            
                                                                                                                                                                                                                                                               