<mvc:View                                                                                                                                                                                                                                                      
    controllerName="br.com.gja.zui5.gjaauto.cockpit.controller.Field"                                                                                                                                                                                          
    xmlns="sap.m"                                                                                                                                                                                                                                              
    xmlns:mvc="sap.ui.core.mvc"                                                                                                                                                                                                                                
    xmlns:f="sap.ui.layout.form"                                                                                                                                                                                                                               
    xmlns:core="sap.ui.core"                                                                                                                                                                                                                                   
    displayBlock="true"                                                                                                                                                                                                                                        
    height="100%"                                                                                                                                                                                                                                              
>                                                                                                                                                                                                                                                              
    <Page                                                                                                                                                                                                                                                      
        id="fieldPage"                                                                                                                                                                                                                                         
        showHeader="true"                                                                                                                                                                                                                                      
        title="{etapa>/selectedField/FieldName}"                                                                                                                                                                                                               
        showNavButton="false"                                                                                                                                                                                                                                  
    >                                                                                                                                                                                                                                                          
        <content>                                                                                                                                                                                                                                              
            <f:SimpleForm                                                                                                                                                                                                                                      
                id="fieldForm"                                                                                                                                                                                                                                 
                editable="false"                                                                                                                                                                                                                               
                layout="ResponsiveGridLayout"                                                                                                                                                                                                                  
                labelSpanXL="4"                                                                                                                                                                                                                                
                labelSpanL="4"                                                                                                                                                                                                                                 
                labelSpanM="4"                                                                                                                                                                                                                                 
                labelSpanS="12"                                                                                                                                                                                                                                
                emptySpanXL="0"                                                                                                                                                                                                                                
                emptySpanL="0"                                                                                                                                                                                                                                 
                emptySpanM="0"                                                                                                                                                                                                                                 
                emptySpanS="0"                                                                                                                                                                                                                                 
                columnsXL="1"                                                                                                                                                                                                                                  
                columnsL="1"                                                                                                                                                                                                                                   
                columnsM="1"                                                                                                                                                                                                                                   
                singleContainerFullSize="false"                                                                                                                                                                                                                
                class="sapUiSmallMargin"                                                                                                                                                                                                                       
            >                                                                                                                                                                                                                                                  
                <f:content>                                                                                                                                                                                                                                    
                    <core:Title id="_IDGenTitle2" text="Informações do Campo"/>                                                                                                                                                                                
&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;                                                                                                                                       
                    <Label id="_IDGenLabel" text="Nome do Campo"/>                                                                                                                                                                                             
                    <Text id="_IDGenText" text="{etapa>/selectedField/FieldName}"/>                                                                                                                                                                            
&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;                                                                                                                                       
                    <Label id="_IDGenLabel1" text="Descrição"/>                                                                                                                                                                                                
                    <Text id="_IDGenText1" text="{etapa>/selectedField/Desc}"/>                                                                                                                                                                                
&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;                                                                                                                                       
                    <Label id="_IDGenLabel2" text="Tipo de Dado"/>                                                                                                                                                                                             
                    <Text id="_IDGenText2" text="{etapa>/selectedField/DataType}"/>                                                                                                                                                                            
&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;                                                                                                                                       
                    <Label id="_IDGenLabel3" text="Comprimento"/>                                                                                                                                                                                              
                    <Text id="_IDGenText3" text="{etapa>/selectedField/Leng}"/>                                                                                                                                                                                
&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;                                                                                                                                       
                    <Label id="_IDGenLabel4" text="Decimais"/>                                                                                                                                                                                                 
                    <Text id="_IDGenText4" text="{etapa>/selectedField/Decimals}"/>                                                                                                                                                                            
&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;                                                                                                                                       
                    <Label id="_IDGenLabel5" text="Valor Fixo"/>                                                                                                                                                                                               
                    <Text id="_IDGenText5" text="{= ${etapa>/selectedField/FixValue} === 'X' ? 'Sim' : 'Não'}"/>                                                                                                                                               
                </f:content>                                                                                                                                                                                                                                   
            </f:SimpleForm>                                                                                                                                                                                                                                    
                        <f:SimpleForm                                                                                                                                                                                                                          
                id="fieldFormMapeamento"                                                                                                                                                                                                                       
                editable="true"                                                                                                                                                                                                                                
                layout="ResponsiveGridLayout"                                                                                                                                                                                                                  
                labelSpanXL="4"                                                                                                                                                                                                                                
                labelSpanL="4"                                                                                                                                                                                                                                 
                labelSpanM="4"                                                                                                                                                                                                                                 
                labelSpanS="12"                                                                                                                                                                                                                                
                emptySpanXL="0"                                                                                                                                                                                                                                
                emptySpanL="0"                                                                                                                                                                                                                                 
                emptySpanM="0"                                                                                                                                                                                                                                 
                emptySpanS="0"                                                                                                                                                                                                                                 
                columnsXL="1"                                                                                                                                                                                                                                  
                columnsL="1"                                                                                                                                                                                                                                   
                columnsM="1"                                                                                                                                                                                                                                   
                singleContainerFullSize="false"                                                                                                                                                                                                                
                class="sapUiSmallMargin"                                                                                                                                                                                                                       
            >                                                                                                                                                                                                                                                  
                <f:content>                                                                                                                                                                                                                                    
                    <core:Title id="_IDGenTitleMapeamento" text="Mapeamento"/>                                                                                                                                                                                 
&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;                                                                                                                                       
                    <Label id="labelMapeamentoTabelaOrigem" text="Tabela Origem"/>                                                                                                                                                                             
                    <Select                                                                                                                                                                                                                                    
                        id="selectTabelaOrigem"                                                                                                                                                                                                                
                        selectedKey="{etapa>/fieldMapping/tabname_from}"                                                                                                                                                                                       
                        items="{etapa>/dadosOrigem}"                                                                                                                                                                                                           
                        change=".onTabelaOrigemChange"                                                                                                                                                                                                         
                        forceSelection="false"                                                                                                                                                                                                                 
                    >                                                                                                                                                                                                                                          
                        <core:Item id="itemTabelaOrigem" key="{etapa>Name}" text="{etapa>Name}"/>                                                                                                                                                              
                    </Select>                                                                                                                                                                                                                                  
&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;                                                                                                                                       
                    <Label id="labelMapeamentoOrigem" text="Campo Origem"/>                                                                                                                                                                                    
                    <Select                                                                                                                                                                                                                                    
                        id="selectCampoOrigem"                                                                                                                                                                                                                 
                        selectedKey="{etapa>/fieldMapping/param_from}"                                                                                                                                                                                         
                        items="{etapa>/camposOrigem}"                                                                                                                                                                                                          
                        enabled="{= !!${etapa>/fieldMapping/tabname_from} }"                                                                                                                                                                                   
                        forceSelection="false"                                                                                                                                                                                                                 
                    >                                                                                                                                                                                                                                          
                        <core:Item id="itemCampoOrigem" key="{etapa>FieldName}" text="{= ${etapa>FieldName} + ' - ' + ${etapa>Desc} }"/>                                                                                                                       
                    </Select>                                                                                                                                                                                                                                  
&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;                                                                                                                                       
                    <Label id="labelMapeamentoValorFixo" text="Valor Fixo"/>                                                                                                                                                                                   
                    <Input                                                                                                                                                                                                                                     
                        id="inputValorFixo"                                                                                                                                                                                                                    
                        value="{etapa>/fieldMapping/paramval}"                                                                                                                                                                                                 
                        placeholder="Digite o valor fixo..."                                                                                                                                                                                                   
                    />                                                                                                                                                                                                                                         
&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;                                                                                                                                       
                    <Label id="labelMapeamentoOpcional" text="Opcional"/>                                                                                                                                                                                      
                    <CheckBox                                                                                                                                                                                                                                  
                        id="checkboxOpcional"                                                                                                                                                                                                                  
                        selected="{etapa>/fieldMapping/paramopt}"                                                                                                                                                                                              
                    />                                                                                                                                                                                                                                         
                </f:content>                                                                                                                                                                                                                                   
                <f:toolbar>                                                                                                                                                                                                                                    
                    <OverflowToolbar id="mappingToolbar">                                                                                                                                                                                                      
                        <ToolbarSpacer id="mappingToolbarSpacer"/>                                                                                                                                                                                             
                        <Button                                                                                                                                                                                                                                
                            id="btnDeleteMapping"                                                                                                                                                                                                              
                            text="Deletar"                                                                                                                                                                                                                     
                            type="Reject"                                                                                                                                                                                                                      
                            icon="sap-icon://delete"                                                                                                                                                                                                           
                            press=".onDeleteMapping"                                                                                                                                                                                                           
                            visible="{= !${etapa>/isNewMapping} }"                                                                                                                                                                                             
                        />                                                                                                                                                                                                                                     
                        <Button                                                                                                                                                                                                                                
                            id="btnSaveMapping"                                                                                                                                                                                                                
                            text="Salvar"                                                                                                                                                                                                                      
                            type="Emphasized"                                                                                                                                                                                                                  
                            icon="sap-icon://save"                                                                                                                                                                                                             
                            press=".onSaveMapping"                                                                                                                                                                                                             
                        />                                                                                                                                                                                                                                     
                    </OverflowToolbar>                                                                                                                                                                                                                         
                </f:toolbar>                                                                                                                                                                                                                                   
            </f:SimpleForm>                                                                                                                                                                                                                                    
&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;                                                                                                                                                                                       
            <!-- Seção quando não há mapeamento -->                                                                                                                                                                                                            
            <MessageStrip                                                                                                                                                                                                                                      
                id="noMappingStrip"                                                                                                                                                                                                                            
                text="Este campo não possui mapeamento configurado. Preencha os campos acima para criar um mapeamento."                                                                                                                                        
                type="Information"                                                                                                                                                                                                                             
                showIcon="true"                                                                                                                                                                                                                                
                visible="{= !${etapa>/fieldMapping/TabnameFrom} &amp;&amp; !${etapa>/fieldMapping/Paramval} }"                                                                                                                                                 
                class="sapUiSmallMargin"                                                                                                                                                                                                                       
            />                                                                                                                                                                                                                                                 
&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;                                                                                                                                                                                       
            <!-- Valores Fixos (se houver) -->                                                                                                                                                                                                                 
            <Panel                                                                                                                                                                                                                                             
                id="fixValuesPanel"                                                                                                                                                                                                                            
                headerText="Valores Permitidos"                                                                                                                                                                                                                
                expandable="true"                                                                                                                                                                                                                              
                expanded="true"                                                                                                                                                                                                                                
                visible="{= ${etapa>/selectedFieldFixValues}.length > 0 }"                                                                                                                                                                                     
                class="sapUiSmallMargin"                                                                                                                                                                                                                       
            >                                                                                                                                                                                                                                                  
                <Table                                                                                                                                                                                                                                         
                    id="fixValuesTable"                                                                                                                                                                                                                        
                    items="{etapa>/selectedFieldFixValues}"                                                                                                                                                                                                    
                    growing="true"                                                                                                                                                                                                                             
                    growingThreshold="10"                                                                                                                                                                                                                      
                >                                                                                                                                                                                                                                              
                    <columns>                                                                                                                                                                                                                                  
                        <Column id="_IDGenColumn">                                                                                                                                                                                                             
                            <Text id="_IDGenText6" text="Valor"/>                                                                                                                                                                                              
                        </Column>                                                                                                                                                                                                                              
                        <Column id="_IDGenColumn1">                                                                                                                                                                                                            
                            <Text id="_IDGenText7" text="Descrição"/>                                                                                                                                                                                          
                        </Column>                                                                                                                                                                                                                              
                    </columns>                                                                                                                                                                                                                                 
                    <items>                                                                                                                                                                                                                                    
                        <ColumnListItem id="_IDGenColumnListItem">                                                                                                                                                                                             
                            <cells>                                                                                                                                                                                                                            
                                <Text id="_IDGenText8" text="{etapa>Value}"/>                                                                                                                                                                                  
                                <Text id="_IDGenText9" text="{etapa>Text}"/>                                                                                                                                                                                   
                            </cells>                                                                                                                                                                                                                           
                        </ColumnListItem>                                                                                                                                                                                                                      
                    </items>                                                                                                                                                                                                                                   
                </Table>                                                                                                                                                                                                                                       
            </Panel>                                                                                                                                                                                                                                           
        </content>                                                                                                                                                                                                                                             
    </Page>                                                                                                                                                                                                                                                    
</mvc:View>                                                                                                                                                                                                                                                    
                                                                                                                                                                                                                                                               