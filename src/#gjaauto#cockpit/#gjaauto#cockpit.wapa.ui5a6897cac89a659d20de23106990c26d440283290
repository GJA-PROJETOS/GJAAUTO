sap.ui.define([                                                                                                                                                                                                                                                
    "sap/ui/core/mvc/Controller"                                                                                                                                                                                                                               
], function (Controller) {                                                                                                                                                                                                                                     
    "use strict";                                                                                                                                                                                                                                              
                                                                                                                                                                                                                                                               
    return Controller.extend("br.com.gja.zui5.gjaauto.cockpit.controller.HomeEtapa", {                                                                                                                                                                         
        /**                                                                                                                                                                                                                                                    
         * Inicializa o controlador.                                                                                                                                                                                                                           
         * @public                                                                                                                                                                                                                                             
         */                                                                                                                                                                                                                                                    
        onInit: function () {                                                                                                                                                                                                                                  
            // O modelo "etapa" é compartilhado com o controlador Etapa.controller.js                                                                                                                                                                          
        },                                                                                                                                                                                                                                                     
                                                                                                                                                                                                                                                               
        /**                                                                                                                                                                                                                                                    
         * Abre o popup de edição da etapa.                                                                                                                                                                                                                    
         * @public                                                                                                                                                                                                                                             
         */                                                                                                                                                                                                                                                    
        onEditEtapa: function () {                                                                                                                                                                                                                             
            var oEtapaModel = this.getView().getModel("etapa");                                                                                                                                                                                                
            var oData = oEtapaModel ? oEtapaModel.getProperty("/etapaData") : {};                                                                                                                                                                              
                                                                                                                                                                                                                                                               
            if (!oData || !oData.auto || !oData.opera || !oData.etapa) {                                                                                                                                                                                       
                return;                                                                                                                                                                                                                                        
            }                                                                                                                                                                                                                                                  
                                                                                                                                                                                                                                                               
            this.getOwnerComponent().getCreateEditDialog().openEdit("etapa", oData, function () {                                                                                                                                                              
                var oMainModel = this.getOwnerComponent().getModel();                                                                                                                                                                                          
                if (oMainModel) {                                                                                                                                                                                                                              
                    oMainModel.refresh(true);                                                                                                                                                                                                                  
                }                                                                                                                                                                                                                                              
            }.bind(this));                                                                                                                                                                                                                                     
        }                                                                                                                                                                                                                                                      
    });                                                                                                                                                                                                                                                        
});                                                                                                                                                                                                                                                            
                                                                                                                                                                                                                                                               