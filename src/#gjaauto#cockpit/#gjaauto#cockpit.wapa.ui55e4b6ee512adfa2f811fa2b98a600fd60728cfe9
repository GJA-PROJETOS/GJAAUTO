sap.ui.define([                                                                                                                                                                                                                                                
    "sap/ui/core/mvc/Controller",                                                                                                                                                                                                                              
    "sap/ui/core/UIComponent",                                                                                                                                                                                                                                 
    "sap/ui/model/Filter",                                                                                                                                                                                                                                     
    "sap/ui/model/FilterOperator",                                                                                                                                                                                                                             
    "sap/m/MessageToast",                                                                                                                                                                                                                                      
    "sap/m/MessageBox"                                                                                                                                                                                                                                         
], function(Controller, UIComponent, Filter, FilterOperator, MessageToast, MessageBox) {                                                                                                                                                                       
    "use strict";                                                                                                                                                                                                                                              
                                                                                                                                                                                                                                                               
    return Controller.extend("br.com.gja.zui5.gjaauto.cockpit.controller.HomeField", {                                                                                                                                                                         
        /**                                                                                                                                                                                                                                                    
         * Chamado quando o controller é instanciado                                                                                                                                                                                                           
         */                                                                                                                                                                                                                                                    
        onInit: function() {                                                                                                                                                                                                                                   
            this._oRouter = UIComponent.getRouterFor(this);                                                                                                                                                                                                    
&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;                                                                                                                                                                                       
            // Escuta as rotas de workarea para carregar os dados                                                                                                                                                                                              
            this._oRouter.getRoute("RouteEtapaImportWorkarea").attachPatternMatched(this._onWorkareaRouteMatched, this);                                                                                                                                       
            this._oRouter.getRoute("RouteEtapaExportWorkarea").attachPatternMatched(this._onWorkareaRouteMatched, this);                                                                                                                                       
            this._oRouter.getRoute("RouteEtapaTables").attachPatternMatched(this._onTablesRouteMatched, this);                                                                                                                                                 
        },                                                                                                                                                                                                                                                     
                                                                                                                                                                                                                                                               
        /**                                                                                                                                                                                                                                                    
         * Retorna o router                                                                                                                                                                                                                                    
         * @returns {sap.m.routing.Router} Router                                                                                                                                                                                                              
         */                                                                                                                                                                                                                                                    
        getRouter: function() {                                                                                                                                                                                                                                
            return this._oRouter;                                                                                                                                                                                                                              
        },                                                                                                                                                                                                                                                     
                                                                                                                                                                                                                                                               
        /**                                                                                                                                                                                                                                                    
         * Retorna o modelo etapa                                                                                                                                                                                                                              
         * @returns {sap.ui.model.json.JSONModel} Modelo etapa                                                                                                                                                                                                 
         * @private                                                                                                                                                                                                                                            
         */                                                                                                                                                                                                                                                    
        _getEtapaModel: function() {                                                                                                                                                                                                                           
            return this.getOwnerComponent().getModel("etapa");                                                                                                                                                                                                 
        },                                                                                                                                                                                                                                                     
                                                                                                                                                                                                                                                               
        /**                                                                                                                                                                                                                                                    
         * Chamado quando a rota de workarea (import/export) é correspondida                                                                                                                                                                                   
         * @param {sap.ui.base.Event} oEvent Evento de correspondência da rota                                                                                                                                                                                 
         * @private                                                                                                                                                                                                                                            
         */                                                                                                                                                                                                                                                    
        _onWorkareaRouteMatched: function(oEvent) {                                                                                                                                                                                                            
            var oArgs = oEvent.getParameter("arguments");                                                                                                                                                                                                      
            this._sCurrentWorkarea = oArgs.keyWorkarea;                                                                                                                                                                                                        
            this._sCurrentParamNatu = oEvent.getParameter("name").includes("Import") ? "import" : "export";                                                                                                                                                    
&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;                                                                                                                                                                                       
            this._loadDadosOrigem();                                                                                                                                                                                                                           
            this._loadAtribuicao();                                                                                                                                                                                                                            
        },                                                                                                                                                                                                                                                     
                                                                                                                                                                                                                                                               
        /**                                                                                                                                                                                                                                                    
         * Chamado quando a rota de tables é correspondida                                                                                                                                                                                                     
         * @param {sap.ui.base.Event} oEvent Evento de correspondência da rota                                                                                                                                                                                 
         * @private                                                                                                                                                                                                                                            
         */                                                                                                                                                                                                                                                    
        _onTablesRouteMatched: function(oEvent) {                                                                                                                                                                                                              
            var oArgs = oEvent.getParameter("arguments");                                                                                                                                                                                                      
            this._sCurrentWorkarea = oArgs.keyTable;                                                                                                                                                                                                           
            this._sCurrentParamNatu = "tables";                                                                                                                                                                                                                
&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;                                                                                                                                                                                       
            this._loadDadosOrigem();                                                                                                                                                                                                                           
            this._loadAtribuicao();                                                                                                                                                                                                                            
        },                                                                                                                                                                                                                                                     
                                                                                                                                                                                                                                                               
        /**                                                                                                                                                                                                                                                    
         * Carrega os dados de origem disponíveis para mapeamento                                                                                                                                                                                              
         * @private                                                                                                                                                                                                                                            
         */                                                                                                                                                                                                                                                    
        _loadDadosOrigem: function() {                                                                                                                                                                                                                         
            var oEtapaModel = this._getEtapaModel();                                                                                                                                                                                                           
            var sCodigoAuto = oEtapaModel.getProperty("/codigoAuto");                                                                                                                                                                                          
            var sCodigoOpera = oEtapaModel.getProperty("/codigoOpera");                                                                                                                                                                                        
            var that = this;                                                                                                                                                                                                                                   
                                                                                                                                                                                                                                                               
            // Verifica se já carregou os dados                                                                                                                                                                                                                
            var aDadosOrigem = oEtapaModel.getProperty("/dadosOrigem");                                                                                                                                                                                        
            if (aDadosOrigem && aDadosOrigem.length > 0) {                                                                                                                                                                                                     
                return;                                                                                                                                                                                                                                        
            }                                                                                                                                                                                                                                                  
                                                                                                                                                                                                                                                               
            var oModel = this.getOwnerComponent().getModel();                                                                                                                                                                                                  
                                                                                                                                                                                                                                                               
            oModel.read("/Dados", {                                                                                                                                                                                                                            
                filters: [                                                                                                                                                                                                                                     
                    new Filter("Auto", FilterOperator.EQ, sCodigoAuto),                                                                                                                                                                                        
                    new Filter("Opera", FilterOperator.EQ, sCodigoOpera)                                                                                                                                                                                       
                ],                                                                                                                                                                                                                                             
                success: function(oData) {                                                                                                                                                                                                                     
                    oEtapaModel.setProperty("/dadosOrigem", oData.results || []);                                                                                                                                                                              
                },                                                                                                                                                                                                                                             
                error: function(oError) {                                                                                                                                                                                                                      
                    console.warn("Erro ao carregar dados de origem:", oError);                                                                                                                                                                                 
                    oEtapaModel.setProperty("/dadosOrigem", []);                                                                                                                                                                                               
                }                                                                                                                                                                                                                                              
            });                                                                                                                                                                                                                                                
        },                                                                                                                                                                                                                                                     
                                                                                                                                                                                                                                                               
        /**                                                                                                                                                                                                                                                    
         * Carrega a atribuição do parâmetro atual                                                                                                                                                                                                             
         * @private                                                                                                                                                                                                                                            
         */                                                                                                                                                                                                                                                    
        _loadAtribuicao: function() {                                                                                                                                                                                                                          
            var oEtapaModel = this._getEtapaModel();                                                                                                                                                                                                           
            var oParamDoku = oEtapaModel.getProperty("/parameterDoku");                                                                                                                                                                                        
            var oAtribuicoes = oEtapaModel.getProperty("/etapaData/to_Atribuicoes");                                                                                                                                                                           
                                                                                                                                                                                                                                                               
            if (!oParamDoku || !oParamDoku.Param) {                                                                                                                                                                                                            
                return;                                                                                                                                                                                                                                        
            }                                                                                                                                                                                                                                                  
                                                                                                                                                                                                                                                               
            var sParam = oParamDoku.Param;                                                                                                                                                                                                                     
            var oAtribuicao = null;                                                                                                                                                                                                                            
            this._bIsNewAtribuicao = true;                                                                                                                                                                                                                     
                                                                                                                                                                                                                                                               
            // Busca se já existe atribuição para este parâmetro                                                                                                                                                                                               
            if (oAtribuicoes && oAtribuicoes.results) {                                                                                                                                                                                                        
                oAtribuicao = oAtribuicoes.results.find(function(oAtrib) {                                                                                                                                                                                     
                    return oAtrib.Param === sParam;                                                                                                                                                                                                            
                });                                                                                                                                                                                                                                            
                                                                                                                                                                                                                                                               
                if (oAtribuicao) {                                                                                                                                                                                                                             
                    this._bIsNewAtribuicao = false;                                                                                                                                                                                                            
                }                                                                                                                                                                                                                                              
            }                                                                                                                                                                                                                                                  
                                                                                                                                                                                                                                                               
            // Se não encontrou, cria objeto vazio                                                                                                                                                                                                             
            if (!oAtribuicao) {                                                                                                                                                                                                                                
                oAtribuicao = {                                                                                                                                                                                                                                
                    ParamFrom: ""                                                                                                                                                                                                                              
                };                                                                                                                                                                                                                                             
            }                                                                                                                                                                                                                                                  
                                                                                                                                                                                                                                                               
            oEtapaModel.setProperty("/paramAtribuicao", oAtribuicao);                                                                                                                                                                                          
        },                                                                                                                                                                                                                                                     
                                                                                                                                                                                                                                                               
        /**                                                                                                                                                                                                                                                    
         * Salva a atribuição do parâmetro                                                                                                                                                                                                                     
         * @public                                                                                                                                                                                                                                             
         */                                                                                                                                                                                                                                                    
        onSaveAtribuicao: function() {                                                                                                                                                                                                                         
            var oEtapaModel = this._getEtapaModel();                                                                                                                                                                                                           
            var oParamAtribuicao = oEtapaModel.getProperty("/paramAtribuicao");                                                                                                                                                                                
            var oParamDoku = oEtapaModel.getProperty("/parameterDoku");                                                                                                                                                                                        
            var that = this;                                                                                                                                                                                                                                   
                                                                                                                                                                                                                                                               
            var sCodigoAuto = oEtapaModel.getProperty("/codigoAuto");                                                                                                                                                                                          
            var sCodigoOpera = oEtapaModel.getProperty("/codigoOpera");                                                                                                                                                                                        
            var sCodigoEtapa = oEtapaModel.getProperty("/codigoEtapa");                                                                                                                                                                                        
                                                                                                                                                                                                                                                               
            // Validação                                                                                                                                                                                                                                       
            if (!oParamAtribuicao.ParamFrom) {                                                                                                                                                                                                                 
                MessageBox.warning("Selecione uma Tabela Origem para atribuição.");                                                                                                                                                                            
                return;                                                                                                                                                                                                                                        
            }                                                                                                                                                                                                                                                  
                                                                                                                                                                                                                                                               
            // Determina Reftype: S para import/export, T para tables                                                                                                                                                                                          
            var sReftype = this._sCurrentParamNatu === "tables" ? "T" : "S";                                                                                                                                                                                   
                                                                                                                                                                                                                                                               
            var oPayload = {                                                                                                                                                                                                                                   
                Auto: sCodigoAuto,                                                                                                                                                                                                                             
                Opera: sCodigoOpera,                                                                                                                                                                                                                           
                Etapa: sCodigoEtapa,                                                                                                                                                                                                                           
                Reftype: sReftype,                                                                                                                                                                                                                             
                Param: oParamDoku.Param,                                                                                                                                                                                                                       
                ParamFrom: oParamAtribuicao.ParamFrom                                                                                                                                                                                                          
            };                                                                                                                                                                                                                                                 
                                                                                                                                                                                                                                                               
            var oModel = this.getOwnerComponent().getModel();                                                                                                                                                                                                  
            oEtapaModel.setProperty("/busy", true);                                                                                                                                                                                                            
                                                                                                                                                                                                                                                               
            if (this._bIsNewAtribuicao) {                                                                                                                                                                                                                      
                // Criar nova atribuição                                                                                                                                                                                                                       
                var sPath = "/Etapas(auto='" + sCodigoAuto + "',opera='" + sCodigoOpera + "',etapa='" + sCodigoEtapa + "')/to_Atribuicoes";                                                                                                                    
&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;                                                                                                                                                               
                oModel.create(sPath, oPayload, {                                                                                                                                                                                                               
                    success: function() {                                                                                                                                                                                                                      
                        oEtapaModel.setProperty("/busy", false);                                                                                                                                                                                               
                        MessageToast.show("Atribuição salva com sucesso!");                                                                                                                                                                                    
                        that._bIsNewAtribuicao = false;                                                                                                                                                                                                        
                        that._refreshEtapaData();                                                                                                                                                                                                              
                    },                                                                                                                                                                                                                                         
                    error: function(oError) {                                                                                                                                                                                                                  
                        oEtapaModel.setProperty("/busy", false);                                                                                                                                                                                               
                        that._handleODataError(oError, "salvar atribuição");                                                                                                                                                                                   
                    }                                                                                                                                                                                                                                          
                });                                                                                                                                                                                                                                            
            } else {                                                                                                                                                                                                                                           
                // Atualizar atribuição existente                                                                                                                                                                                                              
                var sUpdatePath = "/Atribuicoes(Auto='" + sCodigoAuto + "',Opera='" + sCodigoOpera + "',Etapa='" + sCodigoEtapa + "',Reftype='" + sReftype + "',Param='" + oParamDoku.Param + "')";                                                            
&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;                                                                                                                                                               
                oModel.update(sUpdatePath, oPayload, {                                                                                                                                                                                                         
                    success: function() {                                                                                                                                                                                                                      
                        oEtapaModel.setProperty("/busy", false);                                                                                                                                                                                               
                        MessageToast.show("Atribuição atualizada com sucesso!");                                                                                                                                                                               
                        that._refreshEtapaData();                                                                                                                                                                                                              
                    },                                                                                                                                                                                                                                         
                    error: function(oError) {                                                                                                                                                                                                                  
                        oEtapaModel.setProperty("/busy", false);                                                                                                                                                                                               
                        that._handleODataError(oError, "atualizar atribuição");                                                                                                                                                                                
                    }                                                                                                                                                                                                                                          
                });                                                                                                                                                                                                                                            
            }                                                                                                                                                                                                                                                  
        },                                                                                                                                                                                                                                                     
                                                                                                                                                                                                                                                               
        /**                                                                                                                                                                                                                                                    
         * Deleta a atribuição do parâmetro                                                                                                                                                                                                                    
         * @public                                                                                                                                                                                                                                             
         */                                                                                                                                                                                                                                                    
        onDeleteAtribuicao: function() {                                                                                                                                                                                                                       
            var that = this;                                                                                                                                                                                                                                   
&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;                                                                                                                                                                                       
            MessageBox.confirm("Deseja realmente deletar esta atribuição?", {                                                                                                                                                                                  
                title: "Confirmar Exclusão",                                                                                                                                                                                                                   
                onClose: function(oAction) {                                                                                                                                                                                                                   
                    if (oAction === MessageBox.Action.OK) {                                                                                                                                                                                                    
                        that._deleteAtribuicao();                                                                                                                                                                                                              
                    }                                                                                                                                                                                                                                          
                }                                                                                                                                                                                                                                              
            });                                                                                                                                                                                                                                                
        },                                                                                                                                                                                                                                                     
                                                                                                                                                                                                                                                               
        /**                                                                                                                                                                                                                                                    
         * Executa a deleção da atribuição                                                                                                                                                                                                                     
         * @private                                                                                                                                                                                                                                            
         */                                                                                                                                                                                                                                                    
        _deleteAtribuicao: function() {                                                                                                                                                                                                                        
            var oEtapaModel = this._getEtapaModel();                                                                                                                                                                                                           
            var oParamDoku = oEtapaModel.getProperty("/parameterDoku");                                                                                                                                                                                        
            var that = this;                                                                                                                                                                                                                                   
                                                                                                                                                                                                                                                               
            var sCodigoAuto = oEtapaModel.getProperty("/codigoAuto");                                                                                                                                                                                          
            var sCodigoOpera = oEtapaModel.getProperty("/codigoOpera");                                                                                                                                                                                        
            var sCodigoEtapa = oEtapaModel.getProperty("/codigoEtapa");                                                                                                                                                                                        
            var sReftype = this._sCurrentParamNatu === "tables" ? "T" : "S";                                                                                                                                                                                   
                                                                                                                                                                                                                                                               
            var oModel = this.getOwnerComponent().getModel();                                                                                                                                                                                                  
            oEtapaModel.setProperty("/busy", true);                                                                                                                                                                                                            
                                                                                                                                                                                                                                                               
            var sPath = "/Atribuicoes(Auto='" + sCodigoAuto + "',Opera='" + sCodigoOpera + "',Etapa='" + sCodigoEtapa + "',Reftype='" + sReftype + "',Param='" + oParamDoku.Param + "')";                                                                      
                                                                                                                                                                                                                                                               
            oModel.remove(sPath, {                                                                                                                                                                                                                             
                success: function() {                                                                                                                                                                                                                          
                    oEtapaModel.setProperty("/busy", false);                                                                                                                                                                                                   
                    oEtapaModel.setProperty("/paramAtribuicao", { ParamFrom: "" });                                                                                                                                                                            
                    that._bIsNewAtribuicao = true;                                                                                                                                                                                                             
                    MessageToast.show("Atribuição deletada com sucesso!");                                                                                                                                                                                     
                    that._refreshEtapaData();                                                                                                                                                                                                                  
                },                                                                                                                                                                                                                                             
                error: function(oError) {                                                                                                                                                                                                                      
                    oEtapaModel.setProperty("/busy", false);                                                                                                                                                                                                   
                    that._handleODataError(oError, "deletar atribuição");                                                                                                                                                                                      
                }                                                                                                                                                                                                                                              
            });                                                                                                                                                                                                                                                
        },                                                                                                                                                                                                                                                     
                                                                                                                                                                                                                                                               
        /**                                                                                                                                                                                                                                                    
         * Atualiza os dados da etapa após save/delete                                                                                                                                                                                                         
         * @private                                                                                                                                                                                                                                            
         */                                                                                                                                                                                                                                                    
        _refreshEtapaData: function() {                                                                                                                                                                                                                        
            var oEtapaModel = this._getEtapaModel();                                                                                                                                                                                                           
            var sCodigoAuto = oEtapaModel.getProperty("/codigoAuto");                                                                                                                                                                                          
            var sCodigoOpera = oEtapaModel.getProperty("/codigoOpera");                                                                                                                                                                                        
            var sCodigoEtapa = oEtapaModel.getProperty("/codigoEtapa");                                                                                                                                                                                        
            var that = this;                                                                                                                                                                                                                                   
                                                                                                                                                                                                                                                               
            var oModel = this.getOwnerComponent().getModel();                                                                                                                                                                                                  
            var sPath = "/Etapas(auto='" + sCodigoAuto + "',opera='" + sCodigoOpera + "',etapa='" + sCodigoEtapa + "')";                                                                                                                                       
                                                                                                                                                                                                                                                               
            oModel.read(sPath, {                                                                                                                                                                                                                               
                urlParameters: {                                                                                                                                                                                                                               
                    "$expand": "to_Mapeamentos,to_Atribuicoes,to_LoopTables"                                                                                                                                                                                   
                },                                                                                                                                                                                                                                             
                success: function(oData) {                                                                                                                                                                                                                     
                    oEtapaModel.setProperty("/etapaData", oData);                                                                                                                                                                                              
                },                                                                                                                                                                                                                                             
                error: function(oError) {                                                                                                                                                                                                                      
                    console.warn("Erro ao atualizar dados da etapa:", oError);                                                                                                                                                                                 
                }                                                                                                                                                                                                                                              
            });                                                                                                                                                                                                                                                
        },                                                                                                                                                                                                                                                     
                                                                                                                                                                                                                                                               
        /**                                                                                                                                                                                                                                                    
         * Trata erros do OData                                                                                                                                                                                                                                
         * @param {object} oError Objeto de erro                                                                                                                                                                                                               
         * @param {string} sAction Ação que gerou o erro                                                                                                                                                                                                       
         * @private                                                                                                                                                                                                                                            
         */                                                                                                                                                                                                                                                    
        _handleODataError: function(oError, sAction) {                                                                                                                                                                                                         
            var sMessage = "Erro ao " + sAction;                                                                                                                                                                                                               
&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;                                                                                                                                                                                       
            try {                                                                                                                                                                                                                                              
                var oResponse = JSON.parse(oError.responseText);                                                                                                                                                                                               
                if (oResponse.error && oResponse.error.message) {                                                                                                                                                                                              
                    sMessage = oResponse.error.message.value;                                                                                                                                                                                                  
                }                                                                                                                                                                                                                                              
            } catch (e) {                                                                                                                                                                                                                                      
                // Mantém a mensagem padrão                                                                                                                                                                                                                    
            }                                                                                                                                                                                                                                                  
&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;                                                                                                                                                                                       
            MessageBox.error(sMessage);                                                                                                                                                                                                                        
        },                                                                                                                                                                                                                                                     
                                                                                                                                                                                                                                                               
        /**                                                                                                                                                                                                                                                    
         * Busca de campos na tabela                                                                                                                                                                                                                           
         * @param {sap.ui.base.Event} oEvent Evento de busca                                                                                                                                                                                                   
         */                                                                                                                                                                                                                                                    
        onSearchField: function(oEvent) {                                                                                                                                                                                                                      
            var sQuery = oEvent.getParameter("query");                                                                                                                                                                                                         
            var oTable = this.byId("fieldsTable");                                                                                                                                                                                                             
            var oBinding = oTable.getBinding("items");                                                                                                                                                                                                         
&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;                                                                                                                                                                                       
            if (sQuery) {                                                                                                                                                                                                                                      
                var oFilter = new sap.ui.model.Filter({                                                                                                                                                                                                        
                    filters: [                                                                                                                                                                                                                                 
                        new sap.ui.model.Filter("FieldName", sap.ui.model.FilterOperator.Contains, sQuery),                                                                                                                                                    
                        new sap.ui.model.Filter("Desc", sap.ui.model.FilterOperator.Contains, sQuery)                                                                                                                                                          
                    ],                                                                                                                                                                                                                                         
                    and: false                                                                                                                                                                                                                                 
                });                                                                                                                                                                                                                                            
                oBinding.filter([oFilter]);                                                                                                                                                                                                                    
            } else {                                                                                                                                                                                                                                           
                oBinding.filter([]);                                                                                                                                                                                                                           
            }                                                                                                                                                                                                                                                  
        },                                                                                                                                                                                                                                                     
                                                                                                                                                                                                                                                               
        /**                                                                                                                                                                                                                                                    
         * Evento de seleção de campo na tabela                                                                                                                                                                                                                
         * @param {sap.ui.base.Event} oEvent Evento de seleção                                                                                                                                                                                                 
         */                                                                                                                                                                                                                                                    
        onFieldSelect: function(oEvent) {                                                                                                                                                                                                                      
            var oSelectedItem = oEvent.getParameter("listItem");                                                                                                                                                                                               
            this._navigateToField(oSelectedItem);                                                                                                                                                                                                              
        },                                                                                                                                                                                                                                                     
                                                                                                                                                                                                                                                               
        /**                                                                                                                                                                                                                                                    
         * Evento de press no campo                                                                                                                                                                                                                            
         * @param {sap.ui.base.Event} oEvent Evento de press                                                                                                                                                                                                   
         */                                                                                                                                                                                                                                                    
        onFieldPress: function(oEvent) {                                                                                                                                                                                                                       
            var oItem = oEvent.getSource();                                                                                                                                                                                                                    
            this._navigateToField(oItem);                                                                                                                                                                                                                      
        },                                                                                                                                                                                                                                                     
                                                                                                                                                                                                                                                               
        /**                                                                                                                                                                                                                                                    
         * Navega para o detalhe do campo selecionado                                                                                                                                                                                                          
         * @param {sap.m.ColumnListItem} oItem Item selecionado                                                                                                                                                                                                
         * @private                                                                                                                                                                                                                                            
         */                                                                                                                                                                                                                                                    
        _navigateToField: function(oItem) {                                                                                                                                                                                                                    
            var oBindingContext = oItem.getBindingContext("etapa");                                                                                                                                                                                            
            var sFieldName = oBindingContext.getProperty("FieldName");                                                                                                                                                                                         
            var oEtapaModel = this.getView().getModel("etapa");                                                                                                                                                                                                
            var oParameterDoku = oEtapaModel.getProperty("/parameterDoku");                                                                                                                                                                                    
            var aItems = oParameterDoku.items.results;                                                                                                                                                                                                         
                                                                                                                                                                                                                                                               
            // Encontra o índice do campo                                                                                                                                                                                                                      
            var iIndex = aItems.findIndex(function(oField) {                                                                                                                                                                                                   
                return oField.FieldName === sFieldName;                                                                                                                                                                                                        
            });                                                                                                                                                                                                                                                
                                                                                                                                                                                                                                                               
            if (iIndex >= 0) {                                                                                                                                                                                                                                 
                // Atualiza o campo selecionado no modelo                                                                                                                                                                                                      
                oEtapaModel.setProperty("/selectedField", aItems[iIndex]);                                                                                                                                                                                     
                                                                                                                                                                                                                                                               
                // Publica evento para o FieldMaster selecionar o item correto                                                                                                                                                                                 
                var oEventBus = sap.ui.getCore().getEventBus();                                                                                                                                                                                                
                oEventBus.publish("HomeField", "FieldSelected", {                                                                                                                                                                                              
                    index: iIndex,                                                                                                                                                                                                                             
                    fieldName: sFieldName                                                                                                                                                                                                                      
                });                                                                                                                                                                                                                                            
