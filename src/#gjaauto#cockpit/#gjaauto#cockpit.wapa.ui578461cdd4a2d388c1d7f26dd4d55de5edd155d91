sap.ui.define([                                                                                                                                                                                                                                                
    "sap/ui/core/mvc/Controller",                                                                                                                                                                                                                              
    "sap/ui/core/UIComponent",                                                                                                                                                                                                                                 
    "sap/m/MessageToast",                                                                                                                                                                                                                                      
    "sap/m/MessageBox"                                                                                                                                                                                                                                         
], function (Controller, UIComponent, MessageToast, MessageBox) {                                                                                                                                                                                              
    "use strict";                                                                                                                                                                                                                                              
                                                                                                                                                                                                                                                               
    return Controller.extend("br.com.gja.zui5.gjaauto.cockpit.controller.Field", {                                                                                                                                                                             
        /**                                                                                                                                                                                                                                                    
         * Inicializa o controlador.                                                                                                                                                                                                                           
         * @public                                                                                                                                                                                                                                             
         */                                                                                                                                                                                                                                                    
        onInit: function () {                                                                                                                                                                                                                                  
            var oRouter = UIComponent.getRouterFor(this);                                                                                                                                                                                                      
                                                                                                                                                                                                                                                               
            // Escuta as rotas de field para carregar o mapeamento                                                                                                                                                                                             
            oRouter.getRoute("RouteEtapaImportWorkareaField").attachPatternMatched(this._onWorkareaFieldRouteMatched, this);                                                                                                                                   
            oRouter.getRoute("RouteEtapaExportWorkareaField").attachPatternMatched(this._onWorkareaFieldRouteMatched, this);                                                                                                                                   
            oRouter.getRoute("RouteEtapaTablesField").attachPatternMatched(this._onWorkareaFieldRouteMatched, this);                                                                                                                                           
                                                                                                                                                                                                                                                               
            oRouter.getRoute("RouteEtapaImportField").attachPatternMatched(this._onFieldRouteMatched, this);                                                                                                                                                   
            oRouter.getRoute("RouteEtapaExportField").attachPatternMatched(this._onFieldRouteMatched, this);                                                                                                                                                   
                                                                                                                                                                                                                                                               
            var oTarget = oRouter.getTargets().getTarget("TargetField");                                                                                                                                                                                       
            if (oTarget) {                                                                                                                                                                                                                                     
                oTarget.attachDisplay(this._onFieldTargetDisplay, this);                                                                                                                                                                                       
            }                                                                                                                                                                                                                                                  
        },                                                                                                                                                                                                                                                     
                                                                                                                                                                                                                                                               
        /**                                                                                                                                                                                                                                                    
         * Retorna o router.                                                                                                                                                                                                                                   
         * @returns {sap.m.routing.Router} Router                                                                                                                                                                                                              
         */                                                                                                                                                                                                                                                    
        getRouter: function () {                                                                                                                                                                                                                               
            return UIComponent.getRouterFor(this);                                                                                                                                                                                                             
        },                                                                                                                                                                                                                                                     
                                                                                                                                                                                                                                                               
        /**                                                                                                                                                                                                                                                    
         * Chamado quando a rota do field é correspondida.                                                                                                                                                                                                     
         * @param {sap.ui.base.Event} oEvent Evento de correspondência da rota                                                                                                                                                                                 
         * @private                                                                                                                                                                                                                                            
         */                                                                                                                                                                                                                                                    
        _onWorkareaFieldRouteMatched: function (oEvent) {                                                                                                                                                                                                      
            var oArgs = oEvent.getParameter("arguments");                                                                                                                                                                                                      
            var sKeyField = oArgs.keyField;                                                                                                                                                                                                                    
            var sKeyWorkarea = oArgs.keyWorkarea || oArgs.keyTable;                                                                                                                                                                                            
                                                                                                                                                                                                                                                               
            // Armazena os argumentos da rota para usar no save                                                                                                                                                                                                
            this._sCurrentWorkarea = sKeyWorkarea;                                                                                                                                                                                                             
            this._sCurrentField = sKeyField;                                                                                                                                                                                                                   
                                                                                                                                                                                                                                                               
            this._loadFieldMapping(sKeyWorkarea, sKeyField);                                                                                                                                                                                                   
            this._loadDadosOrigem();                                                                                                                                                                                                                           
        },                                                                                                                                                                                                                                                     
                                                                                                                                                                                                                                                               
&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;                                                                                                                                                                                                               
        /**                                                                                                                                                                                                                                                    
         * Chamado quando a rota do field é correspondida.                                                                                                                                                                                                     
         * @param {sap.ui.base.Event} oEvent Evento de correspondência da rota                                                                                                                                                                                 
         * @private                                                                                                                                                                                                                                            
         */                                                                                                                                                                                                                                                    
        _onFieldRouteMatched: function (oEvent) {                                                                                                                                                                                                              
            var oArgs = oEvent.getParameter("arguments");                                                                                                                                                                                                      
            var sKeyField = oArgs.keyField;                                                                                                                                                                                                                    
            var sKeyWorkarea = oArgs.keyWorkarea || oArgs.keyTable;                                                                                                                                                                                            
                                                                                                                                                                                                                                                               
            // Armazena os argumentos da rota para usar no save                                                                                                                                                                                                
            this._sCurrentField = sKeyField;                                                                                                                                                                                                                   
                                                                                                                                                                                                                                                               
            this._loadFieldMapping(null, sKeyField);                                                                                                                                                                                                           
            this._loadDadosOrigem();                                                                                                                                                                                                                           
        },                                                                                                                                                                                                                                                     
                                                                                                                                                                                                                                                               
        /**                                                                                                                                                                                                                                                    
         * Chamado quando o target do field é exibido pela primeira vez.                                                                                                                                                                                       
         * @param {sap.ui.base.Event} oEvent Evento de exibição do target                                                                                                                                                                                      
         * @private                                                                                                                                                                                                                                            
         */                                                                                                                                                                                                                                                    
        _onFieldTargetDisplay: function (oEvent) {                                                                                                                                                                                                             
            var oData = oEvent.getParameter("data") || {};                                                                                                                                                                                                     
            if (oData.keyField) {                                                                                                                                                                                                                              
                this._sCurrentField = oData.keyField;                                                                                                                                                                                                          
                this._loadFieldMapping(null, oData.keyField);                                                                                                                                                                                                  
                this._loadDadosOrigem();                                                                                                                                                                                                                       
            }                                                                                                                                                                                                                                                  
        },                                                                                                                                                                                                                                                     
                                                                                                                                                                                                                                                               
        /**                                                                                                                                                                                                                                                    
         * Carrega o mapeamento do campo selecionado.                                                                                                                                                                                                          
         * @param {string} sWorkarea Nome da workarea/tabela                                                                                                                                                                                                   
         * @param {string} sFieldName Nome do campo                                                                                                                                                                                                            
         * @private                                                                                                                                                                                                                                            
         */                                                                                                                                                                                                                                                    
        _loadFieldMapping: function (sWorkarea, sFieldName) {                                                                                                                                                                                                  
            var oEtapaModel = this._getEtapaModel();                                                                                                                                                                                                           
                                                                                                                                                                                                                                                               
            var oMapeamentos = oEtapaModel.getProperty("/etapaData/to_Mapeamentos");                                                                                                                                                                           
                                                                                                                                                                                                                                                               
            // Inicializa o mapeamento vazio se não existir                                                                                                                                                                                                    
            var oFieldMapping = null;                                                                                                                                                                                                                          
            this._bIsNewMapping = true;                                                                                                                                                                                                                        
            oEtapaModel.setProperty("/isNewMapping", true);                                                                                                                                                                                                    
                                                                                                                                                                                                                                                               
            if (oMapeamentos && oMapeamentos.results) {                                                                                                                                                                                                        
                // Busca o mapeamento do campo selecionado                                                                                                                                                                                                     
                // Usa minúsculas pois é como vem do OData (tabname, param)                                                                                                                                                                                    
                oFieldMapping = oMapeamentos.results.find(function (oMapeamento) {                                                                                                                                                                             
                    // Se for uma estrutura (workarea), verifica tabname + param                                                                                                                                                                               
                    if (sWorkarea) {                                                                                                                                                                                                                           
                        return oMapeamento.tabname === sWorkarea && oMapeamento.param === sFieldName;                                                                                                                                                          
                    }                                                                                                                                                                                                                                          
                    // Se for campo simples, verifica só o param                                                                                                                                                                                               
                    return oMapeamento.param === sFieldName;                                                                                                                                                                                                   
                });                                                                                                                                                                                                                                            
                                                                                                                                                                                                                                                               
                if (oFieldMapping) {                                                                                                                                                                                                                           
                    this._bIsNewMapping = false;                                                                                                                                                                                                               
                    oEtapaModel.setProperty("/isNewMapping", false);                                                                                                                                                                                           
                }                                                                                                                                                                                                                                              
            }                                                                                                                                                                                                                                                  
                                                                                                                                                                                                                                                               
            // Se não encontrou mapeamento, cria um objeto vazio para permitir edição                                                                                                                                                                          
            if (!oFieldMapping) {                                                                                                                                                                                                                              
                oFieldMapping = {                                                                                                                                                                                                                              
                    tabname_from: "",                                                                                                                                                                                                                          
                    param_from: "",                                                                                                                                                                                                                            
                    paramval: "",                                                                                                                                                                                                                              
                    paramopt: false                                                                                                                                                                                                                            
                };                                                                                                                                                                                                                                             
            }                                                                                                                                                                                                                                                  
                                                                                                                                                                                                                                                               
            // Armazena o mapeamento no modelo                                                                                                                                                                                                                 
            oEtapaModel.setProperty("/fieldMapping", oFieldMapping);                                                                                                                                                                                           
                                                                                                                                                                                                                                                               
            // Limpa os campos de origem quando troca de field                                                                                                                                                                                                 
            oEtapaModel.setProperty("/camposOrigem", []);                                                                                                                                                                                                      
                                                                                                                                                                                                                                                               
            // Se já tem tabela origem, carrega os campos                                                                                                                                                                                                      
            if (oFieldMapping.tabname_from) {                                                                                                                                                                                                                  
                this._loadCamposOrigem(oFieldMapping.tabname_from);                                                                                                                                                                                            
            }                                                                                                                                                                                                                                                  
        },                                                                                                                                                                                                                                                     
                                                                                                                                                                                                                                                               
        /**                                                                                                                                                                                                                                                    
         * Carrega os dados de origem disponíveis (to_Dados da Operação).                                                                                                                                                                                      
         * @private                                                                                                                                                                                                                                            
         */                                                                                                                                                                                                                                                    
        _loadDadosOrigem: function () {                                                                                                                                                                                                                        
            var oEtapaModel = this._getEtapaModel();                                                                                                                                                                                                           
            var sCodigoAuto = oEtapaModel.getProperty("/codigoAuto");                                                                                                                                                                                          
            var sCodigoOpera = oEtapaModel.getProperty("/codigoOpera");                                                                                                                                                                                        
            var that = this;                                                                                                                                                                                                                                   
                                                                                                                                                                                                                                                               
            // Verifica se já carregou                                                                                                                                                                                                                         
            var aDadosOrigem = oEtapaModel.getProperty("/dadosOrigem");                                                                                                                                                                                        
            if (aDadosOrigem && aDadosOrigem.length > 0) {                                                                                                                                                                                                     
                return;                                                                                                                                                                                                                                        
            }                                                                                                                                                                                                                                                  
                                                                                                                                                                                                                                                               
            var oModel = this.getOwnerComponent().getModel();                                                                                                                                                                                                  
            var sPath = "/Operacoes(auto='" + sCodigoAuto + "',opera='" + sCodigoOpera + "')/to_Dados";                                                                                                                                                        
                                                                                                                                                                                                                                                               
            oModel.read(sPath, {                                                                                                                                                                                                                               
                success: function (oData) {                                                                                                                                                                                                                    
                    var aDados = oData.results || [];                                                                                                                                                                                                          
                    oEtapaModel.setProperty("/dadosOrigem", aDados);                                                                                                                                                                                           
                },                                                                                                                                                                                                                                             
                error: function (oError) {                                                                                                                                                                                                                     
                    console.warn("Erro ao carregar dados de origem:", oError);                                                                                                                                                                                 
                    oEtapaModel.setProperty("/dadosOrigem", []);                                                                                                                                                                                               
                }                                                                                                                                                                                                                                              
            });                                                                                                                                                                                                                                                
        },                                                                                                                                                                                                                                                     
                                                                                                                                                                                                                                                               
        /**                                                                                                                                                                                                                                                    
         * Carrega os campos da tabela de origem selecionada.                                                                                                                                                                                                  
         * @param {string} sTabelaOrigem Nome da tabela de origem                                                                                                                                                                                              
         * @private                                                                                                                                                                                                                                            
         */                                                                                                                                                                                                                                                    
        _loadCamposOrigem: function (sTabelaOrigem) {                                                                                                                                                                                                          
            var oEtapaModel = this._getEtapaModel();                                                                                                                                                                                                           
            var that = this;                                                                                                                                                                                                                                   
                                                                                                                                                                                                                                                               
            // Busca os dados da tabela origem para obter o tipo                                                                                                                                                                                               
            var aDadosOrigem = oEtapaModel.getProperty("/dadosOrigem") || [];                                                                                                                                                                                  
            var oDadoSelecionado = aDadosOrigem.find(function (oDado) {                                                                                                                                                                                        
                return oDado.Name === sTabelaOrigem;                                                                                                                                                                                                           
            });                                                                                                                                                                                                                                                
                                                                                                                                                                                                                                                               
            if (!oDadoSelecionado) {                                                                                                                                                                                                                           
                console.warn("Tabela origem não encontrada:", sTabelaOrigem);                                                                                                                                                                                  
                oEtapaModel.setProperty("/camposOrigem", []);                                                                                                                                                                                                  
                return;                                                                                                                                                                                                                                        
            }                                                                                                                                                                                                                                                  
                                                                                                                                                                                                                                                               
            var sDataType = oDadoSelecionado.Reftypname || "";                                                                                                                                                                                                 
            var oMainServiceModel = this.getOwnerComponent().getModel("mainService");                                                                                                                                                                          
                                                                                                                                                                                                                                                               
            if (!oMainServiceModel) {                                                                                                                                                                                                                          
                oMainServiceModel = this.getOwnerComponent().getModel();                                                                                                                                                                                       
            }                                                                                                                                                                                                                                                  
                                                                                                                                                                                                                                                               
            var sPath = "/ParameterDoku(Param='" + sTabelaOrigem + "',DataType='" + sDataType.replace(/\//g, "\\") + "')";                                                                                                                                     
                                                                                                                                                                                                                                                               
            oMainServiceModel.read(sPath, {                                                                                                                                                                                                                    
                urlParameters: {                                                                                                                                                                                                                               
                    "$expand": "items"                                                                                                                                                                                                                         
                },                                                                                                                                                                                                                                             
                success: function (oData) {                                                                                                                                                                                                                    
                    var aCampos = oData.items && oData.items.results ? oData.items.results : [];                                                                                                                                                               
                    oEtapaModel.setProperty("/camposOrigem", aCampos);                                                                                                                                                                                         
                },                                                                                                                                                                                                                                             
                error: function (oError) {                                                                                                                                                                                                                     
                    console.warn("Erro ao carregar campos da tabela origem:", oError);                                                                                                                                                                         
                    oEtapaModel.setProperty("/camposOrigem", []);                                                                                                                                                                                              
                }                                                                                                                                                                                                                                              
            });                                                                                                                                                                                                                                                
        },                                                                                                                                                                                                                                                     
                                                                                                                                                                                                                                                               
        /**                                                                                                                                                                                                                                                    
         * Evento de mudança da Tabela Origem.                                                                                                                                                                                                                 
         * @param {sap.ui.base.Event} oEvent Evento de mudança                                                                                                                                                                                                 
         * @public                                                                                                                                                                                                                                             
         */                                                                                                                                                                                                                                                    
        onTabelaOrigemChange: function (oEvent) {                                                                                                                                                                                                              
            var oSelectedItem = oEvent.getParameter("selectedItem");                                                                                                                                                                                           
            var sSelectedKey = oSelectedItem ? oSelectedItem.getKey() : "";                                                                                                                                                                                    
            var oEtapaModel = this._getEtapaModel();                                                                                                                                                                                                           
                                                                                                                                                                                                                                                               
            // Limpa o campo origem quando troca a tabela                                                                                                                                                                                                      
            oEtapaModel.setProperty("/fieldMapping/param_from", "");                                                                                                                                                                                           
            oEtapaModel.setProperty("/camposOrigem", []);                                                                                                                                                                                                      
                                                                                                                                                                                                                                                               
            if (sSelectedKey) {                                                                                                                                                                                                                                
                this._loadCamposOrigem(sSelectedKey);                                                                                                                                                                                                          
            }                                                                                                                                                                                                                                                  
        },                                                                                                                                                                                                                                                     
                                                                                                                                                                                                                                                               
        /**                                                                                                                                                                                                                                                    
         * Salva o mapeamento do campo.                                                                                                                                                                                                                        
         * @public                                                                                                                                                                                                                                             
         */                                                                                                                                                                                                                                                    
        onSaveMapping: function () {                                                                                                                                                                                                                           
            var oEtapaModel = this._getEtapaModel();                                                                                                                                                                                                           
            var oFieldMapping = oEtapaModel.getProperty("/fieldMapping");                                                                                                                                                                                      
            var that = this;                                                                                                                                                                                                                                   
                                                                                                                                                                                                                                                               
            // Obtém dados da etapa                                                                                                                                                                                                                            
            var sCodigoAuto = oEtapaModel.getProperty("/codigoAuto");                                                                                                                                                                                          
            var sCodigoOpera = oEtapaModel.getProperty("/codigoOpera");                                                                                                                                                                                        
            var sCodigoEtapa = oEtapaModel.getProperty("/codigoEtapa");                                                                                                                                                                                        
            var sParamNatu = oEtapaModel.getProperty("/currentParamNatu");                                                                                                                                                                                     
            var oParamDoku = oEtapaModel.getProperty("/parameterDoku");                                                                                                                                                                                        
                                                                                                                                                                                                                                                               
            // Determina paramnat (I=Import, E=Export, T=Tables)                                                                                                                                                                                               
            var sParamnat = "";                                                                                                                                                                                                                                
            switch (sParamNatu) {                                                                                                                                                                                                                              
                case "import":                                                                                                                                                                                                                                 
                    sParamnat = "I";                                                                                                                                                                                                                           
                    break;                                                                                                                                                                                                                                     
                case "export":                                                                                                                                                                                                                                 
                    sParamnat = "E";                                                                                                                                                                                                                           
                    break;                                                                                                                                                                                                                                     
                case "tables":                                                                                                                                                                                                                                 
                    sParamnat = "T";                                                                                                                                                                                                                           
                    break;                                                                                                                                                                                                                                     
            }                                                                                                                                                                                                                                                  
                                                                                                                                                                                                                                                               
            // Determina paramtyp (F=Campo simples, S=Estrutura/Tabela)                                                                                                                                                                                        
            var sParamtyp = oParamDoku.ParamTyp === "T" ? "S" : "F";                                                                                                                                                                                           
                                                                                                                                                                                                                                                               
            var oModel = this.getOwnerComponent().getModel();                                                                                                                                                                                                  
                                                                                                                                                                                                                                                               
            oEtapaModel.setProperty("/busy", true);                                                                                                                                                                                                            
                                                                                                                                                                                                                                                               
            if (this._bIsNewMapping) {                                                                                                                                                                                                                         
                // Calcula o próximo Seqnr baseado nos mapeamentos existentes da mesma Etapa                                                                                                                                                                   
                var oMapeamentos = oEtapaModel.getProperty("/etapaData/to_Mapeamentos");                                                                                                                                                                       
                var iNextSeqnr = 1;                                                                                                                                                                                                                            
&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;                                                                                                                                                               
                if (oMapeamentos && oMapeamentos.results && oMapeamentos.results.length > 0) {                                                                                                                                                                 
                    // Encontra o maior Seqnr existente                                                                                                                                                                                                        
                    var iMaxSeqnr = oMapeamentos.results.reduce(function (iMax, oMap) {                                                                                                                                                                        
                        var iSeqnr = parseInt(oMap.Seqnr, 10) || 0;                                                                                                                                                                                            
                        return iSeqnr > iMax ? iSeqnr : iMax;                                                                                                                                                                                                  
                    }, 0);                                                                                                                                                                                                                                     
                    iNextSeqnr = iMaxSeqnr + 1;                                                                                                                                                                                                                
                }                                                                                                                                                                                                                                              
&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;                                                                                                                                                               
                // Formata o Seqnr com 5 dígitos (00001, 00002, etc.)                                                                                                                                                                                          
                var sNextSeqnr = String(iNextSeqnr).padStart(5, "0");                                                                                                                                                                                          
&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;                                                                                                                                                               
                // Monta o objeto para criar - POST via navigation property                                                                                                                                                                                    
                var oMapeamentoData = {                                                                                                                                                                                                                        
                    Seqnr: sNextSeqnr,                                                                                                                                                                                                                         
                    paramnat: sParamnat,                                                                                                                                                                                                                       
                    paramtyp: "V",                                                                                                                                                                                                                             
                    tabname: this._sCurrentWorkarea || "",                                                                                                                                                                                                     
                    param: this._sCurrentField || "",                                                                                                                                                                                                          
                    param_from: oFieldMapping.param_from || "",                                                                                                                                                                                                
                    tabname_from: oFieldMapping.tabname_from || "",                                                                                                                                                                                            
                    paramval: oFieldMapping.paramval || "",                                                                                                                                                                                                    
                    paramopt: oFieldMapping.paramopt || false,                                                                                                                                                                                                 
                    zeroleft: ""                                                                                                                                                                                                                               
                };                                                                                                                                                                                                                                             
                                                                                                                                                                                                                                                               
                // POST via navigation property da Etapa                                                                                                                                                                                                       
                var sPath = "/Etapas(auto='" + sCodigoAuto + "',opera='" + sCodigoOpera + "',etapa='" + sCodigoEtapa + "')/to_Mapeamentos";                                                                                                                    
                                                                                                                                                                                                                                                               
                oModel.create(sPath, oMapeamentoData, {                                                                                                                                                                                                        
                    success: function (oData) {                                                                                                                                                                                                                
                        oEtapaModel.setProperty("/busy", false);                                                                                                                                                                                               
                        MessageToast.show("Mapeamento salvo com sucesso!");                                                                                                                                                                                    
                        that._bIsNewMapping = false;                                                                                                                                                                                                           
                        oEtapaModel.setProperty("/isNewMapping", false);                                                                                                                                                                                       
                                                                                                                                                                                                                                                               
                        // Atualiza o fieldMapping com os dados retornados (incluindo Seqnr)                                                                                                                                                                   
                        oEtapaModel.setProperty("/fieldMapping", oData);                                                                                                                                                                                       
                                                                                                                                                                                                                                                               
                        // Recarrega os mapeamentos da etapa                                                                                                                                                                                                   
                        that._reloadMapeamentos();                                                                                                                                                                                                             
                    },                                                                                                                                                                                                                                         
                    error: function (oError) {                                                                                                                                                                                                                 
                        oEtapaModel.setProperty("/busy", false);                                                                                                                                                                                               
                        that._handleODataError(oError, "salvar mapeamento");                                                                                                                                                                                   
                    }                                                                                                                                                                                                                                          
                });                                                                                                                                                                                                                                            
            } else {                                                                                                                                                                                                                                           
                // Monta o objeto para atualizar - mantém o mesmo Seqnr                                                                                                                                                                                        
                var oMapeamentoUpdateData = {                                                                                                                                                                                                                  
                    paramnat: sParamnat,                                                                                                                                                                                                                       
                    paramtyp: sParamtyp,                                                                                                                                                                                                                       
                    tabname: this._sCurrentWorkarea || "",                                                                                                                                                                                                     
                    param: this._sCurrentField || "",                                                                                                                                                                                                          
                    param_from: oFieldMapping.ParamFrom || "",                                                                                                                                                                                                 
                    tabname_from: oFieldMapping.TabnameFrom || "",                                                                                                                                                                                             
                    paramval: oFieldMapping.Paramval || "",                                                                                                                                                                                                    
                    paramopt: oFieldMapping.Paramopt || false,                                                                                                                                                                                                 
                    zeroleft: oFieldMapping.Zeroleft || ""                                                                                                                                                                                                     
                };                                                                                                                                                                                                                                             
                                                                                                                                                                                                                                                               
                // Atualiza mapeamento existente - usa o Seqnr atual                                                                                                                                                                                           
                var sSeqnr = oFieldMapping.Seqnr;                                                                                                                                                                                                              
                var sPath = "/Mapeamentos(Auto='" + sCodigoAuto + "',Opera='" + sCodigoOpera + "',Etapa='" + sCodigoEtapa + "',Seqnr='" + sSeqnr + "')";                                                                                                       
                                                                                                                                                                                                                                                               
                oModel.update(sPath, oMapeamentoUpdateData, {                                                                                                                                                                                                  
                    success: function () {                                                                                                                                                                                                                     
                        oEtapaModel.setProperty("/busy", false);                                                                                                                                                                                               
                        MessageToast.show("Mapeamento atualizado com sucesso!");                                                                                                                                                                               
                                                                                                                                                                                                                                                               
                        // Recarrega os mapeamentos da etapa                                                                                                                                                                                                   
                        that._reloadMapeamentos();                                                                                                                                                                                                             
                    },                                                                                                                                                                                                                                         
                    error: function (oError) {                                                                                                                                                                                                                 
                        oEtapaModel.setProperty("/busy", false);                                                                                                                                                                                               
                        that._handleODataError(oError, "atualizar mapeamento");                                                                                                                                                                                
                    }                                                                                                                                                                                                                                          
                });                                                                                                                                                                                                                                            
            }                                                                                                                                                                                                                                                  
        },                                                                                                                                                                                                                                                     
                                                                                                                                                                                                                                                               
        /**                                                                                                                                                                                                                                                    
         * Deleta o mapeamento atual.                                                                                                                                                                                                                          
         * @public                                                                                                                                                                                                                                             
         */                                                                                                                                                                                                                                                    
        onDeleteMapping: function () {                                                                                                                                                                                                                         
            var oEtapaModel = this._getEtapaModel();                                                                                                                                                                                                           
            var oFieldMapping = oEtapaModel.getProperty("/fieldMapping");                                                                                                                                                                                      
            var that = this;                                                                                                                                                                                                                                   
                                                                                                                                                                                                                                                               
            // Verifica se é um mapeamento novo (não salvo)                                                                                                                                                                                                    
            if (this._bIsNewMapping) {                                                                                                                                                                                                                         
                MessageToast.show("Não há mapeamento salvo para deletar.");                                                                                                                                                                                    
                return;                                                                                                                                                                                                                                        
            }                                                                                                                                                                                                                                                  
                                                                                                                                                                                                                                                               
            // Confirma a exclusão                                                                                                                                                                                                                             
            MessageBox.confirm("Deseja realmente deletar este mapeamento?", {                                                                                                                                                                                  
                title: "Confirmar Exclusão",                                                                                                                                                                                                                   
                onClose: function (oAction) {                                                                                                                                                                                                                  
                    if (oAction === MessageBox.Action.OK) {                                                                                                                                                                                                    
                        that._executeDeleteMapping(oFieldMapping);                                                                                                                                                                                             
                    }                                                                                                                                                                                                                                          
                }                                                                                                                                                                                                                                              
            });                                                                                                                                                                                                                                                
        },                                                                                                                                                                                                                                                     
                                                                                                                                                                                                                                                               
        /**                                                                                                                                                                                                                                                    
         * Executa a exclusão do mapeamento.                                                                                                                                                                                                                   
         * @param {object} oFieldMapping Objeto do mapeamento a ser deletado                                                                                                                                                                                   
         * @private                                                                                                                                                                                                                                            
         */                                                                                                                                                                                                                                                    
        _executeDeleteMapping: function (oFieldMapping) {                                                                                                                                                                                                      
            var oEtapaModel = this._getEtapaModel();                                                                                                                                                                                                           
            var that = this;                                                                                                                                                                                                                                   
                                                                                                                                                                                                                                                               
            // Obtém dados da etapa                                                                                                                                                                                                                            
            var sCodigoAuto = oEtapaModel.getProperty("/codigoAuto");                                                                                                                                                                                          
            var sCodigoOpera = oEtapaModel.getProperty("/codigoOpera");                                                                                                                                                                                        
            var sCodigoEtapa = oEtapaModel.getProperty("/codigoEtapa");                                                                                                                                                                                        
            var sSeqnr = oFieldMapping.Seqnr;                                                                                                                                                                                                                  
                                                                                                                                                                                                                                                               
            var oModel = this.getOwnerComponent().getModel();                                                                                                                                                                                                  
                                                                                                                                                                                                                                                               
            oEtapaModel.setProperty("/busy", true);                                                                                                                                                                                                            
                                                                                                                                                                                                                                                               
            // DELETE do mapeamento                                                                                                                                                                                                                            
            var sPath = "/Mapeamentos(Auto='" + sCodigoAuto + "',Opera='" + sCodigoOpera + "',Etapa='" + sCodigoEtapa + "',Seqnr='" + sSeqnr + "')";                                                                                                           
                                                                                                                                                                                                                                                               
            oModel.remove(sPath, {                                                                                                                                                                                                                             
                success: function () {                                                                                                                                                                                                                         
                    oEtapaModel.setProperty("/busy", false);                                                                                                                                                                                                   
                    MessageToast.show("Mapeamento deletado com sucesso!");                                                                                                                                                                                     
                                                                                                                                                                                                                                                               
                    // Limpa o fieldMapping e marca como novo                                                                                                                                                                                                  
                    that._bIsNewMapping = true;                                                                                                                                                                                                                
                    oEtapaModel.setProperty("/isNewMapping", true);                                                                                                                                                                                            
                    oEtapaModel.setProperty("/fieldMapping", {                                                                                                                                                                                                 
                        tabname_from: "",                                                                                                                                                                                                                      
                        param_from: "",                                                                                                                                                                                                                        
                        paramval: "",                                                                                                                                                                                                                          
                        paramopt: false                                                                                                                                                                                                                        
                    });                                                                                                                                                                                                                                        
                    oEtapaModel.setProperty("/camposOrigem", []);                                                                                                                                                                                              
                                                                                                                                                                                                                                                               
                    // Recarrega os mapeamentos da etapa                                                                                                                                                                                                       
                    that._reloadMapeamentos();                                                                                                                                                                                                                 
                },                                                                                                                                                                                                                                             
                error: function (oError) {                                                                                                                                                                                                                     
                    oEtapaModel.setProperty("/busy", false);                                                                                                                                                                                                   
                    that._handleODataError(oError, "deletar mapeamento");                                                                                                                                                                                      
                }                                                                                                                                                                                                                                              
            });                                                                                                                                                                                                                                                
        },                                                                                                                                                                                                                                                     
                                                                                                                                                                                                                                                               
        /**                                                                                                                                                                                                                                                    
         * Recarrega os mapeamentos da etapa.                                                                                                                                                                                                                  
         * @private                                                                                                                                                                                                                                            
         */                                                                                                                                                                                                                                                    
        _reloadMapeamentos: function () {                                                                                                                                                                                                                      
            var oEtapaModel = this._getEtapaModel();                                                                                                                                                                                                           
            var sCodigoAuto = oEtapaModel.getProperty("/codigoAuto");                                                                                                                                                                                          
            var sCodigoOpera = oEtapaModel.getProperty("/codigoOpera");                                                                                                                                                                                        
            var sCodigoEtapa = oEtapaModel.getProperty("/codigoEtapa");                                                                                                                                                                                        
            var that = this;                                                                                                                                                                                                                                   
                                                                                                                                                                                                                                                               
            var oModel = this.getOwnerComponent().getModel();                                                                                                                                                                                                  
            var sPath = "/Etapas(auto='" + sCodigoAuto + "',opera='" + sCodigoOpera + "',etapa='" + sCodigoEtapa + "')/to_Mapeamentos";                                                                                                                        
                                                                                                                                                                                                                                                               
            oModel.read(sPath, {                                                                                                                                                                                                                               
                success: function (oData) {                                                                                                                                                                                                                    
                    oEtapaModel.setProperty("/etapaData/to_Mapeamentos", oData);                                                                                                                                                                               
                },                                                                                                                                                                                                                                             
                error: function (oError) {                                                                                                                                                                                                                     
                    console.warn("Erro ao recarregar mapeamentos:", oError);                                                                                                                                                                                   
                }                                                                                                                                                                                                                                              
            });                                                                                                                                                                                                                                                
        },                                                                                                                                                                                                                                                     
                                                                                                                                                                                                                                                               
        /**                                                                                                                                                                                                                                                    
         * Trata erros de chamadas OData.                                                                                                                                                                                                                      
         * @param {object} oError Objeto de erro                                                                                                                                                                                                               
         * @param {string} sAction Ação que causou o erro                                                                                                                                                                                                      
         * @private                                                                                                                                                                                                                                            
         */                                                                                                                                                                                                                                                    
        _handleODataError: function (oError, sAction) {                                                                                                                                                                                                        
            var sMessage = "Erro ao " + sAction;                                                                                                                                                                                                               
                                                                                                                                                                                                                                                               
            if (oError && oError.responseText) {                                                                                                                                                                                                               
                try {                                                                                                                                                                                                                                          
                    var oErrorResponse = JSON.parse(oError.responseText);                                                                                                                                                                                      
                    sMessage = oErrorResponse.error.message.value || sMessage;                                                                                                                                                                                 
                } catch (e) {                                                                                                                                                                                                                                  
                    // Usar mensagem padrão                                                                                                                                                                                                                    
                }                                                                                                                                                                                                                                              
            }                                                                                                                                                                                                                                                  
                                                                                                                                                                                                                                                               
            MessageBox.error(sMessage);                                                                                                                                                                                                                        
        },                                                                                                                                                                                                                                                     
                                                                                                                                                                                                                                                               
        /**                                                                                                                                                                                                                                                    
         * Retorna o modelo etapa.                                                                                                                                                                                                                             
         * @returns {sap.ui.model.json.JSONModel} Modelo etapa                                                                                                                                                                                                 
         * @private                                                                                                                                                                                                                                            
         */                                                                                                                                                                                                                                                    
        _getEtapaModel: function () {                                                                                                                                                                                                                          
            var oEtapaModel = this.getView().getModel("etapa");                                                                                                                                                                                                
            if (!oEtapaModel) {                                                                                                                                                                                                                                
                oEtapaModel = this.getOwnerComponent().getModel("etapa");                                                                                                                                                                                      
            }                                                                                                                                                                                                                                                  
            return oEtapaModel;                                                                                                                                                                                                                                
        },                                                                                                                                                                                                                                                     
                                                                                                                                                                                                                                                               
        /**                                                                                                                                                                                                                                                    
         * Retorna o mapeamento do campo atual.                                                                                                                                                                                                                
         * @returns {object} Objeto com o mapeamento ou null                                                                                                                                                                                                   
         */                                                                                                                                                                                                                                                    
        getFieldMapping: function () {                                                                                                                                                                                                                         
            return this._getEtapaModel().getProperty("/fieldMapping");                                                                                                                                                                                         
        }                                                                                                                                                                                                                                                      
    });                                                                                                                                                                                                                                                        
});                                                                                                                                                                                                                                                            
                                                                                                                                                                                                                                                               