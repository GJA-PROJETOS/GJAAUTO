sap.ui.define([                                                                                                                                                                                                                                                
    "sap/ui/core/mvc/Controller",                                                                                                                                                                                                                              
    "sap/ui/model/json/JSONModel",                                                                                                                                                                                                                             
    "sap/ui/model/Filter",                                                                                                                                                                                                                                     
    "sap/ui/model/FilterOperator",                                                                                                                                                                                                                             
    "sap/m/MessageBox"                                                                                                                                                                                                                                         
], function (Controller, JSONModel, Filter, FilterOperator, MessageBox) {                                                                                                                                                                                      
    "use strict";                                                                                                                                                                                                                                              
                                                                                                                                                                                                                                                               
    return Controller.extend("br.com.gja.zui5.gjaauto.cockpit.controller.DadosEtapa", {                                                                                                                                                                        
        /**                                                                                                                                                                                                                                                    
         * Inicializa o controlador.                                                                                                                                                                                                                           
         * @public                                                                                                                                                                                                                                             
         */                                                                                                                                                                                                                                                    
        onInit: function () {                                                                                                                                                                                                                                  
            var oViewModel = new JSONModel({                                                                                                                                                                                                                   
                busy: false,                                                                                                                                                                                                                                   
                items: []                                                                                                                                                                                                                                      
            });                                                                                                                                                                                                                                                
            this.getView().setModel(oViewModel, "dados");                                                                                                                                                                                                      
                                                                                                                                                                                                                                                               
            var oRouter = this.getOwnerComponent().getRouter();                                                                                                                                                                                                
            var oRoute = oRouter.getRoute("RouteEtapaDados");                                                                                                                                                                                                  
            oRoute.attachPatternMatched(this._onRouteMatched, this);                                                                                                                                                                                           
                                                                                                                                                                                                                                                               
            var oTarget = oRouter.getTargets().getTarget("TargetDadosEtapa");                                                                                                                                                                                  
            if (oTarget) {                                                                                                                                                                                                                                     
                oTarget.attachDisplay(this._onTargetDisplay, this);                                                                                                                                                                                            
            }                                                                                                                                                                                                                                                  
        },                                                                                                                                                                                                                                                     
                                                                                                                                                                                                                                                               
        /**                                                                                                                                                                                                                                                    
         * Chamado quando a rota é correspondida.                                                                                                                                                                                                              
         * @param {sap.ui.base.Event} oEvent Evento de correspondência da rota                                                                                                                                                                                 
         * @private                                                                                                                                                                                                                                            
         */                                                                                                                                                                                                                                                    
        _onRouteMatched: function (oEvent) {                                                                                                                                                                                                                   
            var oArgs = oEvent.getParameter("arguments");                                                                                                                                                                                                      
            this._loadDados(oArgs.codigoAuto, oArgs.codigoOpera);                                                                                                                                                                                              
        },                                                                                                                                                                                                                                                     
                                                                                                                                                                                                                                                               
        /**                                                                                                                                                                                                                                                    
         * Chamado quando o target da tela é exibido pela primeira vez.                                                                                                                                                                                        
         * @param {sap.ui.base.Event} oEvent Evento de exibição do target                                                                                                                                                                                      
         * @private                                                                                                                                                                                                                                            
         */                                                                                                                                                                                                                                                    
        _onTargetDisplay: function (oEvent) {                                                                                                                                                                                                                  
            var oData = oEvent.getParameter("data") || {};                                                                                                                                                                                                     
            if (oData.codigoAuto && oData.codigoOpera) {                                                                                                                                                                                                       
                this._loadDados(oData.codigoAuto, oData.codigoOpera);                                                                                                                                                                                          
            }                                                                                                                                                                                                                                                  
        },                                                                                                                                                                                                                                                     
                                                                                                                                                                                                                                                               
        /**                                                                                                                                                                                                                                                    
         * Carrega os dados da operação.                                                                                                                                                                                                                       
         * @param {string} sCodigoAuto Código da automação                                                                                                                                                                                                     
         * @param {string} sCodigoOpera Código da operação                                                                                                                                                                                                     
         * @private                                                                                                                                                                                                                                            
         */                                                                                                                                                                                                                                                    
        _loadDados: function (sCodigoAuto, sCodigoOpera) {                                                                                                                                                                                                     
            var oView = this.getView();                                                                                                                                                                                                                        
            var oModel = this.getOwnerComponent().getModel();                                                                                                                                                                                                  
            var oViewModel = oView.getModel("dados");                                                                                                                                                                                                          
            var that = this;                                                                                                                                                                                                                                   
                                                                                                                                                                                                                                                               
            oViewModel.setProperty("/busy", true);                                                                                                                                                                                                             
                                                                                                                                                                                                                                                               
            oModel.read("/Dados", {                                                                                                                                                                                                                            
                filters: [                                                                                                                                                                                                                                     
                    new Filter("Auto", FilterOperator.EQ, sCodigoAuto),                                                                                                                                                                                        
                    new Filter("Opera", FilterOperator.EQ, sCodigoOpera)                                                                                                                                                                                       
                ],                                                                                                                                                                                                                                             
                success: function (oData) {                                                                                                                                                                                                                    
                    oViewModel.setProperty("/items", oData.results || []);                                                                                                                                                                                     
                    oViewModel.setProperty("/busy", false);                                                                                                                                                                                                    
                },                                                                                                                                                                                                                                             
                error: function (oError) {                                                                                                                                                                                                                     
                    oViewModel.setProperty("/busy", false);                                                                                                                                                                                                    
                    that._handleODataError(oError, "Dados");                                                                                                                                                                                                   
                }                                                                                                                                                                                                                                              
            });                                                                                                                                                                                                                                                
        },                                                                                                                                                                                                                                                     
                                                                                                                                                                                                                                                               
        /**                                                                                                                                                                                                                                                    
         * Trata erros de chamadas OData.                                                                                                                                                                                                                      
         * @param {object} oError Objeto de erro                                                                                                                                                                                                               
         * @param {string} sEntity Nome da entidade                                                                                                                                                                                                            
         * @private                                                                                                                                                                                                                                            
         */                                                                                                                                                                                                                                                    
        _handleODataError: function (oError, sEntity) {                                                                                                                                                                                                        
            var sMessage = "Erro ao carregar " + sEntity;                                                                                                                                                                                                      
                                                                                                                                                                                                                                                               
            if (oError && oError.responseText) {                                                                                                                                                                                                               
                try {                                                                                                                                                                                                                                          
                    var oErrorResponse = JSON.parse(oError.responseText);                                                                                                                                                                                      
                    sMessage = oErrorResponse.error.message.value || sMessage;                                                                                                                                                                                 
                } catch (e) {                                                                                                                                                                                                                                  
                    // Usar mensagem padrão                                                                                                                                                                                                                    
                }                                                                                                                                                                                                                                              
            }                                                                                                                                                                                                                                                  
                                                                                                                                                                                                                                                               
            MessageBox.error(sMessage);                                                                                                                                                                                                                        
        },                                                                                                                                                                                                                                                     
                                                                                                                                                                                                                                                               
        /**                                                                                                                                                                                                                                                    
         * Pesquisa na lista de dados.                                                                                                                                                                                                                         
         * @param {sap.ui.base.Event} oEvent Evento de pesquisa                                                                                                                                                                                                
         * @public                                                                                                                                                                                                                                             
         */                                                                                                                                                                                                                                                    
        onSearchDados: function (oEvent) {                                                                                                                                                                                                                     
            var sQuery = oEvent.getParameter("query");                                                                                                                                                                                                         
            var oTable = this.byId("dadosTable");                                                                                                                                                                                                              
            var oBinding = oTable.getBinding("items");                                                                                                                                                                                                         
                                                                                                                                                                                                                                                               
            if (sQuery) {                                                                                                                                                                                                                                      
                var aFilters = [                                                                                                                                                                                                                               
                    new Filter("Name", FilterOperator.Contains, sQuery),                                                                                                                                                                                       
                    new Filter("Reftypname", FilterOperator.Contains, sQuery)                                                                                                                                                                                  
                ];                                                                                                                                                                                                                                             
                oBinding.filter(new Filter({                                                                                                                                                                                                                   
                    filters: aFilters,                                                                                                                                                                                                                         
                    and: false                                                                                                                                                                                                                                 
                }));                                                                                                                                                                                                                                           
            } else {                                                                                                                                                                                                                                           
                oBinding.filter([]);                                                                                                                                                                                                                           
            }                                                                                                                                                                                                                                                  
        },                                                                                                                                                                                                                                                     
                                                                                                                                                                                                                                                               
        /**                                                                                                                                                                                                                                                    
         * Manipula o clique em um dado.                                                                                                                                                                                                                       
         * @param {sap.ui.base.Event} oEvent Evento de clique                                                                                                                                                                                                  
         * @public                                                                                                                                                                                                                                             
         */                                                                                                                                                                                                                                                    
        onDadoPress: function (oEvent) {                                                                                                                                                                                                                       
            var oItem = oEvent.getSource();                                                                                                                                                                                                                    
            var oContext = oItem.getBindingContext("dados");                                                                                                                                                                                                   
            var oData = oContext.getObject();                                                                                                                                                                                                                  
                                                                                                                                                                                                                                                               
            // Por enquanto apenas mostra os detalhes                                                                                                                                                                                                          
            MessageBox.information("Dado selecionado: " + oData.Name);                                                                                                                                                                                         
        }                                                                                                                                                                                                                                                      
    });                                                                                                                                                                                                                                                        
});                                                                                                                                                                                                                                                            
                                                                                                                                                                                                                                                               