sap.ui.define([                                                                                                                                                                                                                                                
    "sap/ui/core/mvc/Controller",                                                                                                                                                                                                                              
    "sap/ui/model/json/JSONModel",                                                                                                                                                                                                                             
    "sap/ui/core/routing/History"                                                                                                                                                                                                                              
], function (Controller, JSONModel, History) {                                                                                                                                                                                                                 
    "use strict";                                                                                                                                                                                                                                              
                                                                                                                                                                                                                                                               
    return Controller.extend("br.com.gja.zui5.gjaauto.cockpit.controller.Automacao", {                                                                                                                                                                         
        /**                                                                                                                                                                                                                                                    
         * Inicializa o controlador.                                                                                                                                                                                                                           
         * @public                                                                                                                                                                                                                                             
         */                                                                                                                                                                                                                                                    
        onInit: function () {                                                                                                                                                                                                                                  
            var oRouter = this.getOwnerComponent().getRouter();                                                                                                                                                                                                
            oRouter.getRoute("RouteAutomacao").attachPatternMatched(this._onObjectMatched, this);                                                                                                                                                              
                                                                                                                                                                                                                                                               
            // Cria modelo local para a automação                                                                                                                                                                                                              
            var oViewModel = new JSONModel();                                                                                                                                                                                                                  
            this.getView().setModel(oViewModel, "automacao");                                                                                                                                                                                                  
        },                                                                                                                                                                                                                                                     
                                                                                                                                                                                                                                                               
        /**                                                                                                                                                                                                                                                    
         * Chamado quando a rota é correspondida.                                                                                                                                                                                                              
         * @param {sap.ui.base.Event} oEvent Evento de correspondência da rota                                                                                                                                                                                 
         * @private                                                                                                                                                                                                                                            
         */                                                                                                                                                                                                                                                    
        _onObjectMatched: function (oEvent) {                                                                                                                                                                                                                  
            var sCodigoAuto = oEvent.getParameter("arguments").codigoAuto;                                                                                                                                                                                     
            this._loadAutomacao(sCodigoAuto);                                                                                                                                                                                                                  
        },                                                                                                                                                                                                                                                     
                                                                                                                                                                                                                                                               
        /**                                                                                                                                                                                                                                                    
         * Carrega os dados da automação.                                                                                                                                                                                                                      
         * @param {string} sCodigoAuto Código da automação                                                                                                                                                                                                     
         * @private                                                                                                                                                                                                                                            
         */                                                                                                                                                                                                                                                    
        _loadAutomacao: function (sCodigoAuto) {                                                                                                                                                                                                               
            var oView = this.getView();                                                                                                                                                                                                                        
            var oModel = this.getOwnerComponent().getModel();                                                                                                                                                                                                  
&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;                                                                                                                                                                                       
            oView.setBusy(true);                                                                                                                                                                                                                               
                                                                                                                                                                                                                                                               
            // Busca os dados da automação                                                                                                                                                                                                                     
            oModel.read("/Automacoes('" + sCodigoAuto + "')", {                                                                                                                                                                                                
                urlParameters: {                                                                                                                                                                                                                               
                    "$expand": "to_Operacoes"                                                                                                                                                                                                                  
                },                                                                                                                                                                                                                                             
                success: function (oData) {                                                                                                                                                                                                                    
                    oView.getModel("automacao").setData(oData);                                                                                                                                                                                                
                    oView.setBusy(false);                                                                                                                                                                                                                      
                }.bind(this),                                                                                                                                                                                                                                  
                error: function () {                                                                                                                                                                                                                           
                    oView.setBusy(false);                                                                                                                                                                                                                      
                }.bind(this)                                                                                                                                                                                                                                   
            });                                                                                                                                                                                                                                                
        },                                                                                                                                                                                                                                                     
                                                                                                                                                                                                                                                               
        /**                                                                                                                                                                                                                                                    
         * Handler para quando uma operação é pressionada.                                                                                                                                                                                                     
         * @param {sap.ui.base.Event} oEvent Evento de pressionar                                                                                                                                                                                              
         * @public                                                                                                                                                                                                                                             
         */                                                                                                                                                                                                                                                    
        onOperacaoPress: function (oEvent) {                                                                                                                                                                                                                   
            var oItem = oEvent.getParameter("listItem");                                                                                                                                                                                                       
            var oContext = oItem.getBindingContext("automacao");                                                                                                                                                                                               
            var oOperacao = oContext.getObject();                                                                                                                                                                                                              
&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;                                                                                                                                                                                       
            var oRouter = this.getOwnerComponent().getRouter();                                                                                                                                                                                                
            oRouter.navTo("RouteOperacao", {                                                                                                                                                                                                                   
                codigoAuto: oOperacao.auto,                                                                                                                                                                                                                    
                codigoOpera: oOperacao.opera                                                                                                                                                                                                                   
            });                                                                                                                                                                                                                                                
        },                                                                                                                                                                                                                                                     
                                                                                                                                                                                                                                                               
        /**                                                                                                                                                                                                                                                    
         * Abre o popup de edição da automação.                                                                                                                                                                                                                
         * @public                                                                                                                                                                                                                                             
         */                                                                                                                                                                                                                                                    
        onEditAutomacao: function () {                                                                                                                                                                                                                         
            var oData = this.getView().getModel("automacao").getData() || {};                                                                                                                                                                                  
            if (!oData.auto) {                                                                                                                                                                                                                                 
                return;                                                                                                                                                                                                                                        
            }                                                                                                                                                                                                                                                  
                                                                                                                                                                                                                                                               
            this.getOwnerComponent().getCreateEditDialog().openEdit("automacao", oData, function () {                                                                                                                                                          
                this._loadAutomacao(oData.auto);                                                                                                                                                                                                               
            }.bind(this));                                                                                                                                                                                                                                     
        }                                                                                                                                                                                                                                                      
    });                                                                                                                                                                                                                                                        
});                                                                                                                                                                                                                                                            
                                                                                                                                                                                                                                                               