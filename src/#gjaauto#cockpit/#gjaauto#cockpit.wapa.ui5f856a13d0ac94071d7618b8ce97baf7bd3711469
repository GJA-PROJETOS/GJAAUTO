                });                                                                                                                                                                                                                                            
            } else if (sKey === "dados") {                                                                                                                                                                                                                     
                oRouter.navTo("RouteEtapaDados", {                                                                                                                                                                                                             
                    codigoAuto: sCodigoAuto,                                                                                                                                                                                                                   
                    codigoOpera: sCodigoOpera,                                                                                                                                                                                                                 
                    codigoEtapa: sCodigoEtapa                                                                                                                                                                                                                  
                });                                                                                                                                                                                                                                            
            } else if (sKey === "import" || sKey === "export") {                                                                                                                                                                                               
                // Não faz nada - só os filhos têm tela                                                                                                                                                                                                        
                return;                                                                                                                                                                                                                                        
            } else if (sKey === "tables") {                                                                                                                                                                                                                    
                // Não faz nada - só os filhos têm tela                                                                                                                                                                                                        
                return;                                                                                                                                                                                                                                        
            } else if (sKey.startsWith("import-") || sKey.startsWith("export-") || sKey.startsWith("tables-")) {                                                                                                                                               
                var sfunction = oViewModel.getProperty("/functionImport");                                                                                                                                                                                     
                var sParam = sKey.split("-")[1];                                                                                                                                                                                                               
                var sParamNatu = sKey.split("-")[0];                                                                                                                                                                                                           
                if (sParamNatu === "import") {                                                                                                                                                                                                                 
