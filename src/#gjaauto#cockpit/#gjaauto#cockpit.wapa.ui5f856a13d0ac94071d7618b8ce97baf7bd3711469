sap.ui.define([                                                                                                                                                                                                                                                
    "sap/ui/core/mvc/Controller",                                                                                                                                                                                                                              
    "sap/ui/model/json/JSONModel",                                                                                                                                                                                                                             
    "sap/m/MessageToast",                                                                                                                                                                                                                                      
    "sap/m/MessageBox",                                                                                                                                                                                                                                        
    "sap/ui/core/routing/History"                                                                                                                                                                                                                              
], function (Controller, JSONModel, MessageToast, MessageBox, History) {                                                                                                                                                                                       
    "use strict";                                                                                                                                                                                                                                              
                                                                                                                                                                                                                                                               
    return Controller.extend("br.com.gja.zui5.gjaauto.cockpit.controller.Etapa", {                                                                                                                                                                             
        /* =========================================================== */                                                                                                                                                                                      
        /* Eventos do Ciclo de Vida                                   */                                                                                                                                                                                       
        /* =========================================================== */                                                                                                                                                                                      
                                                                                                                                                                                                                                                               
        /**                                                                                                                                                                                                                                                    
         * Inicializa o controlador.                                                                                                                                                                                                                           
         * @public                                                                                                                                                                                                                                             
         */                                                                                                                                                                                                                                                    
        onInit: function () {                                                                                                                                                                                                                                  
            var oViewModel = this._createViewModel();                                                                                                                                                                                                          
            this.getView().setModel(oViewModel, "etapa");                                                                                                                                                                                                      
                                                                                                                                                                                                                                                               
            // Configura o roteador para gerenciar as navegações                                                                                                                                                                                               
            var oRouter = this.getOwnerComponent().getRouter();                                                                                                                                                                                                
                                                                                                                                                                                                                                                               
            // Rotas principais                                                                                                                                                                                                                                
            oRouter.getRoute("RouteEtapa").attachPatternMatched(this._onEtapaMatched, this);                                                                                                                                                                   
            oRouter.getRoute("RouteEtapaDados").attachPatternMatched(this._onDadosMatched, this);                                                                                                                                                              
                                                                                                                                                                                                                                                               
            // Rotas para estruturas (com menu lateral - SplitApp)                                                                                                                                                                                             
            oRouter.getRoute("RouteEtapaImportWorkarea").attachPatternMatched(this._onImportWorkareaMatched, this);                                                                                                                                            
            oRouter.getRoute("RouteEtapaExportWorkarea").attachPatternMatched(this._onExportWorkareaMatched, this);                                                                                                                                            
            oRouter.getRoute("RouteEtapaTables").attachPatternMatched(this._onTablesMatched, this);                                                                                                                                                            
                                                                                                                                                                                                                                                               
            // Rotas para campos dentro de estruturas (com menu lateral)                                                                                                                                                                                       
            oRouter.getRoute("RouteEtapaImportWorkareaField").attachPatternMatched(this._onImportWorkareaFieldMatched, this);                                                                                                                                  
            oRouter.getRoute("RouteEtapaExportWorkareaField").attachPatternMatched(this._onExportWorkareaFieldMatched, this);                                                                                                                                  
            oRouter.getRoute("RouteEtapaTablesField").attachPatternMatched(this._onTablesFieldMatched, this);                                                                                                                                                  
                                                                                                                                                                                                                                                               
            // Rotas para campos simples (sem menu lateral)                                                                                                                                                                                                    
            oRouter.getRoute("RouteEtapaImportField").attachPatternMatched(this._onImportFieldMatched, this);                                                                                                                                                  
            oRouter.getRoute("RouteEtapaExportField").attachPatternMatched(this._onExportFieldMatched, this);                                                                                                                                                  
        },                                                                                                                                                                                                                                                     
                                                                                                                                                                                                                                                               
        /* =========================================================== */                                                                                                                                                                                      
        /* Métodos Privados - Inicialização                           */                                                                                                                                                                                       
        /* =========================================================== */                                                                                                                                                                                      
                                                                                                                                                                                                                                                               
        /**                                                                                                                                                                                                                                                    
         * Cria e retorna o modelo de visualização com valores iniciais.                                                                                                                                                                                       
         * @returns {JSONModel} Modelo de visualização configurado                                                                                                                                                                                             
         * @private                                                                                                                                                                                                                                            
         */                                                                                                                                                                                                                                                    
        _createViewModel: function () {                                                                                                                                                                                                                        
            return new JSONModel({                                                                                                                                                                                                                             
                busy: false,                                                                                                                                                                                                                                   
                selectedMenuKey: "etapa",                                                                                                                                                                                                                      
                codigoAuto: "",                                                                                                                                                                                                                                
                codigoOpera: "",                                                                                                                                                                                                                               
                codigoEtapa: "",                                                                                                                                                                                                                               
                etapaData: {},                                                                                                                                                                                                                                 
                functionImport: {                                                                                                                                                                                                                              
                    import: [],                                                                                                                                                                                                                                
                    export: [],                                                                                                                                                                                                                                
                    tables: [],                                                                                                                                                                                                                                
                    changing: [],                                                                                                                                                                                                                              
                    exception: [],                                                                                                                                                                                                                             
                    dokumentation: []                                                                                                                                                                                                                          
                },                                                                                                                                                                                                                                             
                parameterDoku: {},                                                                                                                                                                                                                             
                parameterAtribuicao: [],                                                                                                                                                                                                                       
                currentParamNatu: "",                                                                                                                                                                                                                          
                selectedField: {},                                                                                                                                                                                                                             
                selectedFieldFixValues: [],                                                                                                                                                                                                                    
                showSideNavigation: true                                                                                                                                                                                                                       
            });                                                                                                                                                                                                                                                
        },                                                                                                                                                                                                                                                     
                                                                                                                                                                                                                                                               
        /* =========================================================== */                                                                                                                                                                                      
        /* Event Handlers - Rotas                                     */                                                                                                                                                                                       
        /* =========================================================== */                                                                                                                                                                                      
                                                                                                                                                                                                                                                               
        /**                                                                                                                                                                                                                                                    
         * Chamado quando a rota da Etapa é correspondida.                                                                                                                                                                                                     
         * @param {sap.ui.base.Event} oEvent Evento de correspondência da rota                                                                                                                                                                                 
         * @private                                                                                                                                                                                                                                            
         */                                                                                                                                                                                                                                                    
        _onEtapaMatched: function (oEvent) {                                                                                                                                                                                                                   
            var oArgs = oEvent.getParameter("arguments");                                                                                                                                                                                                      
            this._loadEtapaData(oArgs.codigoAuto, oArgs.codigoOpera, oArgs.codigoEtapa);                                                                                                                                                                       
            this._updateMenuSelection("etapa");                                                                                                                                                                                                                
            this._setSideNavigationVisible(true);                                                                                                                                                                                                              
            this._navigateToTarget("TargetHomeEtapa");                                                                                                                                                                                                         
        },                                                                                                                                                                                                                                                     
                                                                                                                                                                                                                                                               
        /**                                                                                                                                                                                                                                                    
         * Chamado quando a rota de Dados é correspondida.                                                                                                                                                                                                     
         * @param {sap.ui.base.Event} oEvent Evento de correspondência da rota                                                                                                                                                                                 
         * @private                                                                                                                                                                                                                                            
         */                                                                                                                                                                                                                                                    
        _onDadosMatched: function (oEvent) {                                                                                                                                                                                                                   
            var oArgs = oEvent.getParameter("arguments");                                                                                                                                                                                                      
            this._loadEtapaData(oArgs.codigoAuto, oArgs.codigoOpera, oArgs.codigoEtapa);                                                                                                                                                                       
            this._updateMenuSelection("dados");                                                                                                                                                                                                                
            this._setSideNavigationVisible(true);                                                                                                                                                                                                              
            this._navigateToTarget("TargetDadosEtapa", {                                                                                                                                                                                                       
                codigoAuto: oArgs.codigoAuto,                                                                                                                                                                                                                  
                codigoOpera: oArgs.codigoOpera,                                                                                                                                                                                                                
                codigoEtapa: oArgs.codigoEtapa                                                                                                                                                                                                                 
            });                                                                                                                                                                                                                                                
        },                                                                                                                                                                                                                                                     
                                                                                                                                                                                                                                                               
        /**                                                                                                                                                                                                                                                    
         * Chamado quando a rota de Import Workarea é correspondida (estrutura com múltiplos campos).                                                                                                                                                          
         * @param {sap.ui.base.Event} oEvent Evento de correspondência da rota                                                                                                                                                                                 
         * @private                                                                                                                                                                                                                                            
         */                                                                                                                                                                                                                                                    
        _onImportWorkareaMatched: function (oEvent) {                                                                                                                                                                                                          
            var oArgs = oEvent.getParameter("arguments");                                                                                                                                                                                                      
            this._loadEtapaData(oArgs.codigoAuto, oArgs.codigoOpera, oArgs.codigoEtapa);                                                                                                                                                                       
            this._updateMenuSelection("import-" + oArgs.keyWorkarea);                                                                                                                                                                                          
            this._setSideNavigationVisible(false);                                                                                                                                                                                                             
            // Não precisa navegar - o router já carrega o SplitApp com FieldMaster e FieldDetail                                                                                                                                                              
        },                                                                                                                                                                                                                                                     
                                                                                                                                                                                                                                                               
        /**                                                                                                                                                                                                                                                    
         * Chamado quando a rota de Export Workarea é correspondida (estrutura com múltiplos campos).                                                                                                                                                          
         * @param {sap.ui.base.Event} oEvent Evento de correspondência da rota                                                                                                                                                                                 
         * @private                                                                                                                                                                                                                                            
         */                                                                                                                                                                                                                                                    
        _onExportWorkareaMatched: function (oEvent) {                                                                                                                                                                                                          
            var oArgs = oEvent.getParameter("arguments");                                                                                                                                                                                                      
            this._loadEtapaData(oArgs.codigoAuto, oArgs.codigoOpera, oArgs.codigoEtapa);                                                                                                                                                                       
            this._updateMenuSelection("export-" + oArgs.keyWorkarea);                                                                                                                                                                                          
            this._setSideNavigationVisible(false);                                                                                                                                                                                                             
            // Não precisa navegar - o router já carrega o SplitApp com FieldMaster e FieldDetail                                                                                                                                                              
        },                                                                                                                                                                                                                                                     
                                                                                                                                                                                                                                                               
        /**                                                                                                                                                                                                                                                    
         * Chamado quando a rota de Import Workarea Field é correspondida.                                                                                                                                                                                     
         * @param {sap.ui.base.Event} oEvent Evento de correspondência da rota                                                                                                                                                                                 
         * @private                                                                                                                                                                                                                                            
         */                                                                                                                                                                                                                                                    
        _onImportWorkareaFieldMatched: function (oEvent) {                                                                                                                                                                                                     
            var oArgs = oEvent.getParameter("arguments");                                                                                                                                                                                                      
            var oViewModel = this.getView().getModel("etapa");                                                                                                                                                                                                 
                                                                                                                                                                                                                                                               
            this._loadEtapaData(oArgs.codigoAuto, oArgs.codigoOpera, oArgs.codigoEtapa);                                                                                                                                                                       
            this._updateMenuSelection("import-" + oArgs.keyWorkarea);                                                                                                                                                                                          
            this._setSideNavigationVisible(false);                                                                                                                                                                                                             
                                                                                                                                                                                                                                                               
            // Define o campo selecionado                                                                                                                                                                                                                      
            this._setSelectedFieldByName(oArgs.keyField);                                                                                                                                                                                                      
        },                                                                                                                                                                                                                                                     
                                                                                                                                                                                                                                                               
        /**                                                                                                                                                                                                                                                    
         * Chamado quando a rota de Export Workarea Field é correspondida.                                                                                                                                                                                     
         * @param {sap.ui.base.Event} oEvent Evento de correspondência da rota                                                                                                                                                                                 
         * @private                                                                                                                                                                                                                                            
         */                                                                                                                                                                                                                                                    
        _onExportWorkareaFieldMatched: function (oEvent) {                                                                                                                                                                                                     
            var oArgs = oEvent.getParameter("arguments");                                                                                                                                                                                                      
                                                                                                                                                                                                                                                               
            this._loadEtapaData(oArgs.codigoAuto, oArgs.codigoOpera, oArgs.codigoEtapa);                                                                                                                                                                       
            this._updateMenuSelection("export-" + oArgs.keyWorkarea);                                                                                                                                                                                          
            this._setSideNavigationVisible(false);                                                                                                                                                                                                             
                                                                                                                                                                                                                                                               
            // Define o campo selecionado                                                                                                                                                                                                                      
            this._setSelectedFieldByName(oArgs.keyField);                                                                                                                                                                                                      
        },                                                                                                                                                                                                                                                     
                                                                                                                                                                                                                                                               
        /**                                                                                                                                                                                                                                                    
         * Chamado quando a rota de Import Field é correspondida (campo simples).                                                                                                                                                                              
         * @param {sap.ui.base.Event} oEvent Evento de correspondência da rota                                                                                                                                                                                 
         * @private                                                                                                                                                                                                                                            
         */                                                                                                                                                                                                                                                    
        _onImportFieldMatched: function (oEvent) {                                                                                                                                                                                                             
            var oArgs = oEvent.getParameter("arguments");                                                                                                                                                                                                      
            this._loadEtapaData(oArgs.codigoAuto, oArgs.codigoOpera, oArgs.codigoEtapa);                                                                                                                                                                       
            this._updateMenuSelection("import-" + oArgs.keyField);                                                                                                                                                                                             
            this._setSideNavigationVisible(true);                                                                                                                                                                                                              
            this._navigateToTarget("TargetField", {                                                                                                                                                                                                            
                codigoAuto: oArgs.codigoAuto,                                                                                                                                                                                                                  
                codigoOpera: oArgs.codigoOpera,                                                                                                                                                                                                                
                codigoEtapa: oArgs.codigoEtapa,                                                                                                                                                                                                                
                keyField: oArgs.keyField                                                                                                                                                                                                                       
            });                                                                                                                                                                                                                                                
        },                                                                                                                                                                                                                                                     
                                                                                                                                                                                                                                                               
        /**                                                                                                                                                                                                                                                    
         * Chamado quando a rota de Export Field é correspondida (campo simples).                                                                                                                                                                              
         * @param {sap.ui.base.Event} oEvent Evento de correspondência da rota                                                                                                                                                                                 
         * @private                                                                                                                                                                                                                                            
         */                                                                                                                                                                                                                                                    
        _onExportFieldMatched: function (oEvent) {                                                                                                                                                                                                             
            var oArgs = oEvent.getParameter("arguments");                                                                                                                                                                                                      
            this._loadEtapaData(oArgs.codigoAuto, oArgs.codigoOpera, oArgs.codigoEtapa);                                                                                                                                                                       
            this._updateMenuSelection("export-" + oArgs.keyField);                                                                                                                                                                                             
            this._setSideNavigationVisible(true);                                                                                                                                                                                                              
            this._navigateToTarget("TargetField", {                                                                                                                                                                                                            
                codigoAuto: oArgs.codigoAuto,                                                                                                                                                                                                                  
                codigoOpera: oArgs.codigoOpera,                                                                                                                                                                                                                
                codigoEtapa: oArgs.codigoEtapa,                                                                                                                                                                                                                
                keyField: oArgs.keyField                                                                                                                                                                                                                       
            });                                                                                                                                                                                                                                                
        },                                                                                                                                                                                                                                                     
                                                                                                                                                                                                                                                               
        /**                                                                                                                                                                                                                                                    
         * Chamado quando a rota de Tables é correspondida (estrutura com múltiplos campos).                                                                                                                                                                   
         * @param {sap.ui.base.Event} oEvent Evento de correspondência da rota                                                                                                                                                                                 
         * @private                                                                                                                                                                                                                                            
         */                                                                                                                                                                                                                                                    
        _onTablesMatched: function (oEvent) {                                                                                                                                                                                                                  
            var oArgs = oEvent.getParameter("arguments");                                                                                                                                                                                                      
            this._loadEtapaData(oArgs.codigoAuto, oArgs.codigoOpera, oArgs.codigoEtapa);                                                                                                                                                                       
            this._updateMenuSelection("tables-" + oArgs.keyTable);                                                                                                                                                                                             
            this._setSideNavigationVisible(false);                                                                                                                                                                                                             
            // Não precisa navegar - o router já carrega o SplitApp com FieldMaster e FieldDetail                                                                                                                                                              
        },                                                                                                                                                                                                                                                     
                                                                                                                                                                                                                                                               
        /**                                                                                                                                                                                                                                                    
         * Chamado quando a rota de Tables Field é correspondida.                                                                                                                                                                                              
         * @param {sap.ui.base.Event} oEvent Evento de correspondência da rota                                                                                                                                                                                 
         * @private                                                                                                                                                                                                                                            
         */                                                                                                                                                                                                                                                    
        _onTablesFieldMatched: function (oEvent) {                                                                                                                                                                                                             
            var oArgs = oEvent.getParameter("arguments");                                                                                                                                                                                                      
            this._loadEtapaData(oArgs.codigoAuto, oArgs.codigoOpera, oArgs.codigoEtapa);                                                                                                                                                                       
            this._updateMenuSelection("tables-" + oArgs.keyTable);                                                                                                                                                                                             
            this._setSideNavigationVisible(false);                                                                                                                                                                                                             
                                                                                                                                                                                                                                                               
            // Define o campo selecionado                                                                                                                                                                                                                      
            this._setSelectedFieldByName(oArgs.keyField);                                                                                                                                                                                                      
        },                                                                                                                                                                                                                                                     
                                                                                                                                                                                                                                                               
        /**                                                                                                                                                                                                                                                    
         * Define o campo selecionado pelo nome.                                                                                                                                                                                                               
         * @param {string} sFieldName Nome do campo                                                                                                                                                                                                            
         * @private                                                                                                                                                                                                                                            
         */                                                                                                                                                                                                                                                    
        _setSelectedFieldByName: function (sFieldName) {                                                                                                                                                                                                       
            var oViewModel = this.getView().getModel("etapa");                                                                                                                                                                                                 
            var oParamDoku = oViewModel.getProperty("/parameterDoku");                                                                                                                                                                                         
                                                                                                                                                                                                                                                               
            if (oParamDoku && oParamDoku.items && oParamDoku.items.results) {                                                                                                                                                                                  
                var oField = oParamDoku.items.results.find(function (item) {                                                                                                                                                                                   
                    return item.FieldName === sFieldName;                                                                                                                                                                                                      
                });                                                                                                                                                                                                                                            
                                                                                                                                                                                                                                                               
                if (oField) {                                                                                                                                                                                                                                  
                    oViewModel.setProperty("/selectedField", oField);                                                                                                                                                                                          
                                                                                                                                                                                                                                                               
                    // Busca os valores fixos para o campo                                                                                                                                                                                                     
                    var aFixValues = oParamDoku.fixValuesItems && oParamDoku.fixValuesItems.results ?                                                                                                                                                          
                        oParamDoku.fixValuesItems.results.filter(function (item) {                                                                                                                                                                             
                            return item.FieldName === sFieldName;                                                                                                                                                                                              
                        }) : [];                                                                                                                                                                                                                               
                    oViewModel.setProperty("/selectedFieldFixValues", aFixValues);                                                                                                                                                                             
                }                                                                                                                                                                                                                                              
            }                                                                                                                                                                                                                                                  
        },                                                                                                                                                                                                                                                     
                                                                                                                                                                                                                                                               
        /**                                                                                                                                                                                                                                                    
         * Atualiza a seleção do menu.                                                                                                                                                                                                                         
         * @param {string} sKey Chave do menu selecionado                                                                                                                                                                                                      
         * @private                                                                                                                                                                                                                                            
         */                                                                                                                                                                                                                                                    
        _updateMenuSelection: function (sKey) {                                                                                                                                                                                                                
            this.getView().getModel("etapa").setProperty("/selectedMenuKey", sKey);                                                                                                                                                                            
        },                                                                                                                                                                                                                                                     
                                                                                                                                                                                                                                                               
        /**                                                                                                                                                                                                                                                    
         * Define a visibilidade do menu lateral de navegação.                                                                                                                                                                                                 
         * @param {boolean} bVisible Se o menu deve estar visível                                                                                                                                                                                              
         * @private                                                                                                                                                                                                                                            
         */                                                                                                                                                                                                                                                    
        _setSideNavigationVisible: function (bVisible) {                                                                                                                                                                                                       
            var oViewModel = this.getView().getModel("etapa");                                                                                                                                                                                                 
            oViewModel.setProperty("/showSideNavigation", bVisible);                                                                                                                                                                                           
                                                                                                                                                                                                                                                               
            // Também controla a expansão do ToolPage                                                                                                                                                                                                          
            var oToolPage = this.byId("etapaToolPage");                                                                                                                                                                                                        
            if (oToolPage) {                                                                                                                                                                                                                                   
                oToolPage.setSideExpanded(bVisible);                                                                                                                                                                                                           
            }                                                                                                                                                                                                                                                  
        },                                                                                                                                                                                                                                                     
                                                                                                                                                                                                                                                               
        /**                                                                                                                                                                                                                                                    
         * Navega para o target especificado.                                                                                                                                                                                                                  
         * @param {string} sTarget Nome do target                                                                                                                                                                                                              
         * @private                                                                                                                                                                                                                                            
         */                                                                                                                                                                                                                                                    
        _navigateToTarget: function (sTarget, oData) {                                                                                                                                                                                                         
            var oRouter = this.getOwnerComponent().getRouter();                                                                                                                                                                                                
            oRouter.getTargets().display(sTarget, oData || {});                                                                                                                                                                                                
        },                                                                                                                                                                                                                                                     
                                                                                                                                                                                                                                                               
        /* =========================================================== */                                                                                                                                                                                      
        /* Métodos Privados - Carregamento de Dados                   */                                                                                                                                                                                       
        /* =========================================================== */                                                                                                                                                                                      
                                                                                                                                                                                                                                                               
        /**                                                                                                                                                                                                                                                    
         * Carrega os dados da etapa e sua documentação de função.                                                                                                                                                                                             
         * @param {string} sCodigoAuto Código da automação                                                                                                                                                                                                     
         * @param {string} sCodigoOpera Código da operação                                                                                                                                                                                                     
         * @param {string} sCodigoEtapa Código da etapa                                                                                                                                                                                                        
         * @private                                                                                                                                                                                                                                            
         */                                                                                                                                                                                                                                                    
        _loadEtapaData: function (sCodigoAuto, sCodigoOpera, sCodigoEtapa) {                                                                                                                                                                                   
            var oViewModel = this.getView().getModel("etapa");                                                                                                                                                                                                 
                                                                                                                                                                                                                                                               
            // Verifica se já carregou os dados desta etapa                                                                                                                                                                                                    
            if (oViewModel.getProperty("/codigoAuto") === sCodigoAuto &&                                                                                                                                                                                       
                oViewModel.getProperty("/codigoOpera") === sCodigoOpera &&                                                                                                                                                                                     
                oViewModel.getProperty("/codigoEtapa") === sCodigoEtapa &&                                                                                                                                                                                     
                oViewModel.getProperty("/etapaData/etapa")) {                                                                                                                                                                                                  
                return;                                                                                                                                                                                                                                        
            }                                                                                                                                                                                                                                                  
                                                                                                                                                                                                                                                               
            oViewModel.setProperty("/codigoAuto", sCodigoAuto);                                                                                                                                                                                                
            oViewModel.setProperty("/codigoOpera", sCodigoOpera);                                                                                                                                                                                              
            oViewModel.setProperty("/codigoEtapa", sCodigoEtapa);                                                                                                                                                                                              
            oViewModel.setProperty("/busy", true);                                                                                                                                                                                                             
                                                                                                                                                                                                                                                               
            this._loadEtapaInfo(sCodigoAuto, sCodigoOpera, sCodigoEtapa);                                                                                                                                                                                      
        },                                                                                                                                                                                                                                                     
                                                                                                                                                                                                                                                               
        /**                                                                                                                                                                                                                                                    
         * Carrega as informações básicas da etapa.                                                                                                                                                                                                            
         * @param {string} sCodigoAuto Código da automação                                                                                                                                                                                                     
         * @param {string} sCodigoOpera Código da operação                                                                                                                                                                                                     
         * @param {string} sCodigoEtapa Código da etapa                                                                                                                                                                                                        
         * @private                                                                                                                                                                                                                                            
         */                                                                                                                                                                                                                                                    
        _loadEtapaInfo: function (sCodigoAuto, sCodigoOpera, sCodigoEtapa) {                                                                                                                                                                                   
            var oView = this.getView();                                                                                                                                                                                                                        
            var oModel = this.getOwnerComponent().getModel();                                                                                                                                                                                                  
            var oViewModel = oView.getModel("etapa");                                                                                                                                                                                                          
            var that = this;                                                                                                                                                                                                                                   
                                                                                                                                                                                                                                                               
            var sPath = "/Etapas(auto='" + sCodigoAuto + "',opera='" + sCodigoOpera + "',etapa='" + sCodigoEtapa + "')";                                                                                                                                       
                                                                                                                                                                                                                                                               
            oModel.read(sPath, {                                                                                                                                                                                                                               
                urlParameters: {                                                                                                                                                                                                                               
                    "$expand": "to_Mapeamentos,to_Atribuicoes,to_LoopTables"                                                                                                                                                                                   
                },                                                                                                                                                                                                                                             
                success: function (oData) {                                                                                                                                                                                                                    
                    oViewModel.setProperty("/etapaData", oData);                                                                                                                                                                                               
                                                                                                                                                                                                                                                               
                    // Se tiver rotina, carrega a documentação da função                                                                                                                                                                                       
                    if (oData.rotin) {                                                                                                                                                                                                                         
                        that._loadFunctionImportDoku(oData.rotin);                                                                                                                                                                                             
                    } else {                                                                                                                                                                                                                                   
                        oViewModel.setProperty("/busy", false);                                                                                                                                                                                                
                    }                                                                                                                                                                                                                                          
                },                                                                                                                                                                                                                                             
                error: function (oError) {                                                                                                                                                                                                                     
                    oViewModel.setProperty("/busy", false);                                                                                                                                                                                                    
                    that._handleODataError(oError, "Etapa");                                                                                                                                                                                                   
                }                                                                                                                                                                                                                                              
            });                                                                                                                                                                                                                                                
        },                                                                                                                                                                                                                                                     
                                                                                                                                                                                                                                                               
        /**                                                                                                                                                                                                                                                    
         * Carrega a documentação do módulo de função.                                                                                                                                                                                                         
         * @param {string} sFuncname Nome do módulo de função                                                                                                                                                                                                  
         * @private                                                                                                                                                                                                                                            
         */                                                                                                                                                                                                                                                    
        _loadFunctionImportDoku: function (sFuncname) {                                                                                                                                                                                                        
            var oView = this.getView();                                                                                                                                                                                                                        
            var oViewModel = oView.getModel("etapa");                                                                                                                                                                                                          
            var that = this;                                                                                                                                                                                                                                   
                                                                                                                                                                                                                                                               
            // Usa o modelo mainService para buscar dados do GJAAUTO/MAIN_SRV                                                                                                                                                                                  
            var oMainServiceModel = this.getOwnerComponent().getModel("mainService");                                                                                                                                                                          
                                                                                                                                                                                                                                                               
            if (!oMainServiceModel) {                                                                                                                                                                                                                          
                // Se não tiver o modelo mainService, tenta usar o modelo padrão                                                                                                                                                                               
                oMainServiceModel = this.getOwnerComponent().getModel();                                                                                                                                                                                       
            }                                                                                                                                                                                                                                                  
                                                                                                                                                                                                                                                               
            var sPath = "/FunctionImportDoku('" + sFuncname + "')";                                                                                                                                                                                            
                                                                                                                                                                                                                                                               
            oMainServiceModel.read(sPath, {                                                                                                                                                                                                                    
                urlParameters: {                                                                                                                                                                                                                               
                    "$expand": "import,export,changing,exception,dokumentation,tables"                                                                                                                                                                         
                },                                                                                                                                                                                                                                             
                success: function (oData) {                                                                                                                                                                                                                    
                    var oMapeamentos = oViewModel.getProperty("/etapaData/to_Mapeamentos");                                                                                                                                                                    
                                                                                                                                                                                                                                                               
                    // Função auxiliar para marcar parâmetros mapeados                                                                                                                                                                                         
                    var fnMarkMappedParams = function (aParams) {                                                                                                                                                                                              
                        if (!aParams || !aParams.results) {                                                                                                                                                                                                    
                            return;                                                                                                                                                                                                                            
                        }                                                                                                                                                                                                                                      
                        aParams.results.forEach(function (oParam) {                                                                                                                                                                                            
                            var bIsMapped = false;                                                                                                                                                                                                             
                            if (oMapeamentos && oMapeamentos.results) {                                                                                                                                                                                        
                                bIsMapped = oMapeamentos.results.some(function (oMapeamento) {                                                                                                                                                                 
                                    return oMapeamento.param  === oParam.Parameter || oMapeamento.tabname === oParam.Parameter;                                                                                                                                
                                });                                                                                                                                                                                                                            
                            }                                                                                                                                                                                                                                  
                            oParam.isMapped = bIsMapped;                                                                                                                                                                                                       
                        });                                                                                                                                                                                                                                    
                    };                                                                                                                                                                                                                                         
                                                                                                                                                                                                                                                               
                    // Marca os parâmetros mapeados em todas as categorias                                                                                                                                                                                     
                    fnMarkMappedParams(oData.import);                                                                                                                                                                                                          
                    fnMarkMappedParams(oData.export);                                                                                                                                                                                                          
                    fnMarkMappedParams(oData.tables);                                                                                                                                                                                                          
                    fnMarkMappedParams(oData.changing);                                                                                                                                                                                                        
                                                                                                                                                                                                                                                               
                    // Processa os dados de import                                                                                                                                                                                                             
                    var aImport = oData.import && oData.import.results ? oData.import.results : [];                                                                                                                                                            
                    var aExport = oData.export && oData.export.results ? oData.export.results : [];                                                                                                                                                            
                    var aTables = oData.tables && oData.tables.results ? oData.tables.results : [];                                                                                                                                                            
                    var aChanging = oData.changing && oData.changing.results ? oData.changing.results : [];                                                                                                                                                    
                    var aException = oData.exception && oData.exception.results ? oData.exception.results : [];                                                                                                                                                
                    var aDokumentation = oData.dokumentation && oData.dokumentation.results ? oData.dokumentation.results : [];                                                                                                                                
                                                                                                                                                                                                                                                               
                    oViewModel.setProperty("/functionImport", {                                                                                                                                                                                                
                        import: aImport,                                                                                                                                                                                                                       
                        export: aExport,                                                                                                                                                                                                                       
                        tables: aTables,                                                                                                                                                                                                                       
                        changing: aChanging,                                                                                                                                                                                                                   
                        exception: aException,                                                                                                                                                                                                                 
                        dokumentation: aDokumentation                                                                                                                                                                                                          
                    });                                                                                                                                                                                                                                        
                                                                                                                                                                                                                                                               
                    oViewModel.setProperty("/busy", false);                                                                                                                                                                                                    
                },                                                                                                                                                                                                                                             
                error: function (oError) {                                                                                                                                                                                                                     
                    oViewModel.setProperty("/busy", false);                                                                                                                                                                                                    
                    // Não mostra erro se não encontrar - pode ser que não tenha documentação                                                                                                                                                                  
                    console.warn("Não foi possível carregar documentação da função:", sFuncname);                                                                                                                                                              
                }                                                                                                                                                                                                                                              
            });                                                                                                                                                                                                                                                
        },                                                                                                                                                                                                                                                     
                                                                                                                                                                                                                                                               
        /* =========================================================== */                                                                                                                                                                                      
        /* Métodos Privados - Tratamento de Erros                    */                                                                                                                                                                                        
        /* =========================================================== */                                                                                                                                                                                      
                                                                                                                                                                                                                                                               
        /**                                                                                                                                                                                                                                                    
         * Trata erros de chamadas OData.                                                                                                                                                                                                                      
         * @param {object} oError Objeto de erro                                                                                                                                                                                                               
         * @param {string} sEntity Nome da entidade                                                                                                                                                                                                            
         * @private                                                                                                                                                                                                                                            
         */                                                                                                                                                                                                                                                    
        _handleODataError: function (oError, sEntity) {                                                                                                                                                                                                        
            var sMessage = "Erro ao carregar " + sEntity;                                                                                                                                                                                                      
                                                                                                                                                                                                                                                               
            if (oError && oError.responseText) {                                                                                                                                                                                                               
                try {                                                                                                                                                                                                                                          
                    var oErrorResponse = JSON.parse(oError.responseText);                                                                                                                                                                                      
                    sMessage = oErrorResponse.error.message.value || sMessage;                                                                                                                                                                                 
                } catch (e) {                                                                                                                                                                                                                                  
                    // Usar mensagem padrão                                                                                                                                                                                                                    
                }                                                                                                                                                                                                                                              
            }                                                                                                                                                                                                                                                  
                                                                                                                                                                                                                                                               
            MessageBox.error(sMessage);                                                                                                                                                                                                                        
        },                                                                                                                                                                                                                                                     
                                                                                                                                                                                                                                                               
