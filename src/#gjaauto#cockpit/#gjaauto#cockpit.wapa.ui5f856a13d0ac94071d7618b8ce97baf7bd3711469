        onSideMenuItemSelect: function (oEvent) {                                                                                                                                                                                                              
            var oItem = oEvent.getParameter("item");                                                                                                                                                                                                           
            var sKey = oItem.getKey();                                                                                                                                                                                                                         
            var oViewModel = this.getView().getModel("etapa");                                                                                                                                                                                                 
            var sCodigoAuto = oViewModel.getProperty("/codigoAuto");                                                                                                                                                                                           
            var sCodigoOpera = oViewModel.getProperty("/codigoOpera");                                                                                                                                                                                         
            var sCodigoEtapa = oViewModel.getProperty("/codigoEtapa");                                                                                                                                                                                         
                                                                                                                                                                                                                                                               
            if (!sKey) {                                                                                                                                                                                                                                       
                return;                                                                                                                                                                                                                                        
            }                                                                                                                                                                                                                                                  
                                                                                                                                                                                                                                                               
            var oRouter = this.getOwnerComponent().getRouter();                                                                                                                                                                                                
                                                                                                                                                                                                                                                               
            // Analisa a key para determinar a navegação                                                                                                                                                                                                       
            if (sKey === "etapa") {                                                                                                                                                                                                                            
