                        return item.Parameter === sParam;                                                                                                                                                                                                      
                    });                                                                                                                                                                                                                                        
                    if (sParamDataStruct) {                                                                                                                                                                                                                    
                        var sParamType = sParamDataStruct.Typ || sParamDataStruct.Dbfield || sParamDataStruct.Default || "";                                                                                                                                   
                    }                                                                                                                                                                                                                                          
                                                                                                                                                                                                                                                               
                } else if (sParamNatu === "export") {                                                                                                                                                                                                          
