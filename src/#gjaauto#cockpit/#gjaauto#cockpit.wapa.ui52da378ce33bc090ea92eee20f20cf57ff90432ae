sap.ui.define([                                                                                                                                                                                                                                                
    "sap/ui/model/json/JSONModel",                                                                                                                                                                                                                             
    "sap/m/Dialog",                                                                                                                                                                                                                                            
    "sap/m/Button",                                                                                                                                                                                                                                            
    "sap/m/Select",                                                                                                                                                                                                                                            
    "sap/m/Label",                                                                                                                                                                                                                                             
    "sap/m/VBox",                                                                                                                                                                                                                                              
    "sap/ui/layout/form/SimpleForm",                                                                                                                                                                                                                           
    "sap/ui/core/Item",                                                                                                                                                                                                                                        
    "sap/m/MessageBox",                                                                                                                                                                                                                                        
    "sap/m/MessageToast",                                                                                                                                                                                                                                      
    "br/com/gja/zui5/gjaauto/cockpit/util/createEditExtensions/Automacao",                                                                                                                                                                                     
    "br/com/gja/zui5/gjaauto/cockpit/util/createEditExtensions/Operacao",                                                                                                                                                                                      
    "br/com/gja/zui5/gjaauto/cockpit/util/createEditExtensions/Etapa",                                                                                                                                                                                         
    "br/com/gja/zui5/gjaauto/cockpit/util/createEditExtensions/Dados"                                                                                                                                                                                          
], function (JSONModel, Dialog, Button, Select, Label, VBox, SimpleForm, Item, MessageBox, MessageToast, AutomacaoExtension, OperacaoExtension, EtapaExtension, DadosExtension) {                                                                              
    "use strict";                                                                                                                                                                                                                                              
                                                                                                                                                                                                                                                               
    var EXTENSIONS = [                                                                                                                                                                                                                                         
        AutomacaoExtension,                                                                                                                                                                                                                                    
        OperacaoExtension,                                                                                                                                                                                                                                     
        EtapaExtension,                                                                                                                                                                                                                                        
        DadosExtension                                                                                                                                                                                                                                         
    ];                                                                                                                                                                                                                                                         
                                                                                                                                                                                                                                                               
    var EXTENSIONS_BY_KEY = EXTENSIONS.reduce(function (oMap, oExtension) {                                                                                                                                                                                    
        oMap[oExtension.key] = oExtension;                                                                                                                                                                                                                     
        return oMap;                                                                                                                                                                                                                                           
    }, {});                                                                                                                                                                                                                                                    
                                                                                                                                                                                                                                                               
    function buildInitialModelData(aExtensions) {                                                                                                                                                                                                              
        var sDefaultType = aExtensions.length ? aExtensions[0].key : "";                                                                                                                                                                                       
        var oData = {                                                                                                                                                                                                                                          
            mode: "create",                                                                                                                                                                                                                                    
            title: "Criar",                                                                                                                                                                                                                                    
            confirmText: "Criar",                                                                                                                                                                                                                              
            selectedType: sDefaultType,                                                                                                                                                                                                                        
            typeEditable: true,                                                                                                                                                                                                                                
            labels: {},                                                                                                                                                                                                                                        
            maxLength: {},                                                                                                                                                                                                                                     
            required: {},                                                                                                                                                                                                                                      
            editableCreate: {},                                                                                                                                                                                                                                
            editableEdit: {},                                                                                                                                                                                                                                  
            editable: {}                                                                                                                                                                                                                                       
        };                                                                                                                                                                                                                                                     
                                                                                                                                                                                                                                                               
        aExtensions.forEach(function (oExtension) {                                                                                                                                                                                                            
            var sKey = oExtension.key;                                                                                                                                                                                                                         
            var oGroup = {};                                                                                                                                                                                                                                   
            var oLabels = {};                                                                                                                                                                                                                                  
                                                                                                                                                                                                                                                               
            (oExtension.fields || []).forEach(function (sField) {                                                                                                                                                                                              
                oGroup[sField] = "";                                                                                                                                                                                                                           
                oLabels[sField] = sField;                                                                                                                                                                                                                      
            });                                                                                                                                                                                                                                                
                                                                                                                                                                                                                                                               
            oData[sKey] = oGroup;                                                                                                                                                                                                                              
            oData.labels[sKey] = oLabels;                                                                                                                                                                                                                      
            oData.maxLength[sKey] = {};                                                                                                                                                                                                                        
            oData.required[sKey] = {};                                                                                                                                                                                                                         
            oData.editableCreate[sKey] = {};                                                                                                                                                                                                                   
            oData.editableEdit[sKey] = {};                                                                                                                                                                                                                     
            oData.editable[sKey] = {};                                                                                                                                                                                                                         
        });                                                                                                                                                                                                                                                    
                                                                                                                                                                                                                                                               
        return oData;                                                                                                                                                                                                                                          
    }                                                                                                                                                                                                                                                          
                                                                                                                                                                                                                                                               
    function CreateEditDialog(oComponent) {                                                                                                                                                                                                                    
        this._component = oComponent;                                                                                                                                                                                                                          
        this._dialog = null;                                                                                                                                                                                                                                   
        this._metadataLoaded = false;                                                                                                                                                                                                                          
        this._onSuccess = null;                                                                                                                                                                                                                                
                                                                                                                                                                                                                                                               
        this._extensions = EXTENSIONS;                                                                                                                                                                                                                         
        this._extensionsByKey = EXTENSIONS_BY_KEY;                                                                                                                                                                                                             
        this._model = new JSONModel(buildInitialModelData(this._extensions));                                                                                                                                                                                  
    }                                                                                                                                                                                                                                                          
                                                                                                                                                                                                                                                               
    CreateEditDialog.prototype.openCreate = function (sType, oPrefill, fnSuccess) {                                                                                                                                                                            
        this._ensureMetadata();                                                                                                                                                                                                                                
        this._ensureDialog();                                                                                                                                                                                                                                  
                                                                                                                                                                                                                                                               
        this._onSuccess = fnSuccess || null;                                                                                                                                                                                                                   
        this._setMode("create");                                                                                                                                                                                                                               
                                                                                                                                                                                                                                                               
        if (sType) {                                                                                                                                                                                                                                           
            this._model.setProperty("/selectedType", sType);                                                                                                                                                                                                   
        }                                                                                                                                                                                                                                                      
                                                                                                                                                                                                                                                               
        this._resetAllGroups();                                                                                                                                                                                                                                
        if (oPrefill) {                                                                                                                                                                                                                                        
            this._applyPrefill(oPrefill);                                                                                                                                                                                                                      
        }                                                                                                                                                                                                                                                      
                                                                                                                                                                                                                                                               
        this._dialog.open();                                                                                                                                                                                                                                   
    };                                                                                                                                                                                                                                                         
                                                                                                                                                                                                                                                               
    CreateEditDialog.prototype.openEdit = function (sType, oData, fnSuccess) {                                                                                                                                                                                 
        this._ensureMetadata();                                                                                                                                                                                                                                
        this._ensureDialog();                                                                                                                                                                                                                                  
                                                                                                                                                                                                                                                               
        this._onSuccess = fnSuccess || null;                                                                                                                                                                                                                   
        this._setMode("edit");                                                                                                                                                                                                                                 
        this._model.setProperty("/selectedType", sType);                                                                                                                                                                                                       
        this._resetGroup(sType);                                                                                                                                                                                                                               
        this._setGroupData(sType, oData || {});                                                                                                                                                                                                                
                                                                                                                                                                                                                                                               
        this._dialog.open();                                                                                                                                                                                                                                   
    };                                                                                                                                                                                                                                                         
                                                                                                                                                                                                                                                               
    CreateEditDialog.prototype._ensureDialog = function () {                                                                                                                                                                                                   
        if (this._dialog) {                                                                                                                                                                                                                                    
            return;                                                                                                                                                                                                                                            
        }                                                                                                                                                                                                                                                      
                                                                                                                                                                                                                                                               
        var aTypeItems = this._extensions.map(function (oExtension) {                                                                                                                                                                                          
            return new Item({                                                                                                                                                                                                                                  
                key: oExtension.key,                                                                                                                                                                                                                           
                text: oExtension.title || oExtension.key                                                                                                                                                                                                       
            });                                                                                                                                                                                                                                                
        });                                                                                                                                                                                                                                                    
                                                                                                                                                                                                                                                               
        var oSelect = new Select({                                                                                                                                                                                                                             
            width: "100%",                                                                                                                                                                                                                                     
            selectedKey: "{create>/selectedType}",                                                                                                                                                                                                             
            enabled: "{create>/typeEditable}",                                                                                                                                                                                                                 
            items: aTypeItems                                                                                                                                                                                                                                  
        });                                                                                                                                                                                                                                                    
                                                                                                                                                                                                                                                               
        var oTypeForm = new SimpleForm({                                                                                                                                                                                                                       
            layout: "ResponsiveGridLayout",                                                                                                                                                                                                                    
            editable: true,                                                                                                                                                                                                                                    
            content: [                                                                                                                                                                                                                                         
                new Label({ text: "Tipo" }),                                                                                                                                                                                                                   
                oSelect                                                                                                                                                                                                                                        
            ]                                                                                                                                                                                                                                                  
        });                                                                                                                                                                                                                                                    
                                                                                                                                                                                                                                                               
        var aForms = this._extensions.map(function (oExtension) {                                                                                                                                                                                              
            return oExtension.buildForm ? oExtension.buildForm() : null;                                                                                                                                                                                       
        }).filter(function (oForm) {                                                                                                                                                                                                                           
            return !!oForm;                                                                                                                                                                                                                                    
        });                                                                                                                                                                                                                                                    
                                                                                                                                                                                                                                                               
        var oContent = new VBox({                                                                                                                                                                                                                              
            width: "100%",                                                                                                                                                                                                                                     
            items: [oTypeForm].concat(aForms)                                                                                                                                                                                                                  
        });                                                                                                                                                                                                                                                    
                                                                                                                                                                                                                                                               
        this._dialog = new Dialog({                                                                                                                                                                                                                            
            title: "{create>/title}",                                                                                                                                                                                                                          
            contentWidth: "540px",                                                                                                                                                                                                                             
            content: [oContent],                                                                                                                                                                                                                               
            beginButton: new Button({                                                                                                                                                                                                                          
                text: "{create>/confirmText}",                                                                                                                                                                                                                 
                type: "Emphasized",                                                                                                                                                                                                                            
                press: this._onConfirm.bind(this)                                                                                                                                                                                                              
            }),                                                                                                                                                                                                                                                
            endButton: new Button({                                                                                                                                                                                                                            
                text: "Fechar",                                                                                                                                                                                                                                
                press: function () {                                                                                                                                                                                                                           
                    this._dialog.close();                                                                                                                                                                                                                      
                }.bind(this)                                                                                                                                                                                                                                   
            })                                                                                                                                                                                                                                                 
        });                                                                                                                                                                                                                                                    
                                                                                                                                                                                                                                                               
        this._dialog.setModel(this._model, "create");                                                                                                                                                                                                          
                                                                                                                                                                                                                                                               
        var oRoot = this._component.getRootControl && this._component.getRootControl();                                                                                                                                                                        
        if (oRoot) {                                                                                                                                                                                                                                           
            oRoot.addDependent(this._dialog);                                                                                                                                                                                                                  
        }                                                                                                                                                                                                                                                      
    };                                                                                                                                                                                                                                                         
                                                                                                                                                                                                                                                               
    CreateEditDialog.prototype._ensureMetadata = function () {                                                                                                                                                                                                 
        if (this._metadataLoaded) {                                                                                                                                                                                                                            
            return;                                                                                                                                                                                                                                            
        }                                                                                                                                                                                                                                                      
                                                                                                                                                                                                                                                               
        var oMainModel = this._component.getModel();                                                                                                                                                                                                           
        if (!oMainModel) {                                                                                                                                                                                                                                     
            return;                                                                                                                                                                                                                                            
        }                                                                                                                                                                                                                                                      
                                                                                                                                                                                                                                                               
        var oMetaModel = oMainModel.getMetaModel();                                                                                                                                                                                                            
        oMetaModel.loaded().then(function () {                                                                                                                                                                                                                 
            this._extensions.forEach(function (oExtension) {                                                                                                                                                                                                   
                this._applyMetaInfo(oExtension.entityType, oExtension.key, oExtension.fields || []);                                                                                                                                                           
            }.bind(this));                                                                                                                                                                                                                                     
            this._metadataLoaded = true;                                                                                                                                                                                                                       
            this._syncEditableAll();                                                                                                                                                                                                                           
        }.bind(this));                                                                                                                                                                                                                                         
    };                                                                                                                                                                                                                                                         
                                                                                                                                                                                                                                                               
    CreateEditDialog.prototype._applyMetaInfo = function (sEntityType, sGroup, aProps) {                                                                                                                                                                       
        var oMainModel = this._component.getModel();                                                                                                                                                                                                           
        if (!oMainModel) {                                                                                                                                                                                                                                     
            return;                                                                                                                                                                                                                                            
        }                                                                                                                                                                                                                                                      
                                                                                                                                                                                                                                                               
        var oMetaModel = oMainModel.getMetaModel();                                                                                                                                                                                                            
        var oEntityType = oMetaModel.getODataEntityType(sEntityType);                                                                                                                                                                                          
        if (!oEntityType) {                                                                                                                                                                                                                                    
            return;                                                                                                                                                                                                                                            
        }                                                                                                                                                                                                                                                      
                                                                                                                                                                                                                                                               
        var aKeyRefs = [];                                                                                                                                                                                                                                     
        if (oEntityType.key && oEntityType.key.propertyRef) {                                                                                                                                                                                                  
            aKeyRefs = oEntityType.key.propertyRef.map(function (oRef) {                                                                                                                                                                                       
                return oRef.name;                                                                                                                                                                                                                              
            });                                                                                                                                                                                                                                                
        }                                                                                                                                                                                                                                                      
                                                                                                                                                                                                                                                               
        aProps.forEach(function (sProp) {                                                                                                                                                                                                                      
            var oProp = oMetaModel.getODataProperty(oEntityType, sProp) || {};                                                                                                                                                                                 
            var sLabel = oProp["sap:label"] || sProp;                                                                                                                                                                                                          
            var iMaxLength = oProp.maxLength ? parseInt(oProp.maxLength, 10) : null;                                                                                                                                                                           
            var bRequired = oProp.nullable === "false" || oProp.nullable === false;                                                                                                                                                                            
            var bCreatable = oProp["sap:creatable"] !== "false";                                                                                                                                                                                               
            var bUpdatable = oProp["sap:updatable"] !== "false";                                                                                                                                                                                               
            if (aKeyRefs.indexOf(sProp) > -1) {                                                                                                                                                                                                                
                bUpdatable = false;                                                                                                                                                                                                                            
            }                                                                                                                                                                                                                                                  
                                                                                                                                                                                                                                                               
            this._model.setProperty("/labels/" + sGroup + "/" + sProp, sLabel);                                                                                                                                                                                
            if (iMaxLength) {                                                                                                                                                                                                                                  
                this._model.setProperty("/maxLength/" + sGroup + "/" + sProp, iMaxLength);                                                                                                                                                                     
            }                                                                                                                                                                                                                                                  
            this._model.setProperty("/required/" + sGroup + "/" + sProp, bRequired);                                                                                                                                                                           
            this._model.setProperty("/editableCreate/" + sGroup + "/" + sProp, bCreatable);                                                                                                                                                                    
            this._model.setProperty("/editableEdit/" + sGroup + "/" + sProp, bUpdatable);                                                                                                                                                                      
        }.bind(this));                                                                                                                                                                                                                                         
    };                                                                                                                                                                                                                                                         
                                                                                                                                                                                                                                                               
    CreateEditDialog.prototype._setMode = function (sMode) {                                                                                                                                                                                                   
        var bIsEdit = sMode === "edit";                                                                                                                                                                                                                        
        this._model.setProperty("/mode", sMode);                                                                                                                                                                                                               
        this._model.setProperty("/title", bIsEdit ? "Editar" : "Criar");                                                                                                                                                                                       
        this._model.setProperty("/confirmText", bIsEdit ? "Salvar" : "Criar");                                                                                                                                                                                 
        this._model.setProperty("/typeEditable", !bIsEdit);                                                                                                                                                                                                    
        this._syncEditableAll();                                                                                                                                                                                                                               
    };                                                                                                                                                                                                                                                         
                                                                                                                                                                                                                                                               
    CreateEditDialog.prototype._syncEditableAll = function () {                                                                                                                                                                                                
        this._extensions.forEach(function (oExtension) {                                                                                                                                                                                                       
            var sGroup = oExtension.key;                                                                                                                                                                                                                       
            this._syncEditableGroup(sGroup);                                                                                                                                                                                                                   
        }.bind(this));                                                                                                                                                                                                                                         
    };                                                                                                                                                                                                                                                         
                                                                                                                                                                                                                                                               
    CreateEditDialog.prototype._syncEditableGroup = function (sGroup) {                                                                                                                                                                                        
        var sMode = this._model.getProperty("/mode");                                                                                                                                                                                                          
        var sSource = sMode === "edit" ? "editableEdit" : "editableCreate";                                                                                                                                                                                    
        var oSource = this._model.getProperty("/" + sSource + "/" + sGroup) || {};                                                                                                                                                                             
        var oTarget = {};                                                                                                                                                                                                                                      
                                                                                                                                                                                                                                                               
        Object.keys(oSource).forEach(function (sKey) {                                                                                                                                                                                                         
            oTarget[sKey] = oSource[sKey] !== false;                                                                                                                                                                                                           
        });                                                                                                                                                                                                                                                    
                                                                                                                                                                                                                                                               
        this._model.setProperty("/editable/" + sGroup, oTarget);                                                                                                                                                                                               
    };                                                                                                                                                                                                                                                         
                                                                                                                                                                                                                                                               
    CreateEditDialog.prototype._resetAllGroups = function () {                                                                                                                                                                                                 
        this._extensions.forEach(function (oExtension) {                                                                                                                                                                                                       
            this._resetGroup(oExtension.key);                                                                                                                                                                                                                  
        }.bind(this));                                                                                                                                                                                                                                         
    };                                                                                                                                                                                                                                                         
                                                                                                                                                                                                                                                               
    CreateEditDialog.prototype._resetGroup = function (sGroup) {                                                                                                                                                                                               
        var oExtension = this._extensionsByKey[sGroup];                                                                                                                                                                                                        
        if (!oExtension) {                                                                                                                                                                                                                                     
            return;                                                                                                                                                                                                                                            
        }                                                                                                                                                                                                                                                      
                                                                                                                                                                                                                                                               
        var oData = {};                                                                                                                                                                                                                                        
        (oExtension.fields || []).forEach(function (sKey) {                                                                                                                                                                                                    
            oData[sKey] = "";                                                                                                                                                                                                                                  
        });                                                                                                                                                                                                                                                    
        this._model.setProperty("/" + sGroup, oData);                                                                                                                                                                                                          
    };                                                                                                                                                                                                                                                         
                                                                                                                                                                                                                                                               
    CreateEditDialog.prototype._setGroupData = function (sGroup, oData) {                                                                                                                                                                                      
        var oExtension = this._extensionsByKey[sGroup];                                                                                                                                                                                                        
        if (!oExtension) {                                                                                                                                                                                                                                     
            return;                                                                                                                                                                                                                                            
        }                                                                                                                                                                                                                                                      
                                                                                                                                                                                                                                                               
        var oTarget = {};                                                                                                                                                                                                                                      
        (oExtension.fields || []).forEach(function (sKey) {                                                                                                                                                                                                    
            oTarget[sKey] = oData[sKey] || "";                                                                                                                                                                                                                 
        });                                                                                                                                                                                                                                                    
        this._model.setProperty("/" + sGroup, oTarget);                                                                                                                                                                                                        
    };                                                                                                                                                                                                                                                         
                                                                                                                                                                                                                                                               
    CreateEditDialog.prototype._applyPrefill = function (oPrefill) {                                                                                                                                                                                           
        var oData = oPrefill || {};                                                                                                                                                                                                                            
        this._extensions.forEach(function (oExtension) {                                                                                                                                                                                                       
            if (typeof oExtension.applyPrefill === "function") {                                                                                                                                                                                               
                oExtension.applyPrefill(this._model, oData);                                                                                                                                                                                                   
            }                                                                                                                                                                                                                                                  
        }.bind(this));                                                                                                                                                                                                                                         
    };                                                                                                                                                                                                                                                         
                                                                                                                                                                                                                                                               
    CreateEditDialog.prototype._onConfirm = function () {                                                                                                                                                                                                      
        var sMode = this._model.getProperty("/mode");                                                                                                                                                                                                          
        if (sMode === "edit") {                                                                                                                                                                                                                                
            this._handleUpdate();                                                                                                                                                                                                                              
        } else {                                                                                                                                                                                                                                               
            this._handleCreate();                                                                                                                                                                                                                              
        }                                                                                                                                                                                                                                                      
    };                                                                                                                                                                                                                                                         
                                                                                                                                                                                                                                                               
    CreateEditDialog.prototype._handleCreate = function () {                                                                                                                                                                                                   
        var oMainModel = this._component.getModel();                                                                                                                                                                                                           
        if (!oMainModel) {                                                                                                                                                                                                                                     
            MessageBox.error("Modelo OData não está disponível.");                                                                                                                                                                                             
            return;                                                                                                                                                                                                                                            
        }                                                                                                                                                                                                                                                      
                                                                                                                                                                                                                                                               
        var sType = this._model.getProperty("/selectedType");                                                                                                                                                                                                  
        var oValidation = this._validateRequired(sType);                                                                                                                                                                                                       
        if (!oValidation.valid) {                                                                                                                                                                                                                              
            MessageBox.warning("Preencha os campos obrigatórios: " + oValidation.missing.join(", "));                                                                                                                                                          
            return;                                                                                                                                                                                                                                            
        }                                                                                                                                                                                                                                                      
                                                                                                                                                                                                                                                               
        var oPayload = this._buildCreatePayload(sType);                                                                                                                                                                                                        
        var sPath = this._getCreatePath(sType, oPayload);                                                                                                                                                                                                      
        if (!sPath) {                                                                                                                                                                                                                                          
            MessageBox.warning("Selecione uma automação/operação válida antes de criar.");                                                                                                                                                                     
            return;                                                                                                                                                                                                                                            
        }                                                                                                                                                                                                                                                      
                                                                                                                                                                                                                                                               
        oMainModel.create(sPath, oPayload, {                                                                                                                                                                                                                   
            success: function () {                                                                                                                                                                                                                             
                MessageToast.show("Registro criado com sucesso!");                                                                                                                                                                                             
                this._dialog.close();                                                                                                                                                                                                                          
                if (this._onSuccess) {                                                                                                                                                                                                                         
                    this._onSuccess();                                                                                                                                                                                                                         
                }                                                                                                                                                                                                                                              
            }.bind(this),                                                                                                                                                                                                                                      
            error: function (oError) {                                                                                                                                                                                                                         
                MessageBox.error(this._getErrorMessage(oError, sType));                                                                                                                                                                                        
            }.bind(this)                                                                                                                                                                                                                                       
        });                                                                                                                                                                                                                                                    
    };                                                                                                                                                                                                                                                         
                                                                                                                                                                                                                                                               
    CreateEditDialog.prototype._handleUpdate = function () {                                                                                                                                                                                                   
        var oMainModel = this._component.getModel();                                                                                                                                                                                                           
        if (!oMainModel) {                                                                                                                                                                                                                                     
            MessageBox.error("Modelo OData não está disponível.");                                                                                                                                                                                             
            return;                                                                                                                                                                                                                                            
        }                                                                                                                                                                                                                                                      
                                                                                                                                                                                                                                                               
        var sType = this._model.getProperty("/selectedType");                                                                                                                                                                                                  
        var oPayload = this._buildUpdatePayload(sType);                                                                                                                                                                                                        
        var sPath = this._getUpdatePath(sType);                                                                                                                                                                                                                
                                                                                                                                                                                                                                                               
        if (!sPath) {                                                                                                                                                                                                                                          
            MessageBox.warning("Não foi possível montar a chave para atualização.");                                                                                                                                                                           
            return;                                                                                                                                                                                                                                            
        }                                                                                                                                                                                                                                                      
                                                                                                                                                                                                                                                               
        if (!Object.keys(oPayload).length) {                                                                                                                                                                                                                   
            MessageBox.warning("Nenhum campo editável para salvar.");                                                                                                                                                                                          
            return;                                                                                                                                                                                                                                            
        }                                                                                                                                                                                                                                                      
                                                                                                                                                                                                                                                               
        oMainModel.update(sPath, oPayload, {                                                                                                                                                                                                                   
            success: function () {                                                                                                                                                                                                                             
                MessageToast.show("Registro atualizado com sucesso!");                                                                                                                                                                                         
                this._dialog.close();                                                                                                                                                                                                                          
                if (this._onSuccess) {                                                                                                                                                                                                                         
                    this._onSuccess();                                                                                                                                                                                                                         
                }                                                                                                                                                                                                                                              
            }.bind(this),                                                                                                                                                                                                                                      
            error: function (oError) {                                                                                                                                                                                                                         
                MessageBox.error(this._getErrorMessage(oError, sType));                                                                                                                                                                                        
            }.bind(this)                                                                                                                                                                                                                                       
        });                                                                                                                                                                                                                                                    
    };                                                                                                                                                                                                                                                         
                                                                                                                                                                                                                                                               
    CreateEditDialog.prototype._buildCreatePayload = function (sType) {                                                                                                                                                                                        
        var oData = this._model.getProperty("/" + sType) || {};                                                                                                                                                                                                
        var oPayload = {};                                                                                                                                                                                                                                     
                                                                                                                                                                                                                                                               
        Object.keys(oData).forEach(function (sKey) {                                                                                                                                                                                                           
            if (oData[sKey] !== "") {                                                                                                                                                                                                                          
                oPayload[sKey] = oData[sKey];                                                                                                                                                                                                                  
            }                                                                                                                                                                                                                                                  
        });                                                                                                                                                                                                                                                    
                                                                                                                                                                                                                                                               
        return oPayload;                                                                                                                                                                                                                                       
    };                                                                                                                                                                                                                                                         
                                                                                                                                                                                                                                                               
    CreateEditDialog.prototype._buildUpdatePayload = function (sType) {                                                                                                                                                                                        
        var oData = this._model.getProperty("/" + sType) || {};                                                                                                                                                                                                
        var oEditable = this._model.getProperty("/editable/" + sType) || {};                                                                                                                                                                                   
        var oPayload = {};                                                                                                                                                                                                                                     
                                                                                                                                                                                                                                                               
        Object.keys(oData).forEach(function (sKey) {                                                                                                                                                                                                           
            if (oEditable[sKey]) {                                                                                                                                                                                                                             
                oPayload[sKey] = oData[sKey];                                                                                                                                                                                                                  
            }                                                                                                                                                                                                                                                  
        });                                                                                                                                                                                                                                                    
                                                                                                                                                                                                                                                               
        return oPayload;                                                                                                                                                                                                                                       
    };                                                                                                                                                                                                                                                         
                                                                                                                                                                                                                                                               
    CreateEditDialog.prototype._getCreatePath = function (sType, oPayload) {                                                                                                                                                                                   
        var oMainModel = this._component.getModel();                                                                                                                                                                                                           
        if (!oMainModel) {                                                                                                                                                                                                                                     
            return null;                                                                                                                                                                                                                                       
        }                                                                                                                                                                                                                                                      
                                                                                                                                                                                                                                                               
        var oExtension = this._extensionsByKey[sType];                                                                                                                                                                                                         
        if (!oExtension || typeof oExtension.getCreatePath !== "function") {                                                                                                                                                                                   
            return null;                                                                                                                                                                                                                                       
        }                                                                                                                                                                                                                                                      
                                                                                                                                                                                                                                                               
        return oExtension.getCreatePath(oMainModel, oPayload);                                                                                                                                                                                                 
    };                                                                                                                                                                                                                                                         
                                                                                                                                                                                                                                                               
    CreateEditDialog.prototype._getUpdatePath = function (sType) {                                                                                                                                                                                             
        var oMainModel = this._component.getModel();                                                                                                                                                                                                           
        if (!oMainModel) {                                                                                                                                                                                                                                     
            return null;                                                                                                                                                                                                                                       
        }                                                                                                                                                                                                                                                      
                                                                                                                                                                                                                                                               
        var oData = this._model.getProperty("/" + sType) || {};                                                                                                                                                                                                
                                                                                                                                                                                                                                                               
        var oExtension = this._extensionsByKey[sType];                                                                                                                                                                                                         
        if (!oExtension || typeof oExtension.getUpdatePath !== "function") {                                                                                                                                                                                   
            return null;                                                                                                                                                                                                                                       
        }                                                                                                                                                                                                                                                      
                                                                                                                                                                                                                                                               
        return oExtension.getUpdatePath(oMainModel, oData);                                                                                                                                                                                                    
    };                                                                                                                                                                                                                                                         
                                                                                                                                                                                                                                                               
    CreateEditDialog.prototype._validateRequired = function (sType) {                                                                                                                                                                                          
        var oData = this._model.getProperty("/" + sType) || {};                                                                                                                                                                                                
        var oRequired = this._model.getProperty("/required/" + sType) || {};                                                                                                                                                                                   
        var oEditable = this._model.getProperty("/editable/" + sType) || {};                                                                                                                                                                                   
        var oLabels = this._model.getProperty("/labels/" + sType) || {};                                                                                                                                                                                       
        var aMissing = [];                                                                                                                                                                                                                                     
                                                                                                                                                                                                                                                               
        Object.keys(oRequired).forEach(function (sKey) {                                                                                                                                                                                                       
            if (oRequired[sKey] && oEditable[sKey] !== false && !oData[sKey]) {                                                                                                                                                                                
                aMissing.push(oLabels[sKey] || sKey);                                                                                                                                                                                                          
            }                                                                                                                                                                                                                                                  
        });                                                                                                                                                                                                                                                    
                                                                                                                                                                                                                                                               
        return {                                                                                                                                                                                                                                               
            valid: aMissing.length === 0,                                                                                                                                                                                                                      
            missing: aMissing                                                                                                                                                                                                                                  
        };                                                                                                                                                                                                                                                     
    };                                                                                                                                                                                                                                                         
                                                                                                                                                                                                                                                               
    CreateEditDialog.prototype._getErrorMessage = function (oError, sEntity) {                                                                                                                                                                                 
        var sMessage = "Erro ao salvar " + sEntity;                                                                                                                                                                                                            
        if (oError && oError.responseText) {                                                                                                                                                                                                                   
            try {                                                                                                                                                                                                                                              
                var oErrorResponse = JSON.parse(oError.responseText);                                                                                                                                                                                          
                sMessage = oErrorResponse.error.message.value || sMessage;                                                                                                                                                                                     
            } catch (e) {                                                                                                                                                                                                                                      
                // usa mensagem padrao                                                                                                                                                                                                                         
            }                                                                                                                                                                                                                                                  
        }                                                                                                                                                                                                                                                      
        return sMessage;                                                                                                                                                                                                                                       
    };                                                                                                                                                                                                                                                         
                                                                                                                                                                                                                                                               
    return CreateEditDialog;                                                                                                                                                                                                                                   
