<mvc:View                                                                                                                                                                                                                                                      
    controllerName="br.com.gja.zui5.gjaauto.cockpit.controller.FieldMaster"                                                                                                                                                                                    
    xmlns="sap.m"                                                                                                                                                                                                                                              
    xmlns:mvc="sap.ui.core.mvc">                                                                                                                                                                                                                               
    <Page&nbsp;                                                                                                                                                                                                                                                
        id="fieldMasterPage"                                                                                                                                                                                                                                   
        showHeader="true"                                                                                                                                                                                                                                      
        title="{etapa>/parameterDoku/Param}"                                                                                                                                                                                                                   
        showNavButton="true"                                                                                                                                                                                                                                   
        navButtonPress=".onNavBack">                                                                                                                                                                                                                           
        <landmarkInfo>                                                                                                                                                                                                                                         
            <PageAccessibleLandmarkInfo id="_IDGenPageAccessibleLandmarkInfo"                                                                                                                                                                                  
                rootRole="Region"                                                                                                                                                                                                                              
                rootLabel="Lista de Campos"                                                                                                                                                                                                                    
                contentRole="Navigation"                                                                                                                                                                                                                       
                contentLabel="Campos da Estrutura"/>                                                                                                                                                                                                           
        </landmarkInfo>                                                                                                                                                                                                                                        
        <List                                                                                                                                                                                                                                                  
            id="fieldMasterList"                                                                                                                                                                                                                               
            mode="SingleSelectMaster"                                                                                                                                                                                                                          
            selectionChange=".onHomeFieldSelected">                                                                                                                                                                                                            
            <items>                                                                                                                                                                                                                                            
                <!-- Item fixo para Visão Geral -->                                                                                                                                                                                                            
                <StandardListItem&nbsp;                                                                                                                                                                                                                        
                    id="homeFieldItem"                                                                                                                                                                                                                         
                    title="Visão Geral"                                                                                                                                                                                                                        
                    description="Informações da estrutura"                                                                                                                                                                                                     
                    icon="sap-icon://home"                                                                                                                                                                                                                     
                    type="Navigation"/>                                                                                                                                                                                                                        
                </items>                                                                                                                                                                                                                                       
        </List>                                                                                                                                                                                                                                                
        <!-- Lista de campos -->                                                                                                                                                                                                                               
        <List                                                                                                                                                                                                                                                  
            id="fieldItemsList"                                                                                                                                                                                                                                
            items="{etapa>/parameterDoku/items/results}"                                                                                                                                                                                                       
            mode="SingleSelectMaster"                                                                                                                                                                                                                          
            selectionChange=".onFieldSelected">                                                                                                                                                                                                                
            <StandardListItem                                                                                                                                                                                                                                  
            id="_IDGenStandardListItem"                                                                                                                                                                                                                        
                title="{etapa>FieldName}"                                                                                                                                                                                                                      
                type="Navigation"                                                                                                                                                                                                                              
                description="{etapa>Desc}"                                                                                                                                                                                                                     
                icon="{= ${etapa>isMapped} ? 'sap-icon://circle-task-2' : 'sap-icon://circle-task'}"/>                                                                                                                                                         
        </List>                                                                                                                                                                                                                                                
    </Page>                                                                                                                                                                                                                                                    
</mvc:View>                                                                                                                                                                                                                                                    
                                                                                                                                                                                                                                                               