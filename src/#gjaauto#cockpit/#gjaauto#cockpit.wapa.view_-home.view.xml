<mvc:View                                                                                                                                                                                                                                                      
    controllerName="br.com.gja.zui5.gjaauto.cockpit.controller.Home"                                                                                                                                                                                           
    xmlns="sap.m"                                                                                                                                                                                                                                              
    xmlns:mvc="sap.ui.core.mvc"                                                                                                                                                                                                                                
    displayBlock="true"                                                                                                                                                                                                                                        
    height="100%"                                                                                                                                                                                                                                              
>                                                                                                                                                                                                                                                              
    <Page                                                                                                                                                                                                                                                      
        id="homePage"                                                                                                                                                                                                                                          
        showHeader="false"                                                                                                                                                                                                                                     
    >                                                                                                                                                                                                                                                          
        <content>                                                                                                                                                                                                                                              
            <VBox                                                                                                                                                                                                                                              
                id="centerBox"                                                                                                                                                                                                                                 
                alignItems="Center"                                                                                                                                                                                                                            
                justifyContent="Center"                                                                                                                                                                                                                        
                height="100%"                                                                                                                                                                                                                                  
            >                                                                                                                                                                                                                                                  
                <Title                                                                                                                                                                                                                                         
                    id="welcomeTitle"                                                                                                                                                                                                                          
                    text="Escolha uma Automação ou Operação"                                                                                                                                                                                                   
                    level="H1"                                                                                                                                                                                                                                 
                    class="sapUiMediumMargin"                                                                                                                                                                                                                  
                />                                                                                                                                                                                                                                             
                <Text                                                                                                                                                                                                                                          
                    id="instructionText"                                                                                                                                                                                                                       
                    text="Use o menu lateral para navegar"                                                                                                                                                                                                     
                    class="sapUiTinyMarginTop"                                                                                                                                                                                                                 
                />                                                                                                                                                                                                                                             
            </VBox>                                                                                                                                                                                                                                            
        </content>                                                                                                                                                                                                                                             
    </Page>                                                                                                                                                                                                                                                    
</mvc:View>                                                                                                                                                                                                                                                    
                                                                                                                                                                                                                                                               