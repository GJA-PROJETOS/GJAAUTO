sap.ui.define([                                                                                                                                                                                                                                                
    "sap/ui/layout/form/SimpleForm",                                                                                                                                                                                                                           
    "sap/m/Label",                                                                                                                                                                                                                                             
    "sap/m/Input"                                                                                                                                                                                                                                              
], function (SimpleForm, Label, Input) {                                                                                                                                                                                                                       
    "use strict";                                                                                                                                                                                                                                              
                                                                                                                                                                                                                                                               
    return {                                                                                                                                                                                                                                                   
        key: "dados",                                                                                                                                                                                                                                          
        title: "Criar fonte de dados",                                                                                                                                                                                                                         
        entityType: "cds_xgjaautoxsd_cockpit.DadosType",                                                                                                                                                                                                       
        fields: ["Auto", "Opera", "Name", "Reftypname", "Reftype", "EtapaBorn", "Datanatu"],                                                                                                                                                                   
        buildForm: function () {                                                                                                                                                                                                                               
            return new SimpleForm({                                                                                                                                                                                                                            
                layout: "ResponsiveGridLayout",                                                                                                                                                                                                                
                editable: true,                                                                                                                                                                                                                                
                visible: "{= ${create>/selectedType} === 'dados' }",                                                                                                                                                                                           
                content: [                                                                                                                                                                                                                                     
                    new Label({ text: "{create>/labels/dados/Auto}" }),                                                                                                                                                                                        
                    new Input({                                                                                                                                                                                                                                
                        value: "{create>/dados/Auto}",                                                                                                                                                                                                         
                        maxLength: "{create>/maxLength/dados/Auto}",                                                                                                                                                                                           
                        required: "{create>/required/dados/Auto}",                                                                                                                                                                                             
                        editable: "{create>/editable/dados/Auto}"                                                                                                                                                                                              
                    }),                                                                                                                                                                                                                                        
                    new Label({ text: "{create>/labels/dados/Opera}" }),                                                                                                                                                                                       
                    new Input({                                                                                                                                                                                                                                
                        value: "{create>/dados/Opera}",                                                                                                                                                                                                        
                        maxLength: "{create>/maxLength/dados/Opera}",                                                                                                                                                                                          
                        required: "{create>/required/dados/Opera}",                                                                                                                                                                                            
                        editable: "{create>/editable/dados/Opera}"                                                                                                                                                                                             
                    }),                                                                                                                                                                                                                                        
                    new Label({ text: "{create>/labels/dados/Name}" }),                                                                                                                                                                                        
                    new Input({                                                                                                                                                                                                                                
                        value: "{create>/dados/Name}",                                                                                                                                                                                                         
                        maxLength: "{create>/maxLength/dados/Name}",                                                                                                                                                                                           
                        required: "{create>/required/dados/Name}",                                                                                                                                                                                             
                        editable: "{create>/editable/dados/Name}"                                                                                                                                                                                              
                    }),                                                                                                                                                                                                                                        
                    new Label({ text: "{create>/labels/dados/Reftypname}" }),                                                                                                                                                                                  
                    new Input({                                                                                                                                                                                                                                
                        value: "{create>/dados/Reftypname}",                                                                                                                                                                                                   
                        maxLength: "{create>/maxLength/dados/Reftypname}",                                                                                                                                                                                     
                        required: "{create>/required/dados/Reftypname}",                                                                                                                                                                                       
                        editable: "{create>/editable/dados/Reftypname}"                                                                                                                                                                                        
                    }),                                                                                                                                                                                                                                        
                    new Label({ text: "{create>/labels/dados/Reftype}" }),                                                                                                                                                                                     
                    new Input({                                                                                                                                                                                                                                
                        value: "{create>/dados/Reftype}",                                                                                                                                                                                                      
                        maxLength: "{create>/maxLength/dados/Reftype}",                                                                                                                                                                                        
                        required: "{create>/required/dados/Reftype}",                                                                                                                                                                                          
                        editable: "{create>/editable/dados/Reftype}"                                                                                                                                                                                           
                    }),                                                                                                                                                                                                                                        
                    new Label({ text: "{create>/labels/dados/EtapaBorn}" }),                                                                                                                                                                                   
                    new Input({                                                                                                                                                                                                                                
                        value: "{create>/dados/EtapaBorn}",                                                                                                                                                                                                    
                        maxLength: "{create>/maxLength/dados/EtapaBorn}",                                                                                                                                                                                      
                        required: "{create>/required/dados/EtapaBorn}",                                                                                                                                                                                        
                        editable: "{create>/editable/dados/EtapaBorn}"                                                                                                                                                                                         
                    }),                                                                                                                                                                                                                                        
                    new Label({ text: "{create>/labels/dados/Datanatu}" }),                                                                                                                                                                                    
                    new Input({                                                                                                                                                                                                                                
                        value: "{create>/dados/Datanatu}",                                                                                                                                                                                                     
                        maxLength: "{create>/maxLength/dados/Datanatu}",                                                                                                                                                                                       
                        required: "{create>/required/dados/Datanatu}",                                                                                                                                                                                         
                        editable: "{create>/editable/dados/Datanatu}"                                                                                                                                                                                          
                    })                                                                                                                                                                                                                                         
                ]                                                                                                                                                                                                                                              
            });                                                                                                                                                                                                                                                
        },                                                                                                                                                                                                                                                     
        applyPrefill: function (oModel, oPrefill) {                                                                                                                                                                                                            
            if (oPrefill.auto) {                                                                                                                                                                                                                               
                oModel.setProperty("/dados/Auto", oPrefill.auto);                                                                                                                                                                                              
            }                                                                                                                                                                                                                                                  
            if (oPrefill.opera) {                                                                                                                                                                                                                              
                oModel.setProperty("/dados/Opera", oPrefill.opera);                                                                                                                                                                                            
            }                                                                                                                                                                                                                                                  
        },                                                                                                                                                                                                                                                     
        getCreatePath: function (oMainModel, oPayload) {                                                                                                                                                                                                       
            if (!oPayload.Auto || !oPayload.Opera) {                                                                                                                                                                                                           
                return null;                                                                                                                                                                                                                                   
            }                                                                                                                                                                                                                                                  
            var sOperaKey = oMainModel.createKey("Operacoes", {                                                                                                                                                                                                
                auto: oPayload.Auto,                                                                                                                                                                                                                           
                opera: oPayload.Opera                                                                                                                                                                                                                          
            });                                                                                                                                                                                                                                                
            return "/" + sOperaKey + "/to_Dados";                                                                                                                                                                                                              
        },                                                                                                                                                                                                                                                     
        getUpdatePath: function (oMainModel, oData) {                                                                                                                                                                                                          
            return "/" + oMainModel.createKey("Dados", {                                                                                                                                                                                                       
                Auto: oData.Auto,                                                                                                                                                                                                                              
                Opera: oData.Opera,                                                                                                                                                                                                                            
                Name: oData.Name                                                                                                                                                                                                                               
            });                                                                                                                                                                                                                                                
        }                                                                                                                                                                                                                                                      
    };                                                                                                                                                                                                                                                         
});                                                                                                                                                                                                                                                            
                                                                                                                                                                                                                                                               