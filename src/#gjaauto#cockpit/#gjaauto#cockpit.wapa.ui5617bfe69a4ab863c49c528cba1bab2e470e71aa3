sap.ui.define([                                                                                                                                                                                                                                                
    "sap/ui/core/mvc/Controller",                                                                                                                                                                                                                              
    "sap/ui/model/json/JSONModel",                                                                                                                                                                                                                             
    "sap/ui/model/Filter",                                                                                                                                                                                                                                     
    "sap/ui/model/FilterOperator",                                                                                                                                                                                                                             
    "sap/ui/core/routing/History",                                                                                                                                                                                                                             
    "sap/m/MessageBox"                                                                                                                                                                                                                                         
], function (Controller, JSONModel, Filter, FilterOperator, History, MessageBox) {                                                                                                                                                                             
    "use strict";                                                                                                                                                                                                                                              
                                                                                                                                                                                                                                                               
    return Controller.extend("br.com.gja.zui5.gjaauto.cockpit.controller.Operacao", {                                                                                                                                                                          
        /**                                                                                                                                                                                                                                                    
         * Inicializa o controlador.                                                                                                                                                                                                                           
         * @public                                                                                                                                                                                                                                             
         */                                                                                                                                                                                                                                                    
        onInit: function () {                                                                                                                                                                                                                                  
            var oRouter = this.getOwnerComponent().getRouter();                                                                                                                                                                                                
            oRouter.getRoute("RouteOperacao").attachPatternMatched(this._onObjectMatched, this);                                                                                                                                                               
                                                                                                                                                                                                                                                               
            // Cria modelo local para a operação                                                                                                                                                                                                               
            var oViewModel = new JSONModel({                                                                                                                                                                                                                   
                etapas: []                                                                                                                                                                                                                                     
            });                                                                                                                                                                                                                                                
            this.getView().setModel(oViewModel, "operacao");                                                                                                                                                                                                   
                                                                                                                                                                                                                                                               
            // Cria modelo local para os dados                                                                                                                                                                                                                 
            var oDadosModel = new JSONModel({                                                                                                                                                                                                                  
                busy: false,                                                                                                                                                                                                                                   
                items: []                                                                                                                                                                                                                                      
            });                                                                                                                                                                                                                                                
            this.getView().setModel(oDadosModel, "dados");                                                                                                                                                                                                     
        },                                                                                                                                                                                                                                                     
                                                                                                                                                                                                                                                               
        /**                                                                                                                                                                                                                                                    
         * Chamado quando a rota é correspondida.                                                                                                                                                                                                              
         * @param {sap.ui.base.Event} oEvent Evento de correspondência da rota                                                                                                                                                                                 
         * @private                                                                                                                                                                                                                                            
         */                                                                                                                                                                                                                                                    
        _onObjectMatched: function (oEvent) {                                                                                                                                                                                                                  
            var oArgs = oEvent.getParameter("arguments");                                                                                                                                                                                                      
            var sCodigoAuto = oArgs.codigoAuto;                                                                                                                                                                                                                
            var sCodigoOpera = oArgs.codigoOpera;                                                                                                                                                                                                              
&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;                                                                                                                                                                                       
            this._loadOperacao(sCodigoAuto, sCodigoOpera);                                                                                                                                                                                                     
            this._loadDados(sCodigoAuto, sCodigoOpera);                                                                                                                                                                                                        
        },                                                                                                                                                                                                                                                     
                                                                                                                                                                                                                                                               
        /**                                                                                                                                                                                                                                                    
         * Carrega os dados da operação.                                                                                                                                                                                                                       
         * @param {string} sCodigoAuto Código da automação                                                                                                                                                                                                     
         * @param {string} sCodigoOpera Código da operação                                                                                                                                                                                                     
         * @private                                                                                                                                                                                                                                            
         */                                                                                                                                                                                                                                                    
        _loadOperacao: function (sCodigoAuto, sCodigoOpera) {                                                                                                                                                                                                  
            var oView = this.getView();                                                                                                                                                                                                                        
            var oModel = this.getOwnerComponent().getModel();                                                                                                                                                                                                  
&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;                                                                                                                                                                                       
            oView.setBusy(true);                                                                                                                                                                                                                               
                                                                                                                                                                                                                                                               
            // Busca os dados da operação                                                                                                                                                                                                                      
            var sPath = "/Operacoes(auto='" + sCodigoAuto + "',opera='" + sCodigoOpera + "')";                                                                                                                                                                 
&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;                                                                                                                                                                                       
            oModel.read(sPath, {                                                                                                                                                                                                                               
                success: function (oData) {                                                                                                                                                                                                                    
                    oView.getModel("operacao").setProperty("/", oData);                                                                                                                                                                                        
&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;                                                                                                                                       
                    // Carrega as etapas                                                                                                                                                                                                                       
                    this._loadEtapas(sCodigoAuto, sCodigoOpera);                                                                                                                                                                                               
                }.bind(this),                                                                                                                                                                                                                                  
                error: function () {                                                                                                                                                                                                                           
                    oView.setBusy(false);                                                                                                                                                                                                                      
                }.bind(this)                                                                                                                                                                                                                                   
            });                                                                                                                                                                                                                                                
        },                                                                                                                                                                                                                                                     
                                                                                                                                                                                                                                                               
        /**                                                                                                                                                                                                                                                    
         * Carrega as etapas da operação.                                                                                                                                                                                                                      
         * @param {string} sCodigoAuto Código da automação                                                                                                                                                                                                     
         * @param {string} sCodigoOpera Código da operação                                                                                                                                                                                                     
         * @private                                                                                                                                                                                                                                            
         */                                                                                                                                                                                                                                                    
        _loadEtapas: function (sCodigoAuto, sCodigoOpera) {                                                                                                                                                                                                    
            var oView = this.getView();                                                                                                                                                                                                                        
            var oModel = this.getOwnerComponent().getModel();                                                                                                                                                                                                  
                                                                                                                                                                                                                                                               
            // Busca as etapas da operação                                                                                                                                                                                                                     
            oModel.read("/Etapas", {                                                                                                                                                                                                                           
                filters: [                                                                                                                                                                                                                                     
                    new sap.ui.model.Filter("auto", sap.ui.model.FilterOperator.EQ, sCodigoAuto),                                                                                                                                                              
                    new sap.ui.model.Filter("opera", sap.ui.model.FilterOperator.EQ, sCodigoOpera)                                                                                                                                                             
                ],                                                                                                                                                                                                                                             
                urlParameters: {                                                                                                                                                                                                                               
                    "$orderby": "etapa asc"                                                                                                                                                                                                                    
                },                                                                                                                                                                                                                                             
                success: function (oData) {                                                                                                                                                                                                                    
                    oView.getModel("operacao").setProperty("/etapas", oData.results || []);                                                                                                                                                                    
                    oView.setBusy(false);                                                                                                                                                                                                                      
                }.bind(this),                                                                                                                                                                                                                                  
                error: function () {                                                                                                                                                                                                                           
                    oView.setBusy(false);                                                                                                                                                                                                                      
                }.bind(this)                                                                                                                                                                                                                                   
            });                                                                                                                                                                                                                                                
        },                                                                                                                                                                                                                                                     
                                                                                                                                                                                                                                                               
        /**                                                                                                                                                                                                                                                    
         * Carrega os dados da opera????o.                                                                                                                                                                                                                     
         * @param {string} sCodigoAuto C??digo da automa????o                                                                                                                                                                                                  
         * @param {string} sCodigoOpera C??digo da opera????o                                                                                                                                                                                                  
         * @private                                                                                                                                                                                                                                            
         */                                                                                                                                                                                                                                                    
        _loadDados: function (sCodigoAuto, sCodigoOpera) {                                                                                                                                                                                                     
            var oView = this.getView();                                                                                                                                                                                                                        
            var oModel = this.getOwnerComponent().getModel();                                                                                                                                                                                                  
            var oViewModel = oView.getModel("operacao");                                                                                                                                                                                                       
                                                                                                                                                                                                                                                               
            oViewModel.setProperty("/busy", true);                                                                                                                                                                                                             
                                                                                                                                                                                                                                                               
            oModel.read("/Dados", {                                                                                                                                                                                                                            
                filters: [                                                                                                                                                                                                                                     
                    new Filter("Auto", FilterOperator.EQ, sCodigoAuto),                                                                                                                                                                                        
                    new Filter("Opera", FilterOperator.EQ, sCodigoOpera)                                                                                                                                                                                       
                ],                                                                                                                                                                                                                                             
                success: function (oData) {                                                                                                                                                                                                                    
                    oViewModel.setProperty("/items", oData.results || []);                                                                                                                                                                                     
                    oViewModel.setProperty("/busy", false);                                                                                                                                                                                                    
                }.bind(this),                                                                                                                                                                                                                                  
                error: function (oError) {                                                                                                                                                                                                                     
                    oViewModel.setProperty("/busy", false);                                                                                                                                                                                                    
                    this._handleODataError(oError, "Dados");                                                                                                                                                                                                   
                }.bind(this)                                                                                                                                                                                                                                   
            });                                                                                                                                                                                                                                                
        },                                                                                                                                                                                                                                                     
                                                                                                                                                                                                                                                               
        /**                                                                                                                                                                                                                                                    
         * Trata erros de chamadas OData.                                                                                                                                                                                                                      
         * @param {object} oError Objeto de erro                                                                                                                                                                                                               
         * @param {string} sEntity Nome da entidade                                                                                                                                                                                                            
         * @private                                                                                                                                                                                                                                            
         */                                                                                                                                                                                                                                                    
        _handleODataError: function (oError, sEntity) {                                                                                                                                                                                                        
            var sMessage = "Erro ao carregar " + sEntity;                                                                                                                                                                                                      
                                                                                                                                                                                                                                                               
            if (oError && oError.responseText) {                                                                                                                                                                                                               
                try {                                                                                                                                                                                                                                          
                    var oErrorResponse = JSON.parse(oError.responseText);                                                                                                                                                                                      
                    sMessage = oErrorResponse.error.message.value || sMessage;                                                                                                                                                                                 
                } catch (e) {                                                                                                                                                                                                                                  
                    // Usar mensagem padr??o                                                                                                                                                                                                                   
                }                                                                                                                                                                                                                                              
            }                                                                                                                                                                                                                                                  
                                                                                                                                                                                                                                                               
            MessageBox.error(sMessage);                                                                                                                                                                                                                        
        },                                                                                                                                                                                                                                                     
                                                                                                                                                                                                                                                               
        /**                                                                                                                                                                                                                                                    
         * Pesquisa na lista de dados.                                                                                                                                                                                                                         
         * @param {sap.ui.base.Event} oEvent Evento de pesquisa                                                                                                                                                                                                
         * @public                                                                                                                                                                                                                                             
         */                                                                                                                                                                                                                                                    
        onSearchDados: function (oEvent) {                                                                                                                                                                                                                     
            var sQuery = oEvent.getParameter("query");                                                                                                                                                                                                         
            var oTable = this.byId("dadosTable");                                                                                                                                                                                                              
            var oBinding = oTable.getBinding("items");                                                                                                                                                                                                         
                                                                                                                                                                                                                                                               
            if (sQuery) {                                                                                                                                                                                                                                      
                var aFilters = [                                                                                                                                                                                                                               
                    new Filter("Name", FilterOperator.Contains, sQuery),                                                                                                                                                                                       
                    new Filter("Reftypname", FilterOperator.Contains, sQuery)                                                                                                                                                                                  
                ];                                                                                                                                                                                                                                             
                oBinding.filter(new Filter({                                                                                                                                                                                                                   
                    filters: aFilters,                                                                                                                                                                                                                         
                    and: false                                                                                                                                                                                                                                 
                }));                                                                                                                                                                                                                                           
            } else {                                                                                                                                                                                                                                           
                oBinding.filter([]);                                                                                                                                                                                                                           
            }                                                                                                                                                                                                                                                  
        },                                                                                                                                                                                                                                                     
                                                                                                                                                                                                                                                               
        /**                                                                                                                                                                                                                                                    
         * Pesquisa na lista de etapas.                                                                                                                                                                                                                        
         * @param {sap.ui.base.Event} oEvent Evento de pesquisa                                                                                                                                                                                                
         * @public                                                                                                                                                                                                                                             
         */                                                                                                                                                                                                                                                    
        onSearchEtapas: function (oEvent) {                                                                                                                                                                                                                    
            var sQuery = oEvent.getParameter("query");                                                                                                                                                                                                         
            var oTable = this.byId("etapasTable");                                                                                                                                                                                                             
            var oBinding = oTable.getBinding("items");                                                                                                                                                                                                         
                                                                                                                                                                                                                                                               
            if (sQuery) {                                                                                                                                                                                                                                      
                var aFilters = [                                                                                                                                                                                                                               
                    new Filter("descr", FilterOperator.Contains, sQuery),                                                                                                                                                                                      
                    new Filter("etapa", FilterOperator.Contains, sQuery)                                                                                                                                                                                       
                ];                                                                                                                                                                                                                                             
                oBinding.filter(new Filter({                                                                                                                                                                                                                   
                    filters: aFilters,                                                                                                                                                                                                                         
                    and: false                                                                                                                                                                                                                                 
                }));                                                                                                                                                                                                                                           
            } else {                                                                                                                                                                                                                                           
                oBinding.filter([]);                                                                                                                                                                                                                           
            }                                                                                                                                                                                                                                                  
        },                                                                                                                                                                                                                                                     
                                                                                                                                                                                                                                                               
                                                                                                                                                                                                                                                               
        /**                                                                                                                                                                                                                                                    
         * Manipula o clique em um dado.                                                                                                                                                                                                                       
         * @param {sap.ui.base.Event} oEvent Evento de clique                                                                                                                                                                                                  
         * @public                                                                                                                                                                                                                                             
         */                                                                                                                                                                                                                                                    
        onDadoPress: function (oEvent) {                                                                                                                                                                                                                       
            var oItem = oEvent.getSource();                                                                                                                                                                                                                    
            var oContext = oItem.getBindingContext("operacao");                                                                                                                                                                                                
            var oData = oContext ? oContext.getObject() : null;                                                                                                                                                                                                
            if (!oData) {                                                                                                                                                                                                                                      
                return;                                                                                                                                                                                                                                        
            }                                                                                                                                                                                                                                                  
                                                                                                                                                                                                                                                               
            this.getOwnerComponent().getCreateEditDialog().openEdit("dados", oData, function () {                                                                                                                                                              
                var oViewModel = this.getView().getModel("operacao");                                                                                                                                                                                          
                this._loadDados(oViewModel.getProperty("/auto"), oViewModel.getProperty("/opera"));                                                                                                                                                            
            }.bind(this));                                                                                                                                                                                                                                     
        },                                                                                                                                                                                                                                                     
                                                                                                                                                                                                                                                               
        /**                                                                                                                                                                                                                                                    
         * Abre o popup de criaÃ§Ã£o de fonte de dados.                                                                                                                                                                                                        
         * @public                                                                                                                                                                                                                                             
         */                                                                                                                                                                                                                                                    
        onCreateDataFont: function () {                                                                                                                                                                                                                        
            var oViewModel = this.getView().getModel("operacao");                                                                                                                                                                                              
            var sCodigoAuto = oViewModel.getProperty("/auto");                                                                                                                                                                                                 
            var sCodigoOpera = oViewModel.getProperty("/opera");                                                                                                                                                                                               
                                                                                                                                                                                                                                                               
            if (!sCodigoAuto || !sCodigoOpera) {                                                                                                                                                                                                               
                MessageBox.warning("Selecione uma operaÃ§Ã£o vÃ¡lida antes de criar uma fonte de dados.");                                                                                                                                                     
                return;                                                                                                                                                                                                                                        
            }                                                                                                                                                                                                                                                  
                                                                                                                                                                                                                                                               
            this.getOwnerComponent().getCreateEditDialog().openCreate("dados", {                                                                                                                                                                               
                auto: sCodigoAuto,                                                                                                                                                                                                                             
                opera: sCodigoOpera                                                                                                                                                                                                                            
            }, function () {                                                                                                                                                                                                                                   
                this._loadDados(sCodigoAuto, sCodigoOpera);                                                                                                                                                                                                    
            }.bind(this));                                                                                                                                                                                                                                     
        },                                                                                                                                                                                                                                                     
                                                                                                                                                                                                                                                               
        /**                                                                                                                                                                                                                                                    
         * Navega para a tela de detalhes da etapa selecionada.                                                                                                                                                                                                
         * @param {sap.ui.base.Event} oEvent Evento de clique na etapa                                                                                                                                                                                         
         * @public                                                                                                                                                                                                                                             
         */                                                                                                                                                                                                                                                    
        onEtapaPress: function (oEvent) {                                                                                                                                                                                                                      
            var oItem = oEvent.getSource();                                                                                                                                                                                                                    
            var oContext = oItem.getBindingContext("operacao");                                                                                                                                                                                                
            var oEtapaData = oContext.getObject();                                                                                                                                                                                                             
                                                                                                                                                                                                                                                               
            var oViewModel = this.getView().getModel("operacao");                                                                                                                                                                                              
            var sCodigoAuto = oViewModel.getProperty("/auto");                                                                                                                                                                                                 
            var sCodigoOpera = oViewModel.getProperty("/opera");                                                                                                                                                                                               
            var sCodigoEtapa = oEtapaData.etapa;                                                                                                                                                                                                               
                                                                                                                                                                                                                                                               
            var oRouter = this.getOwnerComponent().getRouter();                                                                                                                                                                                                
            oRouter.navTo("RouteEtapa", {                                                                                                                                                                                                                      
                codigoAuto: sCodigoAuto,                                                                                                                                                                                                                       
                codigoOpera: sCodigoOpera,                                                                                                                                                                                                                     
                codigoEtapa: sCodigoEtapa                                                                                                                                                                                                                      
            });                                                                                                                                                                                                                                                
        },                                                                                                                                                                                                                                                     
                                                                                                                                                                                                                                                               
        /**                                                                                                                                                                                                                                                    
         * Abre o popup de edição da operação.                                                                                                                                                                                                                 
         * @public                                                                                                                                                                                                                                             
         */                                                                                                                                                                                                                                                    
        onEditOperacao: function () {                                                                                                                                                                                                                          
            var oData = this.getView().getModel("operacao").getProperty("/") || {};                                                                                                                                                                            
            if (!oData.auto || !oData.opera) {                                                                                                                                                                                                                 
                return;                                                                                                                                                                                                                                        
            }                                                                                                                                                                                                                                                  
                                                                                                                                                                                                                                                               
            this.getOwnerComponent().getCreateEditDialog().openEdit("operacao", oData, function () {                                                                                                                                                           
                this._loadOperacao(oData.auto, oData.opera);                                                                                                                                                                                                   
            }.bind(this));                                                                                                                                                                                                                                     
        }                                                                                                                                                                                                                                                      
    });                                                                                                                                                                                                                                                        
});                                                                                                                                                                                                                                                            
                                                                                                                                                                                                                                                               