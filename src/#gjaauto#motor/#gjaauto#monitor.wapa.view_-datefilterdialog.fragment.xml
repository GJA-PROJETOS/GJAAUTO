<core:FragmentDefinition                                                                                                                                                                                                                                       
	xmlns="sap.m"                                                                                                                                                                                                                                                 
	xmlns:core="sap.ui.core">                                                                                                                                                                                                                                     
	<Dialog                                                                                                                                                                                                                                                       
		id="dateFilterDialog"                                                                                                                                                                                                                                        
		title="Filtrar por Data"                                                                                                                                                                                                                                     
		contentWidth="400px">                                                                                                                                                                                                                                        
		<content>                                                                                                                                                                                                                                                    
			<VBox id="_IDGenVBox2" class="sapUiSmallMargin">                                                                                                                                                                                                            
				<Label id="_IDGenLabel5" text="Tipo de Filtro:" class="sapUiTinyMarginBottom"/>                                                                                                                                                                            
				<Select                                                                                                                                                                                                                                                    
					id="filterTypeSelect"                                                                                                                                                                                                                                     
					width="100%"                                                                                                                                                                                                                                              
					selectedKey="{monitor>/dateFilterType}"                                                                                                                                                                                                                   
					change=".onDateFilterTypeChange"                                                                                                                                                                                                                          
					class="sapUiSmallMarginBottom">                                                                                                                                                                                                                           
					<items>                                                                                                                                                                                                                                                   
						<core:Item id="_IDGenItem5" key="hoje" text="Hoje"/>                                                                                                                                                                                                     
						<core:Item id="_IDGenItem6" key="especifica" text="Data Específica"/>                                                                                                                                                                                    
						<core:Item id="_IDGenItem7" key="range" text="Intervalo de Datas"/>                                                                                                                                                                                      
						<core:Item id="_IDGenItem8" key="mes" text="Mês"/>                                                                                                                                                                                                       
						<core:Item id="_IDGenItem9" key="ano" text="Ano"/>                                                                                                                                                                                                       
					</items>                                                                                                                                                                                                                                                  
				</Select>                                                                                                                                                                                                                                                  
				                                                                                                                                                                                                                                                           
				<!-- Range de datas -->                                                                                                                                                                                                                                    
				<VBox id="rangeBox" visible="false" class="sapUiSmallMarginTop">                                                                                                                                                                                           
					<Label id="_IDGenLabel6" text="Data Início:" class="sapUiTinyMarginBottom"/>                                                                                                                                                                              
					<DatePicker                                                                                                                                                                                                                                               
						id="dataInicioPicker"                                                                                                                                                                                                                                    
						value="{monitor>/dateFilterStart}"                                                                                                                                                                                                                       
						valueFormat="yyyy-MM-dd"                                                                                                                                                                                                                                 
						displayFormat="dd/MM/yyyy"                                                                                                                                                                                                                               
						class="sapUiSmallMarginBottom"/>                                                                                                                                                                                                                         
					<Label id="_IDGenLabel7" text="Data Fim:" class="sapUiTinyMarginBottom"/>                                                                                                                                                                                 
					<DatePicker                                                                                                                                                                                                                                               
						id="dataFimPicker"                                                                                                                                                                                                                                       
						value="{monitor>/dateFilterEnd}"                                                                                                                                                                                                                         
						valueFormat="yyyy-MM-dd"                                                                                                                                                                                                                                 
						displayFormat="dd/MM/yyyy"/>                                                                                                                                                                                                                             
				</VBox>                                                                                                                                                                                                                                                    
				                                                                                                                                                                                                                                                           
				<!-- Data específica -->                                                                                                                                                                                                                                   
				<VBox id="especificaBox" visible="false" class="sapUiSmallMarginTop">                                                                                                                                                                                      
					<Label id="_IDGenLabel8" text="Data:" class="sapUiTinyMarginBottom"/>                                                                                                                                                                                     
					<DatePicker                                                                                                                                                                                                                                               
						id="dataEspecificaPicker"                                                                                                                                                                                                                                
						value="{monitor>/dateFilterSpecific}"                                                                                                                                                                                                                    
						valueFormat="yyyy-MM-dd"                                                                                                                                                                                                                                 
						displayFormat="dd/MM/yyyy"/>                                                                                                                                                                                                                             
				</VBox>                                                                                                                                                                                                                                                    
				                                                                                                                                                                                                                                                           
				<!-- Mês e Ano -->                                                                                                                                                                                                                                         
				<VBox id="mesAnoBox" visible="false" class="sapUiSmallMarginTop">                                                                                                                                                                                          
					<Label id="_IDGenLabel9" text="Mês:" class="sapUiTinyMarginBottom"/>                                                                                                                                                                                      
					<Select                                                                                                                                                                                                                                                   
						id="mesSelect"                                                                                                                                                                                                                                           
						selectedKey="{monitor>/dateFilterMonth}"                                                                                                                                                                                                                 
						class="sapUiSmallMarginBottom">                                                                                                                                                                                                                          
						<items>                                                                                                                                                                                                                                                  
							<core:Item id="_IDGenItem11" key="0" text="Janeiro"/>                                                                                                                                                                                                   
							<core:Item id="_IDGenItem12" key="1" text="Fevereiro"/>                                                                                                                                                                                                 
							<core:Item id="_IDGenItem13" key="2" text="Março"/>                                                                                                                                                                                                     
							<core:Item id="_IDGenItem14" key="3" text="Abril"/>                                                                                                                                                                                                     
							<core:Item id="_IDGenItem15" key="4" text="Maio"/>                                                                                                                                                                                                      
							<core:Item id="_IDGenItem16" key="5" text="Junho"/>                                                                                                                                                                                                     
							<core:Item id="_IDGenItem17" key="6" text="Julho"/>                                                                                                                                                                                                     
							<core:Item id="_IDGenItem18" key="7" text="Agosto"/>                                                                                                                                                                                                    
							<core:Item id="_IDGenItem19" key="8" text="Setembro"/>                                                                                                                                                                                                  
							<core:Item id="_IDGenItem20" key="9" text="Outubro"/>                                                                                                                                                                                                   
							<core:Item id="_IDGenItem21" key="10" text="Novembro"/>                                                                                                                                                                                                 
							<core:Item id="_IDGenItem22" key="11" text="Dezembro"/>                                                                                                                                                                                                 
						</items>                                                                                                                                                                                                                                                 
					</Select>                                                                                                                                                                                                                                                 
					<Label id="_IDGenLabel10" text="Ano:" class="sapUiTinyMarginBottom"/>                                                                                                                                                                                     
					<Input                                                                                                                                                                                                                                                    
						id="anoInputMes"                                                                                                                                                                                                                                         
						value="{monitor>/dateFilterYear}"                                                                                                                                                                                                                        
						type="Number"/>                                                                                                                                                                                                                                          
				</VBox>                                                                                                                                                                                                                                                    
				                                                                                                                                                                                                                                                           
				<!-- Ano -->                                                                                                                                                                                                                                               
				<VBox id="anoBox" visible="false" class="sapUiSmallMarginTop">                                                                                                                                                                                             
					<Label id="_IDGenLabel11" text="Ano:" class="sapUiTinyMarginBottom"/>                                                                                                                                                                                     
					<Input                                                                                                                                                                                                                                                    
						id="anoInput"                                                                                                                                                                                                                                            
						value="{monitor>/dateFilterYear}"                                                                                                                                                                                                                        
						type="Number"/>                                                                                                                                                                                                                                          
				</VBox>                                                                                                                                                                                                                                                    
			</VBox>                                                                                                                                                                                                                                                     
		</content>                                                                                                                                                                                                                                                   
		<beginButton>                                                                                                                                                                                                                                                
			<Button id="_IDGenButton3"                                                                                                                                                                                                                                  
				text="Aplicar"                                                                                                                                                                                                                                             
				type="Emphasized"                                                                                                                                                                                                                                          
				press=".onConfirmDateFilter"/>                                                                                                                                                                                                                             
		</beginButton>                                                                                                                                                                                                                                               
		<endButton>                                                                                                                                                                                                                                                  
			<Button id="_IDGenButton4"                                                                                                                                                                                                                                  
				text="Cancelar"                                                                                                                                                                                                                                            
				press=".onCancelDateFilter"/>                                                                                                                                                                                                                              
		</endButton>                                                                                                                                                                                                                                                 
	</Dialog>                                                                                                                                                                                                                                                     
</core:FragmentDefinition>                                                                                                                                                                                                                                     
                                                                                                                                                                                                                                                               