sap.ui.define([                                                                                                                                                                                                                                                
    "sap/ui/core/mvc/Controller",                                                                                                                                                                                                                              
    "sap/ui/model/json/JSONModel",                                                                                                                                                                                                                             
    "sap/ui/model/Filter",                                                                                                                                                                                                                                     
    "sap/ui/model/FilterOperator",                                                                                                                                                                                                                             
    "sap/m/MessageToast",                                                                                                                                                                                                                                      
    "sap/m/MessageBox"                                                                                                                                                                                                                                         
], function (Controller, JSONModel, Filter, FilterOperator, MessageToast, MessageBox) {                                                                                                                                                                        
    "use strict";                                                                                                                                                                                                                                              
                                                                                                                                                                                                                                                               
    return Controller.extend("br.com.gja.zui5.gjaauto.monitor.controller.Monitor", {                                                                                                                                                                           
        onInit: function () {                                                                                                                                                                                                                                  
            var oHoje = new Date();                                                                                                                                                                                                                            
            oHoje.setHours(0, 0, 0, 0);                                                                                                                                                                                                                        
            var oViewModel = new JSONModel({                                                                                                                                                                                                                   
                automacoesTodas: [],                                                                                                                                                                                                                           
                automacoesFiltradas: [],                                                                                                                                                                                                                       
                busy: false,                                                                                                                                                                                                                                   
                tituloOperacao: "",                                                                                                                                                                                                                            
                ordenacaoDecrescente: true,                                                                                                                                                                                                                    
                autoSelected: "",                                                                                                                                                                                                                              
                operaSelected: "",                                                                                                                                                                                                                             
                filters: [],                                                                                                                                                                                                                                   
                filtroDataTipo: "hoje",                                                                                                                                                                                                                        
                filtroDataInicio: oHoje,                                                                                                                                                                                                                       
                filtroDataFim: oHoje,                                                                                                                                                                                                                          
                filtroDataEspecifica: oHoje,                                                                                                                                                                                                                   
                filtroMes: oHoje.getMonth(),                                                                                                                                                                                                                   
                filtroAno: oHoje.getFullYear(),                                                                                                                                                                                                                
                filtroDataAtivo: true,                                                                                                                                                                                                                         
            });                                                                                                                                                                                                                                                
                                                                                                                                                                                                                                                               
            this.getView().setModel(oViewModel, "monitor");                                                                                                                                                                                                    
                                                                                                                                                                                                                                                               
            // Carregar menu de automações                                                                                                                                                                                                                     
            this._loadMenuData();                                                                                                                                                                                                                              
                                                                                                                                                                                                                                                               
            // Buscar todas as execuções inicialmente                                                                                                                                                                                                          
            this.onItemSelect();                                                                                                                                                                                                                               
        },                                                                                                                                                                                                                                                     
        _getOrderByFunction: function () {                                                                                                                                                                                                                     
            var oViewModel = this.getView().getModel("monitor");                                                                                                                                                                                               
            var sOrderBy = oViewModel.getProperty("/ordenacaoDecrescente");                                                                                                                                                                                    
            return "Chave " + (sOrderBy ? "desc" : "asc");                                                                                                                                                                                                     
        },                                                                                                                                                                                                                                                     
        /**                                                                                                                                                                                                                                                    
         * Constrói filtro de data em formato OData                                                                                                                                                                                                            
         * @returns {string} String de filtro OData ou vazio se não houver filtro ativo                                                                                                                                                                        
         * @private                                                                                                                                                                                                                                            
         */                                                                                                                                                                                                                                                    
        _buildDateFilterOData: function () {                                                                                                                                                                                                                   
            var oViewModel = this.getView().getModel("monitor");                                                                                                                                                                                               
            var sTipoFiltroData = oViewModel.getProperty("/filtroDataTipo");                                                                                                                                                                                   
            var bFiltroDataAtivo = oViewModel.getProperty("/filtroDataAtivo");                                                                                                                                                                                 
                                                                                                                                                                                                                                                               
            // Se filtro não está ativo ou tipo é "todas", retornar vazio                                                                                                                                                                                      
            if (!bFiltroDataAtivo || sTipoFiltroData === "todas") {                                                                                                                                                                                            
                return "";                                                                                                                                                                                                                                     
            }                                                                                                                                                                                                                                                  
                                                                                                                                                                                                                                                               
            var oHoje = new Date();                                                                                                                                                                                                                            
            oHoje.setHours(0, 0, 0, 0);                                                                                                                                                                                                                        
            var sDateFilter = "";                                                                                                                                                                                                                              
                                                                                                                                                                                                                                                               
            // Função auxiliar para formatar data no padrão OData v2 do SAP                                                                                                                                                                                    
            var formatODataDate = function (oDate) {                                                                                                                                                                                                           
                var sYear = oDate.getFullYear();                                                                                                                                                                                                               
                var sMonth = String(oDate.getMonth() + 1).padStart(2, '0');                                                                                                                                                                                    
                var sDay = String(oDate.getDate()).padStart(2, '0');                                                                                                                                                                                           
                var sHours = String(oDate.getHours()).padStart(2, '0');                                                                                                                                                                                        
                var sMinutes = String(oDate.getMinutes()).padStart(2, '0');                                                                                                                                                                                    
                var sSeconds = String(oDate.getSeconds()).padStart(2, '0');                                                                                                                                                                                    
                return "datetime'" + sYear + "-" + sMonth + "-" + sDay + "T" + sHours + ":" + sMinutes + ":" + sSeconds + "'";                                                                                                                                 
            };                                                                                                                                                                                                                                                 
                                                                                                                                                                                                                                                               
            switch (sTipoFiltroData) {                                                                                                                                                                                                                         
                case "hoje":                                                                                                                                                                                                                                   
                    // Filtrar execuções do dia atual                                                                                                                                                                                                          
                    var oHojeFim = new Date(oHoje);                                                                                                                                                                                                            
                    oHojeFim.setHours(23, 59, 59, 0);                                                                                                                                                                                                          
                    sDateFilter = "Credat ge " + formatODataDate(oHoje) + " and Credat le " + formatODataDate(oHojeFim);                                                                                                                                       
                    break;                                                                                                                                                                                                                                     
                                                                                                                                                                                                                                                               
                case "especifica":                                                                                                                                                                                                                             
                    // Filtrar por data específica                                                                                                                                                                                                             
                    var oDataEspecifica = oViewModel.getProperty("/filtroDataEspecifica");                                                                                                                                                                     
                    if (oDataEspecifica) {                                                                                                                                                                                                                     
                        var oDataEspecificaInicio = new Date(oDataEspecifica);                                                                                                                                                                                 
                        oDataEspecificaInicio.setHours(0, 0, 0, 0);                                                                                                                                                                                            
                        var oDataEspecificaFim = new Date(oDataEspecifica);                                                                                                                                                                                    
                        oDataEspecificaFim.setHours(23, 59, 59, 0);                                                                                                                                                                                            
                        sDateFilter = "Credat ge " + formatODataDate(oDataEspecificaInicio) + " and Credat le " + formatODataDate(oDataEspecificaFim);                                                                                                         
                    }                                                                                                                                                                                                                                          
                    break;                                                                                                                                                                                                                                     
                                                                                                                                                                                                                                                               
                case "range":                                                                                                                                                                                                                                  
                    // Filtrar por intervalo de datas                                                                                                                                                                                                          
                    var oDataInicio = oViewModel.getProperty("/filtroDataInicio");                                                                                                                                                                             
                    var oDataFim = oViewModel.getProperty("/filtroDataFim");                                                                                                                                                                                   
                    if (oDataInicio && oDataFim) {                                                                                                                                                                                                             
                        var oRangeInicio = new Date(oDataInicio);                                                                                                                                                                                              
                        oRangeInicio.setHours(0, 0, 0, 0);                                                                                                                                                                                                     
                        var oRangeFim = new Date(oDataFim);                                                                                                                                                                                                    
                        oRangeFim.setHours(23, 59, 59, 0);                                                                                                                                                                                                     
                        sDateFilter = "Credat ge " + formatODataDate(oRangeInicio) + " and Credat le " + formatODataDate(oRangeFim);                                                                                                                           
                    }                                                                                                                                                                                                                                          
                    break;                                                                                                                                                                                                                                     
                                                                                                                                                                                                                                                               
                case "mes":                                                                                                                                                                                                                                    
                    // Filtrar por mês e ano                                                                                                                                                                                                                   
                    var iMes = oViewModel.getProperty("/filtroMes");                                                                                                                                                                                           
                    var iAno = oViewModel.getProperty("/filtroAno");                                                                                                                                                                                           
                    var oMesInicio = new Date(iAno, iMes, 1, 0, 0, 0, 0);                                                                                                                                                                                      
                    var oMesFim = new Date(iAno, iMes + 1, 0, 23, 59, 59, 0);                                                                                                                                                                                  
                    sDateFilter = "Credat ge " + formatODataDate(oMesInicio) + " and Credat le " + formatODataDate(oMesFim);                                                                                                                                   
                    break;                                                                                                                                                                                                                                     
                                                                                                                                                                                                                                                               
                case "ano":                                                                                                                                                                                                                                    
                    // Filtrar por ano                                                                                                                                                                                                                         
                    var iAno = oViewModel.getProperty("/filtroAno");                                                                                                                                                                                           
                    var oAnoInicio = new Date(iAno, 0, 1, 0, 0, 0, 0);                                                                                                                                                                                         
                    var oAnoFim = new Date(iAno, 11, 31, 23, 59, 59, 0);                                                                                                                                                                                       
                    sDateFilter = "Credat ge " + formatODataDate(oAnoInicio) + " and Credat le " + formatODataDate(oAnoFim);                                                                                                                                   
                    break;                                                                                                                                                                                                                                     
            }                                                                                                                                                                                                                                                  
                                                                                                                                                                                                                                                               
            return sDateFilter;                                                                                                                                                                                                                                
        },                                                                                                                                                                                                                                                     
        _loadMenuData: function () {                                                                                                                                                                                                                           
            var oModel = this.getOwnerComponent().getModel();                                                                                                                                                                                                  
            var oViewModel = this.getView().getModel("monitor");                                                                                                                                                                                               
            var oSharedModel = this.getOwnerComponent().getModel("shared");                                                                                                                                                                                    
            var that = this;                                                                                                                                                                                                                                   
                                                                                                                                                                                                                                                               
            if (!oModel) {                                                                                                                                                                                                                                     
                MessageBox.error("Modelo OData não está disponível. Verifique a configuração do manifest.json");                                                                                                                                               
                return;                                                                                                                                                                                                                                        
            }                                                                                                                                                                                                                                                  
                                                                                                                                                                                                                                                               
            oViewModel.setProperty("/busy", true);                                                                                                                                                                                                             
                                                                                                                                                                                                                                                               
            oModel.read("/Automacoes", {                                                                                                                                                                                                                       
                urlParameters: {                                                                                                                                                                                                                               
                    "$expand": "to_Operacoes",                                                                                                                                                                                                                 
                },                                                                                                                                                                                                                                             
                success: function (oData) {                                                                                                                                                                                                                    
                    var aResults = [                                                                                                                                                                                                                           
                        { descr: "Todas as Automações", icon_fiori: "sap-icon://activities", to_Operacoes: { results: [] } }                                                                                                                                   
                    ].concat(oData.results);                                                                                                                                                                                                                   
                    // Salvar no modelo global compartilhado                                                                                                                                                                                                   
                    oSharedModel.setProperty("/automacoesCK", aResults);                                                                                                                                                                                       
                    oViewModel.setProperty("/busy", false);                                                                                                                                                                                                    
                    MessageToast.show("Dados carregados com sucesso!");                                                                                                                                                                                        
                },                                                                                                                                                                                                                                             
                error: function (oError) {                                                                                                                                                                                                                     
                    oViewModel.setProperty("/busy", false);                                                                                                                                                                                                    
                    that._handleLoadError(oError, oViewModel, "Automacoes");                                                                                                                                                                                   
                }                                                                                                                                                                                                                                              
            });                                                                                                                                                                                                                                                
        },                                                                                                                                                                                                                                                     
                                                                                                                                                                                                                                                               
        _handleLoadError: function (oError, oViewModel, sEntity) {                                                                                                                                                                                             
            oViewModel.setProperty("/busy", false);                                                                                                                                                                                                            
            var sMessage = "Erro ao carregar " + sEntity;                                                                                                                                                                                                      
            if (oError && oError.responseText) {                                                                                                                                                                                                               
                try {                                                                                                                                                                                                                                          
                    var oErrorResponse = JSON.parse(oError.responseText);                                                                                                                                                                                      
                    sMessage = oErrorResponse.error.message.value || sMessage;                                                                                                                                                                                 
                } catch (e) {                                                                                                                                                                                                                                  
                    // Usar mensagem padrão                                                                                                                                                                                                                    
                }                                                                                                                                                                                                                                              
            }                                                                                                                                                                                                                                                  
            MessageBox.error(sMessage);                                                                                                                                                                                                                        
        },                                                                                                                                                                                                                                                     
        onItemSelect: function (oEvent) {                                                                                                                                                                                                                      
            if (this.byId("toolPage").getSideExpanded()) {                                                                                                                                                                                                     
                this.onSideNavButtonPress();                                                                                                                                                                                                                   
            }                                                                                                                                                                                                                                                  
            var oViewModel = this.getView().getModel("monitor");                                                                                                                                                                                               
            var oSharedModel = this.getOwnerComponent().getModel("shared");                                                                                                                                                                                    
            var sDescricao = "";                                                                                                                                                                                                                               
            var oMonitorModel = this.getOwnerComponent().getModel("monitorOData");                                                                                                                                                                             
            if (oEvent !== undefined) {                                                                                                                                                                                                                        
                var oSelectedItem = oEvent.getParameter("item");                                                                                                                                                                                               
                var keys = oSelectedItem.getKey().split("-");                                                                                                                                                                                                  
                var sAuto = keys[0];                                                                                                                                                                                                                           
                oViewModel.setProperty("/autoSelected", sAuto);                                                                                                                                                                                                
                var sOpera = keys[1];                                                                                                                                                                                                                          
                oViewModel.setProperty("/operaSelected", sOpera);                                                                                                                                                                                              
            } else {                                                                                                                                                                                                                                           
                var sAuto = oViewModel.getProperty("/autoSelected");                                                                                                                                                                                           
                var sOpera = oViewModel.getProperty("/operaSelected");                                                                                                                                                                                         
            }                                                                                                                                                                                                                                                  
            var that = this;                                                                                                                                                                                                                                   
                                                                                                                                                                                                                                                               
            if (sOpera) {                                                                                                                                                                                                                                      
                var oAutomacaoCK = oSharedModel.getProperty("/automacoesCK").find(function (oAuto) { return oAuto.auto === sAuto; });                                                                                                                          
                var oOperacaoCK = oAutomacaoCK.to_Operacoes.results.find(function (oOpera) { return oOpera.opera === sOpera; });                                                                                                                               
                sDescricao = sAuto + " - " + sOpera + " - " + oOperacaoCK.descr;                                                                                                                                                                               
                                                                                                                                                                                                                                                               
                // Construir filtro completo incluindo data                                                                                                                                                                                                    
                var sFilter = "Auto eq '" + sAuto + "' and Opera eq '" + sOpera + "'";                                                                                                                                                                         
                var sDateFilter = this._buildDateFilterOData();                                                                                                                                                                                                
                if (sDateFilter) {                                                                                                                                                                                                                             
                    sFilter += " and (" + sDateFilter + ")";                                                                                                                                                                                                   
                }                                                                                                                                                                                                                                              
                                                                                                                                                                                                                                                               
                // Buscar headers filtrados por Auto e Opera                                                                                                                                                                                                   
                oMonitorModel.read("/Header", {                                                                                                                                                                                                                
                    urlParameters: {                                                                                                                                                                                                                           
                        "$expand": "to_EtapasExecutadas/to_Logs",                                                                                                                                                                                              
                        "$filter": sFilter                                                                                                                                                                                                                     
                    },                                                                                                                                                                                                                                         
                    success: function (oData) {                                                                                                                                                                                                                
                        that.preparaAutomaçõesFiltradas(oData, that);                                                                                                                                                                                          
                    },                                                                                                                                                                                                                                         
                    error: function (oError) {                                                                                                                                                                                                                 
                        oViewModel.setProperty("/busy", false);                                                                                                                                                                                                
                        MessageBox.error("Erro ao carregar execuções: " + (oError.message || ""));                                                                                                                                                             
                    }                                                                                                                                                                                                                                          
                });                                                                                                                                                                                                                                            
            } else if (sAuto === "") {                                                                                                                                                                                                                         
                sDescricao = "Todas as Automações";                                                                                                                                                                                                            
                                                                                                                                                                                                                                                               
                // Construir filtro de data se houver                                                                                                                                                                                                          
                var sDateFilter = this._buildDateFilterOData();                                                                                                                                                                                                
                var oUrlParams = {                                                                                                                                                                                                                             
                    "$expand": "to_EtapasExecutadas/to_Logs"                                                                                                                                                                                                   
                };                                                                                                                                                                                                                                             
                if (sDateFilter) {                                                                                                                                                                                                                             
                    oUrlParams["$filter"] = sDateFilter;                                                                                                                                                                                                       
                }                                                                                                                                                                                                                                              
                                                                                                                                                                                                                                                               
                // Buscar todos os headers                                                                                                                                                                                                                     
                oMonitorModel.read("/Header", {                                                                                                                                                                                                                
                    urlParameters: oUrlParams,                                                                                                                                                                                                                 
                    success: function (oData) {                                                                                                                                                                                                                
                        that.preparaAutomaçõesFiltradas(oData, that);                                                                                                                                                                                          
                    },                                                                                                                                                                                                                                         
                    error: function (oError) {                                                                                                                                                                                                                 
                        oViewModel.setProperty("/busy", false);                                                                                                                                                                                                
                        MessageBox.error("Erro ao carregar execuções: " + (oError.message || ""));                                                                                                                                                             
                    }                                                                                                                                                                                                                                          
                });                                                                                                                                                                                                                                            
            } else {                                                                                                                                                                                                                                           
                var oAutomacaoCK = oSharedModel.getProperty("/automacoesCK").find(function (oAuto) { return oAuto.auto === sAuto; });                                                                                                                          
                sDescricao = sAuto + " - " + oAutomacaoCK.descr;                                                                                                                                                                                               
                                                                                                                                                                                                                                                               
                // Construir filtro completo incluindo data                                                                                                                                                                                                    
                var sFilter = "Auto eq '" + sAuto + "'";                                                                                                                                                                                                       
                var sDateFilter = this._buildDateFilterOData();                                                                                                                                                                                                
                if (sDateFilter) {                                                                                                                                                                                                                             
                    sFilter += " and (" + sDateFilter + ")";                                                                                                                                                                                                   
                }                                                                                                                                                                                                                                              
                                                                                                                                                                                                                                                               
                // Buscar headers filtrados por Auto                                                                                                                                                                                                           
                oMonitorModel.read("/Header", {                                                                                                                                                                                                                
                    urlParameters: {                                                                                                                                                                                                                           
                        "$expand": "to_EtapasExecutadas/to_Logs",                                                                                                                                                                                              
                        "$filter": sFilter                                                                                                                                                                                                                     
                    },                                                                                                                                                                                                                                         
                    success: function (oData) {                                                                                                                                                                                                                
                        that.preparaAutomaçõesFiltradas(oData, that);                                                                                                                                                                                          
                    },                                                                                                                                                                                                                                         
                    error: function (oError) {                                                                                                                                                                                                                 
                        oViewModel.setProperty("/busy", false);                                                                                                                                                                                                
                        MessageBox.error("Erro ao carregar execuções: " + (oError.message || ""));                                                                                                                                                             
                    }                                                                                                                                                                                                                                          
                });                                                                                                                                                                                                                                            
            }                                                                                                                                                                                                                                                  
            oViewModel.setProperty("/tituloOperacao", sDescricao);                                                                                                                                                                                             
        },                                                                                                                                                                                                                                                     
        preparaAutomaçõesFiltradas: function (oData, that) {                                                                                                                                                                                                   
            var oViewModel = this.getView().getModel("monitor");                                                                                                                                                                                               
            var iCountSuccess = 0;                                                                                                                                                                                                                             
            var iCountError = 0;                                                                                                                                                                                                                               
            var iCountWarning = 0;                                                                                                                                                                                                                             
            var iCountNone = 0;                                                                                                                                                                                                                                
            oViewModel.setProperty("/execucoesTodas", oData.results);                                                                                                                                                                                          
            var automacoesFiltradas = [];                                                                                                                                                                                                                      
            oData.results.forEach(function (oAuto) {                                                                                                                                                                                                           
                var AutoDuration = "";                                                                                                                                                                                                                         
                var oStatusHeader = that._getStatusHeader(oAuto.Status);                                                                                                                                                                                       
                                                                                                                                                                                                                                                               
                // Formatar data e hora                                                                                                                                                                                                                        
                var sData = "";                                                                                                                                                                                                                                
                var oDateObj = null;                                                                                                                                                                                                                           
                if (oAuto.Credat) {                                                                                                                                                                                                                            
                    oDateObj = that._combineDateAndTime(oAuto.Credat, oAuto.Cretim);                                                                                                                                                                           
                    sData = oDateObj.toLocaleDateString("pt-BR") + " " + oDateObj.toLocaleTimeString("pt-BR");                                                                                                                                                 
                }                                                                                                                                                                                                                                              
                                                                                                                                                                                                                                                               
                if (oAuto.Status === "2" && oAuto.to_EtapasExecutadas && oAuto.to_EtapasExecutadas.results.length > 0) {                                                                                                                                       
                    var oLastEtapa = oAuto.to_EtapasExecutadas.results[oAuto.to_EtapasExecutadas.results.length - 1];                                                                                                                                          
                    if (oLastEtapa.Credat && oLastEtapa.Cretim && oAuto.Credat && oAuto.Cretim) {                                                                                                                                                              
                        var oStartDateTime = that._combineDateAndTime(oAuto.Credat, oAuto.Cretim);                                                                                                                                                             
                        var oEndDateTime = that._combineDateAndTime(oLastEtapa.Credat, oLastEtapa.Cretim);                                                                                                                                                     
                        var durationInMilliseconds = Math.abs(oEndDateTime - oStartDateTime);                                                                                                                                                                  
                        var durationInSeconds = durationInMilliseconds / 1000;                                                                                                                                                                                 
                        var durationInMinutes = Math.floor(durationInSeconds / 60);                                                                                                                                                                            
                        var durationInHours = Math.floor(durationInMinutes / 60);                                                                                                                                                                              
                                                                                                                                                                                                                                                               
                        if (durationInHours >= 1) {                                                                                                                                                                                                            
                            AutoDuration = durationInHours + "hrs ";                                                                                                                                                                                           
                        } else if (durationInMinutes >= 1) {                                                                                                                                                                                                   
                            AutoDuration = durationInMinutes + "min ";                                                                                                                                                                                         
                        } else if (durationInSeconds >= 1) {                                                                                                                                                                                                   
                            AutoDuration = Math.floor(durationInSeconds) + "s ";                                                                                                                                                                               
                        } else {                                                                                                                                                                                                                               
                            AutoDuration = durationInMilliseconds + "ms ";                                                                                                                                                                                     
                        }                                                                                                                                                                                                                                      
                    }                                                                                                                                                                                                                                          
                }                                                                                                                                                                                                                                              
                                                                                                                                                                                                                                                               
                switch (oStatusHeader.type) {                                                                                                                                                                                                                  
                    case "Success":                                                                                                                                                                                                                            
                        iCountSuccess++;                                                                                                                                                                                                                       
                        break;                                                                                                                                                                                                                                 
                    case "Error":                                                                                                                                                                                                                              
                        iCountError++;                                                                                                                                                                                                                         
                        break;                                                                                                                                                                                                                                 
                    case "Warning":                                                                                                                                                                                                                            
                        iCountWarning++;                                                                                                                                                                                                                       
                        break;                                                                                                                                                                                                                                 
                    case "None":                                                                                                                                                                                                                               
                        iCountNone++;                                                                                                                                                                                                                          
                        break;                                                                                                                                                                                                                                 
                }                                                                                                                                                                                                                                              
                automacoesFiltradas.push({                                                                                                                                                                                                                     
                    Chave: oAuto.Chave,                                                                                                                                                                                                                        
                    Auto: oAuto.Auto,                                                                                                                                                                                                                          
                    Opera: oAuto.Opera,                                                                                                                                                                                                                        
                    Credat: oAuto.Credat,                                                                                                                                                                                                                      
                    Cretim: oAuto.Cretim,                                                                                                                                                                                                                      
                    DataHora: sData,                                                                                                                                                                                                                           
                    Duracao: AutoDuration,                                                                                                                                                                                                                     
                    Status: oStatusHeader.status,                                                                                                                                                                                                              
                    StatusType: oStatusHeader.type,                                                                                                                                                                                                            
                    to_EtapasExecutadas: oAuto.to_EtapasExecutadas                                                                                                                                                                                             
                                                                                                                                                                                                                                                               
                });                                                                                                                                                                                                                                            
            });                                                                                                                                                                                                                                                
            oViewModel.setProperty("/automacoesTodas", automacoesFiltradas);                                                                                                                                                                                   
            oViewModel.setProperty("/automacoesFiltradas", automacoesFiltradas);                                                                                                                                                                               
            oViewModel.setProperty("/countAll", oData.results.length);                                                                                                                                                                                         
            oViewModel.setProperty("/countSuccess", iCountSuccess);                                                                                                                                                                                            
            oViewModel.setProperty("/countError", iCountError);                                                                                                                                                                                                
            oViewModel.setProperty("/countWarning", iCountWarning);                                                                                                                                                                                            
            oViewModel.setProperty("/countNone", iCountNone);                                                                                                                                                                                                  
            that.onQuickFilter();                                                                                                                                                                                                                              
        },                                                                                                                                                                                                                                                     
                                                                                                                                                                                                                                                               
                                                                                                                                                                                                                                                               
        onSideNavButtonPress: function () {                                                                                                                                                                                                                    
            var oToolPage = this.byId("toolPage");                                                                                                                                                                                                             
            var bSideExpanded = oToolPage.getSideExpanded();                                                                                                                                                                                                   
            oToolPage.setSideExpanded(!bSideExpanded);                                                                                                                                                                                                         
        },                                                                                                                                                                                                                                                     
                                                                                                                                                                                                                                                               
        _parseDuration: function (sDuration) {                                                                                                                                                                                                                 
            // Accept multiple duration representations:                                                                                                                                                                                                       
            // - PTnHnMnS string (OData duration)                                                                                                                                                                                                              
            // - object with `ms` property (e.g. {ms: 65209000, _edmType: 'Edm.Time'})                                                                                                                                                                         
            // - numeric milliseconds                                                                                                                                                                                                                          
            if (!sDuration && sDuration !== 0) return { hours: 0, minutes: 0, seconds: 0 };                                                                                                                                                                    
                                                                                                                                                                                                                                                               
            var hours = 0, minutes = 0, seconds = 0;                                                                                                                                                                                                           
                                                                                                                                                                                                                                                               
            // If object with ms                                                                                                                                                                                                                               
            if (typeof sDuration === 'object' && sDuration !== null) {                                                                                                                                                                                         
                if (sDuration.ms || sDuration.ms === 0) {                                                                                                                                                                                                      
                    var msVal = Number(sDuration.ms);                                                                                                                                                                                                          
                    if (!isNaN(msVal)) {                                                                                                                                                                                                                       
                        hours = Math.floor(msVal / 3600000);                                                                                                                                                                                                   
                        minutes = Math.floor((msVal % 3600000) / 60000);                                                                                                                                                                                       
                        seconds = Math.floor((msVal % 60000) / 1000);                                                                                                                                                                                          
                        return { hours: hours, minutes: minutes, seconds: seconds };                                                                                                                                                                           
                    }                                                                                                                                                                                                                                          
                }                                                                                                                                                                                                                                              
                // fallback: try toString and parse                                                                                                                                                                                                            
                sDuration = String(sDuration);                                                                                                                                                                                                                 
            }                                                                                                                                                                                                                                                  
                                                                                                                                                                                                                                                               
            // If numeric (milliseconds)                                                                                                                                                                                                                       
            if (typeof sDuration === 'number' && !isNaN(sDuration)) {                                                                                                                                                                                          
                var ms = sDuration;                                                                                                                                                                                                                            
                hours = Math.floor(ms / 3600000);                                                                                                                                                                                                              
                minutes = Math.floor((ms % 3600000) / 60000);                                                                                                                                                                                                  
                seconds = Math.floor((ms % 60000) / 1000);                                                                                                                                                                                                     
                return { hours: hours, minutes: minutes, seconds: seconds };                                                                                                                                                                                   
            }                                                                                                                                                                                                                                                  
                                                                                                                                                                                                                                                               
            // If string, try PT format first                                                                                                                                                                                                                  
            if (typeof sDuration === 'string') {                                                                                                                                                                                                               
                var match = sDuration.match(/PT(\d+H)?(\d+M)?(\d+S)?/);                                                                                                                                                                                        
                if (match) {                                                                                                                                                                                                                                   
                    if (match[1]) hours = parseInt(match[1].replace('H', ''), 10);                                                                                                                                                                             
                    if (match[2]) minutes = parseInt(match[2].replace('M', ''), 10);                                                                                                                                                                           
                    if (match[3]) seconds = parseInt(match[3].replace('S', ''), 10);                                                                                                                                                                           
                    return { hours: hours, minutes: minutes, seconds: seconds };                                                                                                                                                                               
                }                                                                                                                                                                                                                                              
                                                                                                                                                                                                                                                               
                // Try numeric string (milliseconds)                                                                                                                                                                                                           
                var n = Number(sDuration);                                                                                                                                                                                                                     
                if (!isNaN(n)) {                                                                                                                                                                                                                               
                    ms = n;                                                                                                                                                                                                                                    
                    hours = Math.floor(ms / 3600000);                                                                                                                                                                                                          
                    minutes = Math.floor((ms % 3600000) / 60000);                                                                                                                                                                                              
                    seconds = Math.floor((ms % 60000) / 1000);                                                                                                                                                                                                 
                    return { hours: hours, minutes: minutes, seconds: seconds };                                                                                                                                                                               
                }                                                                                                                                                                                                                                              
            }                                                                                                                                                                                                                                                  
                                                                                                                                                                                                                                                               
            // Unknown format -> return zeros                                                                                                                                                                                                                  
            return { hours: 0, minutes: 0, seconds: 0 };                                                                                                                                                                                                       
        },                                                                                                                                                                                                                                                     
        _combineDateAndTime: function (sDate, sDuration) {                                                                                                                                                                                                     
            // Criar data local (sem convers�o de timezone)                                                                                                                                                                                                    
            var dateString = sDate;                                                                                                                                                                                                                            
                                                                                                                                                                                                                                                               
            // Se for um objeto Date, converter para string ISO                                                                                                                                                                                                
            if (sDate instanceof Date) {                                                                                                                                                                                                                       
                dateString = sDate.toISOString();                                                                                                                                                                                                              
            }                                                                                                                                                                                                                                                  
                                                                                                                                                                                                                                                               
            var dateParts = dateString.split('T')[0].split('-');                                                                                                                                                                                               
            var year = parseInt(dateParts[0], 10);                                                                                                                                                                                                             
            var month = parseInt(dateParts[1], 10) - 1; // m�s come�a em 0                                                                                                                                                                                     
            var day = parseInt(dateParts[2], 10);                                                                                                                                                                                                              
                                                                                                                                                                                                                                                               
            var time = this._parseDuration(sDuration);                                                                                                                                                                                                         
                                                                                                                                                                                                                                                               
            // Criar objeto Date com valores locais                                                                                                                                                                                                            
            var oDate = new Date(year, month, day, time.hours, time.minutes, time.seconds);                                                                                                                                                                    
                                                                                                                                                                                                                                                               
            return oDate;                                                                                                                                                                                                                                      
        },                                                                                                                                                                                                                                                     
        _getStatusHeader: function (sStatus) {                                                                                                                                                                                                                 
            var iStatusHeader = parseInt(sStatus, 10);                                                                                                                                                                                                         
            var sStatus = "";                                                                                                                                                                                                                                  
            var sStatusType = "None";                                                                                                                                                                                                                          
                                                                                                                                                                                                                                                               
            switch (iStatusHeader) {                                                                                                                                                                                                                           
                case 0:                                                                                                                                                                                                                                        
                    sStatus = "Aguardando";                                                                                                                                                                                                                    
                    sStatusType = "None";                                                                                                                                                                                                                      
                    break;                                                                                                                                                                                                                                     
                case 1:                                                                                                                                                                                                                                        
                    sStatus = "Executando";                                                                                                                                                                                                                    
                    sStatusType = "Warning";                                                                                                                                                                                                                   
                    break;                                                                                                                                                                                                                                     
                case 2:                                                                                                                                                                                                                                        
                    sStatus = "Completo";                                                                                                                                                                                                                      
                    sStatusType = "Success";                                                                                                                                                                                                                   
                    break;                                                                                                                                                                                                                                     
                case 3:                                                                                                                                                                                                                                        
                    sStatus = "Erro durante o processamento";                                                                                                                                                                                                  
                    sStatusType = "Error";                                                                                                                                                                                                                     
                    break;                                                                                                                                                                                                                                     
                case 4:                                                                                                                                                                                                                                        
                    sStatus = "Falha de validaçõo";                                                                                                                                                                                                            
                    sStatusType = "Error";                                                                                                                                                                                                                     
                    break;                                                                                                                                                                                                                                     
                case 5:                                                                                                                                                                                                                                        
                    sStatus = "Pausado";                                                                                                                                                                                                                       
                    sStatusType = "Warning";                                                                                                                                                                                                                   
                    break;                                                                                                                                                                                                                                     
                default:                                                                                                                                                                                                                                       
                    sStatus = "Desconhecido";                                                                                                                                                                                                                  
                    sStatusType = "None";                                                                                                                                                                                                                      
            }                                                                                                                                                                                                                                                  
            return {                                                                                                                                                                                                                                           
                status: sStatus,                                                                                                                                                                                                                               
                type: sStatusType                                                                                                                                                                                                                              
            };                                                                                                                                                                                                                                                 
        },                                                                                                                                                                                                                                                     
                                                                                                                                                                                                                                                               
        /**                                                                                                                                                                                                                                                    
         * Manipula o filtro rápido de status das execuções                                                                                                                                                                                                    
         * Atualiza os filtros aplicados e sincroniza o ComboBox de status                                                                                                                                                                                     
         * @param {sap.ui.base.Event} oEvent - Evento disparado pelo IconTabBar (opcional)                                                                                                                                                                     
         * @public                                                                                                                                                                                                                                             
         */                                                                                                                                                                                                                                                    
        onQuickFilter: function (oEvent) {                                                                                                                                                                                                                     
            var oViewModel = this.getView().getModel("monitor");                                                                                                                                                                                               
            var sStatusKey = "";                                                                                                                                                                                                                               
            var aFilters = [];                                                                                                                                                                                                                                 
            var oStatusFilter = null;                                                                                                                                                                                                                          
                                                                                                                                                                                                                                                               
            // Definir estado de ocupado durante processamento                                                                                                                                                                                                 
            oViewModel.setProperty("/busy", true);                                                                                                                                                                                                             
                                                                                                                                                                                                                                                               
            // Determinar a chave do filtro de status                                                                                                                                                                                                          
            // Se não houver evento (chamada programática), usar o valor salvo ou "all"                                                                                                                                                                        
            if (oEvent === undefined) {                                                                                                                                                                                                                        
                sStatusKey = oViewModel.getProperty("/statusFiltro") || "all";                                                                                                                                                                                 
            } else {                                                                                                                                                                                                                                           
                // Obter a chave selecionada do evento                                                                                                                                                                                                         
                sStatusKey = oEvent.getParameter("key");                                                                                                                                                                                                       
                // Persistir a seleção no modelo                                                                                                                                                                                                               
                oViewModel.setProperty("/statusFiltro", sStatusKey);                                                                                                                                                                                           
            }                                                                                                                                                                                                                                                  
                                                                                                                                                                                                                                                               
            // Sincronizar o ComboBox de status com a seleção do IconTabBar                                                                                                                                                                                    
            oStatusFilter = this.byId("iconTabBar");                                                                                                                                                                                                           
            if (oStatusFilter) {                                                                                                                                                                                                                               
                oStatusFilter.setSelectedKey(sStatusKey);                                                                                                                                                                                                      
            }                                                                                                                                                                                                                                                  
                                                                                                                                                                                                                                                               
            // Obter filtros existentes                                                                                                                                                                                                                        
            aFilters = oViewModel.getProperty("/filters") || [];                                                                                                                                                                                               
                                                                                                                                                                                                                                                               
            // Remover qualquer filtro de status anterior                                                                                                                                                                                                      
            // Usa filter() para criar um novo array sem os filtros de StatusType                                                                                                                                                                              
            aFilters = aFilters.filter(function (oFilter) {                                                                                                                                                                                                    
                return oFilter.sPath !== "StatusType";                                                                                                                                                                                                         
            });                                                                                                                                                                                                                                                
                                                                                                                                                                                                                                                               
            // Adicionar novo filtro de status se não for "all"                                                                                                                                                                                                
            if (sStatusKey !== "all") {                                                                                                                                                                                                                        
                aFilters.push(new Filter("StatusType", FilterOperator.EQ, sStatusKey));                                                                                                                                                                        
            }                                                                                                                                                                                                                                                  
                                                                                                                                                                                                                                                               
            // Atualizar filtros no modelo                                                                                                                                                                                                                     
            oViewModel.setProperty("/filters", aFilters);                                                                                                                                                                                                      
                                                                                                                                                                                                                                                               
            // Aplicar os filtros à tabela                                                                                                                                                                                                                     
            this.applyFilters();                                                                                                                                                                                                                               
        },                                                                                                                                                                                                                                                     
                                                                                                                                                                                                                                                               
        onSortByDate: function () {                                                                                                                                                                                                                            
            var oViewModel = this.getView().getModel("monitor");                                                                                                                                                                                               
            var bOrdemDecrescente = oViewModel.getProperty("/ordenacaoDecrescente");                                                                                                                                                                           
            var aExecucoesFiltradas = oViewModel.getProperty("/automacoesFiltradas");                                                                                                                                                                          
            var that = this;                                                                                                                                                                                                                                   
                                                                                                                                                                                                                                                               
            // Inverter ordem                                                                                                                                                                                                                                  
            oViewModel.setProperty("/ordenacaoDecrescente", !bOrdemDecrescente);                                                                                                                                                                               
                                                                                                                                                                                                                                                               
            // Ordenar array de todas as execuções                                                                                                                                                                                                             
            aExecucoesFiltradas.sort(function (a, b) {                                                                                                                                                                                                         
                var aDate = a.Credat && a.Cretim ? that._combineDateAndTime(a.Credat, a.Cretim) : null;                                                                                                                                                        
                var bDate = b.Credat && b.Cretim ? that._combineDateAndTime(b.Credat, b.Cretim) : null;                                                                                                                                                        
                                                                                                                                                                                                                                                               
                if (!aDate && !bDate) return 0;                                                                                                                                                                                                                
                if (!aDate) return 1;                                                                                                                                                                                                                          
                if (!bDate) return -1;                                                                                                                                                                                                                         
                return bOrdemDecrescente ? (aDate - bDate) : (bDate - aDate);                                                                                                                                                                                  
            });                                                                                                                                                                                                                                                
                                                                                                                                                                                                                                                               
            oViewModel.setProperty("/automacoesFiltradas", aExecucoesFiltradas);                                                                                                                                                                               
        },                                                                                                                                                                                                                                                     
        /**                                                                                                                                                                                                                                                    
         * Aplica os filtros definidos à tabela de execuções                                                                                                                                                                                                   
         * Combina todos os filtros ativos usando operador AND                                                                                                                                                                                                 
         * Remove o estado de ocupado após aplicação                                                                                                                                                                                                           
         * @public                                                                                                                                                                                                                                             
         */                                                                                                                                                                                                                                                    
        applyFilters: function () {                                                                                                                                                                                                                            
            var oViewModel = this.getView().getModel("monitor");                                                                                                                                                                                               
            var aFilters = [];                                                                                                                                                                                                                                 
            var aDateFilters = [];                                                                                                                                                                                                                             
            var oFilterCombined = null;                                                                                                                                                                                                                        
            var oTable = null;                                                                                                                                                                                                                                 
            var oBinding = null;                                                                                                                                                                                                                               
            var sTipoFiltroData = oViewModel.getProperty("/filtroDataTipo");                                                                                                                                                                                   
            var bFiltroDataAtivo = oViewModel.getProperty("/filtroDataAtivo");                                                                                                                                                                                 
                                                                                                                                                                                                                                                               
            // Obter filtros armazenados no modelo                                                                                                                                                                                                             
            aFilters = oViewModel.getProperty("/filters") || [];                                                                                                                                                                                               
                                                                                                                                                                                                                                                               
            // Obter referência da tabela de execuções                                                                                                                                                                                                         
            oTable = this.byId("execucoesTable");                                                                                                                                                                                                              
            if (!oTable) {                                                                                                                                                                                                                                     
                oViewModel.setProperty("/busy", false);                                                                                                                                                                                                        
                return;                                                                                                                                                                                                                                        
            }                                                                                                                                                                                                                                                  
                                                                                                                                                                                                                                                               
            // Obter binding de items da tabela                                                                                                                                                                                                                
            oBinding = oTable.getBinding("items");                                                                                                                                                                                                             
            if (!oBinding) {                                                                                                                                                                                                                                   
                oViewModel.setProperty("/busy", false);                                                                                                                                                                                                        
                return;                                                                                                                                                                                                                                        
            }                                                                                                                                                                                                                                                  
                                                                                                                                                                                                                                                               
            // Limpar filtros anteriores                                                                                                                                                                                                                       
            oBinding.filter([]);                                                                                                                                                                                                                               
                                                                                                                                                                                                                                                               
            // Se houver filtros, criar um filtro combinado com operador AND                                                                                                                                                                                   
            // Caso contrário, limpar todos os filtros                                                                                                                                                                                                         
            if (aFilters.length > 0) {                                                                                                                                                                                                                         
                oFilterCombined = new Filter({                                                                                                                                                                                                                 
                    filters: aFilters,                                                                                                                                                                                                                         
                    and: true                                                                                                                                                                                                                                  
                });                                                                                                                                                                                                                                            
                oBinding.filter(oFilterCombined);                                                                                                                                                                                                              
            } else {                                                                                                                                                                                                                                           
                // Limpar todos os filtros quando array está vazio                                                                                                                                                                                             
                oBinding.filter([]);                                                                                                                                                                                                                           
            }                                                                                                                                                                                                                                                  
                                                                                                                                                                                                                                                               
            // Remover estado de ocupado após aplicação dos filtros                                                                                                                                                                                            
            oViewModel.setProperty("/busy", false);                                                                                                                                                                                                            
        },                                                                                                                                                                                                                                                     
        onSearch: function (oEvent) {                                                                                                                                                                                                                          
            var oViewModel = this.getView().getModel("monitor");                                                                                                                                                                                               
            var sQuery = oEvent.getParameter("query");                                                                                                                                                                                                         
            var aFilters = oViewModel.getProperty("/filters") || [];                                                                                                                                                                                           
            var oSearchFilter = null;                                                                                                                                                                                                                          
                                                                                                                                                                                                                                                               
            // Definir estado de ocupado durante processamento                                                                                                                                                                                                 
            oViewModel.setProperty("/busy", true);                                                                                                                                                                                                             
                                                                                                                                                                                                                                                               
            // Remover qualquer filtro de status anterior                                                                                                                                                                                                      
            // Usa filter() para criar um novo array sem os filtros de StatusType                                                                                                                                                                              
            aFilters = aFilters.filter(function (oFilter) {                                                                                                                                                                                                    
                return oFilter.sPath !== "Chave";                                                                                                                                                                                                              
            });                                                                                                                                                                                                                                                
                                                                                                                                                                                                                                                               
            // Criar filtro de busca se houver consulta                                                                                                                                                                                                        
            if (sQuery && sQuery.length > 0) {                                                                                                                                                                                                                 
                oSearchFilter = new Filter("Chave", FilterOperator.Contains, sQuery);                                                                                                                                                                          
                aFilters.push(oSearchFilter);                                                                                                                                                                                                                  
            }                                                                                                                                                                                                                                                  
                                                                                                                                                                                                                                                               
            // Atualizar filtros no modelo                                                                                                                                                                                                                     
            oViewModel.setProperty("/filters", aFilters);                                                                                                                                                                                                      
                                                                                                                                                                                                                                                               
            // Aplicar os filtros à tabela                                                                                                                                                                                                                     
            this.applyFilters();                                                                                                                                                                                                                               
        },                                                                                                                                                                                                                                                     
        onClearFilters: function () {                                                                                                                                                                                                                          
            var oViewModel = this.getView().getModel("monitor");                                                                                                                                                                                               
            // Limpar filtros no modelo                                                                                                                                                                                                                        
            oViewModel.setProperty("/filters", []);                                                                                                                                                                                                            
            oViewModel.setProperty("/statusFiltro", "all");                                                                                                                                                                                                    
                                                                                                                                                                                                                                                               
            // Sincronizar o ComboBox de status com a seleção do IconTabBar                                                                                                                                                                                    
            var oStatusFilter = this.byId("iconTabBar");                                                                                                                                                                                                       
            if (oStatusFilter) {                                                                                                                                                                                                                               
                oStatusFilter.setSelectedKey("all");                                                                                                                                                                                                           
            }                                                                                                                                                                                                                                                  
                                                                                                                                                                                                                                                               
            // Aplicar filtros (nenhum filtro)                                                                                                                                                                                                                 
            this.applyFilters();                                                                                                                                                                                                                               
        },                                                                                                                                                                                                                                                     
        onAutomationSelect: function (oEvent) {                                                                                                                                                                                                                
            var oSelectedItem = oEvent.getParameter("listItem") || oEvent.getSource();                                                                                                                                                                         
            var sChave = oSelectedItem.getBindingContext("monitor").getProperty("Chave");                                                                                                                                                                      
            var oRouter = this.getOwnerComponent().getRouter();                                                                                                                                                                                                
            oRouter.navTo("Automacao", {                                                                                                                                                                                                                       
                chave: sChave                                                                                                                                                                                                                                  
            });                                                                                                                                                                                                                                                
        },                                                                                                                                                                                                                                                     
        onDateFilter: function () {                                                                                                                                                                                                                            
            var oView = this.getView();                                                                                                                                                                                                                        
            var oViewModel = oView.getModel("monitor");                                                                                                                                                                                                        
                                                                                                                                                                                                                                                               
            if (!this._dateFilterDialog) {                                                                                                                                                                                                                     
                this._dateFilterDialog = sap.ui.xmlfragment("dateFilterDialog",                                                                                                                                                                                
                    "br.com.gja.zui5.gjaauto.monitor.view.DateFilterDialog", this);                                                                                                                                                                            
                oView.addDependent(this._dateFilterDialog);                                                                                                                                                                                                    
            }                                                                                                                                                                                                                                                  
                                                                                                                                                                                                                                                               
            // Atualizar valores do dialog com os filtros atuais                                                                                                                                                                                               
            var sTipo = oViewModel.getProperty("/filtroDataTipo");                                                                                                                                                                                             
            sap.ui.core.Fragment.byId("dateFilterDialog", "filterTypeSelect").setSelectedKey(sTipo);                                                                                                                                                           
                                                                                                                                                                                                                                                               
            this._dateFilterDialog.open();                                                                                                                                                                                                                     
        },                                                                                                                                                                                                                                                     
        onCancelDateFilter: function () {                                                                                                                                                                                                                      
            this._dateFilterDialog.close();                                                                                                                                                                                                                    
        },                                                                                                                                                                                                                                                     
        onDateFilterTypeChange: function (oEvent) {                                                                                                                                                                                                            
            var sSelectedKey = oEvent.getParameter("selectedItem").getKey();                                                                                                                                                                                   
            var oViewModel = this.getView().getModel("monitor");                                                                                                                                                                                               
            oViewModel.setProperty("/filtroDataTipo", sSelectedKey);                                                                                                                                                                                           
                                                                                                                                                                                                                                                               
            // Mostrar/ocultar campos apropriados                                                                                                                                                                                                              
            var oRangeBox = sap.ui.core.Fragment.byId("dateFilterDialog", "rangeBox");                                                                                                                                                                         
            var oEspecificaBox = sap.ui.core.Fragment.byId("dateFilterDialog", "especificaBox");                                                                                                                                                               
            var oMesAnoBox = sap.ui.core.Fragment.byId("dateFilterDialog", "mesAnoBox");                                                                                                                                                                       
            var oAnoBox = sap.ui.core.Fragment.byId("dateFilterDialog", "anoBox");                                                                                                                                                                             
                                                                                                                                                                                                                                                               
            // Esconder todos primeiro                                                                                                                                                                                                                         
            oRangeBox.setVisible(false);                                                                                                                                                                                                                       
            oEspecificaBox.setVisible(false);                                                                                                                                                                                                                  
            oMesAnoBox.setVisible(false);                                                                                                                                                                                                                      
            oAnoBox.setVisible(false);                                                                                                                                                                                                                         
                                                                                                                                                                                                                                                               
            // Mostrar o apropriado                                                                                                                                                                                                                            
            switch (sSelectedKey) {                                                                                                                                                                                                                            
                case "range":                                                                                                                                                                                                                                  
                    oRangeBox.setVisible(true);                                                                                                                                                                                                                
                    break;                                                                                                                                                                                                                                     
                case "especifica":                                                                                                                                                                                                                             
                    oEspecificaBox.setVisible(true);                                                                                                                                                                                                           
                    break;                                                                                                                                                                                                                                     
                case "mes":                                                                                                                                                                                                                                    
                    oMesAnoBox.setVisible(true);                                                                                                                                                                                                               
                    break;                                                                                                                                                                                                                                     
                case "ano":                                                                                                                                                                                                                                    
                    oAnoBox.setVisible(true);                                                                                                                                                                                                                  
                    break;                                                                                                                                                                                                                                     
            }                                                                                                                                                                                                                                                  
        },                                                                                                                                                                                                                                                     
        onConfirmDateFilter: function () {                                                                                                                                                                                                                     
            var oViewModel = this.getView().getModel("monitor");                                                                                                                                                                                               
                                                                                                                                                                                                                                                               
            // Ativar filtro de data                                                                                                                                                                                                                           
            oViewModel.setProperty("/filtroDataAtivo", true);                                                                                                                                                                                                  
                                                                                                                                                                                                                                                               
            // Fechar dialog                                                                                                                                                                                                                                   
            this._dateFilterDialog.close();                                                                                                                                                                                                                    
                                                                                                                                                                                                                                                               
            // Aplicar filtros                                                                                                                                                                                                                                 
            this.applyFilters();                                                                                                                                                                                                                               
                                                                                                                                                                                                                                                               
            MessageToast.show("Filtro de data aplicado");                                                                                                                                                                                                      
        },                                                                                                                                                                                                                                                     
        onClearFilters: function () {                                                                                                                                                                                                                          
            var oModel = this.getView().getModel("monitor");                                                                                                                                                                                                   
            var oHoje = new Date();                                                                                                                                                                                                                            
            oHoje.setHours(0, 0, 0, 0);                                                                                                                                                                                                                        
                                                                                                                                                                                                                                                               
            // Limpar filtros de status e busca                                                                                                                                                                                                                
            oModel.setProperty("/filters", []);                                                                                                                                                                                                                
            oModel.setProperty("/statusFiltro", "all");                                                                                                                                                                                                        
            oModel.setProperty("/searchQuery", "");                                                                                                                                                                                                            
                                                                                                                                                                                                                                                               
            // Resetar filtros de data para hoje                                                                                                                                                                                                               
            oModel.setProperty("/filtroDataTipo", "hoje");                                                                                                                                                                                                     
            oModel.setProperty("/filtroDataAtivo", true);                                                                                                                                                                                                      
            oModel.setProperty("/filtroDataInicio", oHoje);                                                                                                                                                                                                    
            oModel.setProperty("/filtroDataFim", oHoje);                                                                                                                                                                                                       
            oModel.setProperty("/filtroDataEspecifica", oHoje);                                                                                                                                                                                                
                                                                                                                                                                                                                                                               
            // Sincronizar IconTabBar                                                                                                                                                                                                                          
            var oStatusFilter = this.byId("iconTabBar");                                                                                                                                                                                                       
            if (oStatusFilter) {                                                                                                                                                                                                                               
                oStatusFilter.setSelectedKey("all");                                                                                                                                                                                                           
            }                                                                                                                                                                                                                                                  
                                                                                                                                                                                                                                                               
            // Aplicar filtros limpos                                                                                                                                                                                                                          
            this.applyFilters();                                                                                                                                                                                                                               
                                                                                                                                                                                                                                                               
            MessageToast.show("Filtros limpos");                                                                                                                                                                                                               
        },                                                                                                                                                                                                                                                     
        onConfirmDateFilter: function () {                                                                                                                                                                                                                     
            this.onItemSelect();                                                                                                                                                                                                                               
            this._dateFilterDialog.close();                                                                                                                                                                                                                    
        },                                                                                                                                                                                                                                                     
    });                                                                                                                                                                                                                                                        
});                                                                                                                                                                                                                                                            
                                                                                                                                                                                                                                                               