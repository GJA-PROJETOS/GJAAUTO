<core:FragmentDefinition                                                                                                                                                                                                                                       
    xmlns="sap.m"                                                                                                                                                                                                                                              
    xmlns:core="sap.ui.core"                                                                                                                                                                                                                                   
    xmlns:table="sap.ui.table"                                                                                                                                                                                                                                 
>                                                                                                                                                                                                                                                              
    <Dialog                                                                                                                                                                                                                                                    
        id="logsDialog"                                                                                                                                                                                                                                        
        title="Logs da Etapa {automacao>/etapaSelecionada/descricao}"                                                                                                                                                                                          
        contentWidth="1000px"                                                                                                                                                                                                                                  
        contentHeight="600px"                                                                                                                                                                                                                                  
        resizable="true"                                                                                                                                                                                                                                       
        draggable="true"                                                                                                                                                                                                                                       
    >                                                                                                                                                                                                                                                          
        <VBox id="_IDGenVBox" class="sapUiSmallMargin">                                                                                                                                                                                                        
            <table:Table                                                                                                                                                                                                                                       
                id="logsTable"                                                                                                                                                                                                                                 
                rows="{automacao>/etapaSelecionada/logs}"                                                                                                                                                                                                      
                selectionMode="None"                                                                                                                                                                                                                           
                visibleRowCountMode="Auto"                                                                                                                                                                                                                     
                minAutoRowCount="10"                                                                                                                                                                                                                           
            >                                                                                                                                                                                                                                                  
                <table:columns>                                                                                                                                                                                                                                
                    <table:Column id="_IDGenColumn5" width="5em">                                                                                                                                                                                              
                        <Label id="_IDGenLabel4" text="Tipo" />                                                                                                                                                                                                
                        <table:template>                                                                                                                                                                                                                       
                            <ObjectStatus id="_IDGenObjectStatus2"                                                                                                                                                                                             
                                text="{                                                                                                                                                                                                                        
                                    path: 'automacao>Type',                                                                                                                                                                                                    
                                    formatter: '.formatter.logType'                                                                                                                                                                                            
                                }"                                                                                                                                                                                                                             
                                state="{                                                                                                                                                                                                                       
                                    path: 'automacao>Type',                                                                                                                                                                                                    
                                    formatter: '.formatter.logState'                                                                                                                                                                                           
                                }"                                                                                                                                                                                                                             
                            />                                                                                                                                                                                                                                 
                        </table:template>                                                                                                                                                                                                                      
                    </table:Column>                                                                                                                                                                                                                            
                    <table:Column id="_IDGenColumn6" width="8em">                                                                                                                                                                                              
                        <Label id="_IDGenLabel12" text="ID" />                                                                                                                                                                                                 
                        <table:template>                                                                                                                                                                                                                       
                            <Text id="_IDGenText12" text="{automacao>Id}" />                                                                                                                                                                                   
                        </table:template>                                                                                                                                                                                                                      
                    </table:Column>                                                                                                                                                                                                                            
                    <table:Column id="_IDGenColumn7" width="6em">                                                                                                                                                                                              
                        <Label id="_IDGenLabel13" text="Número" />                                                                                                                                                                                             
                        <table:template>                                                                                                                                                                                                                       
                            <Text id="_IDGenText13" text="{automacao>NumberMsg}" />                                                                                                                                                                            
                        </table:template>                                                                                                                                                                                                                      
                    </table:Column>                                                                                                                                                                                                                            
                    <table:Column id="_IDGenColumn8">                                                                                                                                                                                                          
                        <Label id="_IDGenLabel14" text="Mensagem" />                                                                                                                                                                                           
                        <table:template>                                                                                                                                                                                                                       
                            <Text id="_IDGenText14" text="{automacao>Message}" wrapping="true" />                                                                                                                                                              
                        </table:template>                                                                                                                                                                                                                      
                    </table:Column>                                                                                                                                                                                                                            
                    <!-- <table:Column id="_IDGenColumn9" width="10em">                                                                                                                                                                                        
                        <Label id="_IDGenLabel15" text="V1" />                                                                                                                                                                                                 
                        <table:template>                                                                                                                                                                                                                       
                            <Text id="_IDGenText6" text="{monitor>MessageV1}" />                                                                                                                                                                               
                        </table:template>                                                                                                                                                                                                                      
                    </table:Column>                                                                                                                                                                                                                            
                    <table:Column id="_IDGenColumn10" width="10em">                                                                                                                                                                                            
                        <Label id="_IDGenLabel16" text="V2" />                                                                                                                                                                                                 
                        <table:template>                                                                                                                                                                                                                       
                            <Text id="_IDGenText7" text="{monitor>MessageV2}" />                                                                                                                                                                               
                        </table:template>                                                                                                                                                                                                                      
                    </table:Column>                                                                                                                                                                                                                            
                    <table:Column id="_IDGenColumn11" width="10em">                                                                                                                                                                                            
                        <Label id="_IDGenLabel17" text="V3" />                                                                                                                                                                                                 
                        <table:template>                                                                                                                                                                                                                       
                            <Text id="_IDGenText8" text="{monitor>MessageV3}" />                                                                                                                                                                               
                        </table:template>                                                                                                                                                                                                                      
                    </table:Column>                                                                                                                                                                                                                            
                    <table:Column id="_IDGenColumn12" width="10em">                                                                                                                                                                                            
                        <Label id="_IDGenLabel18" text="V4" />                                                                                                                                                                                                 
                        <table:template>                                                                                                                                                                                                                       
                            <Text id="_IDGenText9" text="{monitor>MessageV4}" />                                                                                                                                                                               
                        </table:template>                                                                                                                                                                                                                      
                    </table:Column> -->                                                                                                                                                                                                                        
                </table:columns>                                                                                                                                                                                                                               
            </table:Table>                                                                                                                                                                                                                                     
        </VBox>                                                                                                                                                                                                                                                
        <beginButton>                                                                                                                                                                                                                                          
            <Button id="_IDGenButton5"                                                                                                                                                                                                                         
                text="Fechar"                                                                                                                                                                                                                                  
                press=".onCloseLogsDialog"                                                                                                                                                                                                                     
            />                                                                                                                                                                                                                                                 
        </beginButton>                                                                                                                                                                                                                                         
    </Dialog>                                                                                                                                                                                                                                                  
</core:FragmentDefinition>                                                                                                                                                                                                                                     
                                                                                                                                                                                                                                                               