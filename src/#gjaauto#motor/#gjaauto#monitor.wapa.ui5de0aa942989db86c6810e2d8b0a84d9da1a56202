        /**                                                                                                                                                                                                                                                    
         * Recarrega os dados de execuções mantendo os filtros atuais.                                                                                                                                                                                         
         * @public                                                                                                                                                                                                                                             
         */                                                                                                                                                                                                                                                    
        onRefresh: function () {                                                                                                                                                                                                                               
            this._loadExecutions();                                                                                                                                                                                                                            
            MessageToast.show("Dados atualizados");                                                                                                                                                                                                            
        },                                                                                                                                                                                                                                                     
                                                                                                                                                                                                                                                               
        /**                                                                                                                                                                                                                                                    
         * Alterna expansão da barra lateral de navegação.                                                                                                                                                                                                     
         * @public                                                                                                                                                                                                                                             
         */                                                                                                                                                                                                                                                    
        onSideNavButtonPress: function () {                                                                                                                                                                                                                    
            var oToolPage = this.byId("toolPage");                                                                                                                                                                                                             
            var bExpanded = oToolPage.getSideExpanded();                                                                                                                                                                                                       
            oToolPage.setSideExpanded(!bExpanded);                                                                                                                                                                                                             
        },                                                                                                                                                                                                                                                     
                                                                                                                                                                                                                                                               
        /**                                                                                                                                                                                                                                                    
         * Recolhe a barra lateral de navegação se estiver expandida.                                                                                                                                                                                          
         * @private                                                                                                                                                                                                                                            
         */                                                                                                                                                                                                                                                    
        _collapseSideNavigation: function () {                                                                                                                                                                                                                 
            var oToolPage = this.byId("toolPage");                                                                                                                                                                                                             
            if (oToolPage && oToolPage.getSideExpanded()) {                                                                                                                                                                                                    
                oToolPage.setSideExpanded(false);                                                                                                                                                                                                              
            }                                                                                                                                                                                                                                                  
        },                                                                                                                                                                                                                                                     
                                                                                                                                                                                                                                                               
        /* =========================================================== */                                                                                                                                                                                      
        /* Event Handlers - Dialog de Filtro de Data                  */                                                                                                                                                                                       
        /* =========================================================== */                                                                                                                                                                                      
                                                                                                                                                                                                                                                               
        /**                                                                                                                                                                                                                                                    
         * Abre dialog de filtro de data.                                                                                                                                                                                                                      
         * @public                                                                                                                                                                                                                                             
         */                                                                                                                                                                                                                                                    
        onDateFilter: function () {                                                                                                                                                                                                                            
            if (!this._dateFilterDialog) {                                                                                                                                                                                                                     
                this._dateFilterDialog = sap.ui.xmlfragment(                                                                                                                                                                                                   
                    "dateFilterDialog",                                                                                                                                                                                                                        
                    "br.com.gja.zui5.gjaauto.monitor.view.DateFilterDialog",                                                                                                                                                                                   
                    this                                                                                                                                                                                                                                       
                );                                                                                                                                                                                                                                             
                this.getView().addDependent(this._dateFilterDialog);                                                                                                                                                                                           
            }                                                                                                                                                                                                                                                  
                                                                                                                                                                                                                                                               
            var oViewModel = this.getView().getModel("monitor");                                                                                                                                                                                               
            var sFilterType = oViewModel.getProperty("/dateFilterType");                                                                                                                                                                                       
                                                                                                                                                                                                                                                               
            sap.ui.core.Fragment.byId("dateFilterDialog", "filterTypeSelect")                                                                                                                                                                                  
                .setSelectedKey(sFilterType);                                                                                                                                                                                                                  
                                                                                                                                                                                                                                                               
            this._dateFilterDialog.open();                                                                                                                                                                                                                     
        },                                                                                                                                                                                                                                                     
                                                                                                                                                                                                                                                               
        /**                                                                                                                                                                                                                                                    
         * Cancela e fecha dialog de filtro de data.                                                                                                                                                                                                           
         * @public                                                                                                                                                                                                                                             
         */                                                                                                                                                                                                                                                    
        onCancelDateFilter: function () {                                                                                                                                                                                                                      
            this._dateFilterDialog.close();                                                                                                                                                                                                                    
        },                                                                                                                                                                                                                                                     
                                                                                                                                                                                                                                                               
        /**                                                                                                                                                                                                                                                    
         * Manipula mudança no tipo de filtro de data.                                                                                                                                                                                                         
         * Mostra/oculta campos apropriados.                                                                                                                                                                                                                   
         * @param {sap.ui.base.Event} oEvent - Evento de mudança                                                                                                                                                                                               
         * @public                                                                                                                                                                                                                                             
         */                                                                                                                                                                                                                                                    
        onDateFilterTypeChange: function (oEvent) {                                                                                                                                                                                                            
            var sSelectedKey = oEvent.getParameter("selectedItem").getKey();                                                                                                                                                                                   
            var oViewModel = this.getView().getModel("monitor");                                                                                                                                                                                               
                                                                                                                                                                                                                                                               
            oViewModel.setProperty("/dateFilterType", sSelectedKey);                                                                                                                                                                                           
                                                                                                                                                                                                                                                               
            // Obter referências dos containers                                                                                                                                                                                                                
            var oRangeBox = sap.ui.core.Fragment.byId("dateFilterDialog", "rangeBox");                                                                                                                                                                         
            var oEspecificaBox = sap.ui.core.Fragment.byId("dateFilterDialog", "especificaBox");                                                                                                                                                               
            var oMesAnoBox = sap.ui.core.Fragment.byId("dateFilterDialog", "mesAnoBox");                                                                                                                                                                       
            var oAnoBox = sap.ui.core.Fragment.byId("dateFilterDialog", "anoBox");                                                                                                                                                                             
                                                                                                                                                                                                                                                               
            // Ocultar todos                                                                                                                                                                                                                                   
            oRangeBox.setVisible(false);                                                                                                                                                                                                                       
            oEspecificaBox.setVisible(false);                                                                                                                                                                                                                  
            oMesAnoBox.setVisible(false);                                                                                                                                                                                                                      
            oAnoBox.setVisible(false);                                                                                                                                                                                                                         
                                                                                                                                                                                                                                                               
            // Mostrar apropriado                                                                                                                                                                                                                              
            switch (sSelectedKey) {                                                                                                                                                                                                                            
                case "range":                                                                                                                                                                                                                                  
                    oRangeBox.setVisible(true);                                                                                                                                                                                                                
                    break;                                                                                                                                                                                                                                     
                case "especifica":                                                                                                                                                                                                                             
                    oEspecificaBox.setVisible(true);                                                                                                                                                                                                           
                    break;                                                                                                                                                                                                                                     
                case "mes":                                                                                                                                                                                                                                    
                    oMesAnoBox.setVisible(true);                                                                                                                                                                                                               
                    break;                                                                                                                                                                                                                                     
                case "ano":                                                                                                                                                                                                                                    
                    oAnoBox.setVisible(true);                                                                                                                                                                                                                  
                    break;                                                                                                                                                                                                                                     
            }                                                                                                                                                                                                                                                  
        },                                                                                                                                                                                                                                                     
                                                                                                                                                                                                                                                               
        /**                                                                                                                                                                                                                                                    
         * Confirma e aplica filtro de data selecionado.                                                                                                                                                                                                       
         * Recarrega execuções com novo filtro.                                                                                                                                                                                                                
         * @public                                                                                                                                                                                                                                             
         */                                                                                                                                                                                                                                                    
        onConfirmDateFilter: function () {                                                                                                                                                                                                                     
            var oViewModel = this.getView().getModel("monitor");                                                                                                                                                                                               
                                                                                                                                                                                                                                                               
            oViewModel.setProperty("/dateFilterActive", true);                                                                                                                                                                                                 
            this._dateFilterDialog.close();                                                                                                                                                                                                                    
            this._updateUrlParams();                                                                                                                                                                                                                           
            this._loadExecutions();                                                                                                                                                                                                                            
                                                                                                                                                                                                                                                               
            MessageToast.show("Filtro de data aplicado");                                                                                                                                                                                                      
        },                                                                                                                                                                                                                                                     
                                                                                                                                                                                                                                                               
        /**                                                                                                                                                                                                                                                    
         * Executa todas as automações via endpoint POST com chave "ALL".                                                                                                                                                                                      
         * @public                                                                                                                                                                                                                                             
         */                                                                                                                                                                                                                                                    
        onExecutarTodas: function () {                                                                                                                                                                                                                         
            var oViewModel = this.getView().getModel("monitor");                                                                                                                                                                                               
            oViewModel.setProperty("/executeButtonEnabled", false);                                                                                                                                                                                            
                                                                                                                                                                                                                                                               
            var oMainModel = this.getOwnerComponent().getModel("mainSrv");                                                                                                                                                                                     
                                                                                                                                                                                                                                                               
            if (!oMainModel) {                                                                                                                                                                                                                                 
                MessageBox.error("Serviço não disponível");                                                                                                                                                                                                    
                oViewModel.setProperty("/executeButtonEnabled", true);                                                                                                                                                                                         
                return;                                                                                                                                                                                                                                        
            }                                                                                                                                                                                                                                                  
                                                                                                                                                                                                                                                               
            var oPayload = {                                                                                                                                                                                                                                   
                Chave: "ALL"                                                                                                                                                                                                                                   
            };                                                                                                                                                                                                                                                 
                                                                                                                                                                                                                                                               
            oMainModel.create("/ExecAutomacao", oPayload, {                                                                                                                                                                                                    
                success: function () {                                                                                                                                                                                                                         
                    MessageToast.show("Automações executadas com sucesso");                                                                                                                                                                                    
                }.bind(this),                                                                                                                                                                                                                                  
                error: function (oError) {                                                                                                                                                                                                                     
                    oViewModel.setProperty("/executeButtonEnabled", true);                                                                                                                                                                                     
                    var sErrorMsg = "Erro ao executar automações";                                                                                                                                                                                             
                                                                                                                                                                                                                                                               
                    if (oError.responseText) {                                                                                                                                                                                                                 
                        try {                                                                                                                                                                                                                                  
                            var oErrorResponse = JSON.parse(oError.responseText);                                                                                                                                                                              
                            if (oErrorResponse.error && oErrorResponse.error.message) {                                                                                                                                                                        
                                sErrorMsg = oErrorResponse.error.message.value || oErrorResponse.error.message;                                                                                                                                                
                            }                                                                                                                                                                                                                                  
                        } catch (e) {                                                                                                                                                                                                                          
                            sErrorMsg += ": " + oError.responseText;                                                                                                                                                                                           
                        }                                                                                                                                                                                                                                      
                    }                                                                                                                                                                                                                                          
                                                                                                                                                                                                                                                               
                    MessageBox.error(sErrorMsg);                                                                                                                                                                                                               
                }.bind(this)                                                                                                                                                                                                                                   
            });                                                                                                                                                                                                                                                
        }                                                                                                                                                                                                                                                      
    });                                                                                                                                                                                                                                                        
});                                                                                                                                                                                                                                                            
                                                                                                                                                                                                                                                               