        /* =========================================================== */                                                                                                                                                                                      
                                                                                                                                                                                                                                                               
        /**                                                                                                                                                                                                                                                    
         * Manipula filtro rápido por status das execuções.                                                                                                                                                                                                    
         * @param {sap.ui.base.Event} [oEvent] - Evento do IconTabBar                                                                                                                                                                                          
         * @public                                                                                                                                                                                                                                             
         */                                                                                                                                                                                                                                                    
        onQuickFilter: function (oEvent) {                                                                                                                                                                                                                     
            var oViewModel = this.getView().getModel("monitor");                                                                                                                                                                                               
            var sStatusKey = "";                                                                                                                                                                                                                               
                                                                                                                                                                                                                                                               
            oViewModel.setProperty("/busy", true);                                                                                                                                                                                                             
                                                                                                                                                                                                                                                               
            if (oEvent) {                                                                                                                                                                                                                                      
                sStatusKey = oEvent.getParameter("key");                                                                                                                                                                                                       
                oViewModel.setProperty("/statusFilter", sStatusKey);                                                                                                                                                                                           
            } else {                                                                                                                                                                                                                                           
                sStatusKey = oViewModel.getProperty("/statusFilter") || "all";                                                                                                                                                                                 
            }                                                                                                                                                                                                                                                  
                                                                                                                                                                                                                                                               
            // Sincronizar IconTabBar                                                                                                                                                                                                                          
            var oIconTabBar = this.byId("iconTabBar");                                                                                                                                                                                                         
            if (oIconTabBar) {                                                                                                                                                                                                                                 
                oIconTabBar.setSelectedKey(sStatusKey);                                                                                                                                                                                                        
            }                                                                                                                                                                                                                                                  
                                                                                                                                                                                                                                                               
            this._applyStatusFilter(sStatusKey);                                                                                                                                                                                                               
            this._updateUrlParams();                                                                                                                                                                                                                           
        },                                                                                                                                                                                                                                                     
                                                                                                                                                                                                                                                               
        /**                                                                                                                                                                                                                                                    
         * Aplica filtro de status à tabela.                                                                                                                                                                                                                   
         * @param {string} [sStatusKey] - Chave do status ("all", "Success", "Error", "Warning", "None")                                                                                                                                                       
         * @private                                                                                                                                                                                                                                            
         */                                                                                                                                                                                                                                                    
        _applyStatusFilter: function (sStatusKey) {                                                                                                                                                                                                            
            var oViewModel = this.getView().getModel("monitor");                                                                                                                                                                                               
                                                                                                                                                                                                                                                               
            if (!sStatusKey) {                                                                                                                                                                                                                                 
                sStatusKey = oViewModel.getProperty("/statusFilter") || "all";                                                                                                                                                                                 
            }                                                                                                                                                                                                                                                  
                                                                                                                                                                                                                                                               
            var aFilters = oViewModel.getProperty("/filters") || [];                                                                                                                                                                                           
                                                                                                                                                                                                                                                               
            // Remover filtros de status anteriores                                                                                                                                                                                                            
            aFilters = aFilters.filter(function (oFilter) {                                                                                                                                                                                                    
                return oFilter.sPath !== "StatusType";                                                                                                                                                                                                         
            });                                                                                                                                                                                                                                                
                                                                                                                                                                                                                                                               
            // Adicionar novo filtro de status                                                                                                                                                                                                                 
            if (sStatusKey && sStatusKey !== "all") {                                                                                                                                                                                                          
                aFilters.push(new Filter("StatusType", FilterOperator.EQ, sStatusKey));                                                                                                                                                                        
            }                                                                                                                                                                                                                                                  
                                                                                                                                                                                                                                                               
            // Reaplicar filtro de busca se existir no model                                                                                                                                                                                                   
            var sSearch = oViewModel.getProperty("/searchQuery");                                                                                                                                                                                              
            var bHasSearchFilter = aFilters.some(function (oFilter) {                                                                                                                                                                                          
                return oFilter.sPath === "Chave";                                                                                                                                                                                                              
            });                                                                                                                                                                                                                                                
            if (sSearch && !bHasSearchFilter) {                                                                                                                                                                                                                
                aFilters.push(new Filter("Chave", FilterOperator.Contains, sSearch));                                                                                                                                                                          
            }                                                                                                                                                                                                                                                  
                                                                                                                                                                                                                                                               
            oViewModel.setProperty("/filters", aFilters);                                                                                                                                                                                                      
            this._applyFiltersToTable();                                                                                                                                                                                                                       
        },                                                                                                                                                                                                                                                     
                                                                                                                                                                                                                                                               
        /**                                                                                                                                                                                                                                                    
         * Manipula busca por chave de execução.                                                                                                                                                                                                               
         * @param {sap.ui.base.Event} oEvent - Evento de busca                                                                                                                                                                                                 
         * @public                                                                                                                                                                                                                                             
         */                                                                                                                                                                                                                                                    
        onSearch: function (oEvent) {                                                                                                                                                                                                                          
            var oViewModel = this.getView().getModel("monitor");                                                                                                                                                                                               
            var sQuery = oEvent.getParameter("query");                                                                                                                                                                                                         
            var aFilters = oViewModel.getProperty("/filters") || [];                                                                                                                                                                                           
                                                                                                                                                                                                                                                               
            oViewModel.setProperty("/busy", true);                                                                                                                                                                                                             
            oViewModel.setProperty("/searchQuery", sQuery || "");                                                                                                                                                                                              
                                                                                                                                                                                                                                                               
            // Remover filtros de busca anteriores                                                                                                                                                                                                             
            aFilters = aFilters.filter(function (oFilter) {                                                                                                                                                                                                    
                return oFilter.sPath !== "Chave";                                                                                                                                                                                                              
            });                                                                                                                                                                                                                                                
                                                                                                                                                                                                                                                               
            // Adicionar novo filtro de busca                                                                                                                                                                                                                  
            if (sQuery && sQuery.length > 0) {                                                                                                                                                                                                                 
                aFilters.push(new Filter("Chave", FilterOperator.Contains, sQuery));                                                                                                                                                                           
            }                                                                                                                                                                                                                                                  
                                                                                                                                                                                                                                                               
            oViewModel.setProperty("/filters", aFilters);                                                                                                                                                                                                      
            this._applyFiltersToTable();                                                                                                                                                                                                                       
            this._updateUrlParams();                                                                                                                                                                                                                           
        },                                                                                                                                                                                                                                                     
                                                                                                                                                                                                                                                               
        /**                                                                                                                                                                                                                                                    
         * Limpa todos os filtros aplicados.                                                                                                                                                                                                                   
         * @public                                                                                                                                                                                                                                             
         */                                                                                                                                                                                                                                                    
        onClearFilters: function () {                                                                                                                                                                                                                          
            var oViewModel = this.getView().getModel("monitor");                                                                                                                                                                                               
            var oToday = this._getToday();                                                                                                                                                                                                                     
                                                                                                                                                                                                                                                               
            // Limpar filtros                                                                                                                                                                                                                                  
            oViewModel.setProperty("/filters", []);                                                                                                                                                                                                            
            oViewModel.setProperty("/statusFilter", "all");                                                                                                                                                                                                    
            oViewModel.setProperty("/searchQuery", "");                                                                                                                                                                                                        
                                                                                                                                                                                                                                                               
            // Resetar filtros de data                                                                                                                                                                                                                         
            oViewModel.setProperty("/dateFilterType", "hoje");                                                                                                                                                                                                 
            oViewModel.setProperty("/dateFilterActive", true);                                                                                                                                                                                                 
            oViewModel.setProperty("/dateFilterStart", oToday);                                                                                                                                                                                                
            oViewModel.setProperty("/dateFilterEnd", oToday);                                                                                                                                                                                                  
            oViewModel.setProperty("/dateFilterSpecific", oToday);                                                                                                                                                                                             
                                                                                                                                                                                                                                                               
            // Sincronizar UI                                                                                                                                                                                                                                  
            var oIconTabBar = this.byId("iconTabBar");                                                                                                                                                                                                         
            if (oIconTabBar) {                                                                                                                                                                                                                                 
                oIconTabBar.setSelectedKey("all");                                                                                                                                                                                                             
            }                                                                                                                                                                                                                                                  
                                                                                                                                                                                                                                                               
            this._applyFiltersToTable();                                                                                                                                                                                                                       
            this._updateUrlParams();                                                                                                                                                                                                                           
            MessageToast.show("Filtros limpos");                                                                                                                                                                                                               
        },                                                                                                                                                                                                                                                     
                                                                                                                                                                                                                                                               
        /**                                                                                                                                                                                                                                                    
         * Aplica filtros combinados à tabela de execuções.                                                                                                                                                                                                    
         * @private                                                                                                                                                                                                                                            
         */                                                                                                                                                                                                                                                    
        _applyFiltersToTable: function () {                                                                                                                                                                                                                    
            var oViewModel = this.getView().getModel("monitor");                                                                                                                                                                                               
            var oTable = this.byId("execucoesTable");                                                                                                                                                                                                          
                                                                                                                                                                                                                                                               
            if (!oTable) {                                                                                                                                                                                                                                     
                oViewModel.setProperty("/busy", false);                                                                                                                                                                                                        
                return;                                                                                                                                                                                                                                        
            }                                                                                                                                                                                                                                                  
                                                                                                                                                                                                                                                               
            var oBinding = oTable.getBinding("items");                                                                                                                                                                                                         
            if (!oBinding) {                                                                                                                                                                                                                                   
                oViewModel.setProperty("/busy", false);                                                                                                                                                                                                        
                return;                                                                                                                                                                                                                                        
            }                                                                                                                                                                                                                                                  
                                                                                                                                                                                                                                                               
            var aFilters = oViewModel.getProperty("/filters") || [];                                                                                                                                                                                           
                                                                                                                                                                                                                                                               
            if (aFilters.length > 0) {                                                                                                                                                                                                                         
                var oFilterCombined = new Filter({                                                                                                                                                                                                             
                    filters: aFilters,                                                                                                                                                                                                                         
                    and: true                                                                                                                                                                                                                                  
                });                                                                                                                                                                                                                                            
                oBinding.filter(oFilterCombined);                                                                                                                                                                                                              
            } else {                                                                                                                                                                                                                                           
                oBinding.filter([]);                                                                                                                                                                                                                           
            }                                                                                                                                                                                                                                                  
                                                                                                                                                                                                                                                               
            oViewModel.setProperty("/busy", false);                                                                                                                                                                                                            
        },                                                                                                                                                                                                                                                     
                                                                                                                                                                                                                                                               
        /* =========================================================== */                                                                                                                                                                                      
        /* Event Handlers - Ordenação                                 */                                                                                                                                                                                       
        /* =========================================================== */                                                                                                                                                                                      
                                                                                                                                                                                                                                                               
        /**                                                                                                                                                                                                                                                    
         * Inverte a ordem de ordenação por data.                                                                                                                                                                                                              
         * @public                                                                                                                                                                                                                                             
         */                                                                                                                                                                                                                                                    
        onSortByDate: function () {                                                                                                                                                                                                                            
            var oViewModel = this.getView().getModel("monitor");                                                                                                                                                                                               
            var bDescending = oViewModel.getProperty("/sortDescending");                                                                                                                                                                                       
            var aExecutions = oViewModel.getProperty("/filteredExecutions");                                                                                                                                                                                   
            var that = this;                                                                                                                                                                                                                                   
                                                                                                                                                                                                                                                               
            oViewModel.setProperty("/sortDescending", !bDescending);                                                                                                                                                                                           
                                                                                                                                                                                                                                                               
            aExecutions.sort(function (a, b) {                                                                                                                                                                                                                 
                var oDateA = a.Credat && a.Cretim ? that._combineDateAndTime(a.Credat, a.Cretim) : null;                                                                                                                                                       
                var oDateB = b.Credat && b.Cretim ? that._combineDateAndTime(b.Credat, b.Cretim) : null;                                                                                                                                                       
                                                                                                                                                                                                                                                               
                if (!oDateA && !oDateB) return 0;                                                                                                                                                                                                              
                if (!oDateA) return 1;                                                                                                                                                                                                                         
                if (!oDateB) return -1;                                                                                                                                                                                                                        
                                                                                                                                                                                                                                                               
                return bDescending ? (oDateA - oDateB) : (oDateB - oDateA);                                                                                                                                                                                    
            });                                                                                                                                                                                                                                                
                                                                                                                                                                                                                                                               
            oViewModel.setProperty("/filteredExecutions", aExecutions);                                                                                                                                                                                        
            this._updateUrlParams();                                                                                                                                                                                                                           
        },                                                                                                                                                                                                                                                     
                                                                                                                                                                                                                                                               
        /* =========================================================== */                                                                                                                                                                                      
