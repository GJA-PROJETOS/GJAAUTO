sap.ui.define([                                                                                                                                                                                                                                                
    "sap/ui/core/mvc/Controller",                                                                                                                                                                                                                              
    "sap/ui/model/json/JSONModel",                                                                                                                                                                                                                             
    "sap/ui/model/Filter",                                                                                                                                                                                                                                     
    "sap/ui/model/FilterOperator",                                                                                                                                                                                                                             
    "sap/m/MessageToast",                                                                                                                                                                                                                                      
    "sap/m/MessageBox"                                                                                                                                                                                                                                         
], function (Controller, JSONModel, Filter, FilterOperator, MessageToast, MessageBox) {                                                                                                                                                                        
    "use strict";                                                                                                                                                                                                                                              
                                                                                                                                                                                                                                                               
    /**                                                                                                                                                                                                                                                        
     * Controlador principal da tela de monitoramento de automações.                                                                                                                                                                                           
     * Responsável por gerenciar a visualização e filtragem de execuções de automações.                                                                                                                                                                        
     *&nbsp;                                                                                                                                                                                                                                                   
     * @namespace br.com.gja.zui5.gjaauto.monitor.controller                                                                                                                                                                                                   
     */                                                                                                                                                                                                                                                        
    return Controller.extend("br.com.gja.zui5.gjaauto.monitor.controller.Monitor", {                                                                                                                                                                           
                                                                                                                                                                                                                                                               
        /* =========================================================== */                                                                                                                                                                                      
        /* Eventos do Ciclo de Vida                                   */                                                                                                                                                                                       
        /* =========================================================== */                                                                                                                                                                                      
                                                                                                                                                                                                                                                               
        /**                                                                                                                                                                                                                                                    
         * Inicializa o controlador.                                                                                                                                                                                                                           
         * Configura o modelo de visualização, carrega o menu de automações                                                                                                                                                                                    
         * e busca as execuções iniciais.                                                                                                                                                                                                                      
         * @public                                                                                                                                                                                                                                             
         */                                                                                                                                                                                                                                                    
        onInit: function () {                                                                                                                                                                                                                                  
            var oToday = this._getToday();                                                                                                                                                                                                                     
            var oViewModel = this._createViewModel(oToday);                                                                                                                                                                                                    
                                                                                                                                                                                                                                                               
            this.getView().setModel(oViewModel, "monitor");                                                                                                                                                                                                    
                                                                                                                                                                                                                                                               
            this._iAutoRefreshInterval = null;                                                                                                                                                                                                                 
                                                                                                                                                                                                                                                               
            this._loadAutomationsMenu();                                                                                                                                                                                                                       
                                                                                                                                                                                                                                                               
            // Anexa handler para ambas as rotas que apontam para Monitor                                                                                                                                                                                      
            var oRouter = this.getOwnerComponent().getRouter();                                                                                                                                                                                                
            oRouter.getRoute("RouteMonitor").attachMatched(this._onRouteMatched, this);                                                                                                                                                                        
            oRouter.getRoute("Monitor").attachMatched(this._onRouteMatched, this);                                                                                                                                                                             
        },                                                                                                                                                                                                                                                     
                                                                                                                                                                                                                                                               
        /**                                                                                                                                                                                                                                                    
         * Limpa o intervalo de auto-refresh ao destruir o controller.                                                                                                                                                                                         
         * @public                                                                                                                                                                                                                                             
         */                                                                                                                                                                                                                                                    
        onExit: function () {                                                                                                                                                                                                                                  
            this._stopAutoRefresh();                                                                                                                                                                                                                           
        },                                                                                                                                                                                                                                                     
                                                                                                                                                                                                                                                               
        /* =========================================================== */                                                                                                                                                                                      
        /* Métodos Privados - Inicialização                           */                                                                                                                                                                                       
        /* =========================================================== */                                                                                                                                                                                      
                                                                                                                                                                                                                                                               
        /**                                                                                                                                                                                                                                                    
         * Cria e retorna o modelo de visualização com valores iniciais.                                                                                                                                                                                       
         * @param {Date} oToday - Data de hoje às 00:00:00                                                                                                                                                                                                     
         * @returns {JSONModel} Modelo de visualização configurado                                                                                                                                                                                             
         * @private                                                                                                                                                                                                                                            
         */                                                                                                                                                                                                                                                    
        _createViewModel: function (oToday) {                                                                                                                                                                                                                  
            // Format today's date as string for DatePicker (yyyy-MM-dd)                                                                                                                                                                                       
            var sTodayFormatted = this._formatDateForDatePicker(oToday);                                                                                                                                                                                       
&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;                                                                                                                                                                                       
            return new JSONModel({                                                                                                                                                                                                                             
                // Dados de execuções                                                                                                                                                                                                                          
                allExecutions: [],                                                                                                                                                                                                                             
                filteredExecutions: [],                                                                                                                                                                                                                        
&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;                                                                                                                                                               
                // Estado da UI                                                                                                                                                                                                                                
                busy: false,                                                                                                                                                                                                                                   
                operationTitle: "",                                                                                                                                                                                                                            
                sortDescending: true,                                                                                                                                                                                                                          
                executeButtonEnabled: true,                                                                                                                                                                                                                    
&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;                                                                                                                                                               
                // Seleção atual                                                                                                                                                                                                                               
                selectedAutomation: "",                                                                                                                                                                                                                        
                selectedOperation: "",                                                                                                                                                                                                                         
&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;                                                                                                                                                               
                // Filtros                                                                                                                                                                                                                                     
                filters: [],                                                                                                                                                                                                                                   
                statusFilter: "all",                                                                                                                                                                                                                           
                searchQuery: "",                                                                                                                                                                                                                               
&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;                                                                                                                                                               
                // Filtros de data                                                                                                                                                                                                                             
                dateFilterType: "hoje",                                                                                                                                                                                                                        
                dateFilterActive: true,                                                                                                                                                                                                                        
                dateFilterStart: sTodayFormatted,                                                                                                                                                                                                              
                dateFilterEnd: sTodayFormatted,                                                                                                                                                                                                                
                dateFilterSpecific: sTodayFormatted,                                                                                                                                                                                                           
                dateFilterMonth: oToday.getMonth(),                                                                                                                                                                                                            
                dateFilterYear: oToday.getFullYear(),                                                                                                                                                                                                          
&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;                                                                                                                                                               
                // Contadores de status                                                                                                                                                                                                                        
                countAll: 0,                                                                                                                                                                                                                                   
                countSuccess: 0,                                                                                                                                                                                                                               
                countError: 0,                                                                                                                                                                                                                                 
                countWarning: 0,                                                                                                                                                                                                                               
                countNone: 0                                                                                                                                                                                                                                   
            });                                                                                                                                                                                                                                                
        },                                                                                                                                                                                                                                                     
                                                                                                                                                                                                                                                               
        /**                                                                                                                                                                                                                                                    
         * Retorna objeto Date de hoje com horário zerado (00:00:00).                                                                                                                                                                                          
         * @returns {Date} Data de hoje às 00:00:00                                                                                                                                                                                                            
         * @private                                                                                                                                                                                                                                            
         */                                                                                                                                                                                                                                                    
        _getToday: function () {                                                                                                                                                                                                                               
            var oToday = new Date();                                                                                                                                                                                                                           
            oToday.setHours(0, 0, 0, 0);                                                                                                                                                                                                                       
            return oToday;                                                                                                                                                                                                                                     
        },                                                                                                                                                                                                                                                     
                                                                                                                                                                                                                                                               
        /**                                                                                                                                                                                                                                                    
         * Formata data para o formato esperado pelo DatePicker (yyyy-MM-dd).                                                                                                                                                                                  
         * @param {Date} oDate - Data a ser formatada                                                                                                                                                                                                          
         * @returns {string} Data formatada como string yyyy-MM-dd                                                                                                                                                                                             
         * @private                                                                                                                                                                                                                                            
         */                                                                                                                                                                                                                                                    
        _formatDateForDatePicker: function (oDate) {                                                                                                                                                                                                           
            var sYear = oDate.getFullYear();                                                                                                                                                                                                                   
            var sMonth = String(oDate.getMonth() + 1).padStart(2, '0');                                                                                                                                                                                        
            var sDay = String(oDate.getDate()).padStart(2, '0');                                                                                                                                                                                               
            return sYear + "-" + sMonth + "-" + sDay;                                                                                                                                                                                                          
        },                                                                                                                                                                                                                                                     
                                                                                                                                                                                                                                                               
        /* =========================================================== */                                                                                                                                                                                      
        /* Métodos Privados - URL e Roteamento                       */                                                                                                                                                                                        
        /* =========================================================== */                                                                                                                                                                                      
                                                                                                                                                                                                                                                               
        /**                                                                                                                                                                                                                                                    
         * Handler executado quando a rota Monitor é matched.                                                                                                                                                                                                  
         * Lê os query parameters da URL e aplica como filtros.                                                                                                                                                                                                
         * @param {sap.ui.base.Event} oEvent - Evento de rota matched                                                                                                                                                                                          
         * @private                                                                                                                                                                                                                                            
         */                                                                                                                                                                                                                                                    
        _onRouteMatched: function (oEvent) {                                                                                                                                                                                                                   
            // Evita reprocessar quando a URL é atualizada programaticamente                                                                                                                                                                                   
            if (this._bSkipRouteMatch) {                                                                                                                                                                                                                       
                this._bSkipRouteMatch = false;                                                                                                                                                                                                                 
                return;                                                                                                                                                                                                                                        
            }                                                                                                                                                                                                                                                  
                                                                                                                                                                                                                                                               
            var oArgs = oEvent.getParameter("arguments");                                                                                                                                                                                                      
            var oQuery = (oArgs && oArgs["?query"]) || {};                                                                                                                                                                                                     
            var oViewModel = this.getView().getModel("monitor");                                                                                                                                                                                               
                                                                                                                                                                                                                                                               
            // Parar auto-refresh anterior (pode estar voltando da tela Automacao)                                                                                                                                                                             
            this._stopAutoRefresh();                                                                                                                                                                                                                           
                                                                                                                                                                                                                                                               
            // Aplicar status da URL ou default                                                                                                                                                                                                                
            var sStatus = oQuery.status || "all";                                                                                                                                                                                                              
            oViewModel.setProperty("/statusFilter", sStatus);                                                                                                                                                                                                  
            var oIconTabBar = this.byId("iconTabBar");                                                                                                                                                                                                         
            if (oIconTabBar) {                                                                                                                                                                                                                                 
                oIconTabBar.setSelectedKey(sStatus);                                                                                                                                                                                                           
            }                                                                                                                                                                                                                                                  
                                                                                                                                                                                                                                                               
            // Aplicar busca da URL ou default                                                                                                                                                                                                                 
            var sSearch = oQuery.search || "";                                                                                                                                                                                                                 
            oViewModel.setProperty("/searchQuery", sSearch);                                                                                                                                                                                                   
                                                                                                                                                                                                                                                               
            // Aplicar ordenação da URL ou default                                                                                                                                                                                                             
            if (oQuery.sort !== undefined) {                                                                                                                                                                                                                   
                oViewModel.setProperty("/sortDescending", oQuery.sort === "desc");                                                                                                                                                                             
            }                                                                                                                                                                                                                                                  
                                                                                                                                                                                                                                                               
            // Aplicar filtros de data da URL ou default (hoje)                                                                                                                                                                                                
            var sDateType = oQuery.dateType || "hoje";                                                                                                                                                                                                         
            oViewModel.setProperty("/dateFilterType", sDateType);                                                                                                                                                                                              
            oViewModel.setProperty("/dateFilterActive", true);                                                                                                                                                                                                 
                                                                                                                                                                                                                                                               
            if (oQuery.dateStart) {                                                                                                                                                                                                                            
                oViewModel.setProperty("/dateFilterStart", oQuery.dateStart);                                                                                                                                                                                  
            }                                                                                                                                                                                                                                                  
            if (oQuery.dateEnd) {                                                                                                                                                                                                                              
                oViewModel.setProperty("/dateFilterEnd", oQuery.dateEnd);                                                                                                                                                                                      
            }                                                                                                                                                                                                                                                  
            if (oQuery.dateSpecific) {                                                                                                                                                                                                                         
                oViewModel.setProperty("/dateFilterSpecific", oQuery.dateSpecific);                                                                                                                                                                            
            }                                                                                                                                                                                                                                                  
            if (oQuery.dateMonth !== undefined) {                                                                                                                                                                                                              
                oViewModel.setProperty("/dateFilterMonth", parseInt(oQuery.dateMonth, 10));                                                                                                                                                                    
            }                                                                                                                                                                                                                                                  
            if (oQuery.dateYear !== undefined) {                                                                                                                                                                                                               
                oViewModel.setProperty("/dateFilterYear", parseInt(oQuery.dateYear, 10));                                                                                                                                                                      
            }                                                                                                                                                                                                                                                  
                                                                                                                                                                                                                                                               
            // Limpar filtros client-side anteriores e carregar execuções                                                                                                                                                                                      
            oViewModel.setProperty("/filters", []);                                                                                                                                                                                                            
            this._loadExecutions();                                                                                                                                                                                                                            
            this._startAutoRefresh();                                                                                                                                                                                                                          
        },                                                                                                                                                                                                                                                     
                                                                                                                                                                                                                                                               
        /**                                                                                                                                                                                                                                                    
         * Atualiza os query parameters da URL com o estado atual dos filtros.                                                                                                                                                                                 
         * Navega para a rota RouteMonitor com os parâmetros atualizados.                                                                                                                                                                                      
         * @private                                                                                                                                                                                                                                            
         */                                                                                                                                                                                                                                                    
        _updateUrlParams: function () {                                                                                                                                                                                                                        
            this._bSkipRouteMatch = true;                                                                                                                                                                                                                      
            var oViewModel = this.getView().getModel("monitor");                                                                                                                                                                                               
            var oRouter = this.getOwnerComponent().getRouter();                                                                                                                                                                                                
                                                                                                                                                                                                                                                               
            var oQuery = {};                                                                                                                                                                                                                                   
                                                                                                                                                                                                                                                               
            // Status                                                                                                                                                                                                                                          
            var sStatus = oViewModel.getProperty("/statusFilter");                                                                                                                                                                                             
            if (sStatus && sStatus !== "all") {                                                                                                                                                                                                                
                oQuery.status = sStatus;                                                                                                                                                                                                                       
            }                                                                                                                                                                                                                                                  
                                                                                                                                                                                                                                                               
            // Busca                                                                                                                                                                                                                                           
            var sSearch = oViewModel.getProperty("/searchQuery");                                                                                                                                                                                              
            if (sSearch) {                                                                                                                                                                                                                                     
                oQuery.search = sSearch;                                                                                                                                                                                                                       
            }                                                                                                                                                                                                                                                  
                                                                                                                                                                                                                                                               
            // Ordenação                                                                                                                                                                                                                                       
            var bDesc = oViewModel.getProperty("/sortDescending");                                                                                                                                                                                             
            if (!bDesc) {                                                                                                                                                                                                                                      
                oQuery.sort = "asc";                                                                                                                                                                                                                           
            }                                                                                                                                                                                                                                                  
                                                                                                                                                                                                                                                               
            // Filtros de data                                                                                                                                                                                                                                 
            var sDateType = oViewModel.getProperty("/dateFilterType");                                                                                                                                                                                         
            if (sDateType && sDateType !== "hoje") {                                                                                                                                                                                                           
                oQuery.dateType = sDateType;                                                                                                                                                                                                                   
                                                                                                                                                                                                                                                               
                if (sDateType === "especifica") {                                                                                                                                                                                                              
                    oQuery.dateSpecific = oViewModel.getProperty("/dateFilterSpecific");                                                                                                                                                                       
                } else if (sDateType === "range") {                                                                                                                                                                                                            
                    oQuery.dateStart = oViewModel.getProperty("/dateFilterStart");                                                                                                                                                                             
                    oQuery.dateEnd = oViewModel.getProperty("/dateFilterEnd");                                                                                                                                                                                 
                } else if (sDateType === "mes") {                                                                                                                                                                                                              
                    oQuery.dateMonth = String(oViewModel.getProperty("/dateFilterMonth"));                                                                                                                                                                     
                    oQuery.dateYear = String(oViewModel.getProperty("/dateFilterYear"));                                                                                                                                                                       
                } else if (sDateType === "ano") {                                                                                                                                                                                                              
                    oQuery.dateYear = String(oViewModel.getProperty("/dateFilterYear"));                                                                                                                                                                       
                }                                                                                                                                                                                                                                              
            }                                                                                                                                                                                                                                                  
                                                                                                                                                                                                                                                               
            oRouter.navTo("RouteMonitor", { "?query": oQuery }, true);                                                                                                                                                                                         
        },                                                                                                                                                                                                                                                     
                                                                                                                                                                                                                                                               
        /* =========================================================== */                                                                                                                                                                                      
        /* Métodos Privados - Carregamento de Dados                   */                                                                                                                                                                                       
        /* =========================================================== */                                                                                                                                                                                      
                                                                                                                                                                                                                                                               
        /**                                                                                                                                                                                                                                                    
         * Carrega o menu de automações do backend.                                                                                                                                                                                                            
         * Adiciona uma opção "Todas as Automações" no início da lista.                                                                                                                                                                                        
         * @private                                                                                                                                                                                                                                            
         */                                                                                                                                                                                                                                                    
        _loadAutomationsMenu: function () {                                                                                                                                                                                                                    
            var oMainModel = this.getOwnerComponent().getModel();                                                                                                                                                                                              
            var oViewModel = this.getView().getModel("monitor");                                                                                                                                                                                               
            var oSharedModel = this.getOwnerComponent().getModel("shared");                                                                                                                                                                                    
            var that = this;                                                                                                                                                                                                                                   
                                                                                                                                                                                                                                                               
            if (!oMainModel) {                                                                                                                                                                                                                                 
                MessageBox.error("Modelo OData não está disponível. Verifique a configuração do manifest.json");                                                                                                                                               
                return;                                                                                                                                                                                                                                        
            }                                                                                                                                                                                                                                                  
                                                                                                                                                                                                                                                               
            oViewModel.setProperty("/busy", true);                                                                                                                                                                                                             
                                                                                                                                                                                                                                                               
            oMainModel.read("/Automacoes", {                                                                                                                                                                                                                   
                urlParameters: {                                                                                                                                                                                                                               
                    "$expand": "to_Operacoes"                                                                                                                                                                                                                  
                },                                                                                                                                                                                                                                             
                success: function (oData) {                                                                                                                                                                                                                    
                    var aAutomations = [{                                                                                                                                                                                                                      
                        descr: "Todas as Automações",                                                                                                                                                                                                          
                        icon_fiori: "sap-icon://activities",                                                                                                                                                                                                   
                        to_Operacoes: { results: [] }                                                                                                                                                                                                          
                    }].concat(oData.results);                                                                                                                                                                                                                  
                                                                                                                                                                                                                                                               
                    oSharedModel.setProperty("/automacoesCK", aAutomations);                                                                                                                                                                                   
                    oViewModel.setProperty("/busy", false);                                                                                                                                                                                                    
                    MessageToast.show("Dados carregados com sucesso!");                                                                                                                                                                                        
                },                                                                                                                                                                                                                                             
                error: function (oError) {                                                                                                                                                                                                                     
                    oViewModel.setProperty("/busy", false);                                                                                                                                                                                                    
                    that._handleODataError(oError, "Automacoes");                                                                                                                                                                                              
                }                                                                                                                                                                                                                                              
            });                                                                                                                                                                                                                                                
        },                                                                                                                                                                                                                                                     
                                                                                                                                                                                                                                                               
        /**                                                                                                                                                                                                                                                    
         * Carrega as execuções com base na seleção atual e filtros de data.                                                                                                                                                                                   
         * Pode ser chamado programaticamente ou por evento de seleção.                                                                                                                                                                                        
         * @param {sap.ui.base.Event} [oEvent] - Evento de seleção (opcional)                                                                                                                                                                                  
         * @private                                                                                                                                                                                                                                            
         */                                                                                                                                                                                                                                                    
        _loadExecutions: function (oEvent) {                                                                                                                                                                                                                   
            this._collapseSideNavigation();                                                                                                                                                                                                                    
                                                                                                                                                                                                                                                               
            var oViewModel = this.getView().getModel("monitor");                                                                                                                                                                                               
            var oSharedModel = this.getOwnerComponent().getModel("shared");                                                                                                                                                                                    
            var oMonitorModel = this.getOwnerComponent().getModel("monitorOData");                                                                                                                                                                             
            var that = this;                                                                                                                                                                                                                                   
                                                                                                                                                                                                                                                               
            // Determinar automação e operação selecionadas                                                                                                                                                                                                    
            var oSelection = this._getSelectedItems(oEvent, oViewModel);                                                                                                                                                                                       
                                                                                                                                                                                                                                                               
            // Construir descrição e filtro OData                                                                                                                                                                                                              
            var sDescription = this._buildOperationDescription(oSelection.automation, oSelection.operation, oSharedModel);                                                                                                                                     
            var sODataFilter = this._buildODataFilter(oSelection.automation, oSelection.operation);                                                                                                                                                            
                                                                                                                                                                                                                                                               
            oViewModel.setProperty("/operationTitle", sDescription);                                                                                                                                                                                           
                                                                                                                                                                                                                                                               
            if (!this._iAutoRefreshInterval) {                                                                                                                                                                                                                 
                oViewModel.setProperty("/busy", true);                                                                                                                                                                                                         
            }                                                                                                                                                                                                                                                  
                                                                                                                                                                                                                                                               
            // Configurar parâmetros da requisição OData                                                                                                                                                                                                       
            var oUrlParameters = {                                                                                                                                                                                                                             
                "$expand": "to_EtapasExecutadas/to_Logs",                                                                                                                                                                                                      
                "$orderby": "Credat desc, Cretim desc",                                                                                                                                                                                                        
                "$top": "9999"                                                                                                                                                                                                                                 
            };                                                                                                                                                                                                                                                 
                                                                                                                                                                                                                                                               
            // Adicionar filtro apenas se houver algum critério                                                                                                                                                                                                
            if (sODataFilter) {                                                                                                                                                                                                                                
                oUrlParameters["$filter"] = sODataFilter;                                                                                                                                                                                                      
            }                                                                                                                                                                                                                                                  
                                                                                                                                                                                                                                                               
            // Buscar execuções do backend                                                                                                                                                                                                                     
            oMonitorModel.read("/Header", {                                                                                                                                                                                                                    
                urlParameters: oUrlParameters,                                                                                                                                                                                                                 
                success: function (oData) {                                                                                                                                                                                                                    
                    that._processExecutionsData(oData);                                                                                                                                                                                                        
                },                                                                                                                                                                                                                                             
                error: function (oError) {                                                                                                                                                                                                                     
                    oViewModel.setProperty("/busy", false);                                                                                                                                                                                                    
                    that._handleODataError(oError, "execuções");                                                                                                                                                                                               
                }                                                                                                                                                                                                                                              
            });                                                                                                                                                                                                                                                
        },                                                                                                                                                                                                                                                     
                                                                                                                                                                                                                                                               
        /**                                                                                                                                                                                                                                                    
         * Obtém os itens selecionados (automação e operação).                                                                                                                                                                                                 
         * @param {sap.ui.base.Event} [oEvent] - Evento de seleção                                                                                                                                                                                             
         * @param {JSONModel} oViewModel - Modelo de visualização                                                                                                                                                                                              
         * @returns {object} Objeto com automation e operation                                                                                                                                                                                                 
         * @private                                                                                                                                                                                                                                            
         */                                                                                                                                                                                                                                                    
        _getSelectedItems: function (oEvent, oViewModel) {                                                                                                                                                                                                     
            var sAutomation = "";                                                                                                                                                                                                                              
            var sOperation = "";                                                                                                                                                                                                                               
                                                                                                                                                                                                                                                               
            if (oEvent) {                                                                                                                                                                                                                                      
                var oSelectedItem = oEvent.getParameter("item");                                                                                                                                                                                               
                var aKeys = oSelectedItem.getKey().split("-");                                                                                                                                                                                                 
                sAutomation = aKeys[0];                                                                                                                                                                                                                        
                sOperation = aKeys[1];                                                                                                                                                                                                                         
                                                                                                                                                                                                                                                               
                oViewModel.setProperty("/selectedAutomation", sAutomation);                                                                                                                                                                                    
                oViewModel.setProperty("/selectedOperation", sOperation);                                                                                                                                                                                      
            } else {                                                                                                                                                                                                                                           
                sAutomation = oViewModel.getProperty("/selectedAutomation") || "";                                                                                                                                                                             
                sOperation = oViewModel.getProperty("/selectedOperation") || "";                                                                                                                                                                               
            }                                                                                                                                                                                                                                                  
                                                                                                                                                                                                                                                               
            return {                                                                                                                                                                                                                                           
                automation: sAutomation,                                                                                                                                                                                                                       
                operation: sOperation                                                                                                                                                                                                                          
            };                                                                                                                                                                                                                                                 
        },                                                                                                                                                                                                                                                     
                                                                                                                                                                                                                                                               
        /**                                                                                                                                                                                                                                                    
         * Constrói a descrição da operação selecionada.                                                                                                                                                                                                       
         * @param {string} sAutomation - ID da automação                                                                                                                                                                                                       
         * @param {string} sOperation - ID da operação                                                                                                                                                                                                         
         * @param {JSONModel} oSharedModel - Modelo compartilhado                                                                                                                                                                                              
         * @returns {string} Descrição formatada                                                                                                                                                                                                               
         * @private                                                                                                                                                                                                                                            
         */                                                                                                                                                                                                                                                    
        _buildOperationDescription: function (sAutomation, sOperation, oSharedModel) {                                                                                                                                                                         
            if (!sAutomation) {                                                                                                                                                                                                                                
                return "Todas as Automações";                                                                                                                                                                                                                  
            }                                                                                                                                                                                                                                                  
                                                                                                                                                                                                                                                               
            var aAutomations = oSharedModel.getProperty("/automacoesCK") || [];                                                                                                                                                                                
            var oAutomation = aAutomations.find(function (item) {                                                                                                                                                                                              
                return item.auto === sAutomation;                                                                                                                                                                                                              
            });                                                                                                                                                                                                                                                
                                                                                                                                                                                                                                                               
            if (!oAutomation) {                                                                                                                                                                                                                                
                return "";                                                                                                                                                                                                                                     
            }                                                                                                                                                                                                                                                  
                                                                                                                                                                                                                                                               
            if (sOperation) {                                                                                                                                                                                                                                  
                var oOperation = oAutomation.to_Operacoes.results.find(function (item) {                                                                                                                                                                       
                    return item.opera === sOperation;                                                                                                                                                                                                          
                });                                                                                                                                                                                                                                            
                return sAutomation + " - " + sOperation + " - " + oOperation.descr;                                                                                                                                                                            
            }                                                                                                                                                                                                                                                  
                                                                                                                                                                                                                                                               
            return sAutomation + " - " + oAutomation.descr;                                                                                                                                                                                                    
        },                                                                                                                                                                                                                                                     
                                                                                                                                                                                                                                                               
        /**                                                                                                                                                                                                                                                    
         * Constrói o filtro OData combinando filtros de automação, operação e data.                                                                                                                                                                           
         * @param {string} sAutomation - ID da automação                                                                                                                                                                                                       
         * @param {string} sOperation - ID da operação                                                                                                                                                                                                         
         * @returns {string} String de filtro OData                                                                                                                                                                                                            
         * @private                                                                                                                                                                                                                                            
         */                                                                                                                                                                                                                                                    
        _buildODataFilter: function (sAutomation, sOperation) {                                                                                                                                                                                                
            var aFilters = [];                                                                                                                                                                                                                                 
                                                                                                                                                                                                                                                               
            // Filtro de automação                                                                                                                                                                                                                             
            if (sAutomation) {                                                                                                                                                                                                                                 
                aFilters.push("Auto eq '" + sAutomation + "'");                                                                                                                                                                                                
            }                                                                                                                                                                                                                                                  
                                                                                                                                                                                                                                                               
            // Filtro de operação                                                                                                                                                                                                                              
            if (sOperation) {                                                                                                                                                                                                                                  
                aFilters.push("Opera eq '" + sOperation + "'");                                                                                                                                                                                                
            }                                                                                                                                                                                                                                                  
                                                                                                                                                                                                                                                               
            // Filtro de data                                                                                                                                                                                                                                  
            var sDateFilter = this._buildDateFilterOData();                                                                                                                                                                                                    
            if (sDateFilter) {                                                                                                                                                                                                                                 
                aFilters.push("(" + sDateFilter + ")");                                                                                                                                                                                                        
            }                                                                                                                                                                                                                                                  
                                                                                                                                                                                                                                                               
            return aFilters.join(" and ");                                                                                                                                                                                                                     
        },                                                                                                                                                                                                                                                     
                                                                                                                                                                                                                                                               
        /**                                                                                                                                                                                                                                                    
         * Constrói filtro de data em formato OData v2 do SAP.                                                                                                                                                                                                 
         * @returns {string} String de filtro OData ou vazio se não houver filtro ativo                                                                                                                                                                        
         * @private                                                                                                                                                                                                                                            
         */                                                                                                                                                                                                                                                    
        _buildDateFilterOData: function () {                                                                                                                                                                                                                   
            var oViewModel = this.getView().getModel("monitor");                                                                                                                                                                                               
            var sFilterType = oViewModel.getProperty("/dateFilterType");                                                                                                                                                                                       
            var bFilterActive = oViewModel.getProperty("/dateFilterActive");                                                                                                                                                                                   
                                                                                                                                                                                                                                                               
            if (!bFilterActive || sFilterType === "todas") {                                                                                                                                                                                                   
                return "";                                                                                                                                                                                                                                     
            }                                                                                                                                                                                                                                                  
                                                                                                                                                                                                                                                               
            var oToday = this._getToday();                                                                                                                                                                                                                     
            var sDateFilter = "";                                                                                                                                                                                                                              
                                                                                                                                                                                                                                                               
            switch (sFilterType) {                                                                                                                                                                                                                             
                case "hoje":                                                                                                                                                                                                                                   
                    sDateFilter = this._createTodayFilter(oToday);                                                                                                                                                                                             
                    break;                                                                                                                                                                                                                                     
                                                                                                                                                                                                                                                               
                case "especifica":                                                                                                                                                                                                                             
                    sDateFilter = this._createSpecificDateFilter(oViewModel);                                                                                                                                                                                  
                    break;                                                                                                                                                                                                                                     
                                                                                                                                                                                                                                                               
                case "range":                                                                                                                                                                                                                                  
                    sDateFilter = this._createDateRangeFilter(oViewModel);                                                                                                                                                                                     
                    break;                                                                                                                                                                                                                                     
                                                                                                                                                                                                                                                               
                case "mes":                                                                                                                                                                                                                                    
                    sDateFilter = this._createMonthFilter(oViewModel);                                                                                                                                                                                         
                    break;                                                                                                                                                                                                                                     
                                                                                                                                                                                                                                                               
                case "ano":                                                                                                                                                                                                                                    
                    sDateFilter = this._createYearFilter(oViewModel);                                                                                                                                                                                          
                    break;                                                                                                                                                                                                                                     
            }                                                                                                                                                                                                                                                  
                                                                                                                                                                                                                                                               
            return sDateFilter;                                                                                                                                                                                                                                
        },                                                                                                                                                                                                                                                     
                                                                                                                                                                                                                                                               
        /**                                                                                                                                                                                                                                                    
         * Cria filtro para o dia de hoje.                                                                                                                                                                                                                     
         * @param {Date} oToday - Data de hoje                                                                                                                                                                                                                 
         * @returns {string} Filtro OData                                                                                                                                                                                                                      
         * @private                                                                                                                                                                                                                                            
         */                                                                                                                                                                                                                                                    
        _createTodayFilter: function (oToday) {                                                                                                                                                                                                                
            var oEndOfDay = new Date(oToday);                                                                                                                                                                                                                  
            oEndOfDay.setHours(23, 59, 59, 0);                                                                                                                                                                                                                 
                                                                                                                                                                                                                                                               
            return "Credat ge " + this._formatDateForOData(oToday) + " and Credat le " + this._formatDateForOData(oEndOfDay);                                                                                                                                  
        },                                                                                                                                                                                                                                                     
                                                                                                                                                                                                                                                               
        /**                                                                                                                                                                                                                                                    
         * Cria filtro para data específica.                                                                                                                                                                                                                   
         * @param {JSONModel} oViewModel - Modelo de visualização                                                                                                                                                                                              
         * @returns {string} Filtro OData                                                                                                                                                                                                                      
         * @private                                                                                                                                                                                                                                            
         */                                                                                                                                                                                                                                                    
        _createSpecificDateFilter: function (oViewModel) {                                                                                                                                                                                                     
            var vDate = oViewModel.getProperty("/dateFilterSpecific");                                                                                                                                                                                         
            if (!vDate) {                                                                                                                                                                                                                                      
                return "";                                                                                                                                                                                                                                     
            }                                                                                                                                                                                                                                                  
                                                                                                                                                                                                                                                               
            var oDate;                                                                                                                                                                                                                                         
            if (typeof vDate === 'string') {                                                                                                                                                                                                                   
                // Parse YYYY-MM-DD manually to avoid timezone issues                                                                                                                                                                                          
                var aParts = vDate.split('-');                                                                                                                                                                                                                 
                oDate = new Date(parseInt(aParts[0]), parseInt(aParts[1]) - 1, parseInt(aParts[2]));                                                                                                                                                           
            } else {                                                                                                                                                                                                                                           
                oDate = vDate instanceof Date ? vDate : new Date(vDate);                                                                                                                                                                                       
            }                                                                                                                                                                                                                                                  
&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;                                                                                                                                                                                       
            if (isNaN(oDate.getTime())) {                                                                                                                                                                                                                      
                return "";                                                                                                                                                                                                                                     
            }                                                                                                                                                                                                                                                  
&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;                                                                                                                                                                                       
            var oStartOfDay = new Date(oDate);                                                                                                                                                                                                                 
            oStartOfDay.setHours(0, 0, 0, 0);                                                                                                                                                                                                                  
                                                                                                                                                                                                                                                               
            var oEndOfDay = new Date(oDate);                                                                                                                                                                                                                   
            oEndOfDay.setHours(23, 59, 59, 0);                                                                                                                                                                                                                 
                                                                                                                                                                                                                                                               
            return "Credat ge " + this._formatDateForOData(oStartOfDay) + " and Credat le " + this._formatDateForOData(oEndOfDay);                                                                                                                             
        },                                                                                                                                                                                                                                                     
                                                                                                                                                                                                                                                               
        /**                                                                                                                                                                                                                                                    
         * Cria filtro para intervalo de datas.                                                                                                                                                                                                                
         * @param {JSONModel} oViewModel - Modelo de visualização                                                                                                                                                                                              
         * @returns {string} Filtro OData                                                                                                                                                                                                                      
         * @private                                                                                                                                                                                                                                            
         */                                                                                                                                                                                                                                                    
        _createDateRangeFilter: function (oViewModel) {                                                                                                                                                                                                        
            var vStartDate = oViewModel.getProperty("/dateFilterStart");                                                                                                                                                                                       
            var vEndDate = oViewModel.getProperty("/dateFilterEnd");                                                                                                                                                                                           
                                                                                                                                                                                                                                                               
            if (!vStartDate || !vEndDate) {                                                                                                                                                                                                                    
                return "";                                                                                                                                                                                                                                     
            }                                                                                                                                                                                                                                                  
                                                                                                                                                                                                                                                               
            var oStart, oEnd;                                                                                                                                                                                                                                  
&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;                                                                                                                                                                                       
            if (typeof vStartDate === 'string') {                                                                                                                                                                                                              
                var aStartParts = vStartDate.split('-');                                                                                                                                                                                                       
                oStart = new Date(parseInt(aStartParts[0]), parseInt(aStartParts[1]) - 1, parseInt(aStartParts[2]));                                                                                                                                           
            } else {                                                                                                                                                                                                                                           
                oStart = vStartDate instanceof Date ? vStartDate : new Date(vStartDate);                                                                                                                                                                       
            }                                                                                                                                                                                                                                                  
&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;                                                                                                                                                                                       
            if (typeof vEndDate === 'string') {                                                                                                                                                                                                                
                var aEndParts = vEndDate.split('-');                                                                                                                                                                                                           
                oEnd = new Date(parseInt(aEndParts[0]), parseInt(aEndParts[1]) - 1, parseInt(aEndParts[2]));                                                                                                                                                   
            } else {                                                                                                                                                                                                                                           
                oEnd = vEndDate instanceof Date ? vEndDate : new Date(vEndDate);                                                                                                                                                                               
            }                                                                                                                                                                                                                                                  
&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;                                                                                                                                                                                       
            if (isNaN(oStart.getTime()) || isNaN(oEnd.getTime())) {                                                                                                                                                                                            
                return "";                                                                                                                                                                                                                                     
            }                                                                                                                                                                                                                                                  
&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;                                                                                                                                                                                       
            oStart.setHours(0, 0, 0, 0);                                                                                                                                                                                                                       
            oEnd.setHours(23, 59, 59, 0);                                                                                                                                                                                                                      
                                                                                                                                                                                                                                                               
            return "Credat ge " + this._formatDateForOData(oStart) + " and Credat le " + this._formatDateForOData(oEnd);                                                                                                                                       
        },                                                                                                                                                                                                                                                     
                                                                                                                                                                                                                                                               
        /**                                                                                                                                                                                                                                                    
         * Cria filtro para mês específico.                                                                                                                                                                                                                    
         * @param {JSONModel} oViewModel - Modelo de visualização                                                                                                                                                                                              
         * @returns {string} Filtro OData                                                                                                                                                                                                                      
         * @private                                                                                                                                                                                                                                            
         */                                                                                                                                                                                                                                                    
        _createMonthFilter: function (oViewModel) {                                                                                                                                                                                                            
            var iMonth = oViewModel.getProperty("/dateFilterMonth");                                                                                                                                                                                           
            var iYear = oViewModel.getProperty("/dateFilterYear");                                                                                                                                                                                             
                                                                                                                                                                                                                                                               
            var oStartOfMonth = new Date(iYear, iMonth, 1, 0, 0, 0, 0);                                                                                                                                                                                        
            var oEndOfMonth = new Date(iYear, iMonth + 1, 0, 23, 59, 59, 0);                                                                                                                                                                                   
                                                                                                                                                                                                                                                               
            return "Credat ge " + this._formatDateForOData(oStartOfMonth) + " and Credat le " + this._formatDateForOData(oEndOfMonth);                                                                                                                         
        },                                                                                                                                                                                                                                                     
                                                                                                                                                                                                                                                               
        /**                                                                                                                                                                                                                                                    
         * Cria filtro para ano específico.                                                                                                                                                                                                                    
         * @param {JSONModel} oViewModel - Modelo de visualização                                                                                                                                                                                              
         * @returns {string} Filtro OData                                                                                                                                                                                                                      
         * @private                                                                                                                                                                                                                                            
         */                                                                                                                                                                                                                                                    
        _createYearFilter: function (oViewModel) {                                                                                                                                                                                                             
            var iYear = oViewModel.getProperty("/dateFilterYear");                                                                                                                                                                                             
                                                                                                                                                                                                                                                               
            var oStartOfYear = new Date(iYear, 0, 1, 0, 0, 0, 0);                                                                                                                                                                                              
            var oEndOfYear = new Date(iYear, 11, 31, 23, 59, 59, 0);                                                                                                                                                                                           
                                                                                                                                                                                                                                                               
            return "Credat ge " + this._formatDateForOData(oStartOfYear) + " and Credat le " + this._formatDateForOData(oEndOfYear);                                                                                                                           
        },                                                                                                                                                                                                                                                     
                                                                                                                                                                                                                                                               
        /**                                                                                                                                                                                                                                                    
         * Formata data no padrão OData v2 do SAP (datetime'YYYY-MM-DDTHH:MM:SS').                                                                                                                                                                             
         * @param {Date} oDate - Data a ser formatada                                                                                                                                                                                                          
         * @returns {string} Data formatada para OData                                                                                                                                                                                                         
         * @private                                                                                                                                                                                                                                            
         */                                                                                                                                                                                                                                                    
        /**                                                                                                                                                                                                                                                    
         * Formata data para formato OData DateTime.                                                                                                                                                                                                           
         * @param {Date|string} vDate - Data como objeto Date ou string                                                                                                                                                                                        
         * @returns {string} Data formatada para OData (ex: datetime'2026-02-25T00:00:00')                                                                                                                                                                     
         * @private                                                                                                                                                                                                                                            
         */                                                                                                                                                                                                                                                    
        _formatDateForOData: function (vDate) {                                                                                                                                                                                                                
            var oDate;                                                                                                                                                                                                                                         
&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;                                                                                                                                                                                       
            // Convert string to Date if needed                                                                                                                                                                                                                
            if (typeof vDate === 'string') {                                                                                                                                                                                                                   
                oDate = new Date(vDate);                                                                                                                                                                                                                       
            } else {                                                                                                                                                                                                                                           
                oDate = vDate;                                                                                                                                                                                                                                 
            }                                                                                                                                                                                                                                                  
&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;                                                                                                                                                                                       
            // Check if date is valid                                                                                                                                                                                                                          
            if (!oDate || isNaN(oDate.getTime())) {                                                                                                                                                                                                            
                return "";                                                                                                                                                                                                                                     
            }                                                                                                                                                                                                                                                  
&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;                                                                                                                                                                                       
            var sYear = oDate.getFullYear();                                                                                                                                                                                                                   
            var sMonth = String(oDate.getMonth() + 1).padStart(2, '0');                                                                                                                                                                                        
            var sDay = String(oDate.getDate()).padStart(2, '0');                                                                                                                                                                                               
            var sHours = String(oDate.getHours()).padStart(2, '0');                                                                                                                                                                                            
            var sMinutes = String(oDate.getMinutes()).padStart(2, '0');                                                                                                                                                                                        
            var sSeconds = String(oDate.getSeconds()).padStart(2, '0');                                                                                                                                                                                        
                                                                                                                                                                                                                                                               
            // OData DateTime format                                                                                                                                                                                                                           
            return "datetime'" + sYear + "-" + sMonth + "-" + sDay + "T" + sHours + ":" + sMinutes + ":" + sSeconds + "'";                                                                                                                                     
        },                                                                                                                                                                                                                                                     
                                                                                                                                                                                                                                                               
        /**                                                                                                                                                                                                                                                    
         * Processa os dados de execuções retornados do backend.                                                                                                                                                                                               
         * Formata datas, calcula durações e contadores de status.                                                                                                                                                                                             
         * @param {object} oData - Dados retornados do OData                                                                                                                                                                                                   
         * @private                                                                                                                                                                                                                                            
         */                                                                                                                                                                                                                                                    
        _processExecutionsData: function (oData) {                                                                                                                                                                                                             
            var oViewModel = this.getView().getModel("monitor");                                                                                                                                                                                               
            var aProcessedExecutions = [];                                                                                                                                                                                                                     
            var that = this;                                                                                                                                                                                                                                   
                                                                                                                                                                                                                                                               
            // Contadores de status                                                                                                                                                                                                                            
            var oCounters = {                                                                                                                                                                                                                                  
                success: 0,                                                                                                                                                                                                                                    
                error: 0,                                                                                                                                                                                                                                      
                warning: 0,                                                                                                                                                                                                                                    
                none: 0                                                                                                                                                                                                                                        
            };                                                                                                                                                                                                                                                 
                                                                                                                                                                                                                                                               
            oData.results.forEach(function (oExecution) {                                                                                                                                                                                                      
                var oProcessedExecution = that._processExecution(oExecution, oCounters);                                                                                                                                                                       
                aProcessedExecutions.push(oProcessedExecution);                                                                                                                                                                                                
            });                                                                                                                                                                                                                                                
                                                                                                                                                                                                                                                               
            // Atualizar modelo                                                                                                                                                                                                                                
            oViewModel.setProperty("/allExecutions", aProcessedExecutions);                                                                                                                                                                                    
            oViewModel.setProperty("/filteredExecutions", aProcessedExecutions);                                                                                                                                                                               
            oViewModel.setProperty("/executeButtonEnabled", true);                                                                                                                                                                                             
            oViewModel.setProperty("/countAll", oData.results.length);                                                                                                                                                                                         
            oViewModel.setProperty("/countSuccess", oCounters.success);                                                                                                                                                                                        
            oViewModel.setProperty("/countError", oCounters.error);                                                                                                                                                                                            
            oViewModel.setProperty("/countWarning", oCounters.warning);                                                                                                                                                                                        
            oViewModel.setProperty("/countNone", oCounters.none);                                                                                                                                                                                              
                                                                                                                                                                                                                                                               
            this._applyStatusFilter();                                                                                                                                                                                                                         
        },                                                                                                                                                                                                                                                     
                                                                                                                                                                                                                                                               
        /**                                                                                                                                                                                                                                                    
         * Inicia o intervalo de auto-refresh (1 segundo).                                                                                                                                                                                                     
         * @private                                                                                                                                                                                                                                            
         */                                                                                                                                                                                                                                                    
        _startAutoRefresh: function () {                                                                                                                                                                                                                       
            if (this._iAutoRefreshInterval) {                                                                                                                                                                                                                  
                return;                                                                                                                                                                                                                                        
            }                                                                                                                                                                                                                                                  
            this._iAutoRefreshInterval = setInterval(function () {                                                                                                                                                                                             
                this._loadExecutions();                                                                                                                                                                                                                        
            }.bind(this), 1000);                                                                                                                                                                                                                               
        },                                                                                                                                                                                                                                                     
                                                                                                                                                                                                                                                               
        /**                                                                                                                                                                                                                                                    
         * Para o intervalo de auto-refresh.                                                                                                                                                                                                                   
         * @private                                                                                                                                                                                                                                            
         */                                                                                                                                                                                                                                                    
        _stopAutoRefresh: function () {                                                                                                                                                                                                                        
            if (this._iAutoRefreshInterval) {                                                                                                                                                                                                                  
                clearInterval(this._iAutoRefreshInterval);                                                                                                                                                                                                     
                this._iAutoRefreshInterval = null;                                                                                                                                                                                                             
            }                                                                                                                                                                                                                                                  
        },                                                                                                                                                                                                                                                     
                                                                                                                                                                                                                                                               
        /**                                                                                                                                                                                                                                                    
         * Processa uma execução individual.                                                                                                                                                                                                                   
         * @param {object} oExecution - Dados da execução                                                                                                                                                                                                      
         * @param {object} oCounters - Objeto de contadores de status                                                                                                                                                                                          
         * @returns {object} Execução processada                                                                                                                                                                                                               
         * @private                                                                                                                                                                                                                                            
         */                                                                                                                                                                                                                                                    
        _processExecution: function (oExecution, oCounters) {                                                                                                                                                                                                  
            var oStatus = this._mapExecutionStatus(oExecution.Status, oExecution.to_EtapasExecutadas);                                                                                                                                                         
            var sFormattedDateTime = this._formatExecutionDateTime(oExecution);                                                                                                                                                                                
            var sDuration = this._calculateExecutionDuration(oExecution);                                                                                                                                                                                      
                                                                                                                                                                                                                                                               
            // Incrementar contador apropriado                                                                                                                                                                                                                 
            var sCounterKey = oStatus.type.toLowerCase();                                                                                                                                                                                                      
            if (oCounters[sCounterKey] !== undefined) {                                                                                                                                                                                                        
                oCounters[sCounterKey]++;                                                                                                                                                                                                                      
            }                                                                                                                                                                                                                                                  
                                                                                                                                                                                                                                                               
            return {                                                                                                                                                                                                                                           
                Chave: oExecution.Chave,                                                                                                                                                                                                                       
                Auto: oExecution.Auto,                                                                                                                                                                                                                         
                Opera: oExecution.Opera,                                                                                                                                                                                                                       
                Credat: oExecution.Credat,                                                                                                                                                                                                                     
                Cretim: oExecution.Cretim,                                                                                                                                                                                                                     
                DataHora: sFormattedDateTime,                                                                                                                                                                                                                  
                Duracao: sDuration,                                                                                                                                                                                                                            
                Status: oStatus.status,                                                                                                                                                                                                                        
                StatusType: oStatus.type,                                                                                                                                                                                                                      
                to_EtapasExecutadas: oExecution.to_EtapasExecutadas                                                                                                                                                                                            
            };                                                                                                                                                                                                                                                 
        },                                                                                                                                                                                                                                                     
                                                                                                                                                                                                                                                               
        /**                                                                                                                                                                                                                                                    
         * Mapeia o código de status para descrição e tipo visual.                                                                                                                                                                                             
         * Para status Aguardando (0), verifica se alguma etapa possui WAITM                                                                                                                                                                                   
         * preenchido e usa a descrição WAITT como motivo do aguardo.                                                                                                                                                                                          
         * @param {string} sStatusCode - Código do status                                                                                                                                                                                                      
         * @param {object} [oEtapasExecutadas] - Objeto com results das etapas executadas                                                                                                                                                                      
         * @returns {object} Objeto com status e type                                                                                                                                                                                                          
         * @private                                                                                                                                                                                                                                            
         */                                                                                                                                                                                                                                                    
        _mapExecutionStatus: function (sStatusCode, oEtapasExecutadas) {                                                                                                                                                                                       
            var iStatus = parseInt(sStatusCode, 10);                                                                                                                                                                                                           
                                                                                                                                                                                                                                                               
            var STATUS_MAP = {                                                                                                                                                                                                                                 
                0: { status: "Aguardando", type: "None" },                                                                                                                                                                                                     
                1: { status: "Executando", type: "Warning" },                                                                                                                                                                                                  
                2: { status: "Completo", type: "Success" },                                                                                                                                                                                                    
                3: { status: "Erro durante o processamento", type: "Error" },                                                                                                                                                                                  
                4: { status: "Falha de validação", type: "Error" },                                                                                                                                                                                            
                5: { status: "Pausado", type: "Warning" }                                                                                                                                                                                                      
            };                                                                                                                                                                                                                                                 
                                                                                                                                                                                                                                                               
            var oResult = STATUS_MAP[iStatus] || { status: "Desconhecido", type: "None" };                                                                                                                                                                     
                                                                                                                                                                                                                                                               
            // Para status Aguardando, buscar motivo do aguardo nas etapas                                                                                                                                                                                     
            if (iStatus === 0 && oEtapasExecutadas && oEtapasExecutadas.results) {                                                                                                                                                                             
                var oEtapaComWait = oEtapasExecutadas.results.find(function (oEtapa) {                                                                                                                                                                         
                    return oEtapa.Waitm && oEtapa.Waitm !== "";                                                                                                                                                                                                
                });                                                                                                                                                                                                                                            
                if (oEtapaComWait && oEtapaComWait.Waitt) {                                                                                                                                                                                                    
                    oResult.status = oEtapaComWait.Waitt;                                                                                                                                                                                                      
                }                                                                                                                                                                                                                                              
            }                                                                                                                                                                                                                                                  
                                                                                                                                                                                                                                                               
            return oResult;                                                                                                                                                                                                                                    
        },                                                                                                                                                                                                                                                     
                                                                                                                                                                                                                                                               
        /**                                                                                                                                                                                                                                                    
         * Formata data e hora da execução para exibição.                                                                                                                                                                                                      
         * @param {object} oExecution - Dados da execução                                                                                                                                                                                                      
         * @returns {string} Data formatada                                                                                                                                                                                                                    
         * @private                                                                                                                                                                                                                                            
         */                                                                                                                                                                                                                                                    
        _formatExecutionDateTime: function (oExecution) {                                                                                                                                                                                                      
            if (!oExecution.Credat) {                                                                                                                                                                                                                          
                return "";                                                                                                                                                                                                                                     
            }                                                                                                                                                                                                                                                  
                                                                                                                                                                                                                                                               
            var oDateTime = this._combineDateAndTime(oExecution.Credat, oExecution.Cretim);                                                                                                                                                                    
            return oDateTime.toLocaleDateString("pt-BR") + " " + oDateTime.toLocaleTimeString("pt-BR");                                                                                                                                                        
        },                                                                                                                                                                                                                                                     
                                                                                                                                                                                                                                                               
        /**                                                                                                                                                                                                                                                    
         * Calcula a duração da execução.                                                                                                                                                                                                                      
         * @param {object} oExecution - Dados da execução                                                                                                                                                                                                      
         * @returns {string} Duração formatada                                                                                                                                                                                                                 
         * @private                                                                                                                                                                                                                                            
         */                                                                                                                                                                                                                                                    
        _calculateExecutionDuration: function (oExecution) {                                                                                                                                                                                                   
            if (oExecution.Status !== "2" || !oExecution.to_EtapasExecutadas ||&nbsp;                                                                                                                                                                          
                oExecution.to_EtapasExecutadas.results.length === 0) {                                                                                                                                                                                         
                return "";                                                                                                                                                                                                                                     
            }                                                                                                                                                                                                                                                  
                                                                                                                                                                                                                                                               
            var oFirstStep = oExecution;                                                                                                                                                                                                                       
            var aSteps = oExecution.to_EtapasExecutadas.results;                                                                                                                                                                                               
            var oLastStep = aSteps[aSteps.length - 1];                                                                                                                                                                                                         
                                                                                                                                                                                                                                                               
            if (!oFirstStep.Credat || !oFirstStep.Cretim || !oLastStep.Credat || !oLastStep.Cretim) {                                                                                                                                                          
                return "";                                                                                                                                                                                                                                     
            }                                                                                                                                                                                                                                                  
                                                                                                                                                                                                                                                               
            var oStartTime = this._combineDateAndTime(oFirstStep.Credat, oFirstStep.Cretim);                                                                                                                                                                   
            var oEndTime = this._combineDateAndTime(oLastStep.Credat, oLastStep.Cretim);                                                                                                                                                                       
            var iDurationMs = Math.abs(oEndTime - oStartTime);                                                                                                                                                                                                 
                                                                                                                                                                                                                                                               
            return this._formatDuration(iDurationMs);                                                                                                                                                                                                          
        },                                                                                                                                                                                                                                                     
                                                                                                                                                                                                                                                               
        /**                                                                                                                                                                                                                                                    
         * Formata duração em milissegundos para formato legível.                                                                                                                                                                                              
         * @param {number} iDurationMs - Duração em milissegundos                                                                                                                                                                                              
         * @returns {string} Duração formatada (ex: "2hrs", "45min", "30s")                                                                                                                                                                                    
         * @private                                                                                                                                                                                                                                            
         */                                                                                                                                                                                                                                                    
        _formatDuration: function (iDurationMs) {                                                                                                                                                                                                              
            var iSeconds = iDurationMs / 1000;                                                                                                                                                                                                                 
            var iMinutes = Math.floor(iSeconds / 60);                                                                                                                                                                                                          
            var iHours = Math.floor(iMinutes / 60);                                                                                                                                                                                                            
                                                                                                                                                                                                                                                               
            if (iHours >= 1) {                                                                                                                                                                                                                                 
                return iHours + "hrs";                                                                                                                                                                                                                         
            } else if (iMinutes >= 1) {                                                                                                                                                                                                                        
                return iMinutes + "min";                                                                                                                                                                                                                       
            } else if (iSeconds >= 1) {                                                                                                                                                                                                                        
                return Math.floor(iSeconds) + "s";                                                                                                                                                                                                             
            } else {                                                                                                                                                                                                                                           
                return iDurationMs + "ms";                                                                                                                                                                                                                     
            }                                                                                                                                                                                                                                                  
        },                                                                                                                                                                                                                                                     
                                                                                                                                                                                                                                                               
        /**                                                                                                                                                                                                                                                    
         * Combina data e duração em um objeto Date.                                                                                                                                                                                                           
         * @param {string|Date} vDate - Data (string ou objeto Date)                                                                                                                                                                                           
         * @param {object|string|number} vDuration - Duração em diversos formatos                                                                                                                                                                              
         * @returns {Date} Objeto Date combinado                                                                                                                                                                                                               
         * @private                                                                                                                                                                                                                                            
         */                                                                                                                                                                                                                                                    
        _combineDateAndTime: function (vDate, vDuration) {                                                                                                                                                                                                     
            var sDateString = vDate;                                                                                                                                                                                                                           
                                                                                                                                                                                                                                                               
            if (vDate instanceof Date) {                                                                                                                                                                                                                       
                sDateString = vDate.toISOString();                                                                                                                                                                                                             
            }                                                                                                                                                                                                                                                  
                                                                                                                                                                                                                                                               
            var aDateParts = sDateString.split('T')[0].split('-');                                                                                                                                                                                             
            var iYear = parseInt(aDateParts[0], 10);                                                                                                                                                                                                           
            var iMonth = parseInt(aDateParts[1], 10) - 1;                                                                                                                                                                                                      
            var iDay = parseInt(aDateParts[2], 10);                                                                                                                                                                                                            
                                                                                                                                                                                                                                                               
            var oTime = this._parseDuration(vDuration);                                                                                                                                                                                                        
                                                                                                                                                                                                                                                               
            return new Date(iYear, iMonth, iDay, oTime.hours, oTime.minutes, oTime.seconds);                                                                                                                                                                   
        },                                                                                                                                                                                                                                                     
                                                                                                                                                                                                                                                               
        /**                                                                                                                                                                                                                                                    
         * Converte duração de vários formatos para objeto com horas, minutos e segundos.                                                                                                                                                                      
         * Suporta: PTnHnMnS (OData), objeto com propriedade ms, número (milissegundos).                                                                                                                                                                       
         * @param {object|string|number} vDuration - Duração em diversos formatos                                                                                                                                                                              
         * @returns {object} Objeto com hours, minutes, seconds                                                                                                                                                                                                
         * @private                                                                                                                                                                                                                                            
         */                                                                                                                                                                                                                                                    
        _parseDuration: function (vDuration) {                                                                                                                                                                                                                 
            var DEFAULT_DURATION = { hours: 0, minutes: 0, seconds: 0 };                                                                                                                                                                                       
                                                                                                                                                                                                                                                               
            if (!vDuration && vDuration !== 0) {                                                                                                                                                                                                               
                return DEFAULT_DURATION;                                                                                                                                                                                                                       
            }                                                                                                                                                                                                                                                  
                                                                                                                                                                                                                                                               
            // Objeto com propriedade ms (ex: {ms: 65209000, _edmType: 'Edm.Time'})                                                                                                                                                                            
            if (typeof vDuration === 'object' && vDuration !== null) {                                                                                                                                                                                         
                if (vDuration.ms || vDuration.ms === 0) {                                                                                                                                                                                                      
                    var iMs = Number(vDuration.ms);                                                                                                                                                                                                            
                    if (!isNaN(iMs)) {                                                                                                                                                                                                                         
                        return this._millisecondsToTime(iMs);                                                                                                                                                                                                  
                    }                                                                                                                                                                                                                                          
                }                                                                                                                                                                                                                                              
                vDuration = String(vDuration);                                                                                                                                                                                                                 
            }                                                                                                                                                                                                                                                  
                                                                                                                                                                                                                                                               
            // Número (milissegundos)                                                                                                                                                                                                                          
            if (typeof vDuration === 'number' && !isNaN(vDuration)) {                                                                                                                                                                                          
                return this._millisecondsToTime(vDuration);                                                                                                                                                                                                    
            }                                                                                                                                                                                                                                                  
                                                                                                                                                                                                                                                               
            // String no formato PT (ex: PT2H30M15S)                                                                                                                                                                                                           
            if (typeof vDuration === 'string') {                                                                                                                                                                                                               
                var oPTMatch = vDuration.match(/PT(\d+H)?(\d+M)?(\d+S)?/);                                                                                                                                                                                     
                if (oPTMatch) {                                                                                                                                                                                                                                
                    return {                                                                                                                                                                                                                                   
                        hours: oPTMatch[1] ? parseInt(oPTMatch[1].replace('H', ''), 10) : 0,                                                                                                                                                                   
                        minutes: oPTMatch[2] ? parseInt(oPTMatch[2].replace('M', ''), 10) : 0,                                                                                                                                                                 
                        seconds: oPTMatch[3] ? parseInt(oPTMatch[3].replace('S', ''), 10) : 0                                                                                                                                                                  
                    };                                                                                                                                                                                                                                         
                }                                                                                                                                                                                                                                              
                                                                                                                                                                                                                                                               
                // String numérica (milissegundos)                                                                                                                                                                                                             
                var iNumber = Number(vDuration);                                                                                                                                                                                                               
                if (!isNaN(iNumber)) {                                                                                                                                                                                                                         
                    return this._millisecondsToTime(iNumber);                                                                                                                                                                                                  
                }                                                                                                                                                                                                                                              
            }                                                                                                                                                                                                                                                  
                                                                                                                                                                                                                                                               
            return DEFAULT_DURATION;                                                                                                                                                                                                                           
        },                                                                                                                                                                                                                                                     
                                                                                                                                                                                                                                                               
        /**                                                                                                                                                                                                                                                    
         * Converte milissegundos para objeto com horas, minutos e segundos.                                                                                                                                                                                   
         * @param {number} iMs - Milissegundos                                                                                                                                                                                                                 
         * @returns {object} Objeto com hours, minutes, seconds                                                                                                                                                                                                
         * @private                                                                                                                                                                                                                                            
         */                                                                                                                                                                                                                                                    
        _millisecondsToTime: function (iMs) {                                                                                                                                                                                                                  
            var iHours = Math.floor(iMs / 3600000);                                                                                                                                                                                                            
            var iMinutes = Math.floor((iMs % 3600000) / 60000);                                                                                                                                                                                                
            var iSeconds = Math.floor((iMs % 60000) / 1000);                                                                                                                                                                                                   
                                                                                                                                                                                                                                                               
            return { hours: iHours, minutes: iMinutes, seconds: iSeconds };                                                                                                                                                                                    
        },                                                                                                                                                                                                                                                     
                                                                                                                                                                                                                                                               
        /* =========================================================== */                                                                                                                                                                                      
        /* Métodos Privados - Tratamento de Erros                    */                                                                                                                                                                                        
