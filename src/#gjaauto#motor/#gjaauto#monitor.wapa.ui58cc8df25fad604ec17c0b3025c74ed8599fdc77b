sap.ui.define([                                                                                                                                                                                                                                                
  "sap/ui/core/mvc/Controller",                                                                                                                                                                                                                                
  "sap/ui/model/json/JSONModel",                                                                                                                                                                                                                               
  "sap/ui/model/Filter",                                                                                                                                                                                                                                       
  "sap/ui/model/FilterOperator",                                                                                                                                                                                                                               
  "sap/m/MessageToast",                                                                                                                                                                                                                                        
  "sap/m/MessageBox",                                                                                                                                                                                                                                          
  "br/com/gja/zui5/gjaauto/monitor/model/formatter"                                                                                                                                                                                                            
], function (Controller, JSONModel, Filter, FilterOperator, MessageToast, MessageBox, formatter) {                                                                                                                                                             
  "use strict";                                                                                                                                                                                                                                                
                                                                                                                                                                                                                                                               
  /**                                                                                                                                                                                                                                                          
   * Controller para a view de detalhes de automação                                                                                                                                                                                                           
   * Responsável por exibir informações detalhadas sobre uma execução de automação,                                                                                                                                                                            
   * incluindo etapas executadas, logs e status                                                                                                                                                                                                                
   * @namespace br.com.gja.zui5.gjaauto.monitor.controller                                                                                                                                                                                                     
   */                                                                                                                                                                                                                                                          
  return Controller.extend("br.com.gja.zui5.gjaauto.monitor.controller.Automacao", {                                                                                                                                                                           
                                                                                                                                                                                                                                                               
    formatter: formatter,                                                                                                                                                                                                                                      
                                                                                                                                                                                                                                                               
    /**                                                                                                                                                                                                                                                        
     * Constantes para códigos de status de automação                                                                                                                                                                                                          
     * @private                                                                                                                                                                                                                                                
     */                                                                                                                                                                                                                                                        
    STATUS_CODES: {                                                                                                                                                                                                                                            
      AGUARDANDO: 0,                                                                                                                                                                                                                                           
      EXECUTANDO: 1,                                                                                                                                                                                                                                           
      COMPLETO: 2,                                                                                                                                                                                                                                             
      ERRO_PROCESSAMENTO: 3,                                                                                                                                                                                                                                   
      FALHA_VALIDACAO: 4,                                                                                                                                                                                                                                      
      PAUSADO: 5                                                                                                                                                                                                                                               
    },                                                                                                                                                                                                                                                         
                                                                                                                                                                                                                                                               
    /**                                                                                                                                                                                                                                                        
     * Constantes para códigos de status de etapa                                                                                                                                                                                                              
     * @private                                                                                                                                                                                                                                                
     */                                                                                                                                                                                                                                                        
    ETAPA_STATUS_CODES: {                                                                                                                                                                                                                                      
      EXECUTANDO: 1,                                                                                                                                                                                                                                           
      COMPLETA: 2,                                                                                                                                                                                                                                             
      ERRO: 3,                                                                                                                                                                                                                                                 
      PAUSADA: 4,                                                                                                                                                                                                                                              
      IGNORADA: 5                                                                                                                                                                                                                                              
    },                                                                                                                                                                                                                                                         
                                                                                                                                                                                                                                                               
    /**                                                                                                                                                                                                                                                        
     * Inicializa o controller                                                                                                                                                                                                                                 
     * Configura o view model e anexa o evento de rota matched                                                                                                                                                                                                 
     * @public                                                                                                                                                                                                                                                 
     */                                                                                                                                                                                                                                                        
    onInit: function () {                                                                                                                                                                                                                                      
      // Inicializa o modelo local da view                                                                                                                                                                                                                     
      var oViewModel = new JSONModel({                                                                                                                                                                                                                         
        busy: false,                                                                                                                                                                                                                                           
        tituloOperacao: "",                                                                                                                                                                                                                                    
        showExecuteButton: false,                                                                                                                                                                                                                              
        executeButtonEnabled: true,                                                                                                                                                                                                                            
        isLoading: false,                                                                                                                                                                                                                                      
        dataLoaded: false                                                                                                                                                                                                                                      
      });                                                                                                                                                                                                                                                      
      this.getView().setModel(oViewModel, "automacao");                                                                                                                                                                                                        
                                                                                                                                                                                                                                                               
      this._iAutoRefreshInterval = null;                                                                                                                                                                                                                       
                                                                                                                                                                                                                                                               
      // Configura o roteamento                                                                                                                                                                                                                                
      var oRouter = this.getOwnerComponent().getRouter();                                                                                                                                                                                                      
      oRouter.getRoute("Automacao").attachMatched(this._onRouteMatched, this);                                                                                                                                                                                 
    },                                                                                                                                                                                                                                                         
                                                                                                                                                                                                                                                               
    /**                                                                                                                                                                                                                                                        
     * Limpa o intervalo de auto-refresh ao destruir o controller.                                                                                                                                                                                             
     * @public                                                                                                                                                                                                                                                 
     */                                                                                                                                                                                                                                                        
    onExit: function () {                                                                                                                                                                                                                                      
      this._stopAutoRefresh();                                                                                                                                                                                                                                 
    },                                                                                                                                                                                                                                                         
                                                                                                                                                                                                                                                               
    /**                                                                                                                                                                                                                                                        
     * Navega de volta para a página anterior                                                                                                                                                                                                                  
     * @public                                                                                                                                                                                                                                                 
     */                                                                                                                                                                                                                                                        
    onNavBack: function () {                                                                                                                                                                                                                                   
      var oRouter = this.getOwnerComponent().getRouter();                                                                                                                                                                                                      
      oRouter.navTo("Monitor");                                                                                                                                                                                                                                
    },                                                                                                                                                                                                                                                         
                                                                                                                                                                                                                                                               
    /**                                                                                                                                                                                                                                                        
     * Navega de volta para a página anterior                                                                                                                                                                                                                  
     * @public                                                                                                                                                                                                                                                 
     */                                                                                                                                                                                                                                                        
    onNavBack: function () {                                                                                                                                                                                                                                   
      var oRouter = this.getOwnerComponent().getRouter();                                                                                                                                                                                                      
      oRouter.navTo("Monitor");                                                                                                                                                                                                                                
    },                                                                                                                                                                                                                                                         
                                                                                                                                                                                                                                                               
    /**                                                                                                                                                                                                                                                        
     * Handler executado ao clicar em uma etapa                                                                                                                                                                                                                
     * Abre o dialog de logs se a etapa tiver logs                                                                                                                                                                                                             
     * @param {sap.ui.base.Event} oEvent - Evento de press                                                                                                                                                                                                     
     * @public                                                                                                                                                                                                                                                 
     */                                                                                                                                                                                                                                                        
    onEtapaPress: function (oEvent) {                                                                                                                                                                                                                          
      var oBindingContext = oEvent.getSource().getBindingContext("automacao");                                                                                                                                                                                 
      var oEtapa = oBindingContext.getObject();                                                                                                                                                                                                                
                                                                                                                                                                                                                                                               
      console.log("Etapa clicada:", oEtapa);                                                                                                                                                                                                                   
      console.log("Logs da etapa:", oEtapa.logs);                                                                                                                                                                                                              
                                                                                                                                                                                                                                                               
      // Verifica se a etapa tem logs                                                                                                                                                                                                                          
      if (oEtapa.logs && oEtapa.logs.length > 0) {                                                                                                                                                                                                             
        this._openLogsDialog(oEtapa);                                                                                                                                                                                                                          
      } else {                                                                                                                                                                                                                                                 
        MessageToast.show("Esta etapa não possui logs");                                                                                                                                                                                                       
      }                                                                                                                                                                                                                                                        
    },                                                                                                                                                                                                                                                         
                                                                                                                                                                                                                                                               
    /**                                                                                                                                                                                                                                                        
     * Abre o dialog de logs para uma etapa                                                                                                                                                                                                                    
     * @param {object} oEtapa - Objeto da etapa selecionada                                                                                                                                                                                                    
     * @private                                                                                                                                                                                                                                                
     */                                                                                                                                                                                                                                                        
    _openLogsDialog: function (oEtapa) {                                                                                                                                                                                                                       
      var oView = this.getView();                                                                                                                                                                                                                              
      var oViewModel = oView.getModel("automacao");                                                                                                                                                                                                            
                                                                                                                                                                                                                                                               
      console.log("Abrindo dialog para etapa:", oEtapa);                                                                                                                                                                                                       
      console.log("Logs a serem exibidos:", oEtapa.logs);                                                                                                                                                                                                      
                                                                                                                                                                                                                                                               
      // Define a etapa selecionada no model                                                                                                                                                                                                                   
      oViewModel.setProperty("/etapaSelecionada", oEtapa);                                                                                                                                                                                                     
                                                                                                                                                                                                                                                               
      console.log("Etapa selecionada definida no model:", oViewModel.getProperty("/etapaSelecionada"));                                                                                                                                                        
                                                                                                                                                                                                                                                               
      // Carrega o fragment se ainda não foi carregado                                                                                                                                                                                                         
      if (!this._oLogsDialog) {                                                                                                                                                                                                                                
        this._oLogsDialog = sap.ui.xmlfragment(                                                                                                                                                                                                                
          oView.getId(),                                                                                                                                                                                                                                       
          "br.com.gja.zui5.gjaauto.monitor.view.LogsDialog",                                                                                                                                                                                                   
          this                                                                                                                                                                                                                                                 
        );                                                                                                                                                                                                                                                     
        oView.addDependent(this._oLogsDialog);                                                                                                                                                                                                                 
      }                                                                                                                                                                                                                                                        
                                                                                                                                                                                                                                                               
      this._oLogsDialog.open();                                                                                                                                                                                                                                
    },                                                                                                                                                                                                                                                         
                                                                                                                                                                                                                                                               
    /**                                                                                                                                                                                                                                                        
     * Fecha o dialog de logs                                                                                                                                                                                                                                  
     * @public                                                                                                                                                                                                                                                 
     */                                                                                                                                                                                                                                                        
    onCloseLogsDialog: function () {                                                                                                                                                                                                                           
      if (this._oLogsDialog) {                                                                                                                                                                                                                                 
        this._oLogsDialog.close();                                                                                                                                                                                                                             
      }                                                                                                                                                                                                                                                        
    },                                                                                                                                                                                                                                                         
                                                                                                                                                                                                                                                               
    /**                                                                                                                                                                                                                                                        
     * Executa a automação via endpoint POST                                                                                                                                                                                                                   
     * @public                                                                                                                                                                                                                                                 
     */                                                                                                                                                                                                                                                        
    onExecutarAutomacao: function () {                                                                                                                                                                                                                         
      var oViewModel = this.getView().getModel("automacao");                                                                                                                                                                                                   
      var sChave = oViewModel.getProperty("/id");                                                                                                                                                                                                              
                                                                                                                                                                                                                                                               
      if (!sChave) {                                                                                                                                                                                                                                           
        MessageBox.error("Chave da automação não encontrada");                                                                                                                                                                                                 
        return;                                                                                                                                                                                                                                                
      }                                                                                                                                                                                                                                                        
                                                                                                                                                                                                                                                               
      oViewModel.setProperty("/executeButtonEnabled", false);                                                                                                                                                                                                  
                                                                                                                                                                                                                                                               
      var oMainModel = this.getOwnerComponent().getModel("mainSrv");                                                                                                                                                                                           
                                                                                                                                                                                                                                                               
      if (!oMainModel) {                                                                                                                                                                                                                                       
        MessageBox.error("Serviço não disponível");                                                                                                                                                                                                            
        this._setBusy(false);                                                                                                                                                                                                                                  
        return;                                                                                                                                                                                                                                                
      }                                                                                                                                                                                                                                                        
                                                                                                                                                                                                                                                               
      var oPayload = {                                                                                                                                                                                                                                         
        Chave: sChave                                                                                                                                                                                                                                          
      };                                                                                                                                                                                                                                                       
                                                                                                                                                                                                                                                               
      oMainModel.create("/ExecAutomacao", oPayload, {                                                                                                                                                                                                          
        success: function (oData) {                                                                                                                                                                                                                            
          this._setBusy(false);                                                                                                                                                                                                                                
          MessageToast.show("Automação executada com sucesso");                                                                                                                                                                                                
                                                                                                                                                                                                                                                               
          // Recarrega os dados da automação após execução                                                                                                                                                                                                     
          this._loadAutomacaoData(sChave);                                                                                                                                                                                                                     
        }.bind(this),                                                                                                                                                                                                                                          
        error: function (oError) {                                                                                                                                                                                                                             
          oViewModel.setProperty("/executeButtonEnabled", true);                                                                                                                                                                                               
          var sErrorMsg = "Erro ao executar automação";                                                                                                                                                                                                        
                                                                                                                                                                                                                                                               
          if (oError.responseText) {                                                                                                                                                                                                                           
            try {                                                                                                                                                                                                                                              
              var oErrorResponse = JSON.parse(oError.responseText);                                                                                                                                                                                            
              if (oErrorResponse.error && oErrorResponse.error.message) {                                                                                                                                                                                      
                sErrorMsg = oErrorResponse.error.message.value || oErrorResponse.error.message;                                                                                                                                                                
              }                                                                                                                                                                                                                                                
            } catch (e) {                                                                                                                                                                                                                                      
              sErrorMsg += ": " + oError.responseText;                                                                                                                                                                                                         
            }                                                                                                                                                                                                                                                  
          }                                                                                                                                                                                                                                                    
                                                                                                                                                                                                                                                               
          MessageBox.error(sErrorMsg);                                                                                                                                                                                                                         
        }.bind(this)                                                                                                                                                                                                                                           
      });                                                                                                                                                                                                                                                      
    },                                                                                                                                                                                                                                                         
                                                                                                                                                                                                                                                               
    /**                                                                                                                                                                                                                                                        
     * Handler executado quando a rota é matched                                                                                                                                                                                                               
     * Carrega os dados da automação baseado na chave recebida                                                                                                                                                                                                 
     * @param {sap.ui.base.Event} oEvent - Evento de rota matched                                                                                                                                                                                              
     * @private                                                                                                                                                                                                                                                
     */                                                                                                                                                                                                                                                        
    _onRouteMatched: function (oEvent) {                                                                                                                                                                                                                       
      this._stopAutoRefresh();                                                                                                                                                                                                                                 
      var oArgs = oEvent.getParameter("arguments");                                                                                                                                                                                                            
      var sChave = decodeURIComponent(oArgs.chave);                                                                                                                                                                                                            
      this._loadAutomacaoData(sChave);                                                                                                                                                                                                                         
    },                                                                                                                                                                                                                                                         
                                                                                                                                                                                                                                                               
    /**                                                                                                                                                                                                                                                        
     * Carrega os dados da automação do backend                                                                                                                                                                                                                
     * @param {string} sChave - Chave identificadora da automação                                                                                                                                                                                              
     * @private                                                                                                                                                                                                                                                
     */                                                                                                                                                                                                                                                        
    _loadAutomacaoData: function (sChave, bSilent) {                                                                                                                                                                                                           
      var oViewModel = this.getView().getModel("automacao");                                                                                                                                                                                                   
                                                                                                                                                                                                                                                               
      if (!bSilent) {                                                                                                                                                                                                                                          
        oViewModel.setProperty("/isLoading", true);                                                                                                                                                                                                            
        oViewModel.setProperty("/dataLoaded", false);                                                                                                                                                                                                          
      }                                                                                                                                                                                                                                                        
                                                                                                                                                                                                                                                               
      var oMonitorModel = this.getOwnerComponent().getModel("monitorOData");                                                                                                                                                                                   
      var aFilters = [new Filter("Chave", FilterOperator.EQ, sChave)];                                                                                                                                                                                         
                                                                                                                                                                                                                                                               
      oMonitorModel.read("/Header", {                                                                                                                                                                                                                          
        filters: aFilters,                                                                                                                                                                                                                                     
        urlParameters: {                                                                                                                                                                                                                                       
          "$expand": "to_EtapasExecutadas/to_Logs"                                                                                                                                                                                                             
        },                                                                                                                                                                                                                                                     
        success: this._onAutomacaoDataLoaded.bind(this),                                                                                                                                                                                                       
        error: this._onAutomacaoDataLoadError.bind(this)                                                                                                                                                                                                       
      });                                                                                                                                                                                                                                                      
    },                                                                                                                                                                                                                                                         
                                                                                                                                                                                                                                                               
    /**                                                                                                                                                                                                                                                        
     * Handler de sucesso ao carregar dados da automação                                                                                                                                                                                                       
     * @param {object} oData - Dados retornados do backend                                                                                                                                                                                                     
     * @private                                                                                                                                                                                                                                                
     */                                                                                                                                                                                                                                                        
    _onAutomacaoDataLoaded: function (oData) {                                                                                                                                                                                                                 
      console.log("Dados carregados:", oData);                                                                                                                                                                                                                 
                                                                                                                                                                                                                                                               
      if (!oData.results || oData.results.length === 0) {                                                                                                                                                                                                      
        this._setBusy(false);                                                                                                                                                                                                                                  
        MessageBox.warning("Nenhuma automação encontrada com esta chave.");                                                                                                                                                                                    
        return;                                                                                                                                                                                                                                                
      }                                                                                                                                                                                                                                                        
                                                                                                                                                                                                                                                               
      var oAuto = oData.results[0];                                                                                                                                                                                                                            
      console.log("Automação encontrada:", oAuto);                                                                                                                                                                                                             
      console.log("Credat:", oAuto.Credat, "Cretim:", oAuto.Cretim);                                                                                                                                                                                           
      console.log("Etapas executadas:", oAuto.to_EtapasExecutadas);                                                                                                                                                                                            
                                                                                                                                                                                                                                                               
      this._setBasicAutomacaoData(oAuto);                                                                                                                                                                                                                      
      this._setAutomacaoStatus(oAuto);                                                                                                                                                                                                                         
      this._calculateTotalDuration(oAuto);                                                                                                                                                                                                                     
      this._loadEtapasDetails(oAuto);                                                                                                                                                                                                                          
                                                                                                                                                                                                                                                               
      var oViewModel = this.getView().getModel("automacao");                                                                                                                                                                                                   
      oViewModel.setProperty("/isLoading", false);                                                                                                                                                                                                             
      oViewModel.setProperty("/dataLoaded", true);                                                                                                                                                                                                             
      oViewModel.setProperty("/executeButtonEnabled", true);                                                                                                                                                                                                   
                                                                                                                                                                                                                                                               
      this._setBusy(false);                                                                                                                                                                                                                                    
                                                                                                                                                                                                                                                               
      // Gerencia auto-refresh baseado no status                                                                                                                                                                                                               
      var iStatus = parseInt(oAuto.Status, 10);                                                                                                                                                                                                                
      this._manageAutoRefresh(iStatus);                                                                                                                                                                                                                        
    },                                                                                                                                                                                                                                                         
                                                                                                                                                                                                                                                               
    /**                                                                                                                                                                                                                                                        
     * Handler de erro ao carregar dados da automação                                                                                                                                                                                                          
     * @param {object} oError - Objeto de erro                                                                                                                                                                                                                 
     * @private                                                                                                                                                                                                                                                
     */                                                                                                                                                                                                                                                        
    _onAutomacaoDataLoadError: function (oError) {                                                                                                                                                                                                             
      var oViewModel = this.getView().getModel("automacao");                                                                                                                                                                                                   
      oViewModel.setProperty("/isLoading", false);                                                                                                                                                                                                             
      oViewModel.setProperty("/dataLoaded", false);                                                                                                                                                                                                            
&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;                                                                                                                                                                                                                           
      this._setBusy(false);                                                                                                                                                                                                                                    
      var sErrorMsg = oError.message || oError.responseText || "Erro desconhecido";                                                                                                                                                                            
      MessageBox.error("Erro ao carregar execuções: " + sErrorMsg);                                                                                                                                                                                            
    },                                                                                                                                                                                                                                                         
                                                                                                                                                                                                                                                               
    /**                                                                                                                                                                                                                                                        
     * Define os dados básicos da automação no view model                                                                                                                                                                                                      
     * @param {object} oAuto - Objeto com dados da automação                                                                                                                                                                                                   
     * @private                                                                                                                                                                                                                                                
     */                                                                                                                                                                                                                                                        
    _setBasicAutomacaoData: function (oAuto) {                                                                                                                                                                                                                 
      var oViewModel = this.getView().getModel("automacao");                                                                                                                                                                                                   
                                                                                                                                                                                                                                                               
      oViewModel.setProperty("/id", oAuto.Chave || "");                                                                                                                                                                                                        
      oViewModel.setProperty("/etapas", (oAuto.to_EtapasExecutadas && oAuto.to_EtapasExecutadas.results) || []);                                                                                                                                               
      oViewModel.setProperty("/auto", oAuto.Auto || "");                                                                                                                                                                                                       
      oViewModel.setProperty("/descrAuto", oAuto.DescrAuto || "");                                                                                                                                                                                             
      oViewModel.setProperty("/opera", oAuto.Opera || "");                                                                                                                                                                                                     
      oViewModel.setProperty("/descrOpera", oAuto.DescrOpera || "");                                                                                                                                                                                           
      oViewModel.setProperty("/createdBy", oAuto.Crenam || "");                                                                                                                                                                                                
                                                                                                                                                                                                                                                               
      // Formata data e hora de criação                                                                                                                                                                                                                        
      if (oAuto.Credat && oAuto.Cretim) {                                                                                                                                                                                                                      
        console.log("Formatando data - Credat:", oAuto.Credat, "Cretim:", oAuto.Cretim);                                                                                                                                                                       
        var oDateObj = this._combineDateAndTime(oAuto.Credat, oAuto.Cretim);                                                                                                                                                                                   
        console.log("Data combinada:", oDateObj);                                                                                                                                                                                                              
        var sFormattedDate = this._formatDateTime(oDateObj);                                                                                                                                                                                                   
        console.log("Data formatada:", sFormattedDate);                                                                                                                                                                                                        
        oViewModel.setProperty("/createdAt", sFormattedDate);                                                                                                                                                                                                  
      } else {                                                                                                                                                                                                                                                 
        console.warn("Data/hora de criação não disponível - Credat:", oAuto.Credat, "Cretim:", oAuto.Cretim);                                                                                                                                                  
        oViewModel.setProperty("/createdAt", "");                                                                                                                                                                                                              
      }                                                                                                                                                                                                                                                        
    },                                                                                                                                                                                                                                                         
                                                                                                                                                                                                                                                               
    /**                                                                                                                                                                                                                                                        
     * Define o status da automação no view model                                                                                                                                                                                                              
     * @param {object} oAuto - Objeto com dados da automação                                                                                                                                                                                                   
     * @private                                                                                                                                                                                                                                                
     */                                                                                                                                                                                                                                                        
    _setAutomacaoStatus: function (oAuto) {                                                                                                                                                                                                                    
      var oViewModel = this.getView().getModel("automacao");                                                                                                                                                                                                   
      var iStatus = parseInt(oAuto.Status, 10);                                                                                                                                                                                                                
      var oStatusInfo = this._getStatusInfo(iStatus);                                                                                                                                                                                                          
                                                                                                                                                                                                                                                               
      oViewModel.setProperty("/status", oStatusInfo.text);                                                                                                                                                                                                     
      oViewModel.setProperty("/statusType", oStatusInfo.type);                                                                                                                                                                                                 
                                                                                                                                                                                                                                                               
      // Mostrar botão de executar se status for diferente de COMPLETO (2)                                                                                                                                                                                     
      var bShowExecuteButton = iStatus !== this.STATUS_CODES.COMPLETO;                                                                                                                                                                                         
      oViewModel.setProperty("/showExecuteButton", bShowExecuteButton);                                                                                                                                                                                        
    },                                                                                                                                                                                                                                                         
                                                                                                                                                                                                                                                               
    /**                                                                                                                                                                                                                                                        
     * Retorna informações de texto e tipo para um código de status                                                                                                                                                                                            
     * @param {number} iStatusCode - Código do status                                                                                                                                                                                                          
     * @returns {object} Objeto com text e type do status                                                                                                                                                                                                      
     * @private                                                                                                                                                                                                                                                
     */                                                                                                                                                                                                                                                        
    _getStatusInfo: function (iStatusCode) {                                                                                                                                                                                                                   
      var STATUS = this.STATUS_CODES;                                                                                                                                                                                                                          
                                                                                                                                                                                                                                                               
      switch (iStatusCode) {                                                                                                                                                                                                                                   
        case STATUS.AGUARDANDO:                                                                                                                                                                                                                                
          return { text: "Aguardando", type: "None" };                                                                                                                                                                                                         
        case STATUS.EXECUTANDO:                                                                                                                                                                                                                                
          return { text: "Executando", type: "Warning" };                                                                                                                                                                                                      
        case STATUS.COMPLETO:                                                                                                                                                                                                                                  
          return { text: "Completo", type: "Success" };                                                                                                                                                                                                        
        case STATUS.ERRO_PROCESSAMENTO:                                                                                                                                                                                                                        
          return { text: "Erro durante o processamento", type: "Error" };                                                                                                                                                                                      
        case STATUS.FALHA_VALIDACAO:                                                                                                                                                                                                                           
          return { text: "Falha de validação", type: "Error" };                                                                                                                                                                                                
        case STATUS.PAUSADO:                                                                                                                                                                                                                                   
          return { text: "Pausado", type: "Warning" };                                                                                                                                                                                                         
        default:                                                                                                                                                                                                                                               
          return { text: "Desconhecido", type: "None" };                                                                                                                                                                                                       
      }                                                                                                                                                                                                                                                        
    },                                                                                                                                                                                                                                                         
                                                                                                                                                                                                                                                               
    /**                                                                                                                                                                                                                                                        
     * Calcula e define a duração total da automação                                                                                                                                                                                                           
     * @param {object} oAuto - Objeto com dados da automação                                                                                                                                                                                                   
     * @private                                                                                                                                                                                                                                                
     */                                                                                                                                                                                                                                                        
    _calculateTotalDuration: function (oAuto) {                                                                                                                                                                                                                
      // Só calcula duração se estiver completa e tiver etapas                                                                                                                                                                                                 
      if (oAuto.Status !== "2" || !oAuto.to_EtapasExecutadas ||                                                                                                                                                                                                
        oAuto.to_EtapasExecutadas.results.length === 0) {                                                                                                                                                                                                      
        return;                                                                                                                                                                                                                                                
      }                                                                                                                                                                                                                                                        
                                                                                                                                                                                                                                                               
      var aEtapas = oAuto.to_EtapasExecutadas.results;                                                                                                                                                                                                         
      var oLastEtapa = aEtapas[aEtapas.length - 1];                                                                                                                                                                                                            
                                                                                                                                                                                                                                                               
      if (!oLastEtapa.Credat || !oLastEtapa.Cretim || !oAuto.Credat || !oAuto.Cretim) {                                                                                                                                                                        
        return;                                                                                                                                                                                                                                                
      }                                                                                                                                                                                                                                                        
                                                                                                                                                                                                                                                               
      var oStartDateTime = this._combineDateAndTime(oAuto.Credat, oAuto.Cretim);                                                                                                                                                                               
      var oEndDateTime = this._combineDateAndTime(oLastEtapa.Credat, oLastEtapa.Cretim);                                                                                                                                                                       
      var iDurationMs = Math.abs(oEndDateTime - oStartDateTime);                                                                                                                                                                                               
      var sDuration = this._formatDuration(iDurationMs);                                                                                                                                                                                                       
                                                                                                                                                                                                                                                               
      var oViewModel = this.getView().getModel("automacao");                                                                                                                                                                                                   
      oViewModel.setProperty("/tempoTotal", sDuration);                                                                                                                                                                                                        
    },                                                                                                                                                                                                                                                         
                                                                                                                                                                                                                                                               
    /**                                                                                                                                                                                                                                                        
     * Carrega os detalhes das etapas da automação                                                                                                                                                                                                             
     * @param {object} oAuto - Objeto com dados da automação                                                                                                                                                                                                   
     * @private                                                                                                                                                                                                                                                
     */                                                                                                                                                                                                                                                        
    _loadEtapasDetails: function (oAuto) {                                                                                                                                                                                                                     
      var oMainModel = this.getOwnerComponent().getModel();                                                                                                                                                                                                    
                                                                                                                                                                                                                                                               
      if (!oMainModel || !oAuto.Auto || !oAuto.Opera) {                                                                                                                                                                                                        
        return;                                                                                                                                                                                                                                                
      }                                                                                                                                                                                                                                                        
                                                                                                                                                                                                                                                               
      var aFilters = [                                                                                                                                                                                                                                         
        new Filter("auto", FilterOperator.EQ, oAuto.Auto),                                                                                                                                                                                                     
        new Filter("opera", FilterOperator.EQ, oAuto.Opera)                                                                                                                                                                                                    
      ];                                                                                                                                                                                                                                                       
                                                                                                                                                                                                                                                               
      oMainModel.read("/Etapas", {                                                                                                                                                                                                                             
        filters: aFilters,                                                                                                                                                                                                                                     
        success: function (oDataEtapas) {                                                                                                                                                                                                                      
          this._processEtapasData(oDataEtapas, oAuto);                                                                                                                                                                                                         
        }.bind(this),                                                                                                                                                                                                                                          
        error: function (oError) {                                                                                                                                                                                                                             
          console.error("Erro ao carregar informações da automação:", oError);                                                                                                                                                                                 
        }                                                                                                                                                                                                                                                      
      });                                                                                                                                                                                                                                                      
    },                                                                                                                                                                                                                                                         
                                                                                                                                                                                                                                                               
    /**                                                                                                                                                                                                                                                        
     * Processa os dados das etapas e atualiza o view model                                                                                                                                                                                                    
     * @param {object} oDataEtapas - Dados das etapas do backend                                                                                                                                                                                               
     * @param {object} oAuto - Objeto com dados da automação                                                                                                                                                                                                   
     * @private                                                                                                                                                                                                                                                
     */                                                                                                                                                                                                                                                        
    _processEtapasData: function (oDataEtapas, oAuto) {                                                                                                                                                                                                        
      console.log("Processando dados de etapas:", oDataEtapas);                                                                                                                                                                                                
                                                                                                                                                                                                                                                               
      if (!oDataEtapas.results || oDataEtapas.results.length === 0) {                                                                                                                                                                                          
        console.warn("Nenhuma definição de etapa encontrada no mainService");                                                                                                                                                                                  
        return;                                                                                                                                                                                                                                                
      }                                                                                                                                                                                                                                                        
                                                                                                                                                                                                                                                               
      var oViewModel = this.getView().getModel("automacao");                                                                                                                                                                                                   
      var aEtapasExecutadas = oViewModel.getProperty("/etapas");                                                                                                                                                                                               
      console.log("Etapas executadas do model:", aEtapasExecutadas);                                                                                                                                                                                           
                                                                                                                                                                                                                                                               
      var aEtapasMapeadas = [];                                                                                                                                                                                                                                
                                                                                                                                                                                                                                                               
      oDataEtapas.results.forEach(function (oEtapa) {                                                                                                                                                                                                          
        // Encontra a etapa executada correspondente                                                                                                                                                                                                           
        var oEtapaExecutada = aEtapasExecutadas.find(function (oExec) {                                                                                                                                                                                        
          return oExec.Etapa === oEtapa.etapa;                                                                                                                                                                                                                 
        });                                                                                                                                                                                                                                                    
                                                                                                                                                                                                                                                               
        if (oEtapaExecutada) {                                                                                                                                                                                                                                 
          var oEtapaMapeada = this._buildEtapaMapeada(oEtapa, oEtapaExecutada, oAuto);                                                                                                                                                                         
          aEtapasMapeadas.push(oEtapaMapeada);                                                                                                                                                                                                                 
        } else {                                                                                                                                                                                                                                               
          var oEtapaMapeada = this._buildEtapaAwaiting(oEtapa);                                                                                                                                                                                                
          aEtapasMapeadas.push(oEtapaMapeada);                                                                                                                                                                                                                 
        }                                                                                                                                                                                                                                                      
      }.bind(this));                                                                                                                                                                                                                                           
                                                                                                                                                                                                                                                               
      console.log("Total de etapas mapeadas:", aEtapasMapeadas.length);                                                                                                                                                                                        
      this._mergeEtapasMapeadas(aEtapasMapeadas);                                                                                                                                                                                                              
                                                                                                                                                                                                                                                               
      // Carregar as keys dos documentos gerados                                                                                                                                                                                                               
      this._loadKeysAutomacao(oAuto.Chave, oViewModel);                                                                                                                                                                                                        
    },                                                                                                                                                                                                                                                         
                                                                                                                                                                                                                                                               
    /**                                                                                                                                                                                                                                                        
     * Carrega as keys dos documentos gerados pelas etapas                                                                                                                                                                                                     
     * @param {string} sChave - Chave da automação                                                                                                                                                                                                             
     * @param {sap.ui.model.json.JSONModel} oViewModel - View model                                                                                                                                                                                            
     * @private                                                                                                                                                                                                                                                
     */                                                                                                                                                                                                                                                        
    _loadKeysAutomacao: function (sChave, oViewModel) {                                                                                                                                                                                                        
      var oMainModel = this.getOwnerComponent().getModel("mainSrv");                                                                                                                                                                                           
                                                                                                                                                                                                                                                               
      if (!oMainModel) {                                                                                                                                                                                                                                       
        console.error("Modelo mainService não encontrado");                                                                                                                                                                                                    
        return;                                                                                                                                                                                                                                                
      }                                                                                                                                                                                                                                                        
                                                                                                                                                                                                                                                               
      var sPath = "/KeysAutomacao";                                                                                                                                                                                                                            
      var aFilters = [new Filter("Chave", FilterOperator.EQ, sChave)];                                                                                                                                                                                         
                                                                                                                                                                                                                                                               
      console.log("Buscando keys de documentos para a chave:", sChave);                                                                                                                                                                                        
                                                                                                                                                                                                                                                               
      oMainModel.read(sPath, {                                                                                                                                                                                                                                 
        filters: aFilters,                                                                                                                                                                                                                                     
        success: function (oData) {                                                                                                                                                                                                                            
          console.log("Keys carregadas com sucesso:", oData);                                                                                                                                                                                                  
          var aKeys = oData.results;                                                                                                                                                                                                                           
                                                                                                                                                                                                                                                               
          // Salvar a lista de keys no view model                                                                                                                                                                                                              
          oViewModel.setProperty("/keys", aKeys);                                                                                                                                                                                                              
                                                                                                                                                                                                                                                               
          // Obter as etapas mapeadas                                                                                                                                                                                                                          
          var aEtapasMapeadas = oViewModel.getProperty("/etapasMapeadas");                                                                                                                                                                                     
                                                                                                                                                                                                                                                               
          if (aEtapasMapeadas && aEtapasMapeadas.length > 0) {                                                                                                                                                                                                 
            // Processar as etapas e adicionar os valores das keys                                                                                                                                                                                             
            aEtapasMapeadas.forEach(function (oEtapa, iIndex) {                                                                                                                                                                                                
              var sBasePath = "/etapasMapeadas/" + iIndex;                                                                                                                                                                                                     
              // Se a etapa foi bem-sucedida e tem keyfieldName                                                                                                                                                                                                
              if (oEtapa.statusType === "Success" && oEtapa.keyfieldName) {                                                                                                                                                                                    
                // Buscar a key correspondente na lista                                                                                                                                                                                                        
                var oKey = aKeys.find(function (key) {                                                                                                                                                                                                         
                  return key.Keyfieldname === oEtapa.keyfieldName;                                                                                                                                                                                             
                });                                                                                                                                                                                                                                            
                                                                                                                                                                                                                                                               
                if (oKey) {                                                                                                                                                                                                                                    
                  if (oEtapa.keyValue !== oKey.Value) {                                                                                                                                                                                                        
                    oViewModel.setProperty(sBasePath + "/keyValue", oKey.Value);                                                                                                                                                                               
                  }                                                                                                                                                                                                                                            
                  if (!oEtapa.hasKey) {                                                                                                                                                                                                                        
                    oViewModel.setProperty(sBasePath + "/hasKey", true);                                                                                                                                                                                       
                  }                                                                                                                                                                                                                                            
                  console.log("Key encontrada para etapa:", oEtapa.keyfieldName, "=", oKey.Value);                                                                                                                                                             
                } else {                                                                                                                                                                                                                                       
                  if (oEtapa.keyValue !== "") {                                                                                                                                                                                                                
                    oViewModel.setProperty(sBasePath + "/keyValue", "");                                                                                                                                                                                       
                  }                                                                                                                                                                                                                                            
                  if (oEtapa.hasKey) {                                                                                                                                                                                                                         
                    oViewModel.setProperty(sBasePath + "/hasKey", false);                                                                                                                                                                                      
                  }                                                                                                                                                                                                                                            
                }                                                                                                                                                                                                                                              
              } else {                                                                                                                                                                                                                                         
                if (oEtapa.keyValue !== "") {                                                                                                                                                                                                                  
                  oViewModel.setProperty(sBasePath + "/keyValue", "");                                                                                                                                                                                         
                }                                                                                                                                                                                                                                              
                if (oEtapa.hasKey) {                                                                                                                                                                                                                           
                  oViewModel.setProperty(sBasePath + "/hasKey", false);                                                                                                                                                                                        
                }                                                                                                                                                                                                                                              
              }                                                                                                                                                                                                                                                
            });                                                                                                                                                                                                                                                
                                                                                                                                                                                                                                                               
            console.log("Etapas atualizadas com keys dos documentos");                                                                                                                                                                                         
          }                                                                                                                                                                                                                                                    
        }.bind(this),                                                                                                                                                                                                                                          
        error: function (oError) {                                                                                                                                                                                                                             
          console.error("Erro ao carregar keys:", oError);                                                                                                                                                                                                     
        }                                                                                                                                                                                                                                                      
      });                                                                                                                                                                                                                                                      
    },                                                                                                                                                                                                                                                         
                                                                                                                                                                                                                                                               
    /**                                                                                                                                                                                                                                                        
     * Constrói objeto com dados mapeados de uma etapa                                                                                                                                                                                                         
     * @param {object} oEtapa - Dados da definição da etapa                                                                                                                                                                                                    
     * @param {object} oEtapaExecutada - Dados da execução da etapa                                                                                                                                                                                            
     * @param {object} oAuto - Dados da automação                                                                                                                                                                                                              
     * @returns {object} Objeto com dados mapeados da etapa                                                                                                                                                                                                    
     * @private                                                                                                                                                                                                                                                
     */                                                                                                                                                                                                                                                        
    _buildEtapaMapeada: function (oEtapa, oEtapaExecutada, oAuto) {                                                                                                                                                                                            
      var sDataHora = "";                                                                                                                                                                                                                                      
      var aLogs = oEtapaExecutada.to_Logs && oEtapaExecutada.to_Logs.results || [];                                                                                                                                                                            
                                                                                                                                                                                                                                                               
      // Formata data/hora da etapa                                                                                                                                                                                                                            
      if (oEtapaExecutada.Credat) {                                                                                                                                                                                                                            
        var oDateEtapa = this._combineDateAndTime(oEtapaExecutada.Credat, oEtapaExecutada.Cretim);                                                                                                                                                             
        sDataHora = this._formatDateTime(oDateEtapa);                                                                                                                                                                                                          
      }                                                                                                                                                                                                                                                        
                                                                                                                                                                                                                                                               
      // Obtém status da etapa                                                                                                                                                                                                                                 
      var iStatusEtapa = parseInt(oEtapaExecutada.Status || oAuto.Status, 10);                                                                                                                                                                                 
      var oStatusEtapa = this._getEtapaStatusInfo(iStatusEtapa, aLogs);                                                                                                                                                                                        
                                                                                                                                                                                                                                                               
      // Monta descrição da etapa                                                                                                                                                                                                                              
      var sDescricao = oEtapa.descr || oEtapaExecutada.Etapa_Descr || "";                                                                                                                                                                                      
      var sDescricaoCompleta = oEtapa.etapa + " - " + sDescricao;                                                                                                                                                                                              
                                                                                                                                                                                                                                                               
      return {                                                                                                                                                                                                                                                 
        etapa: oEtapa.etapa,                                                                                                                                                                                                                                   
        descricao: sDescricaoCompleta,                                                                                                                                                                                                                         
        dataHora: sDataHora,                                                                                                                                                                                                                                   
        duracao: "", // Pode ser calculado se necessário                                                                                                                                                                                                       
        status: oStatusEtapa.text,                                                                                                                                                                                                                             
        statusType: oStatusEtapa.type,                                                                                                                                                                                                                         
        mensagem: oStatusEtapa.mensagem || undefined,                                                                                                                                                                                                          
        logs: aLogs,                                                                                                                                                                                                                                           
        keyfieldName: oEtapa.keyfieldname || "",                                                                                                                                                                                                               
        keyValue: "",                                                                                                                                                                                                                                          
        hasKey: false                                                                                                                                                                                                                                          
      };                                                                                                                                                                                                                                                       
    },                                                                                                                                                                                                                                                         
                                                                                                                                                                                                                                                               
    /**                                                                                                                                                                                                                                                        
     * Constrói objeto com dados de uma etapa aguardando execução                                                                                                                                                                                              
     * @param {object} oEtapa - Dados da definição da etapa                                                                                                                                                                                                    
     * @returns {object} Objeto com dados mapeados da etapa aguardando                                                                                                                                                                                         
     * @private                                                                                                                                                                                                                                                
     */                                                                                                                                                                                                                                                        
    _buildEtapaAwaiting: function (oEtapa) {                                                                                                                                                                                                                   
      // Monta descrição da etapa                                                                                                                                                                                                                              
      var sDescricao = oEtapa.descr || "";                                                                                                                                                                                                                     
      var sDescricaoCompleta = oEtapa.etapa + " - " + sDescricao;                                                                                                                                                                                              
                                                                                                                                                                                                                                                               
      return {                                                                                                                                                                                                                                                 
        etapa: oEtapa.etapa,                                                                                                                                                                                                                                   
        descricao: sDescricaoCompleta,                                                                                                                                                                                                                         
        dataHora: "",                                                                                                                                                                                                                                          
        duracao: "",                                                                                                                                                                                                                                           
        status: "Aguardando",                                                                                                                                                                                                                                  
        statusType: "None",                                                                                                                                                                                                                                    
        mensagem: undefined,                                                                                                                                                                                                                                   
        logs: [],                                                                                                                                                                                                                                              
        keyfieldName: oEtapa.keyfieldname || "",                                                                                                                                                                                                               
        keyValue: "",                                                                                                                                                                                                                                          
        hasKey: false                                                                                                                                                                                                                                          
      };                                                                                                                                                                                                                                                       
    },                                                                                                                                                                                                                                                         
                                                                                                                                                                                                                                                               
    /**                                                                                                                                                                                                                                                        
     * Retorna informações de status de uma etapa                                                                                                                                                                                                              
     * @param {number} iStatusCode - Código do status da etapa                                                                                                                                                                                                 
     * @param {Array} aLogs - Array de logs da etapa                                                                                                                                                                                                           
     * @returns {object} Objeto com text, type e mensagem do status                                                                                                                                                                                            
     * @private                                                                                                                                                                                                                                                
     */                                                                                                                                                                                                                                                        
    _getEtapaStatusInfo: function (iStatusCode, aLogs) {                                                                                                                                                                                                       
      var STATUS = this.ETAPA_STATUS_CODES;                                                                                                                                                                                                                    
      var sMessage = "";                                                                                                                                                                                                                                       
                                                                                                                                                                                                                                                               
      switch (iStatusCode) {                                                                                                                                                                                                                                   
        case STATUS.EXECUTANDO:                                                                                                                                                                                                                                
          return { text: "Executando", type: "Warning", mensagem: sMessage };                                                                                                                                                                                  
        case STATUS.COMPLETA:                                                                                                                                                                                                                                  
          return { text: "Completa", type: "Success", mensagem: sMessage };                                                                                                                                                                                    
        case STATUS.ERRO:                                                                                                                                                                                                                                      
          // Busca primeira mensagem de erro nos logs                                                                                                                                                                                                          
          var oErro = aLogs.find(function (oLog) {                                                                                                                                                                                                             
            return oLog.Type === "E";                                                                                                                                                                                                                          
          });                                                                                                                                                                                                                                                  
          if (oErro) {                                                                                                                                                                                                                                         
            sMessage = oErro.Message;                                                                                                                                                                                                                          
          }                                                                                                                                                                                                                                                    
          return { text: "Erro durante o processamento", type: "Error", mensagem: sMessage };                                                                                                                                                                  
        case STATUS.PAUSADA:                                                                                                                                                                                                                                   
          return { text: "Pausada", type: "Warning", mensagem: sMessage };                                                                                                                                                                                     
        case STATUS.IGNORADA:                                                                                                                                                                                                                                  
          return { text: "Etapa ignorada/pulada", type: "None", mensagem: sMessage };                                                                                                                                                                          
        default:                                                                                                                                                                                                                                               
          return { text: "Desconhecido", type: "None", mensagem: sMessage };                                                                                                                                                                                   
      }                                                                                                                                                                                                                                                        
    },                                                                                                                                                                                                                                                         
    /**                                                                                                                                                                                                                                                        
     * Atualiza as etapas mapeadas de forma incremental, sem substituir o array inteiro.                                                                                                                                                                       
     * Isso evita que o UI5 destrua e recrie todos os itens da lista, eliminando o "piscar".                                                                                                                                                                   
     * @param {Array} aNewEtapas - Novo array de etapas mapeadas                                                                                                                                                                                               
     * @private                                                                                                                                                                                                                                                
     */                                                                                                                                                                                                                                                        
    _mergeEtapasMapeadas: function (aNewEtapas) {                                                                                                                                                                                                              
      var oViewModel = this.getView().getModel("automacao");                                                                                                                                                                                                   
      var aOldEtapas = oViewModel.getProperty("/etapasMapeadas");                                                                                                                                                                                              
                                                                                                                                                                                                                                                               
      // Se não existia array anterior ou mudou o tamanho, substitui tudo                                                                                                                                                                                      
      if (!aOldEtapas || aOldEtapas.length !== aNewEtapas.length) {                                                                                                                                                                                            
        oViewModel.setProperty("/etapasMapeadas", aNewEtapas);                                                                                                                                                                                                 
        return;                                                                                                                                                                                                                                                
      }                                                                                                                                                                                                                                                        
                                                                                                                                                                                                                                                               
      // Atualiza somente as propriedades que mudaram em cada item                                                                                                                                                                                             
      var aSimpleKeys = ["etapa", "descricao", "dataHora", "duracao", "status",                                                                                                                                                                                
        "statusType", "mensagem", "keyfieldName", "keyValue", "hasKey"];                                                                                                                                                                                       
                                                                                                                                                                                                                                                               
      for (var i = 0; i < aNewEtapas.length; i++) {                                                                                                                                                                                                            
        var sBasePath = "/etapasMapeadas/" + i;                                                                                                                                                                                                                
        var oOld = aOldEtapas[i];                                                                                                                                                                                                                              
        var oNew = aNewEtapas[i];                                                                                                                                                                                                                              
                                                                                                                                                                                                                                                               
        aSimpleKeys.forEach(function (sKey) {                                                                                                                                                                                                                  
          if (oOld[sKey] !== oNew[sKey]) {                                                                                                                                                                                                                     
            oViewModel.setProperty(sBasePath + "/" + sKey, oNew[sKey]);                                                                                                                                                                                        
          }                                                                                                                                                                                                                                                    
        });                                                                                                                                                                                                                                                    
                                                                                                                                                                                                                                                               
        // Atualiza logs apenas se mudaram                                                                                                                                                                                                                     
        if (JSON.stringify(oOld.logs) !== JSON.stringify(oNew.logs)) {                                                                                                                                                                                         
          oViewModel.setProperty(sBasePath + "/logs", oNew.logs);                                                                                                                                                                                              
        }                                                                                                                                                                                                                                                      
      }                                                                                                                                                                                                                                                        
    },                                                                                                                                                                                                                                                         
                                                                                                                                                                                                                                                               
    /**                                                                                                                                                                                                                                                        
     * Verifica se a automação está com status ativo (Aguardando ou Executando)                                                                                                                                                                                
     * e inicia ou para o auto-refresh de 1 segundo.                                                                                                                                                                                                           
     * @param {number} iStatus - Código do status da automação                                                                                                                                                                                                 
     * @private                                                                                                                                                                                                                                                
     */                                                                                                                                                                                                                                                        
    _manageAutoRefresh: function (iStatus) {                                                                                                                                                                                                                   
      var bIsActive = iStatus === this.STATUS_CODES.AGUARDANDO || iStatus === this.STATUS_CODES.EXECUTANDO;                                                                                                                                                    
                                                                                                                                                                                                                                                               
      if (bIsActive) {                                                                                                                                                                                                                                         
        this._startAutoRefresh();                                                                                                                                                                                                                              
      } else {                                                                                                                                                                                                                                                 
        this._stopAutoRefresh();                                                                                                                                                                                                                               
      }                                                                                                                                                                                                                                                        
    },                                                                                                                                                                                                                                                         
                                                                                                                                                                                                                                                               
    /**                                                                                                                                                                                                                                                        
     * Inicia o intervalo de auto-refresh (1 segundo).                                                                                                                                                                                                         
     * @private                                                                                                                                                                                                                                                
     */                                                                                                                                                                                                                                                        
    _startAutoRefresh: function () {                                                                                                                                                                                                                           
      if (this._iAutoRefreshInterval) {                                                                                                                                                                                                                        
        return;                                                                                                                                                                                                                                                
      }                                                                                                                                                                                                                                                        
      var oViewModel = this.getView().getModel("automacao");                                                                                                                                                                                                   
      var sChave = oViewModel.getProperty("/id");                                                                                                                                                                                                              
      this._iAutoRefreshInterval = setInterval(function () {                                                                                                                                                                                                   
        this._loadAutomacaoData(sChave, true);                                                                                                                                                                                                                 
      }.bind(this), 1000);                                                                                                                                                                                                                                     
    },                                                                                                                                                                                                                                                         
                                                                                                                                                                                                                                                               
    /**                                                                                                                                                                                                                                                        
     * Para o intervalo de auto-refresh.                                                                                                                                                                                                                       
     * @private                                                                                                                                                                                                                                                
     */                                                                                                                                                                                                                                                        
    _stopAutoRefresh: function () {                                                                                                                                                                                                                            
      if (this._iAutoRefreshInterval) {                                                                                                                                                                                                                        
        clearInterval(this._iAutoRefreshInterval);                                                                                                                                                                                                             
        this._iAutoRefreshInterval = null;                                                                                                                                                                                                                     
      }                                                                                                                                                                                                                                                        
    },                                                                                                                                                                                                                                                         
                                                                                                                                                                                                                                                               
    /**                                                                                                                                                                                                                                                        
     * Define o estado de busy no view model                                                                                                                                                                                                                   
     * @param {boolean} bBusy - Estado de busy                                                                                                                                                                                                                 
     * @private                                                                                                                                                                                                                                                
     */                                                                                                                                                                                                                                                        
    _setBusy: function (bBusy) {                                                                                                                                                                                                                               
      var oViewModel = this.getView().getModel("automacao");                                                                                                                                                                                                   
      oViewModel.setProperty("/busy", bBusy);                                                                                                                                                                                                                  
    },                                                                                                                                                                                                                                                         
                                                                                                                                                                                                                                                               
    /**                                                                                                                                                                                                                                                        
     * Formata data e hora para exibição                                                                                                                                                                                                                       
     * @param {Date} oDate - Objeto Date                                                                                                                                                                                                                       
     * @returns {string} Data formatada no padrão pt-BR                                                                                                                                                                                                        
     * @private                                                                                                                                                                                                                                                
     */                                                                                                                                                                                                                                                        
    _formatDateTime: function (oDate) {                                                                                                                                                                                                                        
      return oDate.toLocaleDateString("pt-BR") + " " + oDate.toLocaleTimeString("pt-BR");                                                                                                                                                                      
    },                                                                                                                                                                                                                                                         
                                                                                                                                                                                                                                                               
    /**                                                                                                                                                                                                                                                        
     * Formata duração em milissegundos para string legível                                                                                                                                                                                                    
     * @param {number} iMilliseconds - Duração em milissegundos                                                                                                                                                                                                
     * @returns {string} Duração formatada (ex: "2hrs", "30min", "45s")                                                                                                                                                                                        
     * @private                                                                                                                                                                                                                                                
     */                                                                                                                                                                                                                                                        
    _formatDuration: function (iMilliseconds) {                                                                                                                                                                                                                
      var iSeconds = Math.floor(iMilliseconds / 1000);                                                                                                                                                                                                         
      var iMinutes = Math.floor(iSeconds / 60);                                                                                                                                                                                                                
      var iHours = Math.floor(iMinutes / 60);                                                                                                                                                                                                                  
                                                                                                                                                                                                                                                               
      if (iHours >= 1) {                                                                                                                                                                                                                                       
        return iHours + "hrs";                                                                                                                                                                                                                                 
      } else if (iMinutes >= 1) {                                                                                                                                                                                                                              
        return iMinutes + "min";                                                                                                                                                                                                                               
      } else if (iSeconds >= 1) {                                                                                                                                                                                                                              
        return iSeconds + "s";                                                                                                                                                                                                                                 
      } else {                                                                                                                                                                                                                                                 
        return iMilliseconds + "ms";                                                                                                                                                                                                                           
      }                                                                                                                                                                                                                                                        
    },                                                                                                                                                                                                                                                         
                                                                                                                                                                                                                                                               
    /**                                                                                                                                                                                                                                                        
     * Combina data e hora (duration) em um único objeto Date                                                                                                                                                                                                  
     * @param {string|Date} sDate - Data no formato ISO ou objeto Date                                                                                                                                                                                         
     * @param {string|object|number} sDuration - Tempo no formato PT, objeto com ms, ou número                                                                                                                                                                 
     * @returns {Date} Objeto Date combinado                                                                                                                                                                                                                   
     * @private                                                                                                                                                                                                                                                
     */                                                                                                                                                                                                                                                        
    _combineDateAndTime: function (sDate, sDuration) {                                                                                                                                                                                                         
      var dateString = sDate;                                                                                                                                                                                                                                  
                                                                                                                                                                                                                                                               
      // Se for um objeto Date, converter para string ISO                                                                                                                                                                                                      
      if (sDate instanceof Date) {                                                                                                                                                                                                                             
        dateString = sDate.toISOString();                                                                                                                                                                                                                      
      }                                                                                                                                                                                                                                                        
                                                                                                                                                                                                                                                               
      // Extrai componentes da data                                                                                                                                                                                                                            
      var dateParts = dateString.split('T')[0].split('-');                                                                                                                                                                                                     
      var year = parseInt(dateParts[0], 10);                                                                                                                                                                                                                   
      var month = parseInt(dateParts[1], 10) - 1; // Mês começa em 0                                                                                                                                                                                           
      var day = parseInt(dateParts[2], 10);                                                                                                                                                                                                                    
                                                                                                                                                                                                                                                               
      // Extrai componentes do tempo                                                                                                                                                                                                                           
      var time = this._parseDuration(sDuration);                                                                                                                                                                                                               
                                                                                                                                                                                                                                                               
      // Cria objeto Date com valores locais                                                                                                                                                                                                                   
      return new Date(year, month, day, time.hours, time.minutes, time.seconds);                                                                                                                                                                               
    },                                                                                                                                                                                                                                                         
                                                                                                                                                                                                                                                               
    /**                                                                                                                                                                                                                                                        
     * Faz parsing de duração em múltiplos formatos                                                                                                                                                                                                            
     * Suporta:                                                                                                                                                                                                                                                
     * - String PTnHnMnS (formato OData duration)                                                                                                                                                                                                              
     * - Objeto com propriedade ms (ex: {ms: 65209000, _edmType: 'Edm.Time'})                                                                                                                                                                                  
     * - Número em milissegundos                                                                                                                                                                                                                               
     * @param {string|object|number} sDuration - Duração em diversos formatos                                                                                                                                                                                  
     * @returns {object} Objeto com hours, minutes e seconds                                                                                                                                                                                                   
     * @private                                                                                                                                                                                                                                                
     */                                                                                                                                                                                                                                                        
    _parseDuration: function (sDuration) {                                                                                                                                                                                                                     
      if (!sDuration && sDuration !== 0) {                                                                                                                                                                                                                     
        return { hours: 0, minutes: 0, seconds: 0 };                                                                                                                                                                                                           
      }                                                                                                                                                                                                                                                        
                                                                                                                                                                                                                                                               
      var hours = 0, minutes = 0, seconds = 0;                                                                                                                                                                                                                 
                                                                                                                                                                                                                                                               
      // Caso 1: Objeto com propriedade ms                                                                                                                                                                                                                     
      if (typeof sDuration === 'object' && sDuration !== null) {                                                                                                                                                                                               
        if (sDuration.ms || sDuration.ms === 0) {                                                                                                                                                                                                              
          return this._millisecondsToTime(Number(sDuration.ms));                                                                                                                                                                                               
        }                                                                                                                                                                                                                                                      
        // Fallback: tenta converter para string e fazer parsing                                                                                                                                                                                               
        sDuration = String(sDuration);                                                                                                                                                                                                                         
      }                                                                                                                                                                                                                                                        
                                                                                                                                                                                                                                                               
      // Caso 2: Número (milissegundos)                                                                                                                                                                                                                        
      if (typeof sDuration === 'number' && !isNaN(sDuration)) {                                                                                                                                                                                                
        return this._millisecondsToTime(sDuration);                                                                                                                                                                                                            
      }                                                                                                                                                                                                                                                        
                                                                                                                                                                                                                                                               
      // Caso 3: String                                                                                                                                                                                                                                        
      if (typeof sDuration === 'string') {                                                                                                                                                                                                                     
        // Tenta formato PT primeiro (ex: PT1H30M45S)                                                                                                                                                                                                          
        var match = sDuration.match(/PT(\d+H)?(\d+M)?(\d+S)?/);                                                                                                                                                                                                
        if (match) {                                                                                                                                                                                                                                           
          if (match[1]) hours = parseInt(match[1].replace('H', ''), 10);                                                                                                                                                                                       
          if (match[2]) minutes = parseInt(match[2].replace('M', ''), 10);                                                                                                                                                                                     
          if (match[3]) seconds = parseInt(match[3].replace('S', ''), 10);                                                                                                                                                                                     
          return { hours: hours, minutes: minutes, seconds: seconds };                                                                                                                                                                                         
        }                                                                                                                                                                                                                                                      
                                                                                                                                                                                                                                                               
        // Tenta converter string numérica para milissegundos                                                                                                                                                                                                  
        var n = Number(sDuration);                                                                                                                                                                                                                             
        if (!isNaN(n)) {                                                                                                                                                                                                                                       
          return this._millisecondsToTime(n);                                                                                                                                                                                                                  
        }                                                                                                                                                                                                                                                      
      }                                                                                                                                                                                                                                                        
                                                                                                                                                                                                                                                               
      // Formato desconhecido - retorna zeros                                                                                                                                                                                                                  
      return { hours: 0, minutes: 0, seconds: 0 };                                                                                                                                                                                                             
    },                                                                                                                                                                                                                                                         
                                                                                                                                                                                                                                                               
    /**                                                                                                                                                                                                                                                        
     * Converte milissegundos em objeto com horas, minutos e segundos                                                                                                                                                                                          
     * @param {number} iMilliseconds - Milissegundos                                                                                                                                                                                                           
     * @returns {object} Objeto com hours, minutes e seconds                                                                                                                                                                                                   
     * @private                                                                                                                                                                                                                                                
     */                                                                                                                                                                                                                                                        
    _millisecondsToTime: function (iMilliseconds) {                                                                                                                                                                                                            
      var hours = Math.floor(iMilliseconds / 3600000);                                                                                                                                                                                                         
      var minutes = Math.floor((iMilliseconds % 3600000) / 60000);                                                                                                                                                                                             
      var seconds = Math.floor((iMilliseconds % 60000) / 1000);                                                                                                                                                                                                
                                                                                                                                                                                                                                                               
      return {                                                                                                                                                                                                                                                 
        hours: hours,                                                                                                                                                                                                                                          
        minutes: minutes,                                                                                                                                                                                                                                      
        seconds: seconds                                                                                                                                                                                                                                       
      };                                                                                                                                                                                                                                                       
    }                                                                                                                                                                                                                                                          
  });                                                                                                                                                                                                                                                          
}                                                                                                                                                                                                                                                              
);                                                                                                                                                                                                                                                             
                                                                                                                                                                                                                                                               