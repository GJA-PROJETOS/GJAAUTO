<mvc:View                                                                                                                                                                                                                                                      
    controllerName="br.com.gja.zui5.gjaauto.monitor.controller.Automacao"                                                                                                                                                                                      
    xmlns="sap.m"                                                                                                                                                                                                                                              
    xmlns:mvc="sap.ui.core.mvc"                                                                                                                                                                                                                                
    xmlns:core="sap.ui.core"                                                                                                                                                                                                                                   
    displayBlock="true"                                                                                                                                                                                                                                        
    height="100%"                                                                                                                                                                                                                                              
>                                                                                                                                                                                                                                                              
    <Page                                                                                                                                                                                                                                                      
        id="automacaoPage"                                                                                                                                                                                                                                     
        title="{automacao>/auto} - {automacao>/descrAuto}"                                                                                                                                                                                                     
        showNavButton="true"                                                                                                                                                                                                                                   
        navButtonPress=".onNavBack"                                                                                                                                                                                                                            
    >                                                                                                                                                                                                                                                          
        <headerContent>                                                                                                                                                                                                                                        
            <Button                                                                                                                                                                                                                                            
                id="btnExecutar"                                                                                                                                                                                                                               
                text="Executar"                                                                                                                                                                                                                                
                type="Emphasized"                                                                                                                                                                                                                              
                icon="sap-icon://sys-enter"                                                                                                                                                                                                                    
                press=".onExecutarAutomacao"                                                                                                                                                                                                                   
                visible="{automacao>/showExecuteButton}"                                                                                                                                                                                                       
                enabled="{automacao>/executeButtonEnabled}"                                                                                                                                                                                                    
            />                                                                                                                                                                                                                                                 
        </headerContent>                                                                                                                                                                                                                                       
&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;                                                                                                                                                                                                               
        <!-- Skeleton Screen - Placeholder Loading -->                                                                                                                                                                                                         
        <VBox                                                                                                                                                                                                                                                  
            id="skeletonContainer"                                                                                                                                                                                                                             
            visible="{automacao>/isLoading}"                                                                                                                                                                                                                   
            class="sapUiMediumMargin"                                                                                                                                                                                                                          
        >                                                                                                                                                                                                                                                      
            <!-- Skeleton para ObjectHeader -->                                                                                                                                                                                                                
            <VBox id="_IDGenVBox3" class="sapUiSmallMarginBottom">                                                                                                                                                                                             
                <core:HTML id="_IDGenHTML" content="&lt;div style='height:24px; background: linear-gradient(90deg, #f0f0f0 25%, #e0e0e0 50%, #f0f0f0 75%); background-size: 200% 100%; animation: loading 1.5s infinite; border-radius: 4px; margin-bottom: 8p+
x;'&gt;&lt;/div&gt;" />                                                                                                                                                                                                                                        
                <core:HTML id="_IDGenHTML1" content="&lt;div style='height:16px; width: 60%; background: linear-gradient(90deg, #f0f0f0 25%, #e0e0e0 50%, #f0f0f0 75%); background-size: 200% 100%; animation: loading 1.5s infinite; border-radius: 4px; marg+
in-bottom: 16px;'&gt;&lt;/div&gt;" />                                                                                                                                                                                                                          
                <core:HTML id="_IDGenHTML2" content="&lt;div style='height:14px; width: 40%; background: linear-gradient(90deg, #f0f0f0 25%, #e0e0e0 50%, #f0f0f0 75%); background-size: 200% 100%; animation: loading 1.5s infinite; border-radius: 4px; marg+
in-bottom: 8px;'&gt;&lt;/div&gt;" />                                                                                                                                                                                                                           
                <core:HTML id="_IDGenHTML3" content="&lt;div style='height:14px; width: 50%; background: linear-gradient(90deg, #f0f0f0 25%, #e0e0e0 50%, #f0f0f0 75%); background-size: 200% 100%; animation: loading 1.5s infinite; border-radius: 4px;'&gt;+
&lt;/div&gt;" />                                                                                                                                                                                                                                               
            </VBox>                                                                                                                                                                                                                                            
&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;                                                                                                                                                                                       
            <!-- Skeleton para Lista de Etapas -->                                                                                                                                                                                                             
            <VBox id="_IDGenVBox7" class="sapUiSmallMarginTop">                                                                                                                                                                                                
                <core:HTML id="_IDGenHTML4" content="&lt;div style='height:18px; width: 30%; background: linear-gradient(90deg, #f0f0f0 25%, #e0e0e0 50%, #f0f0f0 75%); background-size: 200% 100%; animation: loading 1.5s infinite; border-radius: 4px; marg+
in-bottom: 12px;'&gt;&lt;/div&gt;" />                                                                                                                                                                                                                          
                <core:HTML id="_IDGenHTML5" content="&lt;div style='height:80px; background: linear-gradient(90deg, #f0f0f0 25%, #e0e0e0 50%, #f0f0f0 75%); background-size: 200% 100%; animation: loading 1.5s infinite; border-radius: 4px; margin-bottom: 8+
px;'&gt;&lt;/div&gt;" />                                                                                                                                                                                                                                       
                <core:HTML id="_IDGenHTML6" content="&lt;div style='height:80px; background: linear-gradient(90deg, #f0f0f0 25%, #e0e0e0 50%, #f0f0f0 75%); background-size: 200% 100%; animation: loading 1.5s infinite; border-radius: 4px; margin-bottom: 8+
px;'&gt;&lt;/div&gt;" />                                                                                                                                                                                                                                       
                <core:HTML id="_IDGenHTML7" content="&lt;div style='height:80px; background: linear-gradient(90deg, #f0f0f0 25%, #e0e0e0 50%, #f0f0f0 75%); background-size: 200% 100%; animation: loading 1.5s infinite; border-radius: 4px;'&gt;&lt;/div&gt;+
" />                                                                                                                                                                                                                                                           
            </VBox>                                                                                                                                                                                                                                            
&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;                                                                                                                                                                                       
        </VBox>                                                                                                                                                                                                                                                
                                                                                                                                                                                                                                                               
        <!-- Conteúdo Real -->                                                                                                                                                                                                                                 
        <VBox id="_IDGenVBox8" visible="{= !${automacao>/isLoading}}">                                                                                                                                                                                         
            <ObjectHeader                                                                                                                                                                                                                                      
                id="objectHeader"                                                                                                                                                                                                                              
                title="{automacao>/opera} - {automacao>/descrOpera}"                                                                                                                                                                                           
                number="{automacao>/id}"                                                                                                                                                                                                                       
                numberState="{automacao>/statusType}"                                                                                                                                                                                                          
            >                                                                                                                                                                                                                                                  
                <attributes>                                                                                                                                                                                                                                   
                    <ObjectAttribute                                                                                                                                                                                                                           
                        id="_IDGenObjectAttribute1"                                                                                                                                                                                                            
                        title="Data/Hora"                                                                                                                                                                                                                      
                        text="{automacao>/createdAt}"                                                                                                                                                                                                          
                    />                                                                                                                                                                                                                                         
                    <ObjectAttribute                                                                                                                                                                                                                           
                        id="_IDGenObjectAttribute3"                                                                                                                                                                                                            
                        title="Criado por"                                                                                                                                                                                                                     
                        text="{automacao>/createdBy}"                                                                                                                                                                                                          
                    />                                                                                                                                                                                                                                         
                    <ObjectAttribute                                                                                                                                                                                                                           
                        id="_IDGenObjectAttribute4"                                                                                                                                                                                                            
                        title="Tempo Total"                                                                                                                                                                                                                    
                        text="{automacao>/tempoTotal}"                                                                                                                                                                                                         
                        active="{= ${automacao>/status} === '2' }"                                                                                                                                                                                             
                    />                                                                                                                                                                                                                                         
                </attributes>                                                                                                                                                                                                                                  
                <statuses>                                                                                                                                                                                                                                     
                    <ObjectStatus                                                                                                                                                                                                                              
                        id="_IDGenObjectStatus1"                                                                                                                                                                                                               
                        title=""                                                                                                                                                                                                                               
                        text="{automacao>/status}"                                                                                                                                                                                                             
                        state="{automacao>/statusType}"                                                                                                                                                                                                        
                    />                                                                                                                                                                                                                                         
                </statuses>                                                                                                                                                                                                                                    
            </ObjectHeader>                                                                                                                                                                                                                                    
                                                                                                                                                                                                                                                               
            <Panel                                                                                                                                                                                                                                             
                id="_IDGenPanel"                                                                                                                                                                                                                               
                headerText="Etapas da Execução"                                                                                                                                                                                                                
                class="sapUiResponsiveMargin"                                                                                                                                                                                                                  
                width="auto"                                                                                                                                                                                                                                   
            >                                                                                                                                                                                                                                                  
                <List                                                                                                                                                                                                                                          
                    id="etapasList2"                                                                                                                                                                                                                           
                    items="{automacao>/etapasMapeadas}"                                                                                                                                                                                                        
                    noDataText="Nenhuma etapa disponível"                                                                                                                                                                                                      
                >                                                                                                                                                                                                                                              
                    <CustomListItem&nbsp;                                                                                                                                                                                                                      
                            id="_IDGenCustomListItem"                                                                                                                                                                                                          
                            type="Active"                                                                                                                                                                                                                      
                            press=".onEtapaPress"                                                                                                                                                                                                              
                        >                                                                                                                                                                                                                                      
                            <VBox                                                                                                                                                                                                                              
                                id="_IDGenVBox4"                                                                                                                                                                                                               
                                class="sapUiSmallMargin"                                                                                                                                                                                                       
                            >                                                                                                                                                                                                                                  
                                <HBox                                                                                                                                                                                                                          
                                    id="_IDGenHBox5"                                                                                                                                                                                                           
                                    justifyContent="SpaceBetween"                                                                                                                                                                                              
                                    width="100%"                                                                                                                                                                                                               
                                >                                                                                                                                                                                                                              
                                    <VBox                                                                                                                                                                                                                      
                                        id="_IDGenVBox5"                                                                                                                                                                                                       
                                        width="70%"                                                                                                                                                                                                            
                                    >                                                                                                                                                                                                                          
                                        <Title                                                                                                                                                                                                                 
                                            id="_IDGenTitle2"                                                                                                                                                                                                  
                                            text="{automacao>descricao}"                                                                                                                                                                                       
                                            level="H5"                                                                                                                                                                                                         
                                        />                                                                                                                                                                                                                     
                                        <Title                                                                                                                                                                                                                 
                                            id="_IDGenText9"                                                                                                                                                                                                   
                                            text="{automacao>keyValue}"                                                                                                                                                                                        
                                            class="sapUiTinyMarginTop"                                                                                                                                                                                         
                                            level="H3"                                                                                                                                                                                                         
                                        />                                                                                                                                                                                                                     
                                    </VBox>                                                                                                                                                                                                                    
                                    <VBox                                                                                                                                                                                                                      
                                        id="_IDGenVBox6"                                                                                                                                                                                                       
                                        alignItems="End"                                                                                                                                                                                                       
                                    >                                                                                                                                                                                                                          
                                        <ObjectStatus                                                                                                                                                                                                          
                                            id="_IDGenObjectStatus15"                                                                                                                                                                                          
                                            text="{automacao>status}"                                                                                                                                                                                          
                                            state="{automacao>statusType}"                                                                                                                                                                                     
                                        />                                                                                                                                                                                                                     
                                        <Text                                                                                                                                                                                                                  
                                            id="_IDGenText10"                                                                                                                                                                                                  
                                            text="{automacao>dataHora}"                                                                                                                                                                                        
                                            class="sapUiTinyMarginTop"                                                                                                                                                                                         
                                        />                                                                                                                                                                                                                     
                                    </VBox>                                                                                                                                                                                                                    
                                </HBox>                                                                                                                                                                                                                        
                                <HBox                                                                                                                                                                                                                          
                                    id="_IDGenHBox6"                                                                                                                                                                                                           
                                    class="sapUiTinyMarginTop"                                                                                                                                                                                                 
                                    visible="{= ${automacao>duracao} !== ''}"                                                                                                                                                                                  
                                >                                                                                                                                                                                                                              
                                    <Label                                                                                                                                                                                                                     
                                        id="_IDGenLabel3"                                                                                                                                                                                                      
                                        text="Duração: "                                                                                                                                                                                                       
                                        class="sapUiTinyMarginEnd"                                                                                                                                                                                             
                                    />                                                                                                                                                                                                                         
                                    <Text                                                                                                                                                                                                                      
                                        id="_IDGenText11"                                                                                                                                                                                                      
                                        text="{automacao>duracao}"                                                                                                                                                                                             
                                    />                                                                                                                                                                                                                         
                                </HBox>                                                                                                                                                                                                                        
                            </VBox>                                                                                                                                                                                                                            
                        </CustomListItem>                                                                                                                                                                                                                      
                    </List>                                                                                                                                                                                                                                    
            </Panel>                                                                                                                                                                                                                                           
        </VBox>                                                                                                                                                                                                                                                
    </Page>                                                                                                                                                                                                                                                    
</mvc:View>                                                                                                                                                                                                                                                    